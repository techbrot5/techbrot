---
layout: layouts/base.njk
chrome: minimal
---
{#- T-BOFU tier skeleton (design brief §6 + chrome ruling, round 4):
    chrome: minimal default — logo + phone header, slim footer, no nav
    (no funnel leakage on conversion endpoints). Compact paper hero with
    hairline accent (.hero--compact, 48×3 oxblood stripe ::before).
    Page body carries the BOFU sequence (tldr · quick-5 · content ·
    trust+reviews · FORM · FAQ accordion). cta-band light variant on
    --surface-tier-bofu (round 4 ruling B). -#}

<section class="section hero-tier hero--compact section--tier-bofu" id="{{ slug }}-hero">
  <div class="container">
    <div class="hero">
      <p class="hero__eyebrow">{{ hero.eyebrow }}</p>
      <h1 class="hero__heading">{{ hero.heading }}</h1>
      <p class="hero__subheading">{{ hero.subheading }}</p>
      <div class="hero__actions">
        {%- for action in hero.actions %}
        <a class="btn {{ action.class }} btn--lg" href="{{ action.href }}"
          {%- if action.href.startsWith("tel:") %} data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
        {%- endfor %}
      </div>
    </div>
  </div>
</section>

{%- if inBrief %}
<section class="section" id="{{ slug }}-in-brief">
  <div class="container">
    <div class="in-brief">
      <p class="in-brief__text" id="{{ slug }}-in-brief-text">{{ inBrief.text | safe }}</p>
      {%- if inBrief.source %}<p class="in-brief__source">{{ inBrief.source }}</p>{%- endif %}
    </div>
  </div>
</section>
{%- endif %}

{{ content | safe }}

<section class="section section--cta-band section--cta-band--light section--tier-bofu" id="{{ slug }}-cta">
  <div class="container">
    <div class="final-cta">
      <p class="section__eyebrow">{{ ctaBand.eyebrow }}</p>
      <h2 class="final-cta__heading">{{ ctaBand.heading | safe }}</h2>
      <p class="final-cta__lede">{{ ctaBand.lede | safe }}</p>
      <div class="final-cta__actions">
        {%- for action in ctaBand.actions %}
        <a class="btn {{ action.class }}" href="{{ action.href }}"
          {%- if action.href.startsWith("tel:") %} data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
        {%- endfor %}
      </div>
      <p class="final-cta__disclaimer">TechBrot is an independent accounting firm and Certified QuickBooks ProAdvisor. We are not Intuit. QuickBooks and Intuit are registered trademarks of Intuit Inc.</p>
    </div>
  </div>
</section>
