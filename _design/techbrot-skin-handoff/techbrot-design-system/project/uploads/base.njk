<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
{%- if env.production %}
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
{%- else %}
<meta name="robots" content="noindex, nofollow">
{%- endif %}
<link rel="canonical" href="{{ site.url }}{{ page.url }}">
<link rel="alternate" hreflang="en-US" href="{{ site.url }}{{ page.url }}">
<link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ page.url }}">
<meta name="format-detection" content="telephone=yes">
<meta name="theme-color" content="#FAFAF7">
<meta name="trademark" content="QuickBooks is a registered trademark of Intuit Inc. TechBrot Inc. is an independent Certified QuickBooks ProAdvisor firm and is not affiliated with, endorsed by, or sponsored by Intuit Inc.">
<link rel="icon" href="/assets/img/brand/icon.svg" type="image/svg+xml">
<link rel="preload" href="/assets/fonts/fraunces-var-latin.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/assets/fonts/inter-var-latin.woff2" as="font" type="font/woff2" crossorigin>
<link rel="stylesheet" href="/assets/css/site.min.css">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:title" content="{{ ogTitle or title }}">
<meta property="og:description" content="{{ ogDescription or description }}">
<meta property="og:site_name" content="{{ site.name }}">
<meta name="twitter:card" content="summary">
<meta name="twitter:site" content="{{ site.twitterHandle }}">
<meta name="twitter:title" content="{{ ogTitle or title }}">
<meta name="twitter:description" content="{{ ogDescription or description }}">
<script type="application/ld+json">{{ schemaGlobal | dump | safe }}</script>
{%- if pageGraph %}
<script type="application/ld+json">{{ pageGraph | dump | safe }}</script>
{%- endif %}
<script>window.TB_ENV={{ env.name | dump | safe }};window.TB_FORM_ENDPOINT={{ site.formEndpoint | dump | safe }};</script>
{%- if env.production %}
<script async src="https://www.googletagmanager.com/gtag/js?id={{ site.ga4Id }}"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','{{ site.ga4Id }}');</script>
{%- endif %}
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>

<a class="skip-link" href="#main">Skip to content</a>
{% include "partials/site-header.njk" %}

<main id="main">
{{ content | safe }}
</main>

{% include "partials/site-footer.njk" %}

<script src="/assets/js/tb-analytics.js" defer></script>
<script src="/assets/js/tb-faq.js" defer></script>
{%- if chrome != "minimal" %}
<script src="/assets/js/tb-nav.js" defer></script>
{%- endif %}
{%- if includeFormJs %}
<script src="/assets/js/tb-forms.js" defer></script>
{%- endif %}
</body>
</html>
