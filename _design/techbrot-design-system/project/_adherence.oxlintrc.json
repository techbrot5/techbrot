{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/conversion/**",
              "components/core/**",
              "components/disclosure/**",
              "components/editorial/**",
              "components/navigation/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Breadcrumb'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|key|ref|className|style|children)$/]",
        "message": "<Breadcrumb> doesn't accept that prop. Declared props: items."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|inverted|full|href|className|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, inverted, full, href, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|text)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BuyerCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:signal|heading|href|body|cta|key|ref|className|style|children)$/]",
        "message": "<BuyerCard> doesn't accept that prop. Declared props: signal, heading, href, body, cta."
      },
      {
        "selector": "JSXOpeningElement[name.name='CtaBand'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|heading|lede|primary|primaryHref|secondary|secondaryHref|disclaimer|key|ref|className|style|children)$/]",
        "message": "<CtaBand> doesn't accept that prop. Declared props: eyebrow, heading, lede, primary, primaryHref, secondary, secondaryHref, disclaimer."
      },
      {
        "selector": "JSXOpeningElement[name.name='Disclosure'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|children|key|ref|className|style|children)$/]",
        "message": "<Disclosure> doesn't accept that prop. Declared props: eyebrow, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:inverted|as|className|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: inverted, as, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Faq'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|defaultOpen|key|ref|className|style|children)$/]",
        "message": "<Faq> doesn't accept that prop. Declared props: items, defaultOpen."
      },
      {
        "selector": "JSXOpeningElement[name.name='Framework'] > JSXAttribute > JSXIdentifier[name!=/^(?:term|eyebrow|children|attribution|key|ref|className|style|children)$/]",
        "message": "<Framework> doesn't accept that prop. Declared props: term, eyebrow, children, attribution."
      },
      {
        "selector": "JSXOpeningElement[name.name='GuideCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|heading|href|excerpt|cta|key|ref|className|style|children)$/]",
        "message": "<GuideCard> doesn't accept that prop. Declared props: category, heading, href, excerpt, cta."
      },
      {
        "selector": "JSXOpeningElement[name.name='InBrief'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|source|key|ref|className|style|children)$/]",
        "message": "<InBrief> doesn't accept that prop. Declared props: children, source."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhoneCta'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|number|detail|inverted|key|ref|className|style|children)$/]",
        "message": "<PhoneCta> doesn't accept that prop. Declared props: label, number, detail, inverted."
      },
      {
        "selector": "JSXOpeningElement[name.name='PullQuote'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|attribution|key|ref|className|style|children)$/]",
        "message": "<PullQuote> doesn't accept that prop. Declared props: children, attribution."
      },
      {
        "selector": "JSXOpeningElement[name.name='Related'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|links|key|ref|className|style|children)$/]",
        "message": "<Related> doesn't accept that prop. Declared props: label, links."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|heading|lede|centered|className|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: eyebrow, heading, lede, centered, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|heading|href|body|links|cta|key|ref|className|style|children)$/]",
        "message": "<ServiceCard> doesn't accept that prop. Declared props: eyebrow, heading, href, body, links, cta."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|label|source|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: number, label, source."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toc'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|items|currentId|key|ref|className|style|children)$/]",
        "message": "<Toc> doesn't accept that prop. Declared props: label, items, currentId."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrustRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|key|ref|className|style|children)$/]",
        "message": "<TrustRow> doesn't accept that prop. Declared props: items."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
