---
layout: layouts/base.njk
---
{#- T-MOFU / standalone full-chrome tier skeleton (design templates/t-mofu
    + tier-surface ruling B). chrome: full (base default) — full nav +
    footer. Tier surface via front matter `tierClass`
    (section--tier-guide for T-MOFU/T-GUIDE/legal · section--tier-hub for
    hub-structured standalone pages like /trust/) — TL;DR + cta-band sit
    on the tier surface per the standing tier table.
    All blocks optional: legal documents skip hero/cta-band and carry
    their own doc header in content; breadcrumb renders when supplied
    (live legal pages carry a visible breadcrumb — baseline equity). -#}

{%- if breadcrumb %}
<nav class="breadcrumb" aria-label="Breadcrumb" id="{{ slug }}-breadcrumb">
  <div class="container">
    <ol class="breadcrumb__list">
      {%- for item in breadcrumb %}
      {%- if item.href %}
      <li class="breadcrumb__item"><a href="{{ item.href }}">{{ item.name }}</a></li>
      {%- else %}
      <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">{{ item.name }}</li>
      {%- endif %}
      {%- endfor %}
    </ol>
  </div>
</nav>
{%- endif %}

{%- if hero %}
<section class="section hero-tier hero--service" id="{{ slug }}-hero">
  <div class="container">
    <div class="hero">
      <p class="hero__eyebrow">{{ hero.eyebrow }}</p>
      <h1 class="hero__heading">{{ hero.heading | safe }}</h1>
      <p class="hero__subheading">{{ hero.subheading | safe }}</p>
      {%- if hero.actions %}
      <div class="hero__actions">
        {%- for action in hero.actions %}
        <a class="btn {{ action.class }} btn--lg" href="{{ action.href }}"
          {%- if action.href.startsWith("tel:") %} data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
        {%- endfor %}
      </div>
      {%- endif %}
    </div>
  </div>
</section>
{%- endif %}

{%- if inBrief %}
<section class="section" id="{{ slug }}-in-brief">
  <div class="container">
    <div class="in-brief">
      <p class="in-brief__text" id="{{ slug }}-in-brief-text">{{ inBrief.text | safe }}</p>
      {%- if inBrief.source %}<p class="in-brief__source">{{ inBrief.source }}</p>{%- endif %}
    </div>
  </div>
</section>
{%- endif %}

{{ content | safe }}

{%- if ctaBand %}
<section class="section section--cta-band section--cta-band--light {{ tierClass or "section--tier-guide" }}" id="{{ slug }}-cta">
  <div class="container">
    <div class="final-cta">
      <p class="section__eyebrow">{{ ctaBand.eyebrow }}</p>
      <h2 class="final-cta__heading">{{ ctaBand.heading | safe }}</h2>
      <p class="final-cta__lede">{{ ctaBand.lede | safe }}</p>
      <div class="final-cta__actions">
        {%- for action in ctaBand.actions %}
        <a class="btn {{ action.class }}" href="{{ action.href }}"
          {%- if action.href.startsWith("tel:") %} data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
        {%- endfor %}
      </div>
      <p class="final-cta__disclaimer">TechBrot is an independent accounting firm and Certified QuickBooks ProAdvisor. We are not Intuit. QuickBooks and Intuit are registered trademarks of Intuit Inc.</p>
    </div>
  </div>
</section>
{%- endif %}
