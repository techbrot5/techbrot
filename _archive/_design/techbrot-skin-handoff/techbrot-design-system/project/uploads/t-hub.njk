---
layout: layouts/base.njk
chrome: full
---
{#- T-HUB tier skeleton (design brief §6 + founder rulings):
    hero--hub (dark — the ONLY dark band on a hub page) → in-brief →
    page sections (content) → framework → trust-row → cta-band on
    --surface-tier-hub (light variant; ruling B). -#}

<section class="section hero-tier hero--hub" id="{{ slug }}-hero">
  <div class="hero__motif" aria-hidden="true">
    {% include "partials/motif-ledger-full.svg" %}
  </div>
  <div class="container">
    <div class="hero">
      <p class="hero__eyebrow">{{ hero.eyebrow }}</p>
      <h1 class="hero__heading">{{ hero.heading }}</h1>
      <p class="hero__subheading">{{ hero.subheading }}</p>
      <div class="hero__actions">
        {%- for action in hero.actions %}
        <a class="btn {{ action.class }} btn--inverted btn--lg" href="{{ action.href }}">{{ action.label }}</a>
        {%- endfor %}
      </div>
    </div>
  </div>
</section>

<section class="section" id="{{ slug }}-in-brief">
  <div class="container">
    <div class="in-brief">
      <p class="in-brief__text" id="{{ slug }}-in-brief-text">{{ inBrief.text }}</p>
      <p class="in-brief__source">{{ inBrief.source }}</p>
    </div>
  </div>
</section>

{{ content | safe }}

{%- if framework %}
<section class="section" id="{{ slug }}-framework">
  <div class="container container--center">
    <article class="framework">
      <p class="framework__eyebrow">{{ framework.eyebrow }}</p>
      <h2 class="framework__term">{{ framework.term }}</h2>
      <p class="framework__definition">{{ framework.definition }}</p>
      <p class="framework__attribution">{{ framework.attribution }}</p>
    </article>
  </div>
</section>
{%- endif %}

<section class="section section--compact" id="{{ slug }}-trust">
  <div class="container">
    <div class="trust-row">
      {%- for item in trustRow %}
      {%- if not loop.first %}<div class="trust-row__divider"></div>{% endif %}
      <div class="trust-row__item"><p class="trust-row__value">{{ item.value }}</p><p class="trust-row__label">{{ item.label }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{%- if faq %}
<section class="section" id="{{ slug }}-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Before you call</p>
      <h2 class="section__heading">The questions buyers actually ask.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="{{ slug }}-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="{{ slug }}-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

<section class="section section--cta-band section--cta-band--light section--tier-hub" id="{{ slug }}-cta">
  <div class="cta-band__motif" aria-hidden="true">
    {% include "partials/motif-ledger-single.svg" %}
  </div>
  <div class="container">
    <div class="final-cta">
      <p class="section__eyebrow">{{ ctaBand.eyebrow }}</p>
      <h2 class="final-cta__heading">{{ ctaBand.heading }}</h2>
      <p class="final-cta__lede">{{ ctaBand.lede }}</p>
      <div class="final-cta__actions">
        {%- for action in ctaBand.actions %}
        <a class="btn {{ action.class }}" href="{{ action.href }}">{{ action.label }}</a>
        {%- endfor %}
      </div>
      <p class="final-cta__disclaimer">TechBrot is an independent accounting firm and Certified QuickBooks ProAdvisor. We are not Intuit. QuickBooks and Intuit are registered trademarks of Intuit Inc.</p>
    </div>
  </div>
</section>
