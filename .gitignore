# Local agent / editor config (not deploy content)
.claude/

# Dependencies
node_modules/

# Build output (regenerated by `npm run build` / `npm run build:prod`)
_site/
_site-prod/

# Local verification artifacts (regenerable — Lighthouse reports, screenshots,
# probe fingerprints, form payloads). The factory SCRIPTS, REPORTS, BASELINE,
# BATTERY config, and build-new-queue under _build/ ARE tracked (below).
_build/verify/

# Design-capture intermediate (the gunzip->tar payload). The EXTRACTED design
# system under _build/design-capture/extracted/ IS tracked as the locked source.
_build/design-capture/_incoming/

# OS / editor cruft
Thumbs.db
.DS_Store
*.log

# NOTE: _build/scripts/, _build/reports/, _build/baseline/, _build/battery/,
# and _build/build-new-queue.json are intentionally TRACKED (not ignored) —
# they are the factory's living truth and verification harness.

_site-probe/

# Design handoff zips (read-only source, never commit)
*.zip
TechBrot Design System Elevation.zip
