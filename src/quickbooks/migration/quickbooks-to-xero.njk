      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <h3 class="ai-summary__question">{{ item.q | safe }}</h3>
        <div class="ai-summary__answer"><p>{{ item.a | safe }}</p></div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section section--alt" id="qb-toxero-switch">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">When Xero is the right call</p>
      <h2 class="section__heading">Genuine reasons to switch.</h2>
      <p class="section__lede">These are situations where Xero meaningfully outperforms QuickBooks &mdash; not marketing differences, real ones.</p>
    </header>
    <div class="grid-2">
