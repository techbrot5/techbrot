      <div class="buyer-card">
        <h3 class="buyer-card__opener">{{ s.opener | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section" id="qb-toxero-stay">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">When staying on QuickBooks is the right call</p>
      <h2 class="section__heading">Reasons not to switch &mdash; and what to do instead.</h2>
      <p class="section__lede">Most U.S. small and mid-sized businesses are better off staying. These are the most common &ldquo;don&rsquo;t switch&rdquo; situations &mdash; and the right move if you&rsquo;re in one.</p>
    </header>
