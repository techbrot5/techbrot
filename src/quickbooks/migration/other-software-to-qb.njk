{#- §04 CREDENTIALS (checks-list → checklist incl-card) — white -#}
<section class="sec reveal" id="othersw-credentials">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§04</span><span class="idx__t">Certified by Intuit</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:24ch;margin-bottom:12px;">Certified QuickBooks ProAdvisor credentials</h2>
    <p class="lede" style="margin:0 0 28px;max-width:60ch;">Migrating into QuickBooks means building the destination file correctly &mdash; the right chart of accounts, lists, and structure from day one. Every TechBrot operator holds active Certified QuickBooks ProAdvisor credentials across the full QuickBooks stack, plus the Intuit Certified Bookkeeping Professional credential. Verification available on request.</p>
    <div class="incl-card">
      <h3>Active credentials, every operator</h3>
      <ul class="checklist">{%- for c in credentials %}<li>{{ c | safe }}</li>{%- endfor %}</ul>
    </div>
  </div>
</section>

{#- §05 SOURCES (6 source platforms → lift cards) — sand -#}
<section class="sec reveal" id="othersw-sources" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§05</span><span class="idx__t">Where businesses migrate from</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:22ch;margin-bottom:12px;">Coming from one of these? We&rsquo;ve done it.</h2>
    <p class="lede" style="margin:0 0 36px;max-width:60ch;">Every source platform stores data differently, so each migration is mapped to its specifics. These are the moves we handle most often.</p>
    <div class="r-2">
      {%- for s in sources %}
      <div class="lift"><span class="lift__n">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span><div><h3>{{ s.opener | safe }}</h3><p>{{ s.body | safe }}</p></div></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- §06 COVERAGE (6 numbered deliverables → deliver--3 lattice) — white -#}
<section class="sec reveal" id="othersw-coverage">
  <div class="ct">
    <div class="idx"><span class="idx__n">§06</span><span class="idx__t">What the migration covers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:20ch;margin-bottom:12px;">A clean arrival, not a raw import.</h2>
    <p class="lede" style="margin:0 0 36px;max-width:60ch;">The difference between a migration and a data dump is everything below &mdash; the work that makes the QuickBooks file trustworthy on day one.</p>
    <div class="deliver deliver--3">
      {%- for d in coverage %}
      <div class="deliver__cell">
        <span class="lift__n" aria-hidden="true">{{ d.num }}</span>
        <h3>{{ d.name | safe }}</h3>{% if d.body %}<p>{{ d.body | safe }}</p>{% endif %}
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- §07 HISTORY (3 approaches → lift cards) — sand -#}
<section class="sec reveal" id="othersw-history" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§07</span><span class="idx__t">How much history to bring</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:22ch;margin-bottom:36px;">Three approaches to your historical data.</h2>
    <div class="r-3">
      {%- for h in history %}
      <div class="lift"><span class="lift__n">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span><div><h3>{{ h.opener | safe }}</h3><p>{{ h.body | safe }}</p></div></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- §08 PHASES (4-phase HowTo → process-grid) — white -#}
<section class="sec reveal" id="othersw-phases">
  <div class="ct">
    <div class="idx"><span class="idx__n">§08</span><span class="idx__t">How migration works</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:20ch;margin-bottom:12px;">From your old software to a verified QuickBooks file.</h2>
    <p class="lede" style="margin:0 0 44px;max-width:60ch;">Every migration into QuickBooks from another platform follows the same four-phase sequence &mdash; with verification against the source built in.</p>
    <div class="process-grid">
      {%- for s in phases %}
      <div class="process-step"><div class="process-step__n{% if loop.last %} process-step__n--done{% endif %}">PHASE {{ s.num }}{% if loop.last %} &check;{% endif %}</div>{% if s.name %}<h3>{{ s.name | safe }}</h3>{% endif %}<p>{{ s.body | safe }}</p>{% if s.when %}<p style="margin-top:8px;"><strong>{{ s.when | safe }}</strong></p>{% endif %}</div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- §09 REVIEW STANDARDS (reviewSpec → checklist incl-card) — sand -#}
