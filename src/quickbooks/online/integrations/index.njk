---

{# ── SUMMARY ── #}
<section class="section section--compact" id="qbo-integrations-hub-summary-sec">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In short</p>
      <h2 class="section__heading">All nine QuickBooks Online integrations, and where each one breaks the books.</h2>
    </header>
    <p class="prose" id="qbo-integrations-hub-summary">{{ summary | safe }}</p>
  </div>
</section>

{# ── INTEGRATION GRID · grouped by workflow, 9 QBO integration pages (buyer-cards) ── #}
{%- for group in integrationGroups %}
<section class="section{% if loop.index is even %} section--alt{% endif %}" id="qbo-integrations-hub-{{ group.id }}">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">{{ group.eyebrow | safe }}</p>
      <h2 class="section__heading">{{ group.heading | safe }}</h2>
      {%- if group.lede %}<p class="section__lede">{{ group.lede | safe }}</p>{%- endif %}
    </header>
    <div class="grid-3">
      {%- for f in group.integrations %}
      <article class="buyer-card">
        <h3 class="buyer-card__heading">{{ f.title | safe }}</h3>
        <p class="buyer-card__body">{{ f.body | safe }}</p>
        <a class="buyer-card__cta" href="{{ f.href }}">{{ f.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endfor %}

{# ── CROSS-LINKS ── #}
<section class="section section--compact" id="qbo-integrations-hub-related">
  <div class="container container--narrow">
    <p class="prose">{{ relatedNote | safe }}</p>
  </div>
</section>

{# ── FAQ ── #}
<section class="section section--alt" id="qbo-integrations-hub-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">QuickBooks Online integrations questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="qbo-integrations-hub-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="qbo-integrations-hub-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
