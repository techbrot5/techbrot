{# ── CAPABILITY GRID · grouped by what they're for, 10 Advanced capability pages (dc-card hub-cards). (H2 per group.) ── #}
{%- for group in capabilityGroups %}
<section class="sec reveal{% if loop.index is even %} hub-rt--alt{% endif %}" id="qbo-advanced-hub-{{ group.id }}"{% if loop.index is even %} style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);"{% endif %}>
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ group.eyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:28ch;margin-bottom:{% if group.lede %}10{% else %}28{% endif %}px;">{{ group.heading | safe }}</h2>
    {%- if group.lede %}<p class="lede" style="margin:0 0 30px;max-width:66ch;">{{ group.lede | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for c in group.capabilities %}
      <a class="dc-card hub-card" href="{{ c.href }}"><h3>{{ c.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;color:var(--color-ink-mute);">{{ c.body | safe }}</p><span class="hub-card__go">{{ c.cta | safe }}</span></a>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endfor %}

{# ── CROSS-LINKS (read). ── #}
<section class="sec reveal" id="qbo-advanced-hub-related">
  <div class="ct read">
    <p class="prose">{{ relatedNote | safe }}</p>
  </div>
</section>
