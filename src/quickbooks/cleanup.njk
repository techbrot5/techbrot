{#- §04 CREDENTIALS — ProAdvisor credentials list (.checklist in .incl-card).
    Trust-strip uses #cleanup-trust; this is #cleanup-credentials — no collision. -#}
<section class="sec reveal" id="cleanup-credentials" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§04</span><span class="idx__t">Certified by Intuit</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:20ch;margin-bottom:14px;">Certified QuickBooks ProAdvisor credentials.</h2>
    <p class="lede" style="margin:0 0 32px;max-width:56ch;">Every TechBrot operator holds active Certified QuickBooks ProAdvisor credentials across the full QuickBooks stack, plus the Intuit Certified Bookkeeping Professional credential. Verification available on request.</p>
    <div class="incl-card" style="max-width:560px;">
      <h3>The credentials, every operator</h3>
      <ul class="checklist">
        {%- for c in credentials %}<li>{{ c | safe }}</li>{%- endfor %}
      </ul>
    </div>
  </div>
</section>

{#- §05 DELIVERABLES (icon lattice) -#}
<section class="sec reveal" id="cleanup-deliverables">
  <div class="ct">
    <div class="idx"><span class="idx__n">§05</span><span class="idx__t">The scope</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:20ch;margin-bottom:36px;">What QuickBooks cleanup actually delivers.</h2>
    <div class="deliver">
      {%- for d in deliverables %}
      <div class="deliver__cell">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          {%- if loop.index == 1 %}<path d="M4 10a8 8 0 0114-4.5" stroke-linecap="round"/><path d="M4 5.5V10h4.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M20 14a8 8 0 01-14 4.5" stroke-linecap="round"/><path d="M20 18.5V14h-4.5" stroke-linecap="round" stroke-linejoin="round"/>
          {%- elif loop.index == 2 %}<path d="M4 7h16M4 12h16M4 17h10" stroke-linecap="round"/>
          {%- elif loop.index == 3 %}<rect x="4" y="5" width="16" height="14" rx="2"/><path d="M4 9.5h16M9.5 9.5V19" stroke-linecap="round"/>
          {%- elif loop.index == 4 %}<path d="M8 8h8v8H8z" stroke-linejoin="round"/><path d="M5 5l3 3M19 5l-3 3M5 19l3-3M19 19l-3-3" stroke-linecap="round"/>
          {%- elif loop.index == 5 %}<path d="M12 3v18M5 8l7-5 7 5" stroke-linecap="round" stroke-linejoin="round"/>
          {%- elif loop.index == 6 %}<path d="M12 3l7 3v6c0 4.5-3 8-7 9-4-1-7-4.5-7-9V6z" stroke-linejoin="round"/><path d="M9 12l2 2 4-4.5" stroke-linecap="round" stroke-linejoin="round"/>
          {%- elif loop.index == 7 %}<path d="M4 20h16M7 20V9M12 20V4M17 20v-7" stroke-linecap="round"/>
          {%- else %}<path d="M7 3h7l4 4v14H7z" stroke-linejoin="round"/><path d="M14 3v4h4M10 13h5M10 17h5" stroke-linecap="round"/>{%- endif %}
        </svg>
        <h3>{{ d.name | safe }}</h3>{% if d.body %}<p>{{ d.body | safe }}</p>{% endif %}
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- §06 PROCESS (4-step) — no timeline figure (data has none) -#}
<section class="sec reveal" id="cleanup-process" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§06</span><span class="idx__t">The process</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:18ch;margin-bottom:44px;">From file diagnostic to clean QuickBooks.</h2>
    <div class="process-grid">
      {%- for s in process %}
      <div class="process-step"><div class="process-step__n{% if loop.last %} process-step__n--done{% endif %}">STEP {{ s.num }}{% if loop.last %} &check;{% endif %}</div>{% if s.name %}<h3>{{ s.name | safe }}</h3>{% endif %}<p>{{ s.body | safe }}</p>{% if s.when %}<p style="margin-top:8px;"><strong>{{ s.when | safe }}</strong></p>{% endif %}</div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- §07 WHAT CHANGES (statement) + before/after table (full-depth 6-dim compare) -#}
<section class="sec reveal" id="cleanup-compare">
  <div class="ct">
    <div class="idx idx--center"><span class="idx__rule"></span><span class="idx__t">The difference</span><span class="idx__rule"></span></div>
    <div class="read" style="text-align:center;">
      <h2 class="statement">What changes when the file is clean.</h2>
      <p class="lede" style="margin:0 auto 24px;max-width:60ch;">Cleanup unwinds the file-level <em>compounding reconciliation drift</em> &mdash; here is the before and after, dimension by dimension.</p>
    </div>
    <table class="cmp" data-viz="comparison-table" data-viz-state="FINAL" style="margin-top:40px;">
      <caption class="sr-only">A QuickBooks file before and after a TechBrot cleanup, by dimension.</caption>
      <thead><tr><th scope="col">Dimension</th><th scope="col">Before cleanup</th><th scope="col" class="us">After cleanup</th></tr></thead>
      <tbody>
        {%- for r in compare %}
        <tr><th scope="row">{{ r.dim | safe }}</th><td data-col="Before cleanup">{{ r.before | safe }}</td><td class="us" data-col="After cleanup"><strong>{{ r.after | safe }}</strong></td></tr>
        {%- endfor %}
      </tbody>
    </table>
  </div>
</section>
