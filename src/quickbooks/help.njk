---json
{
  "layout": "layouts/t-hub.njk",
  "permalink": "/quickbooks/help/",
  "slug": "help",
  "bodyClass": "page--mofu",
  "heroFigure": false,
  "title": "QuickBooks Help from Certified ProAdvisors",
  "description": "QuickBooks help from Certified ProAdvisors — cleanup, setup, migration, payroll fixes, error resolution, and bookkeeping. Same-day diagnostic for emergencies.",
  "breadcrumb": [
