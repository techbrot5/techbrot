---json
{
  "layout": "layouts/t-mofu.njk",
  "permalink": "/quickbooks/proadvisor-team/",
  "slug": "qbpa",
  "tierClass": "section--tier-guide",
  "bodyClass": "page--mofu",
  "callBar": true,
