{#- ═══ QuickBooks PROADVISOR TEAM (BASELINE). t-mofu→t-prose. Every baseline heading
    + paragraph verbatim; #qbpa-in-brief-text (layout TL;DR) is the ONLY frozen
    speakable id, preserved by the layout. ai-summary + faq rendered by t-prose
    (aiSummary/faq data + sec.aiH/faqH). Old byline-block folded into the layout.
    Summary section authored in-body to keep BOTH baseline h2s (summary + ai-summary)
    and the frozen #qbpa-in-brief-text speakable. ═══ -#}

{#- SUMMARY — baseline h2 + frozen #qbpa-in-brief-text speakable (was inBrief). -#}
<section class="sec reveal" id="qbpa-summary" style="padding-top:8px;">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In short</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:16px;">The ProAdvisor team, summarized.</h2>
    <div class="tldr-prose"><p id="qbpa-in-brief-text">A <strong>Certified QuickBooks ProAdvisor</strong> is an accountant or bookkeeping professional who has passed Intuit&rsquo;s official certification exams and maintains active credentials through ongoing Intuit training. TechBrot&rsquo;s ProAdvisor team holds active certifications across all four core QuickBooks platforms: <strong>QuickBooks Online (Level 2), QuickBooks Desktop, QuickBooks Enterprise, and QuickBooks Payroll.</strong> We deliver bookkeeping, <a href="/quickbooks/setup/">setup</a>, <a href="/quickbooks/cleanup/">cleanup</a>, <a href="/quickbooks/migration/">migration</a>, <a href="/accounting/payroll-management/">payroll management</a>, and <a href="/accounting/sales-tax-compliance/">sales tax compliance</a> directly inside our clients&rsquo; QuickBooks files. <strong>Independent firm &mdash; not affiliated with Intuit Inc.</strong> Credentials are publicly verifiable on Intuit&rsquo;s ProAdvisor directory. The certification matters because it confirms the platform expertise that supports every other accounting decision.</p>
    <p class="tldr__src">Reference maintained by the Certified QuickBooks ProAdvisor team at TechBrot Inc., an independent firm &mdash; not affiliated with Intuit Inc. No affiliate or referral commissions on any QuickBooks platform.</p></div>
  </div>
</section>

{#- CREDENTIALS — ProAdvisor credentials (.checklist). -#}
<section class="sec reveal" id="qbpa-credentials">
  <div class="ct read read--doc">
    <p class="eyebrow" style="display:inline-flex;align-items:center;gap:12px;margin-bottom:14px;"><span class="rule-mark" aria-hidden="true"><span></span><span></span></span>Certified by Intuit &middot; Online (L2), Desktop, Enterprise, Payroll</p>
    <h2 class="h2" style="margin-bottom:18px;">Certified QuickBooks ProAdvisor credentials.</h2>
    <div class="trust-row" style="margin-bottom:22px;">
      {%- for s in credStats %}
      <div class="trust-row__item"><p class="trust-row__value">{{ s.value }}</p><p class="trust-row__label">{{ s.label }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <ul class="checklist">
      {%- for c in credentialsLede %}<li>{{ c | safe }}</li>{%- endfor %}
    </ul>
  </div>
</section>

{#- DEFINITION — what a ProAdvisor actually is (prose). -#}
<section class="sec reveal hub-rt--alt" id="qbpa-definition" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">The credential, defined</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:16px;">What a Certified QuickBooks ProAdvisor actually is.</h2>
    <div class="prose">
      {%- for p in definition %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{#- CERTIFICATIONS — four core certifications → r-2 dc-card + certNote. -#}
<section class="sec reveal" id="qbpa-certifications">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">The four core certifications</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">TechBrot&rsquo;s certifications, in detail.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:72ch;">There are four core Intuit QuickBooks ProAdvisor certifications. TechBrot holds active credentials in all of them. Each covers a distinct platform and a distinct set of capabilities.</p>
    <div class="r-2">
      {%- for c in certifications %}
      <div class="dc-card"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ c.platform | safe }} &middot; {{ c.tier | safe }}</span><h3>{{ c.name | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ c.body | safe }}</p><p style="margin-top:10px;"><a href="{{ c.href }}">{{ c.cta | safe }}</a></p></div>
      {%- endfor %}
    </div>
    <div class="prose" style="margin-top:20px;max-width:72ch;"><p>{{ certNote | safe }}</p></div>
  </div>
</section>

{#- OPERATION — how the practice operates → r-3 dc-card. -#}
<section class="sec reveal hub-rt--alt" id="qbpa-operation" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">How the practice operates</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">What ProAdvisor expertise actually looks like in practice.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:72ch;">Certifications are the signal. The substance is how the practice runs every day. Below is what ProAdvisor expertise produces operationally.</p>
    <div class="r-3">
      {%- for n in operation %}
      <div class="dc-card"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ n.num }}</span><h3>{{ n.name | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ n.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- SERVICES — where ProAdvisor expertise applies → r-3 dc-card (whole card not a link). -#}
<section class="sec reveal" id="qbpa-services">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Where ProAdvisor expertise applies</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">The services this credential anchors.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:72ch;">ProAdvisor certification is the foundation. Below are the specific engagements where it shows up in client work.</p>
    <div class="r-3">
      {%- for s in services %}
      <div class="dc-card"><h3><a href="{{ s.href }}">{{ s.name | safe }}</a></h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ s.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- COMPARISON — ProAdvisor vs alternatives → r-2 dc-card. -#}
<section class="sec reveal hub-rt--alt" id="qbpa-vs" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">ProAdvisor vs alternatives</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">How ProAdvisor compares to other options.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:72ch;">Buyers comparing options usually weigh ProAdvisor against three alternatives. Here&rsquo;s the honest read on each.</p>
    <div class="r-2">
      {%- for v in comparison %}
      <div class="dc-card"><h3>{{ v.name | safe }}</h3><span class="eyebrow" style="display:block;margin:6px 0;">{{ v.verdict | safe }}</span><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ v.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- WHY — what the credential protects you from (prose + ol). -#}
<section class="sec reveal" id="qbpa-why">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Why this matters for buyers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:16px;">What the credential actually protects you from.</h2>
    <div class="prose">
      {%- for p in whyProse %}<p>{{ p | safe }}</p>{%- endfor %}
      <ol>
        {%- for p in protection %}<li>{{ p | safe }}</li>{%- endfor %}
      </ol>
      <p>{{ whyClose | safe }}</p>
    </div>
  </div>
</section>

{#- ROUTING — situation cards → r-3 hub-card. -#}
<section class="sec reveal hub-rt--alt" id="qbpa-routing" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Your situation</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">Where are you with QuickBooks?</h2>
    <div class="r-3">
      {%- for b in routing %}
      <a class="dc-card hub-card" href="{{ b.href }}"><h3>{{ b.opener | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;color:var(--color-ink-mute);">{{ b.body | safe }}</p><span class="hub-card__go">{{ b.cta | safe }} <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
      {%- endfor %}
    </div>
  </div>
</section>

{#- PAGE STANDARDS — maintained-by block (moved from old faq section). -#}
<section class="sec reveal" id="qbpa-standards">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Page standards</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:16px;">Maintained by TechBrot&rsquo;s certified ProAdvisor team.</h2>
    <div class="prose">
      <p>This page is maintained and reviewed by the Certified QuickBooks ProAdvisor team at TechBrot Inc., an independent firm &mdash; not affiliated with Intuit Inc.</p>
    </div>
  </div>
</section>

{#- RELATED — where this credential routes. -#}
<section class="sec reveal hub-rt--alt" id="qbpa-related" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Related</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">Where this credential routes.</h2>
    {%- for n in related %}
    <div class="prose" style="margin-bottom:18px;">
      <h3 style="margin:0 0 4px;"><a href="{{ n.href }}">{{ n.title | safe }}</a></h3>
      <p style="margin:0;">{{ n.body | safe }}</p>
    </div>
    {%- endfor %}
  </div>
</section>
