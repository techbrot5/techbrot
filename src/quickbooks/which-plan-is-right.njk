          <td data-col="Desktop Premier">{% if r.premier == 'yes' %}<span class="mark-yes"></span><span class="sr-only">Yes</span>{% elif r.premier == 'no' %}<span class="mark-no"></span><span class="sr-only">No</span>{% else %}<span style="color:var(--color-ink-mute);">{{ r.premier | safe }}</span>{% endif %}</td>
          <td data-col="Enterprise">{% if r.ent == 'yes' %}<span class="mark-yes"></span><span class="sr-only">Yes</span>{% elif r.ent == 'no' %}<span class="mark-no"></span><span class="sr-only">No</span>{% else %}<span style="color:var(--color-ink-mute);">{{ r.ent | safe }}</span>{% endif %}</td>
        </tr>
        {%- endfor %}
      </tbody>
    </table>
  </div>
</section>

