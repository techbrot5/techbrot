        <h3>{{ p.name | safe }}</h3>
        <p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ p.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="sec reveal" id="qbwp-products">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">The full QuickBooks product map</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Nine tiers and editions, one decision.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">The complete QuickBooks landscape, organized by where each product fits in the lineup. Click through to any product hub for the deep read &mdash; or book the call and we&rsquo;ll walk you through it directly. For specific pricing, check Intuit directly &mdash; we don&rsquo;t publish their numbers because they change.</p>
