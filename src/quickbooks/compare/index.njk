---json
{
  "layout": "layouts/t-hub.njk",
  "permalink": "/quickbooks/compare/",
  "slug": "qb-compare-hub",
  "tierClass": "section--tier-hub",
  "bodyClass": "page--hub",
  "title": "QuickBooks Comparisons: Fair Reviews by ProAdvisors",
  "description": "QuickBooks vs Xero, Wave, Sage, FreshBooks, and Zoho Books, plus Online vs Desktop and the QBO plans. We prefer QuickBooks and say so — written to be fair.",
  "breadcrumb": [
    { "name": "Home", "href": "/" },
    { "name": "QuickBooks", "href": "/quickbooks/" },
    { "name": "Compare" }
  ],
  "heroFigure": false,
  "hero": {
    "eyebrow": "QuickBooks · Comparisons",
    "heading": "Choosing accounting software is a fit decision, not a winner-takes-all.",
    "subheading": "We're Certified QuickBooks ProAdvisors, so we prefer it and say so. But these comparisons are fair: where another tool fits your business better, we tell you. Honest reads of QuickBooks against the main alternatives and against itself. Independent firm — not Intuit.",
    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Book the discovery call", "href": "/contact/?intent=quickbooks", "class": "btn--ghost" }
    ],
    "trust": [
      "Certified QuickBooks ProAdvisor team",
      "Independent · not Intuit · not affiliated with these tools",
      "Fair reads — we name when a competitor fits better"
    ]
  },
  "ctaBand": {
    "eyebrow": "Start with your real file",
    "heading": "Not sure if QuickBooks is the right fit? Let's look at your actual file.",
    "lede": "Get a free QuickBooks file review or book a discovery call. We'll look at how your books are set up today and give you a straight read on whether QuickBooks fits — and if another tool fits you better, we'll tell you. No pitch. Independent firm — not Intuit.",
    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Book the discovery call", "href": "/contact/?intent=quickbooks", "class": "btn--ghost" }
    ]
  },
  "sec": {
    "summaryId": "qb-compare-hub-summary",
    "summaryTag": "In short",
    "summaryH": "Seven fair comparisons, written by ProAdvisors who tell you the truth.",
    "faqTag": "FAQ",
    "faqH": "QuickBooks comparison questions."
  }
}
---

{# ── COMPARISON GRID · grouped (vs alternatives / vs itself), dc-card hub-card r-3. (H2 per group) ── #}
{%- for group in compareGroups %}
<section class="sec reveal{% if loop.index is even %} hub-rt--alt{% endif %}" id="qb-compare-hub-{{ group.id }}"{% if loop.index is even %} style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);"{% endif %}>
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ group.eyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:28ch;margin-bottom:{% if group.lede %}10{% else %}28{% endif %}px;">{{ group.heading | safe }}</h2>
    {%- if group.lede %}<p class="lede" style="margin:0 0 30px;max-width:66ch;">{{ group.lede | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for c in group.cards %}
      <a class="dc-card hub-card" href="{{ c.href }}"><h3>{{ c.title | safe }}</h3><p class="prose" style="font-size:15px;margin:6px 0 0;">{{ c.body | safe }}</p><span class="hub-card__go">{{ c.cta | safe }}</span></a>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endfor %}

{# ── CROSS-LINKS (read). ── #}
<section class="sec reveal" id="qb-compare-hub-related">
  <div class="ct read">
    <p class="prose">{{ relatedNote | safe }}</p>
  </div>
</section>
