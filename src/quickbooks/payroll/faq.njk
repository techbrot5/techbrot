{#- ═══ QB PAYROLL FAQ (BASELINE, equity-gated). t-guide→t-prose / dc-base chrome.
    Every baseline heading verbatim at level (popular H2+lede · featured H3 accordion ·
    body H2 "All QuickBooks Payroll questions…" · cluster H2+H3 from data · related
    H2+H3). FAQPage schema is data-driven (faq.11tydata.js: data.featured ONLY) — the
    featured accordion is BOTH the visible block and the schema source, kept verbatim
    as a v2 .faq details block (schema == rendered). inBrief → layout TL;DR
    (#qbpfaq-in-brief-text speakable). founder-name-zero. ═══ -#}

{#- POPULAR — link cards + featured accordion (FAQPage schema source). -#}
<section class="sec reveal" id="qbpfaq-popular" style="padding-top:8px;">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Most asked</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Six questions answered most often.</h2>
    <p class="lede" style="margin:0 0 24px;max-width:72ch;">The six questions businesses ask most, answered verbatim below. Every other question lives in the topic clusters that follow.</p>
    <div class="r-3">
      {%- for p in popular %}
      <a class="dc-card hub-card" href="#{{ p.anchor }}"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ p.qid }} &middot; {{ p.cluster }}</span><h3 style="font-size:16px;">{{ p.q | safe }}</h3><span class="hub-card__go">Jump to answer <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
      {%- endfor %}
    </div>
    <div class="faq" style="margin-top:32px;">
      {%- for item in featured %}
      <details id="qbpfaq-faq-a{{ loop.index }}" name="qbpfaq-featured"{% if loop.first %} open{% endif %}><summary>{{ item.q | safe }}<span class="pl"></span></summary><div><p>{{ item.a | safe }}</p></div></details>
      {%- endfor %}
    </div>
  </div>
</section>

{#- BODY — all clusters as editorial reading column. Visible body H2 verbatim. -#}
<section class="sec reveal" id="qbpfaq-body" style="padding-top:24px;">
  <div class="ct read read--doc">
    <h2 class="h2" style="margin-bottom:18px;">All QuickBooks Payroll questions, organized by topic</h2>
    <div class="prose-byline" style="margin-top:0;border-top:0;padding-top:0;">
      <span class="prose-byline__mark"><svg width="16" height="16" viewBox="0 0 64 64" fill="#FCFBF8" aria-hidden="true"><path d="M8 10 H38 V54 H26 V22 H8 Z"/><rect x="42" y="10" width="14" height="12"/></svg></span>
      <div>
        <p class="prose-byline__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="prose-byline__meta">Reviewed by a Certified QuickBooks Payroll ProAdvisor &middot; independent, zero affiliate commission on any provider</p>
      </div>
    </div>
    <nav class="prose" aria-label="Topic clusters" style="margin:22px 0 4px;font-size:14px;">
      <span class="eyebrow" style="display:block;margin-bottom:8px;">Topic clusters</span>
      <ol style="margin:0;padding-left:18px;">
        {%- for c in clusters %}
        <li><a href="#{{ c.id }}">{{ c.heading | safe }}</a></li>
        {%- endfor %}
      </ol>
    </nav>
    <div class="opquote" style="margin:26px 0;">
      <blockquote>We implement QuickBooks Payroll, Gusto, ADP, and Paychex alike with zero affiliate commission &mdash; every answer here reflects business fit, not what pays us.</blockquote>
    </div>
    <div class="prose">
      {%- for c in clusters %}
      <section id="{{ c.id }}" aria-labelledby="{{ c.id }}-h">
        <h2 id="{{ c.id }}-h">{{ c.heading | safe }}</h2>
        <p>{{ c.lede | safe }}</p>
        {%- for it in c.items %}
        <h3 id="{{ it.anchor }}">{{ it.q | safe }}</h3>
        {{ it.a | safe }}
        {%- endfor %}
      </section>
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Maintained by the Certified QuickBooks ProAdvisor team</span><span>32 questions &middot; 7 clusters</span><span>Last reviewed: 2026-06 &middot; Certified QuickBooks Payroll ProAdvisor</span></p>
  </div>
</section>

{#- RELATED -#}
<section class="sec reveal" id="qbpfaq-related" style="padding-top:24px;">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Related services</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">The full payroll service universe.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:72ch;">Every payroll engagement type referenced across the FAQ, organized for quick navigation. Start where your question lives.</p>
    <div class="r-3">
      {%- for n in related %}
      <a class="dc-card hub-card" href="{{ n.href }}"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ n.cluster }}</span><h3>{{ n.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;color:var(--color-ink-mute);">{{ n.body | safe }}</p><span class="hub-card__go">Read more <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
      {%- endfor %}
    </div>
  </div>
</section>
