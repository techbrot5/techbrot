---

{# ── SUMMARY ── #}
<section class="section section--compact" id="recon-hub-summary-sec">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In short</p>
      <h2 class="section__heading">Do it right, fix it when it breaks, keep it clean.</h2>
    </header>
    <p class="prose" id="recon-hub-summary">{{ summary | safe }}</p>
  </div>
</section>

{# ── RECONCILIATION GRID · grouped, spoke + related pages (buyer-cards) ── #}
{%- for group in cardGroups %}
<section class="section{% if loop.index is even %} section--alt{% endif %}" id="recon-hub-{{ group.id }}">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">{{ group.eyebrow | safe }}</p>
      <h2 class="section__heading">{{ group.heading | safe }}</h2>
      {%- if group.lede %}<p class="section__lede">{{ group.lede | safe }}</p>{%- endif %}
    </header>
    <div class="grid-3">
      {%- for c in group.cards %}
      <article class="buyer-card">
        <h3 class="buyer-card__heading">{{ c.title | safe }}</h3>
        <p class="buyer-card__body">{{ c.body | safe }}</p>
        <a class="buyer-card__cta" href="{{ c.href }}">{{ c.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endfor %}

{# ── CROSS-LINKS ── #}
<section class="section section--compact" id="recon-hub-related">
  <div class="container container--narrow">
    <p class="prose">{{ relatedNote | safe }}</p>
  </div>
</section>

{# ── FAQ ── #}
<section class="section section--alt" id="recon-hub-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">QuickBooks reconciliation questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="recon-hub-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="recon-hub-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
