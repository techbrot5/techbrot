{# ── RECONCILIATION GRID · grouped, spoke + related pages (dc-card hub-card r-3) ── #}
{%- for group in cardGroups %}
<section class="sec reveal" id="recon-hub-{{ group.id }}"{% if loop.index is even %} style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);"{% endif %}>
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ group.eyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:28ch;margin-bottom:{% if group.lede %}10{% else %}28{% endif %}px;">{{ group.heading | safe }}</h2>
    {%- if group.lede %}<p class="lede" style="margin:0 0 30px;max-width:66ch;">{{ group.lede | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for c in group.cards %}
      <a class="dc-card hub-card" href="{{ c.href }}"><h3>{{ c.title | safe }}</h3><p class="prose" style="font-size:15px;margin:6px 0 0;">{{ c.body | safe }}</p><span class="hub-card__go">{{ c.cta | safe }}</span></a>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endfor %}

{# ── CROSS-LINKS — prose note (sand, read) ── #}
<section class="sec reveal" id="recon-hub-related" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="prose"><p>{{ relatedNote | safe }}</p></div>
  </div>
</section>
