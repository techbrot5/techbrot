<section class="sec reveal" id="qbe-credentials" aria-labelledby="qbe-credentials-heading">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Certified by Intuit &middot; Enterprise, Desktop, Online (L2), Payroll</span><span class="idx__rule"></span></div>
    <h2 class="h2" id="qbe-credentials-heading" style="margin-bottom:24px;">Certified QuickBooks ProAdvisor credentials</h2>
    <div class="r-3" style="margin-bottom:26px;">
      {%- for s in credStats %}
      <div><div class="mono" style="font-size:30px;font-weight:500;color:var(--color-accent);">{{ s.value }}</div><div style="font-size:13px;line-height:1.5;color:var(--color-ink-mute);margin-top:8px;">{{ s.label }}</div></div>
      {%- endfor %}
    </div>
    <ul class="checklist">
      {%- for c in credentials %}<li>{{ c | safe }}</li>{%- endfor %}
    </ul>
  </div>
</section>

