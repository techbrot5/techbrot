{# ── THREE BUYER SITUATIONS · r-3 dc-cards. 3 frozen H3s verbatim. (H2 + 3 H3s verbatim) ── #}
<section class="sec reveal hub-rt--alt" id="qb-speak-situations" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Three buyer situations</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:14px;">What kind of conversation do you need?</h2>
    <p class="lede" style="margin:0 0 32px;max-width:70ch;">Different situations need different response times, and we&rsquo;re honest about what we can and can&rsquo;t do on each &mdash; no false urgency, no false patience. Each is advisory on your own books; an Intuit account or billing problem is Intuit&rsquo;s to fix, not this call&rsquo;s.</p>
    <div class="r-3">
      {%- for s in situations %}
      <div class="dc-card">
        <span class="eyebrow" style="display:block;margin-bottom:8px;">{{ s.signal | safe }}</span>
        <h3>{{ s.title | safe }}</h3>
        <p class="prose" style="font-size:14.5px;margin:8px 0 0;"><strong>Response:</strong> {{ s.response | safe }}</p>
        <p class="prose" style="font-size:14.5px;margin:8px 0 0;">{{ s.body | safe }}</p>
        <p class="prose" style="font-size:14.5px;margin:8px 0 0;"><strong>Honest scope:</strong> {{ s.honesty | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

