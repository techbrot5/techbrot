---

{#- ═══ QUICKBOOKS FAQ (BASELINE, equity-gated). t-guide→t-prose / dc-base chrome.
    Every baseline heading verbatim at level (popular H2 · sr-only body H2 · cluster
    H2+H3 from data · review H2 · related H2+H3). FAQPage schema is data-driven
    (faq.11tydata.js: all cluster items) — clusters render the questions verbatim, so
    schema == rendered. No separate flat-faq array → FAQ stays bespoke-clustered in
    body (no sec.faqH). inBrief → layout TL;DR (#qbfaq-in-brief-text speakable).
    lead-magnet + reconcile-flow figure preserved. founder-name-zero. ═══ -#}

{#- POPULAR -#}
<section class="sec reveal" id="qbfaq-popular" style="padding-top:8px;">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Most asked</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">Six questions answered most often.</h2>
    <div class="r-3">
      {%- for p in popular %}
      <a class="dc-card hub-card" href="#{{ p.anchor }}"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ p.qid }} &middot; {{ p.cluster }}</span><h3 style="font-size:16px;">{{ p.q | safe }}</h3><span class="hub-card__go">Jump to answer <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
      {%- endfor %}
    </div>
  </div>
</section>

{#- BODY — all clusters as editorial reading column. Cluster H2 + per-question H3
    verbatim; mid-article reconcile-flow figure + lead-magnet preserved. -#}
<section class="sec reveal" id="qbfaq-body" style="padding-top:24px;">
  <div class="ct read read--doc">
    <h2 class="sr-only">All QuickBooks questions, organized by topic</h2>
    <div class="prose-byline" style="margin-top:0;border-top:0;padding-top:0;">
      <span class="prose-byline__mark"><svg width="16" height="16" viewBox="0 0 64 64" fill="#FCFBF8" aria-hidden="true"><path d="M8 10 H38 V54 H26 V22 H8 Z"/><rect x="42" y="10" width="14" height="12"/></svg></span>
      <div>
        <p class="prose-byline__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="prose-byline__meta">Reviewed by a Certified QuickBooks ProAdvisor &middot; independent, zero Intuit commission</p>
      </div>
    </div>
    <nav class="prose" aria-label="Topic clusters" style="margin:22px 0 4px;font-size:14px;">
      <span class="eyebrow" style="display:block;margin-bottom:8px;">Topic clusters</span>
      <ol style="margin:0;padding-left:18px;">
        {%- for c in clusters %}
        <li><a href="#{{ c.id }}">{{ c.heading | safe }}</a></li>
        {%- endfor %}
      </ol>
    </nav>
    <div class="opquote" style="margin:26px 0;">
      <blockquote>Every answer here reflects how we&rsquo;d actually advise a client &mdash; no hedging, no affiliate spin, and zero commission on any Intuit product.</blockquote>
    </div>
    <div class="prose">
      {%- for c in clusters %}
      <section id="{{ c.id }}" aria-labelledby="{{ c.id }}-h">
        <h2 id="{{ c.id }}-h">{{ c.heading | safe }}</h2>
        <p>{{ c.lede | safe }}</p>
        {%- if c.id == "cluster-fixing" %}
        {% include "partials/figure-reconcile-flow.svg" %}
        {%- endif %}
        {%- for it in c.items %}
        <h3 id="{{ it.anchor }}">{{ it.q | safe }}</h3>
        {{ it.a | safe }}
        {%- endfor %}
      </section>
      {%- if loop.index == 4 %}
      {#- Lead-magnet — the one mid-article offer. Honest: links to the REAL free
          file review, not a fabricated download. -#}
      <div class="lead-magnet">
        <div class="lead-magnet__text">
          <p class="lead-magnet__title">Still have a question about your own file?</p>
          <p class="lead-magnet__sub">A Certified ProAdvisor reviews your QuickBooks file and answers it directly &mdash; free, no obligation.</p>
        </div>
        <a class="lead-magnet__cta" href="/quickbooks/file-review/?intent=file-review">Get the free file review <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a>
      </div>
      {%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Maintained by the Certified QuickBooks ProAdvisor team</span><span>35 questions &middot; 7 clusters</span><span>Last reviewed: 2026-06 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{#- REVIEW -#}
<section class="sec reveal hub-rt--alt" id="qbfaq-review" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Page review &amp; standards</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:14px;">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    <div class="prose">
      <p>{{ reviewBody | safe }}</p>
    </div>
    <div class="trust-row" style="margin-top:22px;">
      {%- for r in reviewerCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.label | safe }}</p><p class="trust-row__label">{{ r.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
  </div>
</section>

{#- RELATED -#}
<section class="sec reveal" id="qbfaq-related" style="padding-top:24px;">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Related services</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">The full QuickBooks service universe.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:72ch;">Every engagement type referenced across the FAQ, organized for quick navigation. Start where your question lives.</p>
    <div class="r-3">
      {%- for n in related %}
      <a class="dc-card hub-card" href="{{ n.href }}"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ n.cluster }}</span><h3>{{ n.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;color:var(--color-ink-mute);">{{ n.body | safe }}</p><span class="hub-card__go">Read more <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
      {%- endfor %}
    </div>
  </div>
</section>
