    </header>
    <div class="grid-2">
      {%- for c in needs %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ c.rank }}</p>
        <h3>{{ c.name | safe }}</h3>
        <p class="prose">{{ c.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section" id="acct-startup-system">
  <div class="container container--narrow">
