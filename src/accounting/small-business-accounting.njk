      <h2 class="section__heading">What small business accounting includes.</h2>
      <p class="section__lede">Six pieces that fit together &mdash; the foundation first, then the layers a business adds as it grows.</p>
    </header>
    <div class="grid-2">
      {%- for c in scope %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ c.rank }}</p>
        <h3>{{ c.name | safe }}</h3>
        <p class="prose">{{ c.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

