<section class="sec reveal hub-rt--alt" id="acct-coa-anatomy" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">The anatomy</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">What lives in a chart of accounts.</h2>
    <p class="lede" style="margin:0 0 24px;max-width:70ch;">Five account types, two reporting dimensions, one structure that makes the books work.</p>
    <div class="r-3">
      {%- for a in anatomy %}
      <div class="dc-card"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ a.num }}</span><h3>{{ a.name | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ a.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

