---

{# ── DEFINITION · real H2 carrying the e-commerce definition prose + payout-decomposition vs-table (no extra heading, T3 no collapse). (H2: E-commerce accounting, plainly.) ── #}
<section class="section" id="acctind-ecommerce-definition">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In plain terms</p>
      <h2 class="section__heading">E-commerce accounting, plainly.</h2>
    </header>
    <div class="prose">
      {%- for p in definition %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="vs-scroll">
      <table class="vs-table">
        <caption class="sr-only">What a single netted e-commerce payout actually contains, and where each piece belongs in QuickBooks</caption>
        <thead><tr><th scope="col">In one payout</th><th scope="col">Netted &mdash; what you see</th><th scope="col" class="vs-table__us">Decomposed &mdash; how we book it</th></tr></thead>
        <tbody>
          {%- for r in payoutRows %}
          <tr><th scope="row">{{ r.line | safe }}</th><td><span class="vs-table__concede">{{ r.net | safe }}</span></td><td class="vs-table__us"><span class="vs-table__concede">{{ r.clean | safe }}</span></td></tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. NON-heading questions (baseline <dt>). (H2: E-commerce accounting, in five questions.) ── #}
<section class="section section--alt" id="acctind-ecommerce-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">E-commerce accounting, in five questions.</h2>
    </header>
    <div class="ai-summary ai-summary--ruled">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <p class="ai-summary__question">{{ item.q | safe }}</p>
        <div class="ai-summary__answer"><p>{{ item.a | safe }}</p></div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── CHALLENGES · three places sellers lose the numbers (grid-3 buyer-cards). (H2 + 3 H3s) ── #}
<section class="section" id="acctind-ecommerce-challenges">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why e-commerce books break</p>
      <h2 class="section__heading">Three places sellers lose the numbers.</h2>
      <p class="section__lede">Nearly every messy e-commerce file fails in the same three areas. Knowing which one you&rsquo;re in tells us where to start.</p>
    </header>
    <div class="grid-3">
      {%- for c in challenges %}
      <div class="buyer-card">
        <p class="buyer-card__opener">{{ c.signal | safe }}</p>
        <h3 class="buyer-card__heading">{{ c.title | safe }}</h3>
        <p class="buyer-card__body">{{ c.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── WHAT WE HANDLE · the six services (grid-3 stack-8). (H2 + 6 H3s) ── #}
<section class="section section--alt" id="acctind-ecommerce-handle">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What TechBrot handles</p>
      <h2 class="section__heading">E-commerce accounting, done by an expert.</h2>
      <p class="section__lede">Every engagement is scoped to your channels and volume, delivered in your own QuickBooks file by a named Certified ProAdvisor.</p>
    </header>
    <div class="grid-3">
      {%- for s in handle %}
      <div class="stack-8">
        <p class="num">{{ s.num | safe }}</p>
        <h3><a href="{{ s.href }}">{{ s.title | safe }}</a></h3>
        <p class="prose">{{ s.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── INTEGRATIONS · platforms reconciled with QuickBooks (checks-list). (H2: Connected to where you sell.) ── #}
<section class="section" id="acctind-ecommerce-integrations">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Platforms we reconcile</p>
      <h2 class="section__heading">Connected to where you sell.</h2>
    </header>
    <ul class="checks-list">
      {%- for t in integrations %}<li>{{ t | safe }}</li>{%- endfor %}
    </ul>
    <p class="prose">{{ integrationsNote | safe }}</p>
  </div>
</section>

{# ── PROCESS · four-phase engagement rhythm (process-diagram). (H2 + 4 H3s) ── #}
<section class="section section--alt" id="acctind-ecommerce-process">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">How engagements work</p>
      <h2 class="section__heading">From messy payouts to clean margins.</h2>
      <p class="section__lede">Every e-commerce engagement follows the same four-phase rhythm &mdash; books accurate first, profit visibility second, advisory third.</p>
    </header>
    <ol class="process-diagram">
      {%- for s in process %}
      <li class="process-step">
        <p class="process-step__number">{{ s.num | safe }}</p>
        <h3 class="process-step__heading">{{ s.name | safe }}</h3>
        <p class="process-step__body">{{ s.body | safe }}</p>
      </li>
      {%- endfor %}
    </ol>
  </div>
</section>

{# ── ADVISORY · standing brand line carried as section prose; preserves baseline "advice vs bookkeeping" Q/A. (H2: Clean books are the start. Decisions are the point.) ── #}
<section class="section" id="acctind-ecommerce-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Beyond the books</p>
      <h2 class="section__heading">Clean books are the start. Decisions are the point.</h2>
    </header>
    <div class="prose">
      {%- for p in advisoryBody %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="/contact/?intent=accounting">Book the discovery call</a>
    </div>
  </div>
</section>

{# ── FAQ · 5 contract Q/A + 1 appended genuine FAQ (FLAGGED); visible faq__list = FAQPage schema (same array, NO dedup). (H2: E-commerce accounting questions.) ── #}
<section class="section section--alt" id="acctind-ecommerce-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">E-commerce accounting questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="acctind-ecommerce-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="acctind-ecommerce-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name (trust-row + meta-reviewed). (H2: Reviewed by the ProAdvisor team.) ── #}
<section class="section" id="acctind-ecommerce-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the ProAdvisor team.</h2>
    </header>
    <div class="prose">
      <p>This page reflects how TechBrot actually handles e-commerce engagements. It is maintained by the Certified QuickBooks ProAdvisor team at <strong>TechBrot Inc.</strong>, a Delaware-incorporated independent ProAdvisor firm, and reviewed for technical accuracy on multi-channel reconciliation, inventory and COGS, and sales-tax nexus. Where our approach or scope changes, this page is updated. TechBrot delivers the books and coordinates with your CPA, who confirms nexus and files.</p>
    </div>
    <div class="trust-row">
      {%- for r in reviewSpec %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.value | safe }}</p><p class="trust-row__label">{{ r.label | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-15</span><span>Updated: 2026-06-15</span><span>Reviewed: 2026-06-15 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{# ── RELATED · services & industries (stack-8). (H2 + 4 H3s) ── #}
<section class="section section--alt" id="acctind-ecommerce-related">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Related</p>
      <h2 class="section__heading">Related services &amp; industries.</h2>
    </header>
    {%- for r in related %}
    <div class="stack-8">
      <h3><a href="{{ r.href }}">{{ r.title | safe }}</a></h3>
      <p class="prose">{{ r.body | safe }}</p>
    </div>
    {%- endfor %}
  </div>
</section>
