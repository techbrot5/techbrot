{# ── FAQ · 7 contract Q/A VERBATIM (NO dedup); visible faq__list = FAQPage schema (same array). (H2: Professional services accounting questions.) ── #}
<section class="section section--alt" id="acctind-profsvc-faq">
  <div class="container container--narrow">
