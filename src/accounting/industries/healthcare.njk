</section>

{#- CHALLENGES — 3 dc-cards (H2 + 3 H3s). -#}
<section class="sec reveal hub-rt--alt" id="acctind-healthcare-challenges" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Why healthcare books break</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Three places practices lose the numbers.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">Nearly every messy practice file fails in the same three areas. Knowing which one you&rsquo;re in tells us where to start.</p>
    <div class="r-3">
      {%- for c in challenges %}
      <div class="dc-card"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ c.signal | safe }}</span><h3>{{ c.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ c.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- WHAT WE HANDLE — the six services (H2 + 6 H3s). -#}
