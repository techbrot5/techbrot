<section class="section section--alt" id="amz-related">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Related</p>
      <h2 class="section__heading">Related services &amp; industries.</h2>
    </header>
    {%- for r in related %}
    <div class="stack-8">
