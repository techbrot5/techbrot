{# ── DEFINITION · real H2 carrying the Amazon-seller definition prose + settlement-decomposition vs-table (no extra heading, T3 no collapse). (H2: Amazon seller accounting, plainly.) ── #}
<section class="section" id="amz-definition">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In plain terms</p>
      <h2 class="section__heading">Amazon seller accounting, plainly.</h2>
    </header>
    <div class="prose">
      {%- for p in definition %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="vs-scroll">
      <table class="vs-table">
        <caption class="sr-only">What a single Amazon settlement deposit actually contains, and where each piece belongs in QuickBooks</caption>
        <thead><tr><th scope="col">Inside one settlement</th><th scope="col">Netted &mdash; what hits your bank</th><th scope="col" class="vs-table__us">Decomposed &mdash; how we book it</th></tr></thead>
        <tbody>
          {%- for r in settlementRows %}
          <tr><th scope="row">{{ r.line | safe }}</th><td><span class="vs-table__concede">{{ r.net | safe }}</span></td><td class="vs-table__us"><span class="vs-table__concede">{{ r.clean | safe }}</span></td></tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. NON-heading questions. (H2: Amazon seller accounting, in five questions.) ── #}
<section class="section section--alt" id="amz-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">Amazon seller accounting, in five questions.</h2>
    </header>
    <div class="ai-summary ai-summary--ruled">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <p class="ai-summary__question">{{ item.q | safe }}</p>
        <div class="ai-summary__answer"><p>{{ item.a | safe }}</p></div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── CHALLENGES · three places Amazon sellers lose the numbers (grid-3 buyer-cards). (H2 + 3 H3s) ── #}
<section class="section" id="amz-challenges">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why Amazon books break</p>
      <h2 class="section__heading">Three places Amazon sellers lose the numbers.</h2>
      <p class="section__lede">Almost every messy Amazon file fails in the same three areas. Knowing which one you&rsquo;re in tells us where to start.</p>
    </header>
    <div class="grid-3">
      {%- for c in challenges %}
      <div class="buyer-card">
        <p class="buyer-card__opener">{{ c.signal | safe }}</p>
        <h3 class="buyer-card__heading">{{ c.title | safe }}</h3>
        <p class="buyer-card__body">{{ c.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── WHAT WE HANDLE · the six services (grid-3 stack-8). (H2 + 6 H3s) ── #}
<section class="section section--alt" id="amz-handle">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What TechBrot handles</p>
      <h2 class="section__heading">Amazon seller accounting, done by an expert.</h2>
      <p class="section__lede">Every engagement is scoped to your settlement volume, marketplaces, and FBA footprint, delivered in your own QuickBooks file by a named Certified ProAdvisor.</p>
    </header>
    <div class="grid-3">
      {%- for s in handle %}
      <div class="stack-8">
        <h3><a href="{{ s.href }}">{{ s.title | safe }}</a></h3>
        <p class="prose">{{ s.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── INTEGRATIONS · what we reconcile from Seller Central into QuickBooks (checks-list). (H2: From Seller Central into QuickBooks.) ── #}
<section class="section" id="amz-integrations">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">What we reconcile</p>
      <h2 class="section__heading">From Seller Central into QuickBooks.</h2>
    </header>
    <ul class="checks-list">
      {%- for t in integrations %}<li>{{ t | safe }}</li>{%- endfor %}
    </ul>
    <p class="prose">{{ integrationsNote | safe }}</p>
  </div>
</section>

{# ── PROCESS · four-phase engagement rhythm (process-diagram). (H2 + 4 H3s) ── #}
<section class="section section--alt" id="amz-process">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">How engagements work</p>
      <h2 class="section__heading">From netted settlements to clean margins.</h2>
      <p class="section__lede">Every Amazon engagement follows the same four-phase rhythm &mdash; books accurate first, profit visibility second, advisory third.</p>
    </header>
    <ol class="process-diagram">
      {%- for s in process %}
      <li class="process-step">
        <p class="process-step__number">{{ s.num | safe }}</p>
        <h3 class="process-step__heading">{{ s.name | safe }}</h3>
        <p class="process-step__body">{{ s.body | safe }}</p>
      </li>
      {%- endfor %}
    </ol>
  </div>
</section>

{# ── ADVISORY · standing brand line carried as section prose. (H2: Clean books are the start. Decisions are the point.) ── #}
<section class="section" id="amz-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Beyond the books</p>
      <h2 class="section__heading">Clean books are the start. Decisions are the point.</h2>
    </header>
    <div class="prose">
      {%- for p in advisoryBody %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="/contact/?intent=accounting">Book the discovery call</a>
    </div>
  </div>
</section>

{# ── FAQ · distinct Amazon Q/A; visible faq__list = FAQPage schema (same array, NO dedup). (H2: Amazon seller accounting questions.) ── #}
<section class="section section--alt" id="amz-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">Amazon seller accounting questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="amz-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="amz-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name (trust-row + meta-reviewed). (H2: Reviewed by the ProAdvisor team.) ── #}
<section class="section" id="amz-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the ProAdvisor team.</h2>
    </header>
    <div class="prose">
      <p>This page reflects how TechBrot actually handles Amazon seller engagements. It is maintained by the Certified QuickBooks ProAdvisor team at <strong>TechBrot Inc.</strong>, a Delaware-incorporated independent ProAdvisor firm, and reviewed for technical accuracy on settlement-report reconciliation, FBA inventory and COGS, reserve handling, and marketplace-facilitator sales-tax recording. Where our approach or scope changes, this page is updated. TechBrot delivers the books and keeps the records your CPA needs; your CPA confirms nexus and files. Not affiliated with Intuit Inc. or Amazon.com, Inc.</p>
    </div>
    <div class="trust-row">
      {%- for r in reviewSpec %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.value | safe }}</p><p class="trust-row__label">{{ r.label | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-19</span><span>Updated: 2026-06-19</span><span>Reviewed: 2026-06-19 &middot; Certified QuickBooks ProAdvisor</span></p>
