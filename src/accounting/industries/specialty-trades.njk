{#- DEFINITION — speakable target id PRESERVED (trade-definition). -#}
<section class="sec reveal" id="trade-definition">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In plain terms</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:16px;">Specialty trade contractor accounting, plainly.</h2>
    <div class="prose">
      {%- for p in definition %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{#- CHALLENGES — 3 H3s verbatim (r-3 dc-card). -#}
<section class="sec reveal hub-rt--alt" id="trade-challenges" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Why trade-contractor books break</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Three places service-and-replacement trades lose the numbers.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">Almost every messy HVAC, plumbing, or electrical file fails in the same three areas. Knowing which one you&rsquo;re in tells us where to start.</p>
    <div class="r-3">
      {%- for c in challenges %}
      <div class="dc-card"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ c.signal | safe }}</span><h3>{{ c.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ c.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- SUB-VERTICALS — 6 H3s verbatim (r-3 dc-card, NON-linked h3). -#}
<section class="sec reveal" id="trade-trades">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Who we serve</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">One engagement model across the service trades.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">Each specialty trade has its own parts intensity, install-versus-service mix, and ticket profile &mdash; but the accounting backbone is shared: cost the ticket, defer the agreement, reconcile the financing, tie out the FSM platform. The engagement model &mdash; fixed-fee, written scope, named ProAdvisor, work in your own QuickBooks file &mdash; stays consistent.</p>
    <div class="r-3">
      {%- for t in trades %}
      <div class="dc-card"><h3>{{ t.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ t.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- WHAT WE HANDLE — 6 H3s verbatim (r-3 dc-card, h3 linked, s.num eyebrow). No s.cta in data. -#}
<section class="sec reveal hub-rt--alt" id="trade-handle" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">What TechBrot handles</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Trade-contractor accounting, done by an expert.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">Every engagement is scoped to your trade, tech and truck count, agreement volume, financing volume, FSM platform, and any prevailing-wage work, delivered in your own QuickBooks file by a named Certified ProAdvisor.</p>
    <div class="r-3">
      {%- for s in handle %}
      <div class="dc-card"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ s.num | safe }}</span><h3><a href="{{ s.href }}">{{ s.title | safe }}</a></h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ s.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- INTEGRATIONS — checks-list. -#}
<section class="sec reveal" id="trade-integrations">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Tools we work alongside</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Connected to your trade-service stack.</h2>
    <ul class="checklist">
      {%- for t in integrations %}<li>{{ t | safe }}</li>{%- endfor %}
    </ul>
    <p class="prose" style="margin-top:16px;">{{ integrationsNote | safe }}</p>
  </div>
</section>

{#- COMPARISON — vs-table → cmp table. Highlighted col = Per-ticket trade costing (TechBrot). -#}
<section class="sec reveal" id="trade-comparison">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Why generic books miss trade economics</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Per-ticket trade costing vs. month-total bookkeeping.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">The structural differences that explain why a standard P&amp;L can show a profitable month while individual service calls and trucks quietly lose money &mdash; and why trade contractors need the books built at the ticket level.</p>
    <table class="cmp">
      <caption class="sr-only">Per-ticket specialty-trade costing versus month-total generic bookkeeping compared</caption>
      <thead><tr><th scope="col">What the books need to handle</th><th scope="col" class="us">Per-ticket trade costing (TechBrot)</th><th scope="col">Month-total generic bookkeeping</th></tr></thead>
      <tbody>
        {%- for r in comparison %}
        <tr><th scope="row" data-col="What the books need to handle">{{ r.row | safe }}</th><td class="us" data-col="Per-ticket trade costing (TechBrot)">{{ r.us | safe }}</td><td data-col="Month-total generic bookkeeping">{{ r.them | safe }}</td></tr>
        {%- endfor %}
      </tbody>
    </table>
    <p class="prose" style="margin-top:18px;">{{ comparisonNote | safe }}</p>
  </div>
</section>

{#- PROCESS — 4 H3s verbatim (process-grid). -#}
<section class="sec reveal hub-rt--alt" id="trade-process" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">How engagements work</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">From mixed-up tickets to margin per call and per truck.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">Every trade-contractor engagement follows the same four-phase rhythm &mdash; per-ticket costing, agreement deferral, financing and FSM reconciliation, and tech/truck profitability accurate first, before anyone makes hiring, pricing, or fleet-expansion decisions.</p>
    <div class="process-grid">
      {%- for s in process %}
      <div class="process-step"><div class="process-step__n">{{ s.num | safe }}</div><h3>{{ s.name | safe }}</h3><p>{{ s.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

