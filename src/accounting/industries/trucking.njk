{# ── AI SUMMARY · five-question block. NON-heading questions (baseline <dt>). (H2: Trucking accounting, in five questions.) ── #}
<section class="section section--alt" id="acctind-trucking-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">Trucking accounting, in five questions.</h2>
    </header>
    <div class="ai-summary ai-summary--ruled">
