---

{# ── DEFINITION · real H2 carrying the SaaS definition prose. (H2: SaaS accounting, plainly.) ── #}
<section class="section" id="acctind-saas-definition">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In plain terms</p>
      <h2 class="section__heading">SaaS accounting, plainly.</h2>
    </header>
    <div class="prose">
      {%- for p in definition %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. NON-heading questions (baseline <dt>). (H2: SaaS accounting, in five questions.) ── #}
<section class="section section--alt" id="acctind-saas-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">SaaS accounting, in five questions.</h2>
    </header>
    <div class="ai-summary ai-summary--ruled">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <p class="ai-summary__question">{{ item.q | safe }}</p>
        <div class="ai-summary__answer"><p>{{ item.a | safe }}</p></div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── CHALLENGES · three places SaaS companies lose the numbers (grid-3 buyer-cards). (H2 + 3 H3s) ── #}
<section class="section" id="acctind-saas-challenges">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why SaaS books break</p>
      <h2 class="section__heading">Three places SaaS companies lose the numbers.</h2>
      <p class="section__lede">Almost every messy SaaS file fails in the same three areas. Knowing which one you&rsquo;re in tells us where to start.</p>
    </header>
    <div class="grid-3">
      {%- for c in challenges %}
      <div class="buyer-card">
        <p class="buyer-card__opener">{{ c.signal | safe }}</p>
        <h3 class="buyer-card__heading">{{ c.title | safe }}</h3>
        <p class="buyer-card__body">{{ c.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── SUB-VERTICALS · SaaS at every stage and shape (grid-3 stack-8). (H2 + 6 H3s) ── #}
<section class="section section--alt" id="acctind-saas-subverticals">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Who we serve</p>
      <h2 class="section__heading">SaaS at every stage and shape.</h2>
      <p class="section__lede">Each SaaS sub-segment has its own revenue-recognition and unit-economics quirks. The engagement model &mdash; fixed-fee, written scope, named ProAdvisor, work in your own QuickBooks file &mdash; stays consistent.</p>
    </header>
    <div class="grid-3">
      {%- for s in subverticals %}
      <div class="stack-8">
        <h3>{{ s.title | safe }}</h3>
        <p class="prose">{{ s.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── WHAT WE HANDLE · the six services (grid-3 stack-8). (H2 + 6 H3s) ── #}
<section class="section" id="acctind-saas-handle">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What TechBrot handles</p>
      <h2 class="section__heading">SaaS accounting, done by an expert.</h2>
      <p class="section__lede">Every engagement is scoped to your stage, billing model, and entity structure, delivered in your own QuickBooks file by a named Certified ProAdvisor.</p>
    </header>
    <div class="grid-3">
      {%- for s in handle %}
      <div class="stack-8">
        <p class="num">{{ s.num | safe }}</p>
        <h3><a href="{{ s.href }}">{{ s.title | safe }}</a></h3>
        <p class="prose">{{ s.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── INTEGRATIONS · SaaS stack reconciled with QuickBooks (checks-list). (H2: Connected to your SaaS stack.) ── #}
<section class="section section--alt" id="acctind-saas-integrations">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Tools we work alongside</p>
      <h2 class="section__heading">Connected to your SaaS stack.</h2>
    </header>
    <ul class="checks-list">
      {%- for t in integrations %}<li>{{ t | safe }}</li>{%- endfor %}
    </ul>
    <p class="prose">{{ integrationsNote | safe }}</p>
  </div>
</section>

{# ── COMPARISON TABLE · vs-scroll + vs-table (no collapse, T3). Cash-basis vs ASC 606. ── #}
<section class="section" id="acctind-saas-comparison">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why cash-basis bookkeeping fails SaaS</p>
      <h2 class="section__heading">Cash-basis SaaS books vs. ASC 606 SaaS books.</h2>
      <p class="section__lede">The structural differences that explain why a SaaS company switching from cash-basis to ASC 606 sees its real economics for the first time &mdash; and why investors require the right column before writing a check.</p>
    </header>
    <div class="vs-scroll">
      <table class="vs-table">
        <caption class="sr-only">Cash-basis bookkeeping compared with ASC 606 SaaS bookkeeping</caption>
        <thead><tr><th scope="col">What the books need to show</th><th scope="col">Cash-basis bookkeeping</th><th scope="col" class="vs-table__us">ASC 606 SaaS bookkeeping</th></tr></thead>
        <tbody>
          {%- for r in comparison %}
          <tr><th scope="row">{{ r.cap | safe }}</th><td><span class="vs-table__concede">{{ r.left | safe }}</span></td><td class="vs-table__us"><span class="vs-table__concede">{{ r.us | safe }}</span></td></tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

{# ── PROCESS · four-phase engagement rhythm (process-diagram). (H2 + 4 H3s) ── #}
<section class="section section--alt" id="acctind-saas-process">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">How engagements work</p>
      <h2 class="section__heading">From cash-basis confusion to diligence-ready financials.</h2>
      <p class="section__lede">Every SaaS engagement follows the same four-phase rhythm &mdash; built so ASC 606, MRR, deferred revenue, and unit economics are accurate before anyone tries to build a board deck from them.</p>
    </header>
    <ol class="process-diagram">
      {%- for s in process %}
      <li class="process-step">
        <p class="process-step__number">{{ s.num | safe }}</p>
        <h3 class="process-step__heading">{{ s.name | safe }}</h3>
        <p class="process-step__body">{{ s.body | safe }}</p>
      </li>
      {%- endfor %}
    </ol>
  </div>
</section>

{# ── ADVISORY · standing brand line as H2; body carried as section prose (preserved from baseline). (H2: Clean numbers are the start. The next raise is the point.) ── #}
<section class="section" id="acctind-saas-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Beyond the books</p>
      <h2 class="section__heading">Clean numbers are the start. The next raise is the point.</h2>
    </header>
    <div class="prose">
      {%- for p in advisoryBody %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="/contact/?intent=accounting">Book the discovery call</a>
    </div>
  </div>
</section>

{# ── FAQ · all 7 contract Q/A VERBATIM; visible faq__list = FAQPage schema (same array, NO dedup). (H2: SaaS accounting questions.) ── #}
<section class="section section--alt" id="acctind-saas-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">SaaS accounting questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="acctind-saas-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="acctind-saas-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name (trust-row + meta-reviewed). (H2: Reviewed by the ProAdvisor team.) ── #}
<section class="section" id="acctind-saas-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the ProAdvisor team.</h2>
    </header>
    <div class="prose">
      <p>This page reflects how TechBrot actually handles SaaS engagements. It is maintained by the Certified QuickBooks ProAdvisor team at <strong>TechBrot Inc.</strong>, a Delaware-incorporated independent ProAdvisor firm, and reviewed for technical accuracy on ASC 606 revenue recognition, deferred revenue treatment, MRR/ARR reporting, unit economics, and multi-entity SaaS structures. Where our approach or scope changes, this page is updated. TechBrot delivers the books and coordinates with your CPA, who files.</p>
    </div>
    <div class="trust-row">
      {%- for r in reviewSpec %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.value | safe }}</p><p class="trust-row__label">{{ r.label | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-15</span><span>Updated: 2026-06-15</span><span>Reviewed: 2026-06-15 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{# ── RELATED · services & industries (stack-8). (H2 + 4 H3s) ── #}
<section class="section section--alt" id="acctind-saas-related">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Related</p>
      <h2 class="section__heading">Related services &amp; industries.</h2>
    </header>
    {%- for r in related %}
    <div class="stack-8">
      <h3><a href="{{ r.href }}">{{ r.title | safe }}</a></h3>
      <p class="prose">{{ r.body | safe }}</p>
    </div>
    {%- endfor %}
  </div>
</section>
