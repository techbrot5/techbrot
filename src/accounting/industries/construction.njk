---json
{
  "layout": "layouts/t-mofu.njk",
  "permalink": "/accounting/industries/construction/",
  "slug": "acctind-construction",
  "tierClass": "section--tier-guide",
  "bodyClass": "page--mofu",
  "callBar": true,
  "title": "Construction Accounting &amp; QuickBooks Bookkeeping · TechBrot",
  "description": "Expert construction accounting and QuickBooks bookkeeping — job costing, WIP, retainage, AIA progress billing, and certified payroll handled by Certified ProAdvisors for contractors.",
  "breadcrumb": [
    { "name": "Home", "href": "/" },
    { "name": "Accounting", "href": "/accounting/" },
    { "name": "Industries", "href": "/accounting/industries/" },
    { "name": "Construction" }
  ],
  "hero": {
    "eyebrow": "Industry &middot; Construction accounting",
    "heading": "Construction accounting that knows which job made money.",
    "subheading": "Contractors don&rsquo;t fail on revenue &mdash; they fail on jobs that quietly lost money while the books looked fine. TechBrot&rsquo;s Certified QuickBooks ProAdvisors set up real job costing, WIP, and retainage so you see profit per project, bill progress correctly, and stay compliant on certified payroll. We deliver the books in your own QuickBooks file; your CPA files. Independent firm, not affiliated with Intuit Inc.",
    "actions": [
      { "label": "Book the discovery call", "href": "/contact/?intent=accounting", "class": "btn--primary" },
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--ghost" },
      { "label": "Speak to a ProAdvisor", "tel": true, "class": "btn--ghost" }
    ]
  },
  "inBrief": {
    "text": "<strong>Construction accounting</strong> runs on projects, not periods &mdash; per-job revenue and cost, often on percentage-of-completion, with retainage, change orders, certified payroll, and AIA progress billing that standard bookkeeping can&rsquo;t handle. TechBrot&rsquo;s Certified QuickBooks ProAdvisors set up real job costing by cost code, WIP schedules, and retainage tracking in your own QuickBooks file, keep it accurate monthly, and turn it into job-level profit you can bid from. We deliver the books and coordinate with your CPA; we do not file income taxes.",
    "source": "Reviewed by the Certified QuickBooks ProAdvisor team at TechBrot Inc., an independent firm &mdash; not affiliated with Intuit Inc. Bookkeeping and ProAdvisor scope; does not file income taxes &mdash; coordinates with your CPA or EA."
  },
  "ctaBand": {
    "eyebrow": "Contractors start here",
    "heading": "See which jobs actually make you money.",
    "lede": "Book a discovery call. A Certified ProAdvisor reviews your jobs, your payroll requirements, and where the books are breaking, flags any certified-payroll or WIP exposure, and sends a written fixed-fee scope within 3 business days. No pitch. Independent firm &mdash; does not file income taxes; coordinates with your CPA.",
    "actions": [
      { "label": "Book the discovery call", "href": "/contact/?intent=accounting", "class": "btn--primary" },
      { "label": "Speak to a ProAdvisor", "tel": true, "class": "btn--ghost" }
    ]
  }
}
---

{# ── DEFINITION · real H2 carrying the construction definition prose. (H2: Construction accounting, plainly.) ── #}
<section class="section" id="acctind-construction-definition">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In plain terms</p>
      <h2 class="section__heading">Construction accounting, plainly.</h2>
    </header>
    <div class="prose">
      {%- for p in definition %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. NON-heading questions (baseline <dt>). (H2: Construction accounting, in five questions.) ── #}
<section class="section section--alt" id="acctind-construction-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">Construction accounting, in five questions.</h2>
    </header>
    <div class="ai-summary ai-summary--ruled">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <p class="ai-summary__question">{{ item.q | safe }}</p>
        <div class="ai-summary__answer"><p>{{ item.a | safe }}</p></div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── CHALLENGES · three places contractors lose the numbers (grid-3 buyer-cards). (H2 + 3 H3s) ── #}
<section class="section" id="acctind-construction-challenges">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why contractor books break</p>
      <h2 class="section__heading">Three places contractors lose the numbers.</h2>
      <p class="section__lede">Profitable-looking companies go under when these go unmanaged. Knowing which one you&rsquo;re in tells us where to start.</p>
    </header>
    <div class="grid-3">
      {%- for c in challenges %}
      <div class="buyer-card">
        <p class="buyer-card__opener">{{ c.signal | safe }}</p>
        <h3 class="buyer-card__heading">{{ c.title | safe }}</h3>
        <p class="buyer-card__body">{{ c.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── WHAT WE HANDLE · the six services (grid-3 stack-8). (H2 + 6 H3s) ── #}
<section class="section section--alt" id="acctind-construction-handle">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What TechBrot handles</p>
      <h2 class="section__heading">Construction accounting, done by an expert.</h2>
      <p class="section__lede">Every engagement is scoped to your jobs and crew, delivered in your own QuickBooks file by a named Certified ProAdvisor.</p>
    </header>
    <div class="grid-3">
      {%- for s in handle %}
      <div class="stack-8">
        <p class="num">{{ s.num | safe }}</p>
        <h3><a href="{{ s.href }}">{{ s.title | safe }}</a></h3>
        <p class="prose">{{ s.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── INTEGRATIONS · construction tools reconciled with QuickBooks (checks-list). (H2: Connected to how you build.) ── #}
<section class="section" id="acctind-construction-integrations">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Tools we work alongside</p>
      <h2 class="section__heading">Connected to how you build.</h2>
    </header>
    <ul class="checks-list">
      {%- for t in integrations %}<li>{{ t | safe }}</li>{%- endfor %}
    </ul>
    <p class="prose">{{ integrationsNote | safe }}</p>
  </div>
</section>

{# ── REVENUE-RECOGNITION TABLE · vs-scroll + vs-table (no collapse, T3). Supports definition prose. ── #}
<section class="section section--alt" id="acctind-construction-methods">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">How revenue is recognized</p>
      <h2 class="section__heading">Percentage-of-completion vs. completed-contract.</h2>
      <p class="section__lede">Which method you use changes how every job reads on your financials. We set up your books for the right one and keep the WIP behind it accurate.</p>
    </header>
    <div class="vs-scroll">
      <table class="vs-table">
        <caption class="sr-only">Construction revenue-recognition methods compared</caption>
        <thead><tr><th scope="col">Consideration</th><th scope="col" class="vs-table__us">Percentage-of-completion</th><th scope="col">Completed-contract</th></tr></thead>
        <tbody>
          <tr><th scope="row">When revenue is recognized</th><td class="vs-table__us"><span class="vs-table__concede">As the job progresses, by cost or milestone</span></td><td><span class="vs-table__concede">Only when the job is finished</span></td></tr>
          <tr><th scope="row">WIP schedule required</th><td class="vs-table__us"><span class="mark-yes"></span><span class="sr-only">Yes</span></td><td><span class="mark-no"></span><span class="sr-only">No</span></td></tr>
          <tr><th scope="row">Best for</th><td class="vs-table__us"><span class="vs-table__concede">Long, multi-period jobs &amp; bonded work</span></td><td><span class="vs-table__concede">Short jobs &amp; smaller contractors</span></td></tr>
          <tr><th scope="row">Profit visibility mid-job</th><td class="vs-table__us"><span class="mark-yes"></span><span class="sr-only">Yes</span></td><td><span class="mark-no"></span><span class="sr-only">No</span></td></tr>
          <tr><th scope="row">Tax-method eligibility</th><td class="vs-table__us"><span class="vs-table__concede">Often required above gross-receipts threshold</span></td><td><span class="vs-table__concede">Available to many small contractors &mdash; confirm with your CPA</span></td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

{# ── PROCESS · four-phase engagement rhythm (process-diagram). (H2 + 4 H3s) ── #}
<section class="section" id="acctind-construction-process">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">How engagements work</p>
      <h2 class="section__heading">From guesswork to job-level profit.</h2>
      <p class="section__lede">Every construction engagement follows the same four-phase rhythm &mdash; books accurate first, profit visibility second, advisory third.</p>
    </header>
    <ol class="process-diagram">
      {%- for s in process %}
      <li class="process-step">
        <p class="process-step__number">{{ s.num | safe }}</p>
        <h3 class="process-step__heading">{{ s.name | safe }}</h3>
        <p class="process-step__body">{{ s.body | safe }}</p>
      </li>
      {%- endfor %}
    </ol>
  </div>
</section>

{# ── ADVISORY · standing brand line carried as section prose; preserves baseline "advice vs bookkeeping" Q/A. (H2: Accurate job costs are the start. Winning bids is the point.) ── #}
<section class="section section--alt" id="acctind-construction-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Beyond the books</p>
      <h2 class="section__heading">Accurate job costs are the start. Winning bids is the point.</h2>
    </header>
    <div class="prose">
      {%- for p in advisoryBody %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="/contact/?intent=accounting">Book the discovery call</a>
    </div>
  </div>
</section>

{# ── FAQ · 5 contract Q/A + 1 appended genuine FAQ (FLAGGED); visible faq__list = FAQPage schema (same array, NO dedup). (H2: Construction accounting questions.) ── #}
<section class="section" id="acctind-construction-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">Construction accounting questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="acctind-construction-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="acctind-construction-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name (trust-row + meta-reviewed). (H2: Reviewed by the ProAdvisor team.) ── #}
<section class="section section--alt" id="acctind-construction-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the ProAdvisor team.</h2>
    </header>
    <div class="prose">
      <p>This page reflects how TechBrot actually handles construction engagements. It is maintained by the Certified QuickBooks ProAdvisor team at <strong>TechBrot Inc.</strong>, a Delaware-incorporated independent ProAdvisor firm, and reviewed for technical accuracy on job costing, WIP, retainage, AIA progress billing, and certified payroll. Where our approach or scope changes, this page is updated. TechBrot delivers the books and coordinates with your CPA, who files.</p>
    </div>
    <div class="trust-row">
      {%- for r in reviewSpec %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.value | safe }}</p><p class="trust-row__label">{{ r.label | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-15</span><span>Updated: 2026-06-15</span><span>Reviewed: 2026-06-15 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{# ── RELATED · services & industries (stack-8). (H2 + 4 H3s) ── #}
<section class="section" id="acctind-construction-related">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Related</p>
      <h2 class="section__heading">Related services &amp; industries.</h2>
    </header>
    {%- for r in related %}
    <div class="stack-8">
      <h3><a href="{{ r.href }}">{{ r.title | safe }}</a></h3>
      <p class="prose">{{ r.body | safe }}</p>
    </div>
    {%- endfor %}
  </div>
</section>
