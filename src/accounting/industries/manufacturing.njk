      <p class="section__eyebrow">In plain terms</p>
      <h2 class="section__heading">Manufacturing accounting, plainly.</h2>
    </header>
    <div class="prose">
      {%- for p in definition %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. NON-heading questions (baseline <dt>). (H2: Manufacturing accounting, in five questions.) ── #}
<section class="section section--alt" id="acctind-manufacturing-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">Manufacturing accounting, in five questions.</h2>
    </header>
