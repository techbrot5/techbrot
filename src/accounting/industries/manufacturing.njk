      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <p class="ai-summary__question">{{ item.q | safe }}</p>
        <div class="ai-summary__answer"><p>{{ item.a | safe }}</p></div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── CHALLENGES · three places manufacturers lose the numbers (grid-3 buyer-cards). (H2 + 3 H3s) ── #}
<section class="section" id="acctind-manufacturing-challenges">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why manufacturing books break</p>
      <h2 class="section__heading">Three places manufacturers lose the numbers.</h2>
      <p class="section__lede">Nearly every messy manufacturing file fails in the same three areas. Knowing which one you&rsquo;re in tells us where to start.</p>
    </header>
    <div class="grid-3">
      {%- for c in challenges %}
      <div class="buyer-card">
        <p class="buyer-card__opener">{{ c.signal | safe }}</p>
        <h3 class="buyer-card__heading">{{ c.title | safe }}</h3>
        <p class="buyer-card__body">{{ c.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── SUB-VERTICALS · manufacturing comes in many shapes (grid-3 stack-8). (H2 + 6 H3s) ── #}
<section class="section section--alt" id="acctind-manufacturing-subverticals">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Who we serve</p>
      <h2 class="section__heading">Manufacturing comes in many shapes.</h2>
