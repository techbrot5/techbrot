{# ── COMPARISON TABLE · vs-scroll + vs-table (no collapse, T3). Single-truck vs multi-truck. ── #}
<section class="section" id="acctind-homeservices-comparison">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">When home services outgrows owner-operator books</p>
      <h2 class="section__heading">Single-truck owner-operator vs. multi-truck dispatched operation.</h2>
      <p class="section__lede">The structural differences that explain why growing from one truck to multiple multiplies accounting complexity &mdash; and why the transition needs to happen at truck 2, not truck 8.</p>
    </header>
    <div class="vs-scroll">
      <table class="vs-table">
        <caption class="sr-only">Single-truck owner-operator versus multi-truck dispatched home services accounting compared</caption>
        <thead><tr><th scope="col">What the books need to handle</th><th scope="col" class="vs-table__us">Multi-truck dispatched operation (5+ trucks)</th><th scope="col">Single-truck owner-operator</th></tr></thead>
        <tbody>
          {%- for r in comparison %}
          <tr><th scope="row">{{ r.row | safe }}</th><td class="vs-table__us"><span class="vs-table__concede">{{ r.us | safe }}</span></td><td><span class="vs-table__concede">{{ r.them | safe }}</span></td></tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
    <p class="prose">{{ comparisonNote | safe }}</p>
  </div>
</section>

