    </header>
    <div class="grid-3">
      {%- for s in handle %}
      <div class="stack-8">
        <p class="num">{{ s.num | safe }}</p>
        <h3><a href="{{ s.href }}">{{ s.title | safe }}</a></h3>
        <p class="prose">{{ s.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── INTEGRATIONS · home services tools reconciled with QuickBooks (checks-list). (H2: Connected to your home services stack.) ── #}
<section class="section section--alt" id="acctind-homeservices-integrations">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Tools we work alongside</p>
      <h2 class="section__heading">Connected to your home services stack.</h2>
    </header>
