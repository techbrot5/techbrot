{# ── DEFINITION · real H2 carrying the home-services definition prose. (H2: Home services accounting, plainly.) ── #}
<section class="section" id="acctind-homeservices-definition">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In plain terms</p>
      <h2 class="section__heading">Home services accounting, plainly.</h2>
    </header>
    <div class="prose">
      {%- for p in definition %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. NON-heading questions (baseline <dt>). (H2: Home services accounting, in five questions.) ── #}
<section class="section section--alt" id="acctind-homeservices-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">Home services accounting, in five questions.</h2>
    </header>
    <div class="ai-summary ai-summary--ruled">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <p class="ai-summary__question">{{ item.q | safe }}</p>
        <div class="ai-summary__answer"><p>{{ item.a | safe }}</p></div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── CHALLENGES · three places home services operators lose the numbers (grid-3 buyer-cards). (H2 + 3 H3s) ── #}
<section class="section" id="acctind-homeservices-challenges">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why home services books break</p>
      <h2 class="section__heading">Three places home services operators lose the numbers.</h2>
      <p class="section__lede">Almost every messy home services file fails in the same three areas. Knowing which one you&rsquo;re in tells us where to start.</p>
    </header>
    <div class="grid-3">
      {%- for c in challenges %}
      <div class="buyer-card">
        <p class="buyer-card__opener">{{ c.signal | safe }}</p>
        <h3 class="buyer-card__heading">{{ c.title | safe }}</h3>
        <p class="buyer-card__body">{{ c.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── SUB-VERTICALS · home services across trades (grid-3 stack-8). (H2 + 6 H3s) ── #}
<section class="section section--alt" id="acctind-homeservices-trades">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Who we serve</p>
      <h2 class="section__heading">Home services across trades.</h2>
      <p class="section__lede">Each home services trade has its own ticket profile, parts intensity, and seasonality. The engagement model &mdash; fixed-fee, written scope, named ProAdvisor, work in your own QuickBooks file &mdash; stays consistent.</p>
    </header>
    <div class="grid-3">
      {%- for t in trades %}
      <div class="stack-8">
        <h3>{{ t.title | safe }}</h3>
        <p class="prose">{{ t.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── WHAT WE HANDLE · the six services (grid-3 stack-8). (H2 + 6 H3s) ── #}
<section class="section" id="acctind-homeservices-handle">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What TechBrot handles</p>
