{# ── AI SUMMARY · five-question block. NON-heading questions (baseline <dt>). (H2: Dental practice accounting, in five questions.) ── #}
<section class="section section--alt" id="acctind-dental-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
