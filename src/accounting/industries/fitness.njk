    ]
  }
}
---

{# ── DEFINITION · real H2 carrying the fitness definition prose. (H2: Fitness accounting, plainly.) ── #}
<section class="section" id="acctind-fitness-definition">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In plain terms</p>
      <h2 class="section__heading">Fitness accounting, plainly.</h2>
    </header>
    <div class="prose">
      {%- for p in definition %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. NON-heading questions (baseline <dt>). (H2: Fitness accounting, in five questions.) ── #}
<section class="section section--alt" id="acctind-fitness-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">Fitness accounting, in five questions.</h2>
    </header>
    <div class="ai-summary ai-summary--ruled">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <p class="ai-summary__question">{{ item.q | safe }}</p>
        <div class="ai-summary__answer"><p>{{ item.a | safe }}</p></div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── CHALLENGES · three places fitness operators lose the numbers (grid-3 buyer-cards). (H2 + 3 H3s) ── #}
<section class="section" id="acctind-fitness-challenges">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why fitness books break</p>
      <h2 class="section__heading">Three places fitness operators lose the numbers.</h2>
      <p class="section__lede">Almost every messy fitness file fails in the same three areas. Knowing which one you&rsquo;re in tells us where to start.</p>
    </header>
    <div class="grid-3">
      {%- for c in challenges %}
      <div class="buyer-card">
        <p class="buyer-card__opener">{{ c.signal | safe }}</p>
        <h3 class="buyer-card__heading">{{ c.title | safe }}</h3>
        <p class="buyer-card__body">{{ c.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── SUB-VERTICALS · fitness across every format (grid-3 stack-8). (H2 + 6 H3s) ── #}
<section class="section section--alt" id="acctind-fitness-formats">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Who we serve</p>
      <h2 class="section__heading">Fitness across every format.</h2>
      <p class="section__lede">Each fitness segment has its own revenue mix, member economics, and platform pattern. The engagement model &mdash; fixed-fee, written scope, named ProAdvisor, work in your own QuickBooks file &mdash; stays consistent.</p>
    </header>
    <div class="grid-3">
      {%- for f in formats %}
      <div class="stack-8">
        <h3>{{ f.name | safe }}</h3>
        <p class="prose">{{ f.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── WHAT WE HANDLE · the six services (grid-3 stack-8). (H2 + 6 H3s) ── #}
<section class="section" id="acctind-fitness-handle">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What TechBrot handles</p>
      <h2 class="section__heading">Fitness accounting, done by an expert.</h2>
      <p class="section__lede">Every engagement is scoped to your format, location count, platform, membership volume, and franchise overlay if applicable &mdash; delivered in your own QuickBooks file by a named Certified ProAdvisor.</p>
    </header>
    <div class="grid-3">
      {%- for s in handle %}
      <div class="stack-8">
        <p class="num">{{ s.num | safe }}</p>
        <h3><a href="{{ s.href }}">{{ s.title | safe }}</a></h3>
        <p class="prose">{{ s.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── INTEGRATIONS · fitness tools reconciled with QuickBooks (checks-list). (H2: Connected to your fitness stack.) ── #}
<section class="section section--alt" id="acctind-fitness-integrations">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Tools we work alongside</p>
      <h2 class="section__heading">Connected to your fitness stack.</h2>
    </header>
    <ul class="checks-list">
      {%- for t in integrations %}<li>{{ t | safe }}</li>{%- endfor %}
    </ul>
    <p class="prose">{{ integrationsNote | safe }}</p>
  </div>
</section>

{# ── COMPARISON TABLE · vs-scroll + vs-table (no collapse, T3). Independent vs multi-location/franchise. ── #}
<section class="section" id="acctind-fitness-comparison">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">When fitness outgrows single-studio books</p>
      <h2 class="section__heading">Independent studio vs. multi-location or franchise studio accounting.</h2>
      <p class="section__lede">The structural differences that explain why growing from one studio to multiple &mdash; or operating as a boutique franchisee &mdash; multiplies accounting complexity.</p>
    </header>
    <div class="vs-scroll">
      <table class="vs-table">
        <caption class="sr-only">Independent single-studio vs. multi-location or franchise studio accounting compared</caption>
        <thead><tr><th scope="col">What the books need to handle</th><th scope="col" class="vs-table__us">Independent single-studio</th><th scope="col">Multi-location or franchise studio</th></tr></thead>
        <tbody>
          {%- for r in vsTable %}
          <tr><th scope="row">{{ r.cap | safe }}</th><td class="vs-table__us"><span class="vs-table__concede">{{ r.solo | safe }}</span></td><td><span class="vs-table__concede">{{ r.multi | safe }}</span></td></tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
    <p class="prose">{{ vsNote | safe }}</p>
  </div>
</section>

{# ── PROCESS · four-phase engagement rhythm (process-diagram). (H2 + 4 H3s) ── #}
<section class="section section--alt" id="acctind-fitness-process">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">How engagements work</p>
      <h2 class="section__heading">From membership mess to real LTV.</h2>
      <p class="section__lede">Every fitness engagement follows the same four-phase rhythm &mdash; built so membership and package recognition, platform reconciliation, and member economics are accurate before anyone tries to make marketing or expansion decisions.</p>
    </header>
    <ol class="process-diagram">
      {%- for s in process %}
      <li class="process-step">
        <p class="process-step__number">{{ s.num | safe }}</p>
        <h3 class="process-step__heading">{{ s.name | safe }}</h3>
        <p class="process-step__body">{{ s.body | safe }}</p>
      </li>
      {%- endfor %}
    </ol>
  </div>
</section>

{# ── ADVISORY · standing brand line carried as section prose; preserves baseline advisory mission-block. (H2: LTV against CAC is the start. The next studio is the point.) ── #}
<section class="section" id="acctind-fitness-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Beyond the books</p>
      <h2 class="section__heading">LTV against CAC is the start. The next studio is the point.</h2>
    </header>
    <div class="prose">
      {%- for p in advisoryBody %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="/contact/?intent=accounting">Book the discovery call</a>
    </div>
  </div>
</section>

{# ── FAQ · 7 contract Q/A VERBATIM, NO dedup; visible faq__list = FAQPage schema (same array). (H2: Fitness accounting questions.) ── #}
<section class="section section--alt" id="acctind-fitness-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">Fitness accounting questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="acctind-fitness-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="acctind-fitness-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name (trust-row + meta-reviewed). (H2: Reviewed by the ProAdvisor team.) ── #}
<section class="section" id="acctind-fitness-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the ProAdvisor team.</h2>
    </header>
    <div class="prose">
      <p>This page reflects how TechBrot actually handles fitness engagements. It is maintained by the Certified QuickBooks ProAdvisor team at <strong>TechBrot Inc.</strong>, a Delaware-incorporated independent ProAdvisor firm, and reviewed for technical accuracy on ASC 606 membership and package revenue recognition, studio management platform reconciliation, member-level LTV/CAC economics, instructor compensation, and boutique franchise overlay. Where our approach or scope changes, this page is updated. TechBrot delivers the books and coordinates with your CPA, who files.</p>
    </div>
    <div class="trust-row">
      {%- for r in reviewSpec %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.value | safe }}</p><p class="trust-row__label">{{ r.label | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-15</span><span>Updated: 2026-06-15</span><span>Reviewed: 2026-06-15 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{# ── RELATED · services & industries (stack-8). (H2 + 4 H3s) ── #}
<section class="section section--alt" id="acctind-fitness-related">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Related</p>
      <h2 class="section__heading">Related services &amp; industries.</h2>
    </header>
    {%- for r in related %}
    <div class="stack-8">
      <h3><a href="{{ r.href }}">{{ r.title | safe }}</a></h3>
      <p class="prose">{{ r.body | safe }}</p>
    </div>
    {%- endfor %}
  </div>
</section>
