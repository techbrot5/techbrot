---json
{
  "layout": "layouts/t-mofu.njk",
  "permalink": "/accounting/industries/short-term-rentals/",
  "slug": "acctind-str",
  "tierClass": "section--tier-guide",
  "bodyClass": "page--mofu",
  "callBar": true,
  "title": "Short-Term Rental Accounting &amp; Airbnb Bookkeeping · TechBrot",
  "description": "Short-term rental accounting and Airbnb bookkeeping — per-listing P&amp;L, platform payout reconciliation, lodging and occupancy tax recording, cleaning and turnover cost tracking, and channel-manager integration by Certified QuickBooks ProAdvisors for vacation-rental hosts and operators.",
  "breadcrumb": [
    { "name": "Home", "href": "/" },
    { "name": "Accounting", "href": "/accounting/" },
    { "name": "Industries", "href": "/accounting/industries/" },
    { "name": "Short-Term Rentals" }
  ],
  "hero": {
    "eyebrow": "Industry &middot; Short-term rental accounting",
