---

{# ── DEFINITION · real H2 carrying the plain-language definition prose. ── #}
<section class="section section--compact section--tier-guide" id="str-definition">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In plain terms</p>
      <h2 class="section__heading">Short-term rental accounting, plainly.</h2>
    </header>
    <div class="prose">
      {%- for p in definition %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AI SUMMARY · quick-answer block. Questions are NON-heading (<dt>). ── #}
<section class="section" id="str-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">Short-term rental accounting, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="str-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── CHALLENGES · three places STR hosts lose the numbers (grid-3 buyer-cards). ── #}
<section class="section section--alt" id="str-challenges">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why short-term rental books break</p>
      <h2 class="section__heading">Three places hosts lose the numbers.</h2>
      <p class="section__lede">Nearly every messy short-term rental file fails in the same three areas. Knowing which one you&rsquo;re in tells us where to start.</p>
    </header>
    <div class="grid-3">
      {%- for c in challenges %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ c.signal | safe }}</p>
        <h3 class="buyer-card__heading">{{ c.title | safe }}</h3>
        <p class="buyer-card__body">{{ c.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── WHAT WE HANDLE · the six services (grid-3 buyer-cards). ── #}
<section class="section" id="str-handle">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What TechBrot handles</p>
      <h2 class="section__heading">Short-term rental accounting, done by an expert.</h2>
      <p class="section__lede">Every engagement is scoped to your listings and platforms, delivered in your own QuickBooks file by a named Certified ProAdvisor.</p>
    </header>
    <div class="grid-3">
      {%- for s in handle %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ s.num }}</p>
        <h3 class="buyer-card__heading">{{ s.title | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
        <a class="buyer-card__cta" href="{{ s.href }}">{{ s.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── PAYOUT ANATOMY · content-to-goal table (vs-scroll + vs-table, no collapse). ── #}
<section class="section section--alt" id="str-anatomy">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">How the books are built</p>
      <h2 class="section__heading">What a short-term rental ledger does that a standard one can&rsquo;t.</h2>
      <p class="section__lede">The difference between a generalist file and a short-term rental file isn&rsquo;t effort &mdash; it&rsquo;s the gap between a platform&rsquo;s net deposit and your real numbers. Each row below is a place vacation-rental accounting diverges from ordinary bookkeeping.</p>
    </header>
    <div class="vs-scroll">
      <table class="vs-table">
        <caption class="sr-only">How short-term rental bookkeeping differs from standard company-wide bookkeeping</caption>
        <thead><tr><th scope="col">What it tracks</th><th scope="col" class="vs-table__us">Short-term rental books</th><th scope="col">Standard books</th></tr></thead>
        <tbody>
          {%- for r in anatomy %}
          <tr>
            <th scope="row">{{ r.cap | safe }}</th>
            <td class="vs-table__us">{{ r.str | safe }}</td>
            <td>{{ r.std | safe }}</td>
          </tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
    <p class="prose">{{ anatomyNote | safe }}</p>
  </div>
</section>

{# ── INTEGRATIONS · STR platforms & tools reconciled with QuickBooks (checks-list). ── #}
<section class="section" id="str-integrations">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Platforms we reconcile</p>
      <h2 class="section__heading">Connected to how you actually host.</h2>
    </header>
    <ul class="checks-list">
      {%- for t in integrations %}<li>{{ t | safe }}</li>{%- endfor %}
    </ul>
    <p class="prose">{{ integrationsNote | safe }}</p>
  </div>
</section>

{# ── PROCESS · four-phase engagement rhythm (grid-2 buyer-cards). ── #}
<section class="section section--alt" id="str-process">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">How engagements work</p>
      <h2 class="section__heading">From mismatched payouts to clean per-listing books.</h2>
      <p class="section__lede">Every short-term rental engagement follows the same four-phase rhythm &mdash; built so your books reconcile to every payout before anyone tries to advise on them.</p>
    </header>
    <div class="grid-2">
      {%- for p in process %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ p.phase }}</p>
        <h3 class="buyer-card__heading">{{ p.title | safe }}</h3>
        <p class="buyer-card__body">{{ p.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── ADVISORY · standing brand line carried as section prose. ── #}
<section class="section" id="str-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Beyond the books</p>
      <h2 class="section__heading">Clean books are the start. The next listing is the point.</h2>
    </header>
    <div class="prose">
      {%- for p in advisoryBody %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="/contact/?intent=accounting">Book the discovery call</a>
    </div>
  </div>
</section>

{# ── FAQ · visible faq__list = FAQPage schema (same array). ── #}
<section class="section section--alt" id="str-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">Short-term rental accounting questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="str-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="str-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name. ── #}
<section class="section" id="str-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the ProAdvisor team.</h2>
    </header>
    <div class="byline-block">
      <div class="byline-block__mark" aria-hidden="true"></div>
      <div>
        <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="byline-block__review">TechBrot Inc. &middot; Independent Certified QuickBooks ProAdvisor firm</p>
      </div>
    </div>
    <div class="prose">
      <p>This page reflects how TechBrot actually handles short-term rental engagements. It is maintained by the Certified QuickBooks ProAdvisor team at <strong>TechBrot Inc.</strong>, a Delaware-incorporated independent ProAdvisor firm, and reviewed for technical accuracy on platform payout reconciliation, per-listing profit and loss, and lodging and occupancy tax recording. Where our approach or scope changes, this page is updated. TechBrot keeps the books and the records; your CPA or EA decides Schedule C vs. Schedule E classification, sets depreciation treatment, and files income taxes.</p>
    </div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-19</span><span>Updated: 2026-06-19</span><span>Reviewed: 2026-06-19 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{# ── RELATED · services & industries (grid-2 buyer-cards). ── #}
<section class="section section--alt" id="str-related">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Related</p>
      <h2 class="section__heading">Related services &amp; industries.</h2>
    </header>
    <div class="grid-2">
      {%- for r in related %}
      <article class="buyer-card">
        <h3 class="buyer-card__heading">{{ r.title | safe }}</h3>
        <p class="buyer-card__body">{{ r.body | safe }}</p>
        <a class="buyer-card__cta" href="{{ r.href }}">{{ r.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>
