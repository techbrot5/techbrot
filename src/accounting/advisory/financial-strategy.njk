{#- ═══ BODY → v2 (t-mofu→t-prose). Hero/TL;DR(#acct-finstrat-in-brief-text speakable)/
    ai-summary(sec.aiH)/faq(sec.faqH)/CTA are layout-owned. Every baseline heading
    verbatim; content verbatim. Sand bands alternate via hub-rt--alt. ═══ -#}

{#- BYLINE → v2 prose byline -#}
<section class="sec reveal" id="acct-finstrat-byline" style="padding-top:24px;padding-bottom:8px;">
  <div class="ct read read--doc">
    <div class="byline">
      <span class="byline__mark"><svg width="18" height="18" viewBox="0 0 64 64" fill="currentColor" aria-hidden="true"><path d="M8 10 H38 V54 H26 V22 H8 Z"/><rect x="42" y="10" width="14" height="12"/></svg></span>
      <div><p class="byline__name">By the Certified QuickBooks ProAdvisor team</p><p class="byline__meta">Reviewed by the ProAdvisor team &middot; built on accurate books, coordinated with your CPA</p></div>
    </div>
  </div>
</section>

{#- DEFINITION → prose -#}
<section class="sec reveal" id="acct-finstrat-definition" style="padding-top:8px;">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In plain terms</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:16px;">Financial strategy, plainly.</h2>
    <div class="prose">
      {%- for p in definition %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{#- SIGNALS → r-3 of dc-card (sand) -#}
<section class="sec reveal hub-rt--alt" id="acct-finstrat-signals" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">When financial strategy earns its keep</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">If any of these are on the table, the answer is yes.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">Most owners reach for strategy work when a real decision is in front of them and the gut answer no longer feels like enough.</p>
    <div class="r-3">
      {%- for s in signals %}
      <div class="dc-card"><h3>{{ s.name | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ s.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- DELIVERS → r-3 of dc-card with num -#}
<section class="sec reveal" id="acct-finstrat-delivers">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">What&rsquo;s included</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">What financial strategy actually delivers.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">Scoped to the decision in front of you. Discrete projects, ongoing through fractional CFO when the work is continuous.</p>
    <div class="r-3">
      {%- for d in delivers %}
      <div class="dc-card"><p class="num" style="font-family:'Spline Sans Mono',monospace;font-size:12px;color:var(--color-accent);margin:0 0 4px;">{{ d.num }}</p><h3>{{ d.name | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ d.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- PROCESS → process-grid (sand) -#}
<section class="sec reveal hub-rt--alt" id="acct-finstrat-process" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">How it works</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">From decision in front of you to a number you can stand behind.</h2>
    <p class="lede" style="margin:0 0 32px;max-width:70ch;">Strategy engagements follow the same four-phase rhythm, whether discrete projects or ongoing through a fractional CFO.</p>
    <div class="process-grid">
      {%- for s in phases %}
      <div class="process-step"><div class="process-step__n{% if loop.last %} process-step__n--done{% endif %}">{{ s.num | upper }}{% if loop.last %} &check;{% endif %}</div><h3>{{ s.name | safe }}</h3><p>{{ s.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- BOUNDARY → prose lede + boundary table (.cmp) -#}
<section class="sec reveal" id="acct-finstrat-boundary">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">The boundary, honestly</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">What strategy is, and what stays with the licensed professionals.</h2>
    <p class="lede" style="margin:0;max-width:70ch;">Advisory and strategy &mdash; not tax filing, audit, or legal work. We analyze capital structure, build the coverage and capacity analysis lenders ask for, and time financing decisions &mdash; then coordinate with your banker, who provides the actual credit. We do not provide lending, investment, or securities advice.</p>
  </div>
  <div class="ct" style="margin-top:28px;">
    <table class="cmp">
      <caption class="sr-only">What financial strategy advisory covers, and what stays with licensed professionals</caption>
      <thead><tr><th scope="col">Area</th><th scope="col" class="us">Financial strategy advisory</th><th scope="col">Stays with the licensed professional</th></tr></thead>
      <tbody>
        {%- for r in boundaryTable %}
        <tr><th scope="row" data-col="Area">{{ r.area | safe }}</th>
          <td class="us" data-col="Financial strategy advisory">{% if r.strategy == 'yes' %}<span class="mk mk--yes"><span class="mk__dot"></span>Yes</span>{% elif r.strategy == 'no' %}<span class="mk mk--no"><span class="mk__dot"></span>No</span>{% else %}{{ r.strategy | safe }}{% endif %}</td>
          <td data-col="Stays with the licensed professional">{% if r.licensed == 'yes' %}<span class="mk mk--yes"><span class="mk__dot"></span>Yes</span>{% elif r.licensed == 'no' %}<span class="mk mk--no"><span class="mk__dot"></span>No</span>{% else %}{{ r.licensed | safe }}{% endif %}</td>
        </tr>
        {%- endfor %}
      </tbody>
    </table>
  </div>
</section>

{#- SEAT → prose (sand) -#}
<section class="sec reveal hub-rt--alt" id="acct-finstrat-seat" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Beyond the project</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:16px;">Some decisions are projects. Some need a seat at the table.</h2>
    <div class="prose">
      {%- for p in seat %}<p>{{ p | safe }}</p>{%- endfor %}
      <p><a href="/accounting/advisory/fractional-cfo/?intent=fractional-cfo">Explore fractional CFO &amp; advisory <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
    </div>
  </div>
</section>

{#- REVIEW prose + trust-row. meta-reviewed kept here. -#}
<section class="sec reveal" id="acct-finstrat-review">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Page review &amp; standards</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:14px;">Reviewed by the ProAdvisor team.</h2>
    <div class="prose">
      <p>This page reflects how TechBrot delivers financial strategy advisory. It is maintained by the Certified QuickBooks ProAdvisor team at TechBrot Inc., a Delaware-incorporated independent ProAdvisor firm, and reviewed for accuracy on scope, methodology, and the boundary with tax, legal, lending, and investment-advisory work. Where our approach or scope changes, this page is updated. Strategy is delivered on accurate books and coordinated with the licensed professionals whose work it touches.</p>
    </div>
    <div class="trust-row" style="margin-top:22px;">
      {%- for r in reviewSpec %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.value | safe }}</p><p class="trust-row__label">{{ r.label | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed" style="margin-top:18px;"><span>Page last reviewed: May 2026.</span></p>
  </div>
</section>

{#- RELATED → r-2 of dc-card hub-card (sand) -#}
<section class="sec reveal hub-rt--alt" id="acct-finstrat-related" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Related</span><span class="idx__rule"></span></div>
