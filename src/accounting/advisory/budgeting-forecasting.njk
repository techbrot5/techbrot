    </div>
  </div>
</section>

{#- DEFINITION → prose -#}
<section class="sec reveal" id="acct-budget-definition" style="padding-top:8px;">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In plain terms</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:16px;">Budgeting &amp; forecasting, plainly.</h2>
    <div class="prose">
      {%- for p in definition %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{#- SIGNALS → r-2 of dc-card (sand) -#}
<section class="sec reveal hub-rt--alt" id="acct-budget-signals" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">When budgeting &amp; forecasting earns its keep</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">If any of these sound familiar, the answer is yes.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:68ch;">Most owners reach for a real budgeting and forecasting practice when planning by feel stops scaling with the business.</p>
    <div class="r-2">
      {%- for s in signals %}
      <div class="dc-card"><h3>{{ s.opener | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ s.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- DELIVERS → r-3 of dc-card with num -#}
<section class="sec reveal" id="acct-budget-delivers">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">What&rsquo;s included</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">What budgeting &amp; forecasting actually delivers.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">Scoped to your business and stage, sized to the way you actually plan and review &mdash; built on books that are accurate first.</p>
    <div class="r-3">
      {%- for d in delivers %}
      <div class="dc-card"><p class="num" style="font-family:'Spline Sans Mono',monospace;font-size:12px;color:var(--color-accent);margin:0 0 4px;">{{ d.num }}</p><h3>{{ d.name | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ d.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- PROCESS → process-grid (sand) -#}
<section class="sec reveal hub-rt--alt" id="acct-budget-process" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">How it works</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">From first budget to a plan that keeps up with the year.</h2>
    <p class="lede" style="margin:0 0 32px;max-width:68ch;">Every budgeting and forecasting engagement follows the same four-phase rhythm &mdash; built on books that are accurate first.</p>
    <div class="process-grid">
      {%- for s in process %}
      <div class="process-step"><div class="process-step__n{% if loop.last %} process-step__n--done{% endif %}">{{ s.num | upper }}{% if loop.last %} &check;{% endif %}</div><h3>{{ s.name | safe }}</h3><p>{{ s.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- STEER prose + boundary table (.cmp) -#}
<section class="sec reveal" id="acct-budget-steer">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Beyond the budget</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:16px;">A plan is only useful if someone steers by it.</h2>
    <div class="prose">
      {%- for p in steerProse %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
  <div class="ct" style="margin-top:28px;">
    <table class="cmp">
      <caption class="sr-only">Where budgeting &amp; forecasting sits next to cash flow management and tax/audit work</caption>
      <thead><tr><th scope="col">Capability</th><th scope="col" class="us">Budgeting &amp; forecasting</th><th scope="col">Cash flow management</th><th scope="col">Tax / audit</th></tr></thead>
      <tbody>
        {%- for r in boundary %}
        <tr><th scope="row" data-col="Capability">{{ r.cap | safe }}</th>
          <td class="us" data-col="Budgeting &amp; forecasting">{% if r.bf == 'yes' %}<span class="mk mk--yes"><span class="mk__dot"></span>Yes</span>{% elif r.bf == 'no' %}<span class="mk mk--no"><span class="mk__dot"></span>No</span>{% else %}{{ r.bf | safe }}{% endif %}</td>
          <td data-col="Cash flow management">{% if r.cash == 'yes' %}<span class="mk mk--yes"><span class="mk__dot"></span>Yes</span>{% elif r.cash == 'no' %}<span class="mk mk--no"><span class="mk__dot"></span>No</span>{% else %}{{ r.cash | safe }}{% endif %}</td>
          <td data-col="Tax / audit">{% if r.tax == 'yes' %}<span class="mk mk--yes"><span class="mk__dot"></span>Yes</span>{% elif r.tax == 'no' %}<span class="mk mk--no"><span class="mk__dot"></span>No</span>{% else %}{{ r.tax | safe }}{% endif %}</td>
        </tr>
        {%- endfor %}
      </tbody>
    </table>
  </div>
</section>

{#- REVIEW prose + trust-row (sand). meta-reviewed kept here. -#}
<section class="sec reveal hub-rt--alt" id="acct-budget-review" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
