    </div>
  </div>
</section>

{#- TOOLING → r-3 of dc-card (sand) -#}
<section class="sec reveal hub-rt--alt" id="acct-kpi-tooling" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
