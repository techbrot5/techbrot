<section class="section section--alt" id="advisory-tax-planning-operator">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Who does what</p>
      <h2 class="section__heading">Your CPA plans and advises. We keep the books they plan from.</h2>
    </header>
