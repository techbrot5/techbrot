---

<section class="sec reveal" id="acct-outsourced-definition">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In plain terms</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:14px;">Outsourced accounting, plainly.</h2>
    <div class="prose">
      {%- for p in definition %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{#- AI-SUMMARY renders via the t-prose layout slot (sec.aiH). -#}

<section class="sec reveal hub-rt--alt" id="acct-outsourced-included" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">What&rsquo;s included</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">The whole function &mdash; not a slice of it.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">Outsourced accounting bundles the operational layers into one managed service. Each is a discipline in its own right; together they&rsquo;re your accounting department.</p>
    <div class="r-3">
      {%- for d in deliverables %}
      <div class="dc-card">
        <span class="eyebrow" style="display:block;margin-bottom:8px;">{{ d.num }}</span>
        <h3>{{ d.name | safe }}</h3>
        <p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ d.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="sec reveal" id="acct-outsourced-signals">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">When outsourcing the function makes sense</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">If any of these sound familiar, the answer is probably yes.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">Most owners reach for outsourced accounting when running the function internally costs more &mdash; in money, time, or risk &mdash; than it returns.</p>
    <div class="r-3">
      {%- for s in signals %}
      <div class="dc-card">
        <h3>{{ s.opener | safe }}</h3>
        <p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ s.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="sec reveal hub-rt--alt" id="acct-outsourced-vs" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Outsourced vs in-house</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:14px;">The real cost of an internal accounting department.</h2>
    <div class="prose">
      {%- for p in vsInHouse %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

<section class="sec reveal" id="acct-outsourced-process">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">How it works</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">From handoff to a function that just runs.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">Four phases, fixed monthly fee, written scope, your own QuickBooks file.</p>
    <div class="process-grid">
      {%- for s in process %}
      <div class="process-step"><div class="process-step__n">{{ s.num | safe }}</div><h3>{{ s.name | safe }}</h3><p>{{ s.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="sec reveal hub-rt--alt" id="acct-outsourced-scope" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Honest scope</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">What the managed function covers &mdash; and what stays with your CPA.</h2>
    <div class="r-3">
      {%- for c in scope %}
      <div class="dc-card">
        <h3>{{ c.name | safe }}</h3>
        <p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ c.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- FAQ renders via the t-prose layout slot (sec.faqH = "Outsourced accounting questions."). The old display 7th Q/A is preserved below as body prose (NOT in the frozen-6 FAQPage schema array). -#}
<section class="sec reveal" id="acct-outsourced-faq-extra">
  <div class="ct read read--doc">
    <div class="prose">
      {%- for item in faqExtra %}
      <h3 id="acct-outsourced-faq-x{{ loop.index }}">{{ item.q | safe }}</h3>
      <p>{{ item.a | safe }}</p>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="sec reveal hub-rt--alt" id="acct-outsourced-review" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Page review &amp; standards</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:14px;">Reviewed by the ProAdvisor team.</h2>
    <div class="prose">
      <p>This page reflects how TechBrot delivers outsourced accounting. It is maintained by the Certified QuickBooks ProAdvisor team at TechBrot Inc., a Delaware-incorporated independent ProAdvisor firm, and reviewed for accuracy on the scope of the managed function, the in-house comparison, and the boundary with licensed CPA and tax work. Where our approach or scope changes, this page is updated. Outsourced accounting is delivered in your own QuickBooks file on a fixed monthly fee and coordinated with your CPA for filing and any formal CPA engagement.</p>
    </div>
    <div class="trust-row" style="margin-top:22px;">
      {%- for r in reviewSpec %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.value | safe }}</p><p class="trust-row__label">{{ r.label | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="prose" style="font-size:13.5px;color:var(--color-ink-mute);margin-top:14px;">Page last reviewed: May 2026.</p>
  </div>
</section>

<section class="sec reveal" id="acct-outsourced-related">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Related</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">Related services.</h2>
    {%- for n in related %}
    <div style="margin-bottom:18px;">
      <h3><a href="{{ n.href }}">{{ n.title | safe }}</a></h3>
      <p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ n.body | safe }}</p>
    </div>
    {%- endfor %}
  </div>
</section>
