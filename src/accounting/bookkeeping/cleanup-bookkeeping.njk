  "layout": "layouts/t-bofu.njk",
  "permalink": "/accounting/bookkeeping/cleanup-bookkeeping/",
  "slug": "cleanup-bookkeeping",
  "tierClass": "section--tier-bofu",
  "bodyClass": "page--bofu",
