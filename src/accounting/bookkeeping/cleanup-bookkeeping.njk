---

{#- ═══ D1 MONEY V2 — full recompose to the handoff "QuickBooks Cleanup - Money
    Page" using REAL components (dc-system.css). FROZEN content preserved + re-flowed,
    FULL DEPTH (every heading/FAQ/fact/schema). speakable #cleanup-bookkeeping-in-brief-text
    kept on the §01 answer paragraph. Hero + final-dark CTA are layout-owned (t-money). ═══ -#}

{#- PROOF STRIP (dark) -#}
<section class="proofbar" id="cleanup-bookkeeping-proof">
  <div class="ct proofbar__row">
    <span class="proofbar__label">What you can verify</span>
    {%- set checks = ["4&times; Certified QuickBooks ProAdvisor", "Correct, current books restored", "Fixed-fee written scope, first", "1 business day response"] %}
    {%- for c in checks %}<span class="proofbar__item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12.5l4 4 10-10.5" stroke-linecap="round" stroke-linejoin="round"/></svg>{{ c | safe }}</span>{%- endfor %}
    <span class="proofbar__item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12.5l4 4 10-10.5" stroke-linecap="round" stroke-linejoin="round"/></svg><span class="mono">5.0</span>&nbsp;2 verified Clutch reviews</span>
  </div>
</section>

{#- CREDENTIALS — real Intuit badges (kept: full depth) -#}
<section class="sec reveal" id="cleanup-bookkeeping-credentials" style="padding-top:48px;padding-bottom:8px;">
  <div class="ct">
    <p class="eyebrow" style="margin-bottom:18px;">Verifiable Intuit credentials</p>
    {% include "partials/intuit-badges.njk" %}
  </div>
</section>

{#- §01 IN BRIEF / the engagement (idx + 2-col) -#}
<section class="sec reveal" id="cleanup-bookkeeping-definition" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§01</span><span class="idx__t">The engagement</span><span class="idx__rule"></span></div>
    <div class="r-2" style="gap:48px;align-items:start;">
      <h2 class="h2 speakable" style="max-width:18ch;">What a cleanup engagement actually is.</h2>
      <div class="prose speakable">
        <p id="cleanup-bookkeeping-in-brief-text">A bookkeeping cleanup is a project-based engagement that reconstructs accurate financial records from a messy or unreconciled state. It covers QuickBooks file cleanup, real bank reconciliation against actual statements, categorization corrections, clearing undeposited funds, fixing duplicate or missing transactions, correcting prior-period errors, verifying payroll and sales-tax entries, and producing CPA-ready financial statements. Most engagements take 2&ndash;8 weeks and are priced as a fixed fee against a written scope.</p>
        <p>Cleanup is distinct from <a href="/accounting/bookkeeping/catch-up-bookkeeping/?intent=catch-up">catch-up bookkeeping</a> (which brings behind-but-structured books up to date) and from <a href="/accounting/bookkeeping/monthly-bookkeeping/?intent=monthly">monthly bookkeeping</a> (which is recurring). Many engagements combine cleanup with catch-up &mdash; clean up the existing periods, catch up the missing months, then transition to monthly.</p>
        <blockquote class="opquote" style="margin-top:20px;"><blockquote>{{ drift.body | safe }}</blockquote></blockquote>
      </div>
    </div>
  </div>
</section>

{#- §02 SIGNALS / is this you (buyer-cards) -#}
<section class="sec reveal" id="cleanup-bookkeeping-signals">
  <div class="ct">
    <div class="idx"><span class="idx__n">§02</span><span class="idx__t">Is this you</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:20ch;margin-bottom:36px;">If any of these sound familiar, the answer is yes.</h2>
    <div class="r-2">
      {%- for s in signals %}
      <div class="lift"><span class="lift__n">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span><div><h3>{{ s.opener | safe }}</h3><p>{{ s.body | safe }}</p></div></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- §03 AI SUMMARY — dark dossier ruled multi-Q&A -#}
<section class="sec reveal dossier" id="cleanup-bookkeeping-ai-summary">
  <div class="ct">
    <div class="idx"><span class="idx__n">§03</span><span class="idx__t">For AI engines &amp; quick answers</span><span class="idx__rule"></span></div>
    <h2 class="h2 dossier__h" style="max-width:16ch;margin-bottom:40px;">Cleanup, in five questions.</h2>
    <div class="dossier-qa speakable">
      {%- for item in aiSummary %}
      <div class="dossier-qa__item"><h3>{{ item.q | safe }}</h3><p>{{ item.a | safe }}</p></div>
      {%- endfor %}
      <div class="dossier-qa__item dossier-qa__cta"><a class="btn btn-cta" href="tel:{{ site.phone.e164 }}" data-ga="phone_click" data-tb-event="phone_click" style="display:inline-flex;align-items:center;gap:8px;height:46px;padding:0 20px;border-radius:10px;font-size:14.5px;font-weight:600;">{% include "icons/phone.svg" %} Speak to a ProAdvisor</a></div>
    </div>
  </div>
</section>

{#- §04 DELIVERABLES (icon lattice) -#}
<section class="sec reveal" id="cleanup-bookkeeping-deliverables">
  <div class="ct">
    <div class="idx"><span class="idx__n">§04</span><span class="idx__t">Scope of work</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:18ch;margin-bottom:36px;">What cleanup actually delivers.</h2>
    <div class="deliver">
      {%- for d in deliverables %}
      <div class="deliver__cell">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          {%- if loop.index == 1 %}<path d="M4 10a8 8 0 0114-4.5" stroke-linecap="round"/><path d="M4 5.5V10h4.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M20 14a8 8 0 01-14 4.5" stroke-linecap="round"/><path d="M20 18.5V14h-4.5" stroke-linecap="round" stroke-linejoin="round"/>
          {%- elif loop.index == 2 %}<path d="M4 7h16M4 12h16M4 17h10" stroke-linecap="round"/>
          {%- elif loop.index == 3 %}<rect x="4" y="5" width="16" height="14" rx="2"/><path d="M4 9.5h16M9.5 9.5V19" stroke-linecap="round"/>
          {%- elif loop.index == 4 %}<path d="M8 8h8v8H8z" stroke-linejoin="round"/><path d="M5 5l3 3M19 5l-3 3M5 19l3-3M19 19l-3-3" stroke-linecap="round"/>
          {%- elif loop.index == 5 %}<path d="M12 3v18M5 8l7-5 7 5" stroke-linecap="round" stroke-linejoin="round"/>
          {%- elif loop.index == 6 %}<path d="M12 3l7 3v6c0 4.5-3 8-7 9-4-1-7-4.5-7-9V6z" stroke-linejoin="round"/><path d="M9 12l2 2 4-4.5" stroke-linecap="round" stroke-linejoin="round"/>
          {%- elif loop.index == 7 %}<path d="M4 20h16M7 20V9M12 20V4M17 20v-7" stroke-linecap="round"/>
          {%- else %}<path d="M7 3h7l4 4v14H7z" stroke-linejoin="round"/><path d="M14 3v4h4M10 13h5M10 17h5" stroke-linecap="round"/>{%- endif %}
        </svg>
        <h3>{{ d.name | safe }}</h3>{% if d.body %}<p>{{ d.body | safe }}</p>{% endif %}
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- §05 PROCESS (4-step) + cleanup-timeline viz -#}
<section class="sec reveal" id="cleanup-bookkeeping-process" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§05</span><span class="idx__t">How it works</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:16ch;margin-bottom:44px;">From first call to clean books.</h2>
    <div class="process-grid">
      {%- for s in process %}
      <div class="process-step"><div class="process-step__n{% if loop.last %} process-step__n--done{% endif %}">STEP {{ s.num }}{% if loop.last %} &check;{% endif %}</div><h3>{{ s.name | safe }}</h3><p>{{ s.body | safe }}</p>{% if s.when %}<p style="margin-top:8px;"><strong>{{ s.when | safe }}</strong></p>{% endif %}</div>
      {%- endfor %}
    </div>
    <figure class="timeline-card">
      <figcaption><span class="mono" style="font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:var(--color-ink-faint);">Typical schedule &middot; 6 months behind</span><span class="mono" style="font-size:11px;color:var(--color-ink-mute);">weeks, not months</span></figcaption>
      {% include "partials/dc-cleanup-timeline.svg" %}
      <p class="timeline-card__note">Representative schedule, not a guarantee &mdash; your written timeline is set from your own file after the diagnostic. A file ~6 months behind typically runs about five weeks (week&nbsp;1 scope &amp; access, weeks&nbsp;2&ndash;3 categorise &amp; correct, weeks&nbsp;3&ndash;4 reconcile every account, week&nbsp;5 review, corrected statements, and CPA-ready handoff). Files further behind run longer.</p>
    </figure>
  </div>
</section>

{#- §06 WHAT CHANGES (centered statement) + before/after table (full depth: 6-dim compare) -#}
<section class="sec reveal" id="cleanup-bookkeeping-compare">
  <div class="ct">
    <div class="idx idx--center"><span class="idx__rule"></span><span class="idx__t">What changes</span><span class="idx__rule"></span></div>
    <div class="read" style="text-align:center;">
      <h2 class="statement">What changes when the books are clean.</h2>
      <p class="lede" style="margin:0 auto 24px;max-width:60ch;">Cleanup unwinds the accumulated <em>compounding reconciliation drift</em> &mdash; here is the before and after, dimension by dimension.</p>
      <p class="statement-dots"><span><b>&#9679;</b> CPA-ready output</span><span><b>&#9679;</b> Audit-traceable corrections</span><span><b>&#9679;</b> Fixed fee, no surprises</span></p>
    </div>
    <table class="cmp" data-viz="comparison-table" data-viz-state="FINAL" style="margin-top:40px;">
      <caption class="sr-only">Bookkeeping before and after a TechBrot cleanup engagement, by dimension.</caption>
      <thead><tr><th scope="col">Dimension</th><th scope="col">Before cleanup</th><th scope="col" class="us">After cleanup</th></tr></thead>
      <tbody>
        {%- for r in compare %}
        <tr><th scope="row">{{ r.dim | safe }}</th><td data-col="Before cleanup">{{ r.before | safe }}</td><td class="us" data-col="After cleanup"><strong>{{ r.after | safe }}</strong></td></tr>
        {%- endfor %}
      </tbody>
    </table>
  </div>
</section>

{#- §07 PRICING (tiers, MOST COMMON featured) -#}
<section class="sec reveal" id="cleanup-bookkeeping-pricing" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§07</span><span class="idx__t">Pricing</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:20ch;margin-bottom:10px;">Fixed fee, written scope, no hourly billing.</h2>
    <p class="lede" style="margin:0 0 36px;max-width:52ch;">Three tiers; ranges are typical engagements, final pricing follows the diagnostic. See the <a href="/pricing/?intent=pricing">bookkeeping pricing page</a> for ongoing monthly pricing after cleanup.</p>
    <div class="r-3">
      {%- for t in tiers %}
      <article class="ptier{% if t.note %} ptier--featured{% endif %}">
        {%- if t.note %}<p class="ptier__flag">{{ t.note | safe }}</p>{%- endif %}
        <h3 class="ptier__name">{{ t.name | safe }}</h3>
        <p class="ptier__price">{{ t.price | safe }}</p>
        <p class="ptier__for"><strong>For:</strong> {{ t.forWhom | safe }}</p>
        {%- if t.bullets %}<ul>{%- for b in t.bullets %}<li>{{ b | safe }}</li>{%- endfor %}</ul>{%- endif %}
        <a class="ptier__link" href="/contact/?intent=cleanup">{{ t.cta | safe }} <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{#- §08 OPERATOR (editorial + checklist) -#}
<section class="sec reveal" id="cleanup-bookkeeping-operator">
  <div class="ct r-2" style="gap:48px;align-items:center;">
    <div>
      <div class="idx"><span class="idx__n">§08</span><span class="idx__t">Who performs the work</span><span class="idx__rule"></span></div>
      <h2 class="h2" style="max-width:20ch;margin-bottom:18px;">A named, credentialed local operator. Not an anonymous offshore team.</h2>
      <p class="lede" style="margin:0 0 22px;max-width:46ch;">Every TechBrot cleanup is delivered by a vetted local operator &mdash; an independent accounting practice running under TechBrot&rsquo;s brand, standards, and infrastructure. You&rsquo;ll know exactly who is working on your books, how to reach them, and what credentials they hold. Platform-level quality review backs every engagement, and if continuity is ever a question, the platform handles the transition without losing the file context.</p>
      <figure class="opquote"><blockquote>&ldquo;They took something that felt overwhelming to me as a first-year business owner and made it simple.&rdquo;</blockquote><cite>Heidi Schubert &middot; Owner, Beverage Connection &middot; <b>Verified Clutch review</b></cite></figure>
    </div>
    <div class="opcard">
      <p class="opcard__label">The standard, every file</p>
      <ul>
        {%- for r in operatorSpec %}
        <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12.5l4 4 10-10.5" stroke-linecap="round" stroke-linejoin="round"/></svg><span><strong>{{ r.value | safe }}.</strong> {{ r.label | safe }}</span></li>
        {%- endfor %}
      </ul>
    </div>
  </div>
</section>

{#- §09 AROUND THE CLEANUP (related engagements — full depth) -#}
<section class="sec reveal" id="cleanup-bookkeeping-next" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§09</span><span class="idx__t">Around the cleanup</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">Cleanup is often part of a larger engagement.</h2>
    <div class="r-2">
      {%- for n in nextSteps %}
      <a class="rel-card" href="{{ n.href }}"><h3 class="rel-card__t">{{ n.title | safe }}</h3><p class="rel-card__d">{{ n.body | safe }}</p></a>
      {%- endfor %}
    </div>
  </div>
</section>

{#- §10 PRIMARY CALL-BLOCK (split light + dark) -#}
<section class="sec reveal" id="cleanup-bookkeeping-call" style="padding-top:40px;">
  <div class="ct">
    <div class="idx"><span class="idx__n">§10</span><span class="idx__t">Talk to a ProAdvisor</span><span class="idx__rule"></span></div>
    <div class="callcard">
      <div class="callband">
        <div class="callband__main">
          <p class="eyebrow" style="margin-bottom:16px;">Talk to a ProAdvisor</p>
          <h2 class="h2" style="font-size:clamp(26px,1.4rem + 1.4vw,33px);margin-bottom:12px;">One call tells you exactly where your books stand.</h2>
          <p style="font-size:16px;line-height:1.55;color:var(--color-ink-body2);margin:0 0 26px;max-width:42ch;">No form, no sales script. You speak with a Certified QuickBooks ProAdvisor who has looked at files like yours &mdash; and you get a written fixed-fee scope within one business day.</p>
          <a class="btn btn-cta callbtn" href="tel:{{ site.phone.e164 }}" data-ga="phone_click" data-tb-event="phone_click"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.75"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 005 5L15 12l5 2v3a2 2 0 01-2 2A16 16 0 013 6a2 2 0 012-2z" stroke-linecap="round" stroke-linejoin="round"/></svg><span class="mono" style="font-size:22px;font-weight:500;">{{ site.phone.display }}</span></a>
          <p class="mono" style="font-size:12px;color:var(--color-ink-mute);margin:8px 0 16px;">Mon&ndash;Fri &middot; we reply the same business day</p>
          <div style="display:flex;flex-wrap:wrap;gap:10px 18px;">
            <span style="display:inline-flex;align-items:center;gap:7px;font-size:13px;color:var(--color-ink-mute);">Certified ProAdvisor</span><span style="display:inline-flex;align-items:center;gap:7px;font-size:13px;color:var(--color-ink-mute);">Independent firm</span><span style="display:inline-flex;align-items:center;gap:7px;font-size:13px;color:var(--color-ink-mute);">No obligation</span>
          </div>
          <p style="font-size:13.5px;color:var(--color-ink-mute);margin:18px 0 0;">Prefer to write it down? <a href="/contact/?intent=cleanup" style="color:var(--color-accent);">Book the discovery call</a> or <a href="/quickbooks/file-review/?intent=file-review" style="color:var(--color-accent);">get the free file review</a>.</p>
        </div>
        <div class="callband__aside">
          <span class="callband__aside-label">What happens when you call</span>
          <ol class="callband__steps">
            <li><span class="callband__n" aria-hidden="true">01</span><span><b>You talk to a ProAdvisor</b><span>A real Certified QuickBooks ProAdvisor &mdash; not a call centre.</span></span></li>
            <li><span class="callband__n" aria-hidden="true">02</span><span><b>We review your file</b><span>We look at what&rsquo;s actually in your QuickBooks and what it needs.</span></span></li>
            <li><span class="callband__n callband__n--tie" aria-hidden="true">03</span><span><b>You get a written scope</b><span>A fixed fee in writing within 3 business days. Then you decide.</span></span></li>
          </ol>
        </div>
      </div>
    </div>
  </div>
</section>

{#- §11 INTAKE FORM (minimal, secondary seam) -#}
<section class="sec reveal" id="cleanup-bookkeeping-intake" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);padding-top:80px;padding-bottom:80px;">
  <div class="ct" style="max-width:760px;">
    <div class="idx"><span class="idx__n">§11</span><span class="idx__t">Prefer email</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:8px;">Scope your cleanup.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:50ch;">Send a few details and a Certified ProAdvisor replies the same business day. Or just <a href="tel:{{ site.phone.e164 }}" data-ga="phone_click" data-tb-event="phone_click" style="color:var(--color-accent);">call {{ site.phone.display }}</a>.</p>
    <form class="intake" id="cleanup-bookkeeping-intake-form" data-form="contact-discovery" method="POST" action="/contact/submit" novalidate>
      <div class="sr-only" aria-hidden="true"><label for="cb-company-website">Company website (leave blank)</label><input type="text" id="cb-company-website" name="company_website" tabindex="-1" autocomplete="off"></div>
      <div class="r-2" style="gap:16px;">
        <label><span>Full name</span><input type="text" id="cb-name" name="name" required autocomplete="name"></label>
        <label><span>Work email</span><input type="email" id="cb-email" name="email" required autocomplete="email"></label>
        <label><span>Months behind <span style="color:var(--color-ink-faint);font-weight:400;">optional</span></span><select id="cb-months" name="months"><option value="">Select range</option><option value="1-3">1&ndash;3 months</option><option value="3-12">3&ndash;12 months</option><option value="1-2y">1&ndash;2 years</option><option value="2y-plus">2+ years</option></select></label>
        <label><span>QuickBooks version <span style="color:var(--color-ink-faint);font-weight:400;">optional</span></span><select id="cb-qb-status" name="qb_status"><option value="">Select one</option><option value="qbo-current">QuickBooks Online</option><option value="qb-desktop">QuickBooks Desktop</option><option value="qb-enterprise">QuickBooks Enterprise</option><option value="not-sure">Not sure</option></select></label>
      </div>
      <label style="display:block;margin-top:16px;"><span>Anything specific? <span style="color:var(--color-ink-faint);font-weight:400;">optional</span></span><textarea id="cb-message" name="message" rows="3" placeholder="A line or two about the state of the file helps us scope the call."></textarea></label>
      <label class="intake-checkbox" style="display:flex;gap:10px;align-items:flex-start;margin-top:16px;font-size:13.5px;color:var(--color-ink-body2);"><input type="checkbox" name="consent" value="agreed" required style="width:auto;min-height:0;margin-top:3px;"><span>I agree to be contacted by TechBrot regarding this cleanup inquiry. We&rsquo;ll only use your details to respond to this request. See our <a href="/legal/privacy-policy/" style="color:var(--color-accent);">privacy policy</a>.</span></label>
      <input type="hidden" name="intent" data-meta="intent" value="cleanup">
      <input type="hidden" name="source_page" data-meta="source_page" value="accounting/bookkeeping/cleanup-bookkeeping">
      <input type="hidden" name="source_type" data-meta="source_type" value="bofu-conversion">
      <input type="hidden" name="funnel_stage" data-meta="funnel_stage" value="BOFU">
      <input type="hidden" name="referring_page" id="cb-referring-page" value="" data-referrer-tracker>
      <div style="display:flex;flex-wrap:wrap;align-items:center;gap:14px;margin-top:18px;">
        <button class="btn btn-cta" type="submit" data-cta="contact-form-submit" style="display:inline-flex;align-items:center;height:48px;padding:0 22px;border:0;border-radius:10px;font:inherit;font-size:15px;font-weight:600;cursor:pointer;">Send the Discovery Brief</button>
        <span style="font-size:13px;color:var(--color-ink-mute);">Same business day &middot; no obligation. A Certified ProAdvisor replies within one business day.</span>
      </div>
    </form>
  </div>
</section>

{#- §12 FAQ -#}
