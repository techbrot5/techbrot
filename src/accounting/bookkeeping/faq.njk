---

<section class="section section--compact" id="acct-bk-faq-popular">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Most asked</p>
      <h2 class="section__heading">Six questions answered most often.</h2>
    </header>
    <div class="grid-3">
      {%- for p in popular %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ p.qid }} &middot; {{ p.cluster }}</p>
        <p class="prose"><a href="#{{ p.anchor }}">{{ p.q | safe }} &rarr;</a></p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section" id="acct-bk-faq-body">
  <div class="container">
    <h2 class="sr-only">All bookkeeping questions, organized by topic</h2>
    <div class="guide-grid">
      <aside class="toc" aria-label="Topic clusters">
        <p class="toc__label">Topic clusters</p>
        <ol>
          {%- for c in clusters %}
          <li><a {% if loop.first %}class="is-active" {% endif %}href="#{{ c.id }}">{{ c.heading | safe }}</a></li>
          {%- endfor %}
        </ol>
      </aside>
      <article class="article prose">
        <div class="byline-block" style="border-top:0;padding-top:0;margin-bottom:var(--space-6)">
          <svg class="byline-block__mark" viewBox="0 0 64 64" role="img" aria-label="TechBrot"><rect width="64" height="64" rx="14" fill="#1A1915"></rect><g transform="translate(12.16 12.16) scale(0.62)" fill="#F5F3EC"><path d="M8 10 H38 V54 H26 V22 H8 Z"></path><rect x="42" y="10" width="14" height="12"></rect></g></svg>
          <div>
            <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
            <p class="byline-block__review">Reviewed by a Certified QuickBooks ProAdvisor &middot; independent firm, not affiliated with Intuit Inc.</p>
          </div>
        </div>
        <blockquote class="pull-quote">
          <p>Every answer here reflects how we&rsquo;d actually advise a client &mdash; no hedging, no affiliate spin, and zero commission on any Intuit product. We keep the books right; your CPA files from them.</p>
        </blockquote>
        {%- for c in clusters %}
        <section id="{{ c.id }}" aria-labelledby="{{ c.id }}-h">
          <h2 id="{{ c.id }}-h">{{ c.heading | safe }}</h2>
          <p>{{ c.lede | safe }}</p>
          {%- for it in c.items %}
          <h3 id="{{ it.anchor }}">{{ it.q | safe }}</h3>
          {{ it.a | safe }}
          {%- endfor %}
        </section>
        {%- endfor %}
        <p class="meta-reviewed"><span>Maintained by the Certified QuickBooks ProAdvisor team</span><span>7 topic clusters</span><span>Last reviewed: 2026-06 &middot; Certified QuickBooks ProAdvisor</span></p>
      </article>
    </div>
  </div>
</section>

<section class="section section--alt" id="acct-bk-faq-structured">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Quick answers</p>
      <h2 class="section__heading">The seven questions businesses ask most.</h2>
      <p class="section__lede">The core of the bookkeeping reference, condensed. Each answer carries the full detail from the clusters above.</p>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question"><button class="faq__trigger" type="button" aria-expanded="false" aria-controls="acct-bk-faq-a-{{ loop.index }}" id="acct-bk-faq-q-{{ loop.index }}">{{ item.q | safe }}</button></h3>
        <div class="faq__answer" id="acct-bk-faq-a-{{ loop.index }}" data-open="false" role="region" aria-labelledby="acct-bk-faq-q-{{ loop.index }}">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section" id="acct-bk-faq-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    </header>
    <div class="prose">
      <p>{{ reviewBody | safe }}</p>
    </div>
    <div class="trust-row">
      {%- for r in reviewerCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.label | safe }}</p><p class="trust-row__label">{{ r.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section" id="acct-bk-faq-related">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Related services</p>
      <h2 class="section__heading">The full bookkeeping service universe.</h2>
      <p class="section__lede">Every engagement type referenced across the FAQ, organized for quick navigation. Start where your question lives.</p>
    </header>
    <div class="grid-3">
      {%- for n in related %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ n.cluster }}</p>
        <h3><a href="{{ n.href }}">{{ n.title | safe }}</a></h3>
        <p class="prose">{{ n.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
