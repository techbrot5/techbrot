{#- ═══ BESPOKE MIDDLE (catch-up) — deliverables · process · decide (catch-up vs cleanup),
    shared dc-system v2 components, full depth. Spine layout-owned (t-money). ═══ -#}

{#- §04 DELIVERABLES (icon lattice, 6 → 3-col) -#}
<section class="sec reveal" id="catch-up-bookkeeping-deliverables">
  <div class="ct">
    <div class="idx"><span class="idx__n">§04</span><span class="idx__t">The scope</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:18ch;margin-bottom:36px;">What catch-up actually delivers.</h2>
    <div class="deliver deliver--3">
      {%- for d in deliverables %}
      <div class="deliver__cell">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          {%- if loop.index == 1 %}<path d="M4 7h16M4 12h16M4 17h10" stroke-linecap="round"/>
          {%- elif loop.index == 2 %}<path d="M4 10a8 8 0 0114-4.5" stroke-linecap="round"/><path d="M4 5.5V10h4.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M20 14a8 8 0 01-14 4.5" stroke-linecap="round"/><path d="M20 18.5V14h-4.5" stroke-linecap="round" stroke-linejoin="round"/>
          {%- elif loop.index == 3 %}<path d="M4 20h16M7 20V9M12 20V4M17 20v-7" stroke-linecap="round"/>
          {%- elif loop.index == 4 %}<path d="M12 3l7 3v6c0 4.5-3 8-7 9-4-1-7-4.5-7-9V6z" stroke-linejoin="round"/><path d="M9 12l2 2 4-4.5" stroke-linecap="round" stroke-linejoin="round"/>
          {%- elif loop.index == 5 %}<rect x="4" y="5" width="16" height="14" rx="2"/><path d="M4 9.5h16M9.5 9.5V19" stroke-linecap="round"/>
          {%- else %}<path d="M7 3h7l4 4v14H7z" stroke-linejoin="round"/><path d="M14 3v4h4M10 13h5M10 17h5" stroke-linecap="round"/>{%- endif %}
        </svg>
        <h3>{{ d.name | safe }}</h3>{% if d.body %}<p>{{ d.body | safe }}</p>{% endif %}
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- §05 PROCESS (4-step) -#}
<section class="sec reveal" id="catch-up-bookkeeping-process" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§05</span><span class="idx__t">The process</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:16ch;margin-bottom:44px;">From first call to current books.</h2>
    <div class="process-grid">
      {%- for s in process %}
      <div class="process-step"><div class="process-step__n{% if loop.last %} process-step__n--done{% endif %}">STEP {{ s.num }}{% if loop.last %} &check;{% endif %}</div>{% if s.name %}<h3>{{ s.name | safe }}</h3>{% endif %}<p>{{ s.body | safe }}</p>{% if s.when %}<p style="margin-top:8px;"><strong>{{ s.when | safe }}</strong></p>{% endif %}</div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- §06 DECIDE (catch-up vs cleanup) -#}
<section class="sec reveal" id="catch-up-bookkeeping-decide">
  <div class="ct">
    <div class="idx idx--center"><span class="idx__rule"></span><span class="idx__t">Catch-up or cleanup?</span><span class="idx__rule"></span></div>
    <div class="read" style="text-align:center;">
      <h2 class="statement">Which one do you actually need?</h2>
      <p class="lede" style="margin:0 auto 8px;max-width:60ch;">Behind but structured is a catch-up. Messy or wrong is a cleanup. Many files need both &mdash; the diagnostic tells you which, in writing, before any work begins.</p>
    </div>
    <table class="cmp" data-viz="comparison-table" data-viz-state="FINAL" style="margin-top:40px;">
      <caption class="sr-only">Catch-up bookkeeping versus cleanup bookkeeping, by dimension.</caption>
      <thead><tr><th scope="col">Dimension</th><th scope="col" class="us">Catch-up</th><th scope="col">Cleanup</th></tr></thead>
      <tbody>
        {%- for row in decide %}
        <tr><th scope="row">{{ row.dim | safe }}</th><td class="us" data-col="Catch-up"><strong>{{ row.us | safe }}</strong></td><td data-col="Cleanup">{{ row.other | safe }}</td></tr>
        {%- endfor %}
      </tbody>
    </table>
  </div>
</section>
