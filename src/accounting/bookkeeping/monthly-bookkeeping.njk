{#- ═══ BESPOKE MIDDLE (monthly) — close cadence · deliverables (included + layered),
    shared dc-system v2 components, full depth. Spine layout-owned (t-money). ═══ -#}

{#- §04 CLOSE CADENCE (4-step) -#}
<section class="sec reveal" id="monthly-bookkeeping-cadence" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">The monthly close cadence</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:18ch;margin-bottom:12px;">What every month actually looks like.</h2>
    <p class="lede" style="margin:0 0 40px;max-width:54ch;">Every engagement runs the same close cadence &mdash; documents in, reconciliation, close and review, package delivered by the 15th.</p>
    <div class="process-grid">
      {%- for step in closeCadence %}
      <div class="process-step"><div class="process-step__n{% if loop.last %} process-step__n--done{% endif %}">{{ step.band | safe }}{% if loop.last %} &check;{% endif %}</div>{% if step.label %}<h3>{{ step.label | safe }}</h3>{% endif %}<p>{{ step.sub | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- §05 DELIVERABLES (included + layered checklists) -#}
<section class="sec reveal" id="monthly-bookkeeping-deliverables">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">The deliverables</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:18ch;margin-bottom:36px;">What you get, every month.</h2>
    <div class="r-2" style="gap:24px;">
      <div class="incl-card">
        <h3>Included in every engagement</h3>
        <ul class="checklist">{%- for d in included %}<li>{{ d | safe }}</li>{%- endfor %}</ul>
      </div>
      <div class="incl-card">
        <h3>Layered on as scope requires</h3>
        <ul class="checklist">{%- for d in layered %}<li>{{ d | safe }}</li>{%- endfor %}</ul>
      </div>
    </div>
  </div>
</section>
