---

{#- ═══ G2 PARTNERS FAQ (BASELINE, equity-gated). t-guide→t-prose / dc-base chrome.
    All 25 baseline headings verbatim at their level (popular H2 · sr-only body H2 ·
    7 cluster H2 + 26 cluster H3 · structured H2 → layout faqH · related H2 + 8 H3).
    speakable cssSelector ["#partners-faq-in-brief-text"] → layout TL;DR renders that
    id from slug=partners-faq (inBrief kept). 7 structured FAQ + FAQPage rendered by
    t-prose faq slot (sec.faqH from `faq` data). founder-name-zero in visible content
    (David Westgate stays in reviewedBy schema @id only). No fabricated counts/stats. ═══ -#}

{#- POPULAR — featured questions strip → v2 idx + r-3 prose cards. -#}
<section class="sec reveal" id="partners-faq-popular" style="padding-top:8px;">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Most asked</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">Six questions ProAdvisors ask first.</h2>
    <div class="r-3">
      {%- for p in popular %}
      <a class="dc-card hub-card" href="#{{ p.anchor }}"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ p.qid }} &middot; {{ p.cluster }}</span><h3 style="font-size:16px;">{{ p.q | safe }}</h3><span class="hub-card__go">Jump to answer <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
      {%- endfor %}
    </div>
  </div>
</section>

{#- BODY — all 7 clusters as an editorial reading column. Cluster H2 + per-question
    H3 verbatim; prose answers carried VERBATIM. byline + pull-quote + topic nav. -#}
<section class="sec reveal" id="partners-faq-body" style="padding-top:24px;">
  <div class="ct read read--doc">
    <h2 class="sr-only">All operator network questions, organized by topic</h2>
    <div class="prose-byline" style="margin-top:0;border-top:0;padding-top:0;">
      <span class="prose-byline__mark"><svg width="16" height="16" viewBox="0 0 64 64" fill="#FCFBF8" aria-hidden="true"><path d="M8 10 H38 V54 H26 V22 H8 Z"/><rect x="42" y="10" width="14" height="12"/></svg></span>
      <div>
        <p class="prose-byline__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="prose-byline__meta">Reviewed by a Certified QuickBooks ProAdvisor &middot; independent firm, not affiliated with Intuit Inc.</p>
      </div>
    </div>
    <nav class="prose" aria-label="Topic clusters" style="margin:22px 0 4px;font-size:14px;">
      <span class="eyebrow" style="display:block;margin-bottom:8px;">Topic clusters</span>
      <ol style="margin:0;padding-left:18px;">
        {%- for c in clusters %}
        <li><a href="#{{ c.id }}">{{ c.heading | safe }}</a></li>
        {%- endfor %}
      </ol>
    </nav>
    <div class="opquote" style="margin:26px 0;">
      <blockquote>Every answer reflects the actual operator engagement model &mdash; how the network is structured, what each side provides, and the honest economics &mdash; not idealized recruitment language.</blockquote>
    </div>
    <div class="prose">
      {%- for c in clusters %}
      <section id="{{ c.id }}" aria-labelledby="{{ c.id }}-h">
        <h2 id="{{ c.id }}-h">{{ c.heading | safe }}</h2>
        <p>{{ c.lede | safe }}</p>
        {%- for it in c.items %}
        <h3 id="{{ it.anchor }}">{{ it.q | safe }}</h3>
        {{ it.a | safe }}
        {%- endfor %}
      </section>
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Maintained by the Certified QuickBooks ProAdvisor team</span><span>26 questions &middot; 7 clusters</span><span>Last reviewed: 2026-06 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{#- RELATED — route cards (baseline H2 + 8 H3) → r-3 hub-card grid. -#}
<section class="sec reveal hub-rt--alt" id="partners-faq-related" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Related</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Learn more about the firm and the engagement model.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:72ch;">For ProAdvisors evaluating fit, the broader firm context matters. These pages cover how TechBrot operates from the client perspective &mdash; the engagement model network operators deliver against.</p>
    <div class="r-3">
      {%- for n in related %}
      <a class="dc-card hub-card" href="{{ n.href }}"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ n.cluster }}</span><h3>{{ n.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;color:var(--color-ink-mute);">{{ n.body | safe }}</p><span class="hub-card__go">Read more <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
      {%- endfor %}
    </div>
  </div>
</section>
