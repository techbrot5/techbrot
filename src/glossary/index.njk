---json
{
  "layout": "layouts/t-hub.njk",
  "permalink": "/glossary/",
  "slug": "glossary",
  "tierClass": "section--tier-hub",
  "bodyClass": "page--mofu",
  "title": "Accounting & QuickBooks Glossary — Plain-English Definitions · TechBrot",
  "description": "Plain-English definitions of the accounting and QuickBooks terms that come up in real engagements — what each term means, why it matters, and where it shows up. By Certified QuickBooks ProAdvisors.",
  "breadcrumb": [
    { "name": "Home", "href": "/" },
    { "name": "Glossary" }
  ],
  "heroFigure": false,
  "hero": {
    "eyebrow": "Glossary",
    "heading": "The accounting &amp; QuickBooks glossary.",
    "subheading": "Plain-English, accurate definitions of the terms that come up in real bookkeeping and QuickBooks engagements &mdash; what each means, why it matters, and where it shows up in the work. Written and maintained by the Certified QuickBooks ProAdvisor team.",
    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Speak to a ProAdvisor", "tel": true, "class": "btn--ghost" }
    ]
  },
  "summary": "The <strong>TechBrot glossary</strong> defines the accounting and QuickBooks terms that come up in real engagements &mdash; bookkeeping, cleanup, reconciliation, payroll, sales tax, and advisory. Each entry is a genuine, citable definition with the context that makes it useful and links to where the term applies in the work. New terms are added regularly.",
  "summarySource": "Maintained by the Certified QuickBooks ProAdvisor team at TechBrot Inc., an independent firm &mdash; not affiliated with Intuit Inc.",
  "ctaBand": {
    "eyebrow": "Term raised a question about your books?",
    "heading": "Ask a Certified ProAdvisor.",
    "lede": "If a definition here describes a problem in your own QuickBooks file, a free file review will tell you exactly where you stand &mdash; with a written fixed-fee scope to fix it.",
    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Speak to a ProAdvisor", "tel": true, "class": "btn--ghost" }
    ]
  },
  "sec": {
    "summaryId": "glossary-in-brief-text",
    "summaryTag": "In brief"
  }
}
---

{# ── TERMS · grid of glossary entries (grows as the type fans out). (H2: Browse the glossary.) ── #}
<section class="sec reveal" id="glossary-terms">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Browse the terms</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:26ch;margin-bottom:10px;">Browse the glossary.</h2>
    <p class="lede" style="margin:0 0 30px;max-width:66ch;">Every entry is a real, plain-English definition &mdash; what the term means, why it matters, and where it comes up. More terms are added regularly.</p>
    <div class="r-3">
      {%- for t in glossary %}
      <a class="dc-card hub-card" href="/glossary/{{ t.slug }}/"><h3>{{ t.term | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;color:var(--color-ink-mute);">{{ t.blurb | safe }}</p><span class="hub-card__go">Read the definition <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── BYLINE + REVIEW · firm-level (founder-name-zero). ── #}
<section class="sec reveal" id="glossary-review" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="byline">
      <div class="byline__mark" aria-hidden="true" style="background:var(--color-accent);"></div>
      <div>
        <p class="byline__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="byline__review">Reviewed by a Certified QuickBooks ProAdvisor &middot; independent firm, not affiliated with Intuit Inc.</p>
      </div>
    </div>
    <p class="meta-reviewed"><span>Maintained by the Certified QuickBooks ProAdvisor team</span><span>Updated: 2026-06-17</span></p>
  </div>
</section>
