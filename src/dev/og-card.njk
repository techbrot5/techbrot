---json
{ "eleventyExcludeFromCollections": true }
---
<!doctype html>
<html lang="en"><head><meta charset="utf-8">
<link rel="stylesheet" href="/assets/css/site.min.css">
<style>
  html, body { margin: 0; padding: 0; background: #14110C; }
  .og { width: 1200px; height: 630px; background: var(--surface-ink); color: var(--text-on-ink); display: flex; flex-direction: column; justify-content: space-between; padding: 72px 80px; box-sizing: border-box; overflow: hidden; position: relative; }
  .og__tieout { position: absolute; top: -90px; right: -90px; width: 480px; height: 480px; opacity: 0.06; color: #fff; }
  .og__mark { display: inline-flex; gap: 6px; align-items: center; position: relative; }
  .og__mark > span:first-child { width: 56px; height: 6px; background: var(--accent-on-ink); }
  .og__mark > span:last-child { width: 26px; height: 6px; background: var(--cta); }
  .og__title { position: relative; font-family: var(--font-serif); font-variation-settings: var(--serif-display-axes); font-weight: 500; font-size: 74px; line-height: 1.04; letter-spacing: -0.022em; color: #fff; max-width: 19ch; margin: 0; }
  .og__foot { position: relative; display: flex; align-items: center; justify-content: space-between; }
  .og__brand { display: flex; align-items: center; gap: 16px; }
  .og__logo { width: 46px; height: 46px; background: var(--accent); border-radius: 11px; display: inline-flex; align-items: center; justify-content: center; }
  .og__name { font-weight: 600; font-size: 30px; color: #fff; }
  .og__tag { font-family: var(--font-mono); font-size: 20px; color: var(--accent-on-ink); }
</style></head>
<body>
<div class="og">
  <svg class="og__tieout" viewBox="0 0 64 64" fill="currentColor" aria-hidden="true"><path d="M8 10 H38 V54 H26 V22 H8 Z"/><rect x="42" y="10" width="14" height="12"/></svg>
  <div class="og__mark" aria-hidden="true"><span></span><span></span></div>
  <h1 class="og__title">Independent Certified QuickBooks ProAdvisors. We handle the judgment.</h1>
  <div class="og__foot">
    <div class="og__brand">
      <span class="og__logo"><svg width="27" height="27" viewBox="0 0 64 64" fill="#FCFBF8" aria-hidden="true"><path d="M8 10 H38 V54 H26 V22 H8 Z"/><rect x="42" y="10" width="14" height="12"/></svg></span>
      <span class="og__name">TechBrot</span>
    </div>
    <span class="og__tag">techbrot.com</span>
  </div>
</div>
</body></html>
