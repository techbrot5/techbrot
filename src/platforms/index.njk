---

{# ── PLATFORM GRID · only platforms we hold a real certification/partnership on (dc-card hub-cards). (H2 per group.) ── #}
{%- for group in platformGroups %}
<section class="sec reveal{% if loop.index is even %} hub-rt--alt{% endif %}" id="platforms-hub-{{ group.id }}"{% if loop.index is even %} style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);"{% endif %}>
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ group.eyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:28ch;margin-bottom:{% if group.lede %}10{% else %}28{% endif %}px;">{{ group.heading | safe }}</h2>
    {%- if group.lede %}<p class="lede" style="margin:0 0 30px;max-width:66ch;">{{ group.lede | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for p in group.platforms %}
      {%- if p.href %}
      <a class="dc-card hub-card" href="{{ p.href }}"><h3>{{ p.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;color:var(--color-ink-mute);">{{ p.body | safe }}</p><span class="hub-card__go">{{ p.cta | safe }}</span></a>
      {%- else %}
      <div class="dc-card"><h3>{{ p.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;color:var(--color-ink-mute);">{{ p.body | safe }}</p></div>
      {%- endif %}
      {%- endfor %}
    </div>
  </div>
</section>
{%- endfor %}

{# ── CROSS-LINKS (read). ── #}
<section class="sec reveal" id="platforms-hub-related">
  <div class="ct read">
    <p class="prose">{{ relatedNote | safe }}</p>
  </div>
</section>
