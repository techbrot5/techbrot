  "permalink": "/tools/quickbooks-plan-selector/",
  "slug": "plan-select",
  "chrome": "full",
  "callBar": true,
  "includeSelectJs": true,
  "bodyClass": "page--mofu",
  "pageTier": "mofu",
  "title": "QuickBooks Online Plan Selector · Which QBO Plan Fits · TechBrot",
  "description": "Free QuickBooks Online plan selector. Answer five questions about users, inventory, projects, and class tracking to see which QBO plan fits — Simple Start, Essentials, Plus, or Advanced. Fit-based, no pricing (Intuit sets prices). Independent firm, not Intuit. Call (877) 751-5575.",
  "breadcrumb": [
    { "name": "Home", "href": "/" },
    { "name": "Tools", "href": "/tools/" },
    { "name": "QuickBooks Plan Selector" }
  ],
  "hero": {
    "eyebrow": "Free tool · QuickBooks Online",
    "heading": "Which QuickBooks Online plan actually fits your business?",
    "subheading": "Answer five questions about how you work &mdash; users, inventory, projects, class tracking &mdash; and see which QuickBooks Online plan has the features you need, from Simple Start to Advanced. We recommend on <strong>fit, not price</strong>: Intuit sets and changes plan pricing, so we point you to the right tier and you confirm the current cost with Intuit.",
    "actions": [
      { "label": "Skip to the calculator", "href": "#calc", "class": "btn--primary" },
      { "label": "See full pricing", "href": "/pricing/", "class": "btn--ghost" }
    ]
  },
  "inBrief": {
    "text": "<strong>This tool matches you to a QuickBooks Online tier on features, not price.</strong> The deciding factors are how many users you need and whether you require inventory, project profitability, or class/location tracking &mdash; the capabilities that separate Simple Start, Essentials, Plus, and Advanced. We don&rsquo;t quote Intuit&rsquo;s prices because Intuit sets and changes them; check current pricing at Intuit. TechBrot is an independent ProAdvisor firm &mdash; not Intuit &mdash; and we can set up whichever plan fits, correctly.",
    "source": "TechBrot Inc. &middot; independent Certified QuickBooks ProAdvisor firm &mdash; not affiliated with Intuit Inc. Plan names and features are Intuit&rsquo;s and can change."
  },
  "ctaBand": {
    "eyebrow": "Right plan, set up right",
    "heading": "Get the plan picked and set up correctly.",
    "lede": "Picking the tier is the easy part &mdash; setting it up so your books are right from day one is the work. A free 30-minute discovery call confirms the plan for your business and scopes a clean QuickBooks setup. No hourly billing, no obligation. Independent firm &mdash; not Intuit.",
    "actions": [
      { "label": "Book the discovery call", "href": "/contact/?intent=quickbooks-setup", "class": "btn--primary" },
      { "label": "Speak to a ProAdvisor", "tel": true, "class": "btn--ghost" }
    ]
