<section class="section" id="tools-hub-available">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Available now</p>
      <h2 class="section__heading">Tools you can use today.</h2>
      <p class="section__lede">Free, transparent, and honest about their limits &mdash; each one shows its own math.</p>
    </header>
    <div class="grid-3">
      {%- for t in tools %}
      <article class="review-card">
        <h3>{{ t.name }}</h3>
        <p class="review-card__fact">{{ t.body | safe }}</p>
        <a class="review-card__link" href="{{ t.href }}">{{ t.cta }} <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section section--alt" id="tools-hub-roadmap">
  <div class="container container--narrow">
    <header class="section__header">
      {%- if roadmap.length %}
      <p class="section__eyebrow">In development</p>
      <h2 class="section__heading">More tools on the way.</h2>
      <p class="section__lede">We&rsquo;d rather name what&rsquo;s coming than link to pages that don&rsquo;t exist yet. These are in development and will appear here as they&rsquo;re published.</p>
      {%- else %}
      <p class="section__eyebrow">More to come</p>
      <h2 class="section__heading">Need a tool we don&rsquo;t have yet?</h2>
      <p class="section__lede">This set covers the questions we hear most. We add tools as businesses ask for them &mdash; if there&rsquo;s a calculation you wish existed, mention it on a discovery call and we&rsquo;ll look at building it.</p>
      {%- endif %}
    </header>
    {%- if roadmap.length %}
    <ul class="checks-list">
      {%- for r in roadmap %}
      <li>{{ r }}</li>
      {%- endfor %}
    </ul>
    {%- endif %}
  </div>
</section>

<section class="section" id="tools-hub-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">About these tools</p>
      <h2 class="section__heading">Questions about the tools.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="tools-hub-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="tools-hub-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
