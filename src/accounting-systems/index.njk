  "breadcrumb": [
    { "name": "Home", "href": "/" },
    { "name": "Accounting Systems" }
  ],
  "heroFigure": false,
  "hero": {
    "eyebrow": "Accounting Systems · Advisory",
    "heading": "Before you pick software, get the system right.",
    "subheading": "We're an accounting-technology advisory firm: we help you choose the accounting platform and app stack that fit your business, then run them &mdash; independent of any one vendor. We're a Certified QuickBooks ProAdvisor team and we say so, but the advice is fit-first: where another platform fits your business better, we say so. This hub routes to the four decisions that matter &mdash; which accounting software, your app stack, migration planning, and the platforms we're certified on. Independent firm &mdash; not affiliated with Intuit Inc.",
    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Book the discovery call", "href": "/contact/?intent=accounting", "class": "btn--ghost" }
    ],
    "trust": [
      "Vendor-neutral, fit-first advice",
      "Independent · not Intuit",
      "We implement what we recommend"
    ]
  },
  "inBrief": {
    "text": "<strong>TechBrot</strong> is an independent accounting-technology advisory firm and Certified QuickBooks ProAdvisor &mdash; <strong>not Intuit</strong>. This is the platform-agnostic silo: we help you get the <em>system</em> right before you commit to any one piece of software. That means choosing the accounting platform and the connected <a href=\"/app-stack/\">app stack</a> that fit how your business actually works, then running them month to month. We prefer QuickBooks for most small businesses and we disclose that &mdash; but the advice is fit-first, and where another platform fits you better we name it. Start with <a href=\"/which-accounting-software/\">which accounting software</a>, or see the <a href=\"/platforms/\">platforms we're certified on</a>. The four decisions are below.",
    "source": "Reference maintained by the Certified QuickBooks ProAdvisor team at TechBrot Inc., an independent accounting-technology advisory firm — not Intuit, and not Intuit's official software support. We are QuickBooks-certified and disclose it; platform recommendations are fit-first and vendor-neutral. Not affiliated with Intuit Inc."
  },
  "ctaBand": {
    "eyebrow": "Start with your real numbers",
    "heading": "We'll help you choose the right system — then run it.",
    "lede": "Get a free file review or book a discovery call. We'll look at how your books and tools are set up today, where the fit is wrong, and what the right accounting system looks like for your business. Fit-first, no pitch. Independent firm — not Intuit.",
    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Book the discovery call", "href": "/contact/?intent=accounting", "class": "btn--ghost" }
    ]
  }
}
---

{# ── SUMMARY ── #}
<section class="section section--compact" id="accounting-systems-hub-summary-sec">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In short</p>
      <h2 class="section__heading">Own the system before the software.</h2>
    </header>
    <p class="prose" id="accounting-systems-hub-summary">{{ summary | safe }}</p>
  </div>
</section>

{# ── DECISION GRID · the four platform-agnostic decisions (buyer-cards) ── #}
{%- for group in featureGroups %}
<section class="section{% if loop.index is even %} section--alt{% endif %}" id="accounting-systems-hub-{{ group.id }}">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">{{ group.eyebrow | safe }}</p>
      <h2 class="section__heading">{{ group.heading | safe }}</h2>
      {%- if group.lede %}<p class="section__lede">{{ group.lede | safe }}</p>{%- endif %}
    </header>
    <div class="grid-3">
      {%- for f in group.features %}
      <article class="buyer-card">
        <h3 class="buyer-card__heading">{{ f.title | safe }}</h3>
        <p class="buyer-card__body">{{ f.body | safe }}</p>
        <a class="buyer-card__cta" href="{{ f.href }}">{{ f.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endfor %}

{# ── CROSS-LINKS ── #}
<section class="section section--compact" id="accounting-systems-hub-related">
  <div class="container container--narrow">
    <p class="prose">{{ relatedNote | safe }}</p>
  </div>
</section>

{# ── FAQ ── #}
<section class="section section--alt" id="accounting-systems-hub-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">Accounting-systems advisory questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="accounting-systems-hub-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="accounting-systems-hub-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
