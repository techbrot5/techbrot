---json
{
  "layout": "layouts/t-hub.njk",
  "permalink": "/resources/",
  "slug": "resources-hub",
  "title": "Free Accounting & QuickBooks Resources · TechBrot",
  "description": "Free, useful accounting and QuickBooks resources from Certified ProAdvisors — plain-English guides, practical checklists, a glossary, and our original data.",
  "breadcrumb": [
    { "name": "Home", "href": "/" },
    { "name": "Resources" }
  ],
  "heroFigure": false,
  "hero": {
    "eyebrow": "Resources",
    "heading": "Free accounting & QuickBooks resources, from ProAdvisors.",
    "subheading": "Free, genuinely useful accounting & QuickBooks resources from Certified ProAdvisors — plain-English guides, practical checklists, a plain-English glossary, and our original data. Everything here is free and written to actually help, with nothing gated behind a form. We're an independent firm — not affiliated with Intuit Inc. Browse the full library below.",
    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Book the discovery call", "href": "/contact/?intent=accounting", "class": "btn--ghost" }
    ],
    "trust": [
      "Certified QuickBooks ProAdvisor team",
      "Independent · not Intuit",
      "Free · no gated fluff"
    ]
  },
  "summary": "This is our free resource library &mdash; everything we&rsquo;ve published to help you understand your books, in one place. There are four parts: plain-English <a href=\"/resources/guides/\">guides</a> to accounting and QuickBooks, practical <a href=\"/resources/checklists/\">checklists</a> for the work that has to get done, a plain-English <a href=\"/glossary/\">glossary</a> of the terms you actually run into, and our <a href=\"/resources/research/\">original research and data</a>. Everything is <strong>free and genuinely useful</strong> &mdash; written by Certified ProAdvisors, with nothing gated behind a form. As an independent Certified QuickBooks ProAdvisor firm &mdash; <strong>not Intuit</strong> &mdash; we publish these because clear, accurate information is good for everyone, whether or not you ever hire us.",
  "ctaBand": {
    "eyebrow": "Start with your real file",
    "heading": "Ready for help with your own books?",
    "lede": "Get a free QuickBooks file review or book a discovery call. We'll look at how your file is set up and show you exactly where setup or cleanup will help. No pitch. Independent firm — not Intuit.",
    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Book the discovery call", "href": "/contact/?intent=accounting", "class": "btn--ghost" }
    ]
  },
  "sec": {
    "summaryId": "resources-hub-summary",
    "summaryTag": "In short",
    "summaryH": "Everything in the resource library, free.",
    "faqTag": "FAQ",
    "faqH": "Resource library questions."
  }
}
---

{# ── RESOURCE GRID · routes to each resource type (dc-card hub-cards). (H2 per group.) ── #}
{%- for group in resourceGroups %}
<section class="sec reveal{% if loop.index is even %} hub-rt--alt{% endif %}" id="resources-hub-{{ group.id }}"{% if loop.index is even %} style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);"{% endif %}>
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ group.eyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:26ch;margin-bottom:{% if group.lede %}10{% else %}28{% endif %}px;">{{ group.heading | safe }}</h2>
    {%- if group.lede %}<p class="lede" style="margin:0 0 30px;max-width:66ch;">{{ group.lede | safe }}</p>{%- endif %}
    <div class="r-4">
      {%- for r in group.resources %}
      <a class="dc-card hub-card" href="{{ r.href }}"><h3>{{ r.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;color:var(--color-ink-mute);">{{ r.body | safe }}</p><span class="hub-card__go">{{ r.cta | safe }}</span></a>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endfor %}

{# ── CROSS-LINKS (read). ── #}
<section class="sec reveal" id="resources-hub-related">
  <div class="ct read">
    <p class="prose">{{ relatedNote | safe }}</p>
  </div>
</section>
