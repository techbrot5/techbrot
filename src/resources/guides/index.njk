---json
{
  "layout": "layouts/t-hub.njk",
  "permalink": "/resources/guides/",
  "slug": "guides-hub",
  "title": "Accounting & QuickBooks Guides · TechBrot",
  "description": "Plain-English accounting and QuickBooks guides from Certified ProAdvisors — how bookkeeping, hiring, pricing, and compliance work for small businesses.",
  "breadcrumb": [
    { "name": "Home", "href": "/" },
    { "name": "Resources", "href": "/resources/" },
    { "name": "Guides" }
  ],
  "heroFigure": false,
  "hero": {
    "eyebrow": "Resources · Guides",
    "heading": "Plain-English guides from Certified ProAdvisors.",
    "subheading": "Plain-English guides from Certified ProAdvisors — how bookkeeping, QuickBooks, hiring, pricing, and compliance work for small businesses. This hub routes to a dedicated guide for every topic, dated and reviewed. Independent firm — not Intuit.",
    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Book the discovery call", "href": "/contact/?intent=accounting", "class": "btn--ghost" }
    ],
    "trust": [
      "Certified QuickBooks ProAdvisor team",
      "Independent · not Intuit",
      "Free to read · dated &amp; reviewed"
    ]
  },
  "ctaBand": {
    "eyebrow": "Start with your real numbers",
    "heading": "Guides are a start — your file is the answer.",
    "lede": "Get a free QuickBooks file review or book a discovery call. We'll look at your actual books, show you exactly where setup or cleanup will help, and point you to the guides that fit your situation. No pitch. Independent firm — not Intuit.",
    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Book the discovery call", "href": "/contact/?intent=accounting", "class": "btn--ghost" }
    ]
  },
  "sec": {
    "summaryId": "guides-hub-summary",
    "summaryTag": "In short",
    "summaryH": "All 13 guides, in plain English.",
    "faqTag": "FAQ",
    "faqH": "About these guides."
  }
}
---

{# ── GUIDE GRID · grouped by topic, 13 guide pages (dc-card hub-cards). (H2 per group.) ── #}
{%- for group in guideGroups %}
<section class="sec reveal{% if loop.index is even %} hub-rt--alt{% endif %}" id="guides-hub-{{ group.id }}"{% if loop.index is even %} style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);"{% endif %}>
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ group.eyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:26ch;margin-bottom:{% if group.lede %}10{% else %}28{% endif %}px;">{{ group.heading | safe }}</h2>
    {%- if group.lede %}<p class="lede" style="margin:0 0 30px;max-width:66ch;">{{ group.lede | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for g in group.guides %}
      <a class="dc-card hub-card" href="{{ g.href }}"><h3>{{ g.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;color:var(--color-ink-mute);">{{ g.body | safe }}</p><span class="hub-card__go">{{ g.cta | safe }}</span></a>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endfor %}

{# ── CROSS-LINKS (read). ── #}
<section class="sec reveal" id="guides-hub-related">
  <div class="ct read">
    <p class="prose">{{ relatedNote | safe }}</p>
  </div>
</section>
