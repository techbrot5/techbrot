    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Book the discovery call", "href": "/contact/?intent=accounting", "class": "btn--ghost" }
    ],
    "trust": [
      "Certified QuickBooks ProAdvisor team",
      "Independent · not Intuit",
      "Free to use · no email wall"
    ]
  },
  "inBrief": {
    "text": "Practical, free checklists from <strong>Certified ProAdvisors</strong> — the exact steps for monthly close, year-end, setup, and compliance. <strong>Free to use; no email wall.</strong> There are <strong>six checklists</strong> below, grouped by what you're getting done: routine bookkeeping, setup &amp; launch, and compliance. They're built from the same steps we run on real client files. <strong>TechBrot</strong> is an independent Certified QuickBooks ProAdvisor firm — <strong>not Intuit</strong>. Want a hand running them? A <a href=\"/quickbooks/file-review/?intent=file-review\">free file review</a> shows where they apply to your own books.",
    "source": "Reference maintained by the Certified QuickBooks ProAdvisor team at TechBrot Inc., an independent firm — not Intuit, and not Intuit's official software support. Checklists reflect current bookkeeping, tax, and QuickBooks practice as of the review date; rules change, so confirm filing deadlines and thresholds for your situation. Not affiliated with Intuit Inc."
  },
  "ctaBand": {
    "eyebrow": "Rather we ran them?",
    "heading": "We'll run these checklists on your real file.",
    "lede": "Get a free QuickBooks file review or book a discovery call. We'll look at how your books and your QBO file are set up against the steps in these checklists, and show you exactly where attention is needed. No pitch. Independent firm — not Intuit.",
    "actions": [
