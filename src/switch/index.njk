---

{# ── SWITCH GRID · routes the 4 switch pages (dc-card hub-card r-3). (H2: Pick the page that matches your move.) ── #}
{%- for group in switchGroups %}
<section class="sec reveal{% if loop.index is even %} hub-rt--alt{% endif %}" id="switch-hub-{{ group.id }}"{% if loop.index is even %} style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);"{% endif %}>
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ group.eyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:28ch;margin-bottom:{% if group.lede %}10{% else %}28{% endif %}px;">{{ group.heading | safe }}</h2>
    {%- if group.lede %}<p class="lede" style="margin:0 0 30px;max-width:66ch;">{{ group.lede | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for f in group.options %}
      <a class="dc-card hub-card" href="{{ f.href }}"><h3>{{ f.title | safe }}</h3><p class="prose" style="font-size:15px;margin:6px 0 0;">{{ f.body | safe }}</p><span class="hub-card__go">{{ f.cta | safe }} <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endfor %}

{# ── HOW IT WORKS · the four-step switch (process-grid). (H2: Export → migrate → cleanup → ongoing.) ── #}
<section class="sec reveal" id="switch-hub-how" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">The switch, step by step</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Export &rarr; migrate &rarr; cleanup &rarr; ongoing.</h2>
    <p class="lede" style="margin:0 0 30px;max-width:66ch;">Every switch follows the same four steps. The details change by who you're leaving; the shape doesn't.</p>
    <div class="process-grid">
      {%- for step in steps %}
      <div class="process-step">
        <span class="process-step__n">0{{ loop.index }}</span>
        <h3>{{ step.title | safe }}</h3>
        <p>{{ step.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── CROSS-LINKS · prose (white, read). (no heading — additive cross-link aid) ── #}
<section class="sec reveal" id="switch-hub-related">
  <div class="ct read">
    <div class="prose">
      <p>{{ relatedNote | safe }}</p>
    </div>
  </div>
</section>
