  },
  "summarySource": "Reference maintained by the Certified QuickBooks ProAdvisor team at TechBrot Inc., an independent firm — not Intuit, and not affiliated with Bench, Employer.com, Pilot, QuickBooks Live, or any other bookkeeping provider. QuickBooks and Intuit are registered trademarks of Intuit Inc. Switch timelines and scope depend on the state of your books at handover and are confirmed after the free file review.",
  "ctaBand": {
    "eyebrow": "Start with your real file",
    "heading": "We'll tell you honestly what switching takes.",
    "lede": "Get a free QuickBooks file review or book a discovery call. We'll look at the state of your books, where the gaps are, and exactly how we'd migrate you into your own QuickBooks file — with a fixed-fee scope before any work starts. No pitch, no lock-in. Independent firm — not Intuit.",
    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Book the discovery call", "href": "/contact/?intent=accounting", "class": "btn--ghost" }
    ]
  },
  "sec": {
    "summaryId": "switch-hub-summary",
