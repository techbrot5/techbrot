---

{# ── SUMMARY ── #}
<section class="section section--compact" id="switch-hub-summary-sec">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In short</p>
      <h2 class="section__heading">How switching to TechBrot actually works.</h2>
    </header>
    <p class="prose" id="switch-hub-summary">{{ summary | safe }}</p>
  </div>
</section>

{# ── SWITCH GRID · routes the 4 switch pages (buyer-cards) ── #}
{%- for group in switchGroups %}
<section class="section{% if loop.index is even %} section--alt{% endif %}" id="switch-hub-{{ group.id }}">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">{{ group.eyebrow | safe }}</p>
      <h2 class="section__heading">{{ group.heading | safe }}</h2>
      {%- if group.lede %}<p class="section__lede">{{ group.lede | safe }}</p>{%- endif %}
    </header>
    <div class="grid-3">
      {%- for f in group.options %}
      <article class="buyer-card">
        <h3 class="buyer-card__heading">{{ f.title | safe }}</h3>
        <p class="buyer-card__body">{{ f.body | safe }}</p>
        <a class="buyer-card__cta" href="{{ f.href }}">{{ f.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endfor %}

{# ── HOW IT WORKS · the four-step switch ── #}
<section class="section section--alt" id="switch-hub-how">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">The switch, step by step</p>
      <h2 class="section__heading">Export → migrate → cleanup → ongoing.</h2>
      <p class="section__lede">Every switch follows the same four steps. The details change by who you're leaving; the shape doesn't.</p>
    </header>
    <div class="grid-3">
      {%- for step in steps %}
      <article class="buyer-card">
        <h3 class="buyer-card__heading">{{ step.title | safe }}</h3>
        <p class="buyer-card__body">{{ step.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── CROSS-LINKS ── #}
<section class="section section--compact" id="switch-hub-related">
  <div class="container container--narrow">
    <p class="prose">{{ relatedNote | safe }}</p>
  </div>
</section>

{# ── FAQ ── #}
<section class="section section--alt" id="switch-hub-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">Switching questions, answered honestly.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="switch-hub-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="switch-hub-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
