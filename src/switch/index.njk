  "hero": {
    "eyebrow": "Switch to TechBrot",
    "heading": "Already decided to leave? Here's exactly how a switch works.",
    "subheading": "Already decided to leave your current provider? Here's exactly how a switch to TechBrot works — and how we rescue your data, migrate it into your own QuickBooks file, and pick up the books with a named Certified ProAdvisor. We're an independent firm — not Intuit, and not affiliated with whoever you're leaving. This hub routes to a plain-English page for each switch, and explains how the move works in general: export your data, migrate it into QuickBooks, clean up the gaps, then keep the books accurate every month.",
    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Book the discovery call", "href": "/contact/?intent=accounting", "class": "btn--ghost" }
    ],
    "trust": [
      "Named Certified QuickBooks ProAdvisor",
