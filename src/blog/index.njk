---

<section class="section" id="blog-hub-latest">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Latest</p>
      <h2 class="section__heading">Recent articles.</h2>
    </header>
    {%- set posts = collections.post %}
    {%- if posts and posts.length %}
    <div class="grid-3">
      {%- for post in posts | reverse %}
      <article class="review-card">
        <p class="team-card__role">{{ post.data.categoryLabel }} &middot; {{ post.data.dateDisplay }}</p>
        <h3>{{ post.data.headline | safe }}</h3>
        <p class="review-card__fact">{{ post.data.deck | safe }}</p>
        <a class="review-card__link" href="{{ post.url }}">Read it <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a>
      </article>
      {%- endfor %}
    </div>
    {%- endif %}
  </div>
</section>

<section class="section section--alt" id="blog-hub-topics">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Browse by topic</p>
      <h2 class="section__heading">All categories.</h2>
    </header>
    <div class="grid-3">
      {%- for c in blogCategories %}
      <article class="review-card">
        <h3>{{ c.label | safe }}</h3>
        <p class="review-card__fact">{{ c.blurb | safe }}</p>
        <a class="review-card__link" href="/blog/category/{{ c.slug }}/">Browse {{ c.label | safe }} <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>
