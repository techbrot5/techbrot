---
pagination:
  data: blogCategories
  size: 1
  alias: cat
  addAllPagesToCollections: true
layout: layouts/t-hub.njk
bodyClass: page--mofu
eleventyComputed:
  permalink: "/blog/category/{{ cat.slug }}/"
  slug: "blogcat-{{ cat.slug }}"
  title: "{{ cat.label | safe }} Articles · TechBrot Blog"
  description: "{{ cat.blurb | safe }}"
  heroFigure: false
  breadcrumb:
    - name: "Home"
      href: "/"
    - name: "Blog"
      href: "/blog/"
    - name: "{{ cat.label | safe }}"
  hero:
    eyebrow: "Blog category"
    heading: "{{ cat.label | safe }}"
    subheading: "{{ cat.blurb | safe }}"
    actions:
      - label: "Book the discovery call"
        href: "/contact/?intent=accounting"
        class: "btn--primary"
      - label: "Explore Services"
        href: "/accounting/services/"
        class: "btn--ghost"
  ctaBand:
    eyebrow: "From reading to doing"
    heading: "Want this handled on your own books?"
    lede: "Articles explain the what and the why. A free 30-minute discovery call with a Certified ProAdvisor turns it into action on your actual file — a written fixed-fee scope within 3 business days, no obligation."
    actions:
      - label: "Book the discovery call"
        href: "/contact/?intent=accounting"
        class: "btn--primary"
      - label: "Speak to a ProAdvisor"
        tel: true
        class: "btn--ghost"
  pageGraph:
    "@context": "https://schema.org"
    "@graph":
      - "@type": "CollectionPage"
        "@id": "https://techbrot.com/blog/category/{{ cat.slug }}/#webpage"
        url: "https://techbrot.com/blog/category/{{ cat.slug }}/"
        name: "{{ cat.label | safe }} Articles"
        description: "{{ cat.blurb | safe }}"
        isPartOf:
          "@id": "https://techbrot.com/#website"
        about:
          "@id": "https://techbrot.com/#organization"
        publisher:
          "@id": "https://techbrot.com/#organization"
        inLanguage: "en-US"
      - "@type": "BreadcrumbList"
        "@id": "https://techbrot.com/blog/category/{{ cat.slug }}/#breadcrumb"
        itemListElement:
          - "@type": "ListItem"
            position: 1
            name: "Home"
            item: "https://techbrot.com/"
          - "@type": "ListItem"
            position: 2
            name: "Blog"
            item: "https://techbrot.com/blog/"
          - "@type": "ListItem"
            position: 3
            name: "{{ cat.label | safe }}"
            item: "https://techbrot.com/blog/category/{{ cat.slug }}/"
---

{# ── ARTICLES IN THIS CATEGORY · collections[cat.slug], newest first, as dc-card hub-cards. (H2.) ── #}
<section class="sec reveal" id="{{ slug }}-list">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Articles</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:28ch;margin-bottom:28px;">{{ cat.label | safe }} articles.</h2>
    {%- set posts = collections[cat.slug] %}
    {%- if posts and posts.length %}
    <div class="r-3">
      {%- for post in posts | reverse %}
      <a class="dc-card hub-card" href="{{ post.url }}"><span class="mono" style="font-size:12.5px;color:var(--color-ink-faint);">{{ post.data.categoryLabel }} &middot; {{ post.data.dateDisplay }}</span><h3>{{ post.data.headline | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;color:var(--color-ink-mute);">{{ post.data.deck | safe }}</p><span class="hub-card__go">Read it <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
      {%- endfor %}
    </div>
    {%- else %}
    <p class="lede" style="margin:0;max-width:66ch;">New {{ cat.label | safe }} articles are on the way. In the meantime, <a href="/blog/">browse the full blog</a> or <a href="/contact/?intent=accounting">book a free discovery call</a> with a Certified ProAdvisor.</p>
    {%- endif %}
  </div>
</section>

{# ── BROWSE OTHER TOPICS · remaining categories as dc-card hub-cards. sand alt. (H2.) ── #}
<section class="sec reveal hub-rt--alt" id="{{ slug }}-browse" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Browse by topic</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:28ch;margin-bottom:10px;">Other categories.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">We write these to actually help &mdash; plain English, real substance, and an honest answer even when it&rsquo;s that you don&rsquo;t need us.</p>
    <div class="r-3">
      {%- for c in blogCategories %}
      {%- if c.slug != cat.slug %}
      <a class="dc-card hub-card" href="/blog/category/{{ c.slug }}/"><h3>{{ c.label | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;color:var(--color-ink-mute);">{{ c.blurb | safe }}</p><span class="hub-card__go">Browse {{ c.label | safe }} <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
      {%- endif %}
      {%- endfor %}
    </div>
  </div>
</section>
