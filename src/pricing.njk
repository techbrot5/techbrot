---json
{
  "layout": "layouts/t-bofu.njk",
  "permalink": "/pricing/",
  "slug": "pricing",
  "chrome": "full",
  "callBar": false,
  "tierClass": "section--tier-bofu",
  "bodyClass": "page--bofu",
  "title": "Fixed-Fee Bookkeeping & QuickBooks Pricing · TechBrot",
  "description": "Real fixed-fee ranges for bookkeeping, QuickBooks cleanup, setup, migration, payroll & CFO. Written scope, no hourly billing. Call (877) 751-5575.",
  "breadcrumb": [
    { "name": "Home", "href": "/" },
    { "name": "Pricing" }
  ],
  "hero": {
    "eyebrow": "Pricing · Fixed-fee, written scope",
    "heading": "Fixed-fee pricing. Written scope before any work.",
    "subheading": "Most firms hide pricing and bill by the hour. TechBrot does the opposite: every engagement is a fixed fee against a written scope, agreed before work begins. Here are the real ranges across every service &mdash; your exact fixed fee is quoted in writing within 3 business days of a free discovery call.",
    "actions": [
      { "label": "Book the discovery call", "href": "/contact/?intent=pricing", "class": "btn--primary" },
      { "label": "Explore Services", "href": "/accounting/services/", "class": "btn--ghost" }
    ]
  },
  "inBrief": {
    "text": "<strong>Always:</strong> fixed-fee &middot; written scope before work begins &middot; no hourly billing &middot; free 30-minute discovery call &middot; written quote within 3 business days &middot; no long-term lock-in on recurring engagements.",
    "source": "TechBrot Inc. &middot; independent Certified QuickBooks ProAdvisor firm &mdash; not affiliated with Intuit Inc."
  },
  "ctaBand": {
    "eyebrow": "Start here",
    "heading": "Get your exact fixed fee.",
    "lede": "A free 30-minute discovery call, then a written fixed-fee scope within 3 business days &mdash; the exact number, in writing, before you commit to anything. No hourly billing, no obligation.",
    "actions": [
      { "label": "Book the discovery call", "href": "/contact/?intent=pricing", "class": "btn--primary" },
      { "label": "Speak to a ProAdvisor", "href": "tel:{{ site.phone.e164 }}", "class": "btn--ghost" }
    ]
  }
}
---

<section class="section section--compact section--tier-bofu" id="pricing-tldr">
  <div class="container">
    <div class="tldr">
      <p class="tldr__label">In one paragraph</p>
      <h2 class="tldr__heading">How TechBrot pricing works.</h2>
      <p class="tldr__body" id="pricing-tldr-body">Every TechBrot engagement is fixed-fee with a written scope agreed before any work begins &mdash; no hourly billing. Real ranges: <strong>monthly bookkeeping $400&ndash;$2,500+/month</strong>, cleanup $1,500&ndash;$15,000+, catch-up $2,000&ndash;$20,000+, QuickBooks setup $750&ndash;$5,000+, migration $2,500&ndash;$10,000+, payroll $150&ndash;$800+/month, sales tax compliance $250&ndash;$1,500+/month, and fractional CFO $3,000&ndash;$8,000+/month (by application). Where you land depends on real factors &mdash; transaction volume, number of accounts and entities, history depth, file complexity. The 30-minute discovery call is free; your exact fixed fee is delivered in writing within 3 business days. No long-term lock-in on recurring engagements. Tax filing isn&rsquo;t included (your CPA handles that), but a year-end CPA handoff is included free.</p>
    </div>
  </div>
</section>

<section class="section section--compact" id="pricing-path">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">From question to fixed fee</p>
      <h2 class="section__heading">Four steps to a number in writing.</h2>
    </header>
    <div class="flow" role="img" aria-label="The path to a fixed fee: a free 30-minute discovery call, then a written fixed-fee scope within 3 business days, the exact fixed fee in writing with no hourly billing, then work begins with a named operator.">
      <div class="flow__step flow__step--accent"><span class="flow__label">Free discovery call</span><span class="flow__sub">30 min &middot; no obligation</span></div>
      <span class="flow__arrow" aria-hidden="true"><svg width="22" height="10" viewBox="0 0 22 10"><line x1="0" y1="5" x2="16" y2="5" stroke="currentColor" stroke-width="1.5"></line><path d="M14 1 L20 5 L14 9" fill="none" stroke="currentColor" stroke-width="1.5"></path></svg></span>
      <div class="flow__step"><span class="flow__label">Written scope</span><span class="flow__sub">within 3 business days</span></div>
      <span class="flow__arrow" aria-hidden="true"><svg width="22" height="10" viewBox="0 0 22 10"><line x1="0" y1="5" x2="16" y2="5" stroke="currentColor" stroke-width="1.5"></line><path d="M14 1 L20 5 L14 9" fill="none" stroke="currentColor" stroke-width="1.5"></path></svg></span>
      <div class="flow__step"><span class="flow__label">Fixed fee, in writing</span><span class="flow__sub">no hourly billing</span></div>
      <span class="flow__arrow" aria-hidden="true"><svg width="22" height="10" viewBox="0 0 22 10"><line x1="0" y1="5" x2="16" y2="5" stroke="currentColor" stroke-width="1.5"></line><path d="M14 1 L20 5 L14 9" fill="none" stroke="currentColor" stroke-width="1.5"></path></svg></span>
      <div class="flow__step"><span class="flow__label">Work begins</span><span class="flow__sub">named operator</span></div>
    </div>
  </div>
</section>

<section class="section" id="pricing-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">TechBrot pricing, in five questions.</h2>
    </header>
    <div class="ai-summary ai-summary--ruled">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <h3 class="ai-summary__question">{{ item.q | safe }}</h3>
        <div class="ai-summary__answer"><p>{{ item.a | safe }}</p></div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section section--alt" id="pricing-shapes">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Engagement shapes</p>
      <h2 class="section__heading">Every engagement fits one of three shapes.</h2>
      <p class="section__lede">However the work is priced, it takes one of three forms &mdash; so you know what you&rsquo;re committing to before the discovery call.</p>
    </header>
    <div class="grid-3">
      {%- for s in shapes %}
      <article class="review-card">
        <p class="team-card__role">{{ s.label }}</p>
        <h3>{{ s.name }}</h3>
        <p class="review-card__fact">{{ s.body | safe }}</p>
        <p class="review-card__fact"><strong>For:</strong> {{ s.forList | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section" id="pricing-table">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">The full table</p>
      <h2 class="section__heading">Every service, every range.</h2>
      <p class="section__lede">Canonical fixed-fee ranges, identical everywhere on the site. All engagements: fixed fee, written scope before work begins, no hourly billing.</p>
    </header>
    <div class="vs-scroll">
      <table class="vs-table">
        <caption class="sr-only">TechBrot fixed-fee pricing across all engagement types.</caption>
        <thead>
          <tr>
            <th scope="col">Service</th>
            <th scope="col">Engagement type</th>
            <th scope="col" class="vs-table__us">Fee range</th>
            <th scope="col">Cadence</th>
          </tr>
        </thead>
        <tbody>
          {%- for row in pricing %}
          <tr>
            <td><a href="{{ row.href }}?intent={{ row.intent }}">{{ row.service }}</a></td>
            <td class="vs-table__concede">{{ row.type | safe }}</td>
            <td class="vs-table__us"><strong>{{ row.range | safe }}</strong>{% if row.unit %}<span class="vs-table__concede">{{ row.unit }}</span>{% endif %}</td>
            <td class="vs-table__concede">{{ row.cadence | safe }}</td>
          </tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
    <p class="in-brief__source stack-8">Sales tax compliance also carries a one-time nexus review of $500&ndash;$3,000. Your specific quote follows the free discovery call within 3 business days.</p>
  </div>
</section>

<section class="section section--alt" id="pricing-why">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Why fixed-fee</p>
      <h2 class="section__heading">Why we don&rsquo;t bill by the hour.</h2>
    </header>
    <div class="legal-doc__body">
      <p>Hourly billing has a structural problem: it penalizes you for the provider&rsquo;s inefficiency. The slower they work, the more you pay. The invoice is unpredictable, and you can&rsquo;t budget around it. Worse, it makes you hesitate to call your own accountant &mdash; because every question starts a meter.</p>
      <p>TechBrot prices every engagement as a fixed fee against a written scope. You know the total cost before any work begins. Call as often as you need within the engagement &mdash; no meter. If the work genuinely expands beyond the agreed scope, the fee is re-quoted and re-approved in writing before anything proceeds. <strong>You are never surprised by an invoice.</strong></p>
      <p>This only works because the work is delivered by Certified ProAdvisors efficient enough to price confidently. The fixed fee is a statement of competence: we know how long good work takes, so we can quote it.</p>
    </div>
  </div>
</section>

<section class="section" id="pricing-includes">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Every engagement</p>
      <h2 class="section__heading">Every fixed fee includes these.</h2>
      <p class="section__lede">Six things in every engagement, whatever the service or the number.</p>
    </header>
    <div class="grid-3">
      {%- for inc in includes %}
      <article class="review-card">
        <h3>{{ inc.name }}</h3>
        <p class="review-card__fact">{{ inc.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section section--alt" id="pricing-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Before you call</p>
      <h2 class="section__heading">Questions about cost.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="pricing-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="pricing-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section" id="pricing-standards">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Pricing standards</p>
      <h2 class="section__heading">Pricing maintained by the TechBrot platform team.</h2>
    </header>
    <div class="legal-doc__body">
      <p>Pricing on this page is maintained by the <strong>Certified QuickBooks ProAdvisor team</strong> at TechBrot Inc., a Delaware-incorporated independent ProAdvisor firm. Ranges reflect current operational pricing and are reviewed quarterly. Specific fixed fees are quoted per engagement after a free discovery call. Where pricing changes, this page and the individual service pages are updated together to stay consistent.</p>
    </div>
    <div class="trust-row stack-8">
      <div class="trust-row__item"><p class="trust-row__value">Entity</p><p class="trust-row__label">TechBrot Inc. · Delaware C-Corp · independent ProAdvisor firm</p></div>
      <div class="trust-row__divider"></div>
      <div class="trust-row__item"><p class="trust-row__value">Model</p><p class="trust-row__label">Fixed-fee · written scope before work · no hourly billing</p></div>
      <div class="trust-row__divider"></div>
      <div class="trust-row__item"><p class="trust-row__value">Certifications</p><p class="trust-row__label">Active Intuit ProAdvisor — QBO L2, Desktop, Enterprise, Payroll, Bookkeeping</p></div>
      <div class="trust-row__divider"></div>
      <div class="trust-row__item"><p class="trust-row__value">Independence</p><p class="trust-row__label">Not affiliated with Intuit Inc.</p></div>
    </div>
    <p class="in-brief__source stack-8">Pricing last reviewed: May 2026.</p>
  </div>
</section>

<section class="section section--alt" id="pricing-next">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Next steps</p>
      <h2 class="section__heading">Where to go next.</h2>
    </header>
    <div class="grid-2">
      {%- for card in nextCards %}
      <article class="review-card">
        <h3>{{ card.name }}</h3>
        <p class="review-card__fact">{{ card.body | safe }}</p>
        <a class="review-card__link" href="{{ card.href }}">{{ card.cta }} &rarr;</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>
