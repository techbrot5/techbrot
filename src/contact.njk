<section class="section section--compact section--tier-bofu" id="contact-tldr">
  <div class="container">
    <div class="tldr">
      <p class="tldr__label">Our response promise</p>
      <h2 class="tldr__heading">How to reach us &amp; what to expect</h2>
      <p class="tldr__body" id="contact-promise">Every discovery-brief submission gets a response from a Certified ProAdvisor within 1 business day. Discovery calls are scheduled within 3&ndash;5 business days, and written fixed-fee scopes are delivered within 3 business days of the call. Prefer to talk first? Call <a href="tel:+18777515575" data-tb-event="phone_click">(877) 751-5575</a>, Mon&ndash;Fri 9&nbsp;AM&ndash;6&nbsp;PM ET, or email <a href="mailto:{{ site.emails.hello }}">{{ site.emails.hello }}</a> &mdash; replied within 1 business day. If you&rsquo;d rather have the actual file looked at before anyone talks, start with the <a href="/quickbooks/file-review/?intent=file-review">free QuickBooks file review</a>. Canonical pricing for every engagement is published on the <a href="/pricing/">pricing page</a>.</p>
    </div>
  </div>
</section>

<section class="section" id="contact-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">Five questions, answered plainly.</h2>
    </header>
    <div class="ai-summary ai-summary--ruled">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <h3 class="ai-summary__question">{{ item.q | safe }}</h3>
        <div class="ai-summary__answer"><p>{{ item.a | safe }}</p></div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section section--alt" id="contact-expect">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What to expect</p>
      <h2 class="section__heading">From discovery brief to written scope.</h2>
    </header>
    <ol class="process-diagram">
      <li class="process-step">
        <p class="process-step__number">01</p>
        <h3 class="process-step__heading">Confirmation</h3>
        <p class="process-step__body">Confirmation email within 1 business day with discovery call slots.</p>
      </li>
      <li class="process-step">
        <p class="process-step__number">02</p>
        <h3 class="process-step__heading">Discovery call</h3>
        <p class="process-step__body">30-minute discovery call with a Certified ProAdvisor &mdash; no pitch, just review.</p>
      </li>
      <li class="process-step">
        <p class="process-step__number">03</p>
        <h3 class="process-step__heading">Written scope</h3>
        <p class="process-step__body">Written fixed-fee scope within 3 business days &mdash; or an honest &ldquo;not the right fit.&rdquo;</p>
      </li>
    </ol>
  </div>
</section>

<section class="section" id="contact-trust">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Before you decide</p>
      <h2 class="section__heading" id="contact-trust-heading">Why owners choose TechBrot</h2>
    </header>
    <ul class="checks-list">
      {%- for item in whyBullets %}
      <li>{{ item | safe }}</li>
      {%- endfor %}
    </ul>
    <div class="grid-2 stack-8">
      <article class="review-card">
        <h3>Direct contact</h3>
        <p class="review-card__fact"><strong>Phone:</strong> <a href="tel:+18777515575" data-tb-event="phone_click">+1 (877) 751-5575</a> &mdash; Mon&ndash;Fri, 9&nbsp;AM&ndash;6&nbsp;PM ET</p>
        <p class="review-card__fact"><strong>Email:</strong> <a href="mailto:{{ site.emails.hello }}">{{ site.emails.hello }}</a> &mdash; replied within 1 business day</p>
      </article>
      <article class="review-card">
        <h3>Headquartered</h3>
        <p class="review-card__fact">{{ site.legalName }}<br>{{ site.address.streetAddress }}<br>{{ site.address.addressLocality }}, {{ site.address.addressRegion }} {{ site.address.postalCode }}<br>United States</p>
      </article>
    </div>
  </div>
</section>

<section class="section section--alt" id="contact-main">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow" data-intent-headline>Discovery brief</p>
      <h2 class="section__heading" id="contact-main-heading">Send us your situation.</h2>
      <p class="section__lede" data-intent-lede>Six minutes. Six fields. We&rsquo;ll respond within one business day with discovery call slots and a sense of where we&rsquo;d start.</p>
    </header>
    <div class="contact-form-wrap">
      {# NEW-SKIN form shell (handoff pages render). The render is a SHELL:
         every locked contract detail is OURS — services[] names, full
         option sets + values, hidden meta, trackers, honeypot. FENCED. #}
      {%- set intakePrefix = "contact" %}
      {%- set intakeFormId = "contact-discovery-form" %}
      {%- set intakeIntent = "" %}
      {%- set intakeSourceType = "" %}
      {%- set intakeFunnelStage = "" %}
      {%- set intakeLegend = "What we should discuss" %}
      {%- set intakeNote = "Pick what fits. Pick more than one if more than one fits." %}
      {%- set intakeConsent = "I agree to be contacted by TechBrot regarding this inquiry." %}
      {%- set intakeSubmit = "Send the Discovery Brief" %}
      {%- set intakeReassurance = "Response within 1 business day. No marketing list. No sales follow-up sequence." %}
      {% include "partials/intake-form.njk" %}
    </div>
  </div>
</section>

<section class="section" id="contact-alt">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Other ways to connect</p>
      <h2 class="section__heading" id="contact-alt-heading">If the form isn&rsquo;t the right path.</h2>
    </header>
    <div class="grid-2">
      <article class="review-card">
        <h3>Schedule directly</h3>
