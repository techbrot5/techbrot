---

{# ── SHORT VERSION · real H2 carrying the summary prose (right after the in-brief). (H2: The short version.) ── #}
<section class="section section--compact" id="ny-svc-smallbiz-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In one paragraph</p>
      <h2 class="section__heading">The short version.</h2>
    </header>
    <div class="stack-8">
      {%- for p in summary %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. (H2: New York small business accounting, in five questions.) ── #}
<section class="section" id="ny-svc-smallbiz-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">New York small business accounting, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="ny-svc-smallbiz-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── FINANCIAL BACKBONE · the five services (grid-3 buyer-cards). (H2 + 5 H3s) ── #}
<section class="section section--alt" id="ny-svc-smallbiz-handle">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What we handle for New York small businesses</p>
      <h2 class="section__heading">The financial backbone, built and maintained.</h2>
      <p class="section__lede">Every engagement is scoped to your business and entity, delivered in your own QuickBooks file by a named Certified ProAdvisor.</p>
    </header>
    <div class="grid-3">
      {%- for s in handle %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ s.num | safe }}</p>
        <h3 class="buyer-card__heading">{{ s.title | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
        <a class="buyer-card__cta" href="{{ s.href }}">{{ s.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── SCOPE SPLIT · what we do vs. what your CPA does (grid-2 buyer-cards). (H2 + 2 H3s: TechBrot / Your CPA) ── #}
<section class="section" id="ny-svc-smallbiz-scope">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Honest scope</p>
      <h2 class="section__heading">What we do &mdash; and what your CPA does.</h2>
      <p class="section__lede">We&rsquo;re bookkeepers and Certified QuickBooks ProAdvisors, not a CPA or tax-prep firm. The split is clean &mdash; and we coordinate directly across it.</p>
    </header>
    <div class="grid-2">
      {%- for col in scope %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ col.role | safe }}</p>
        <h3 class="buyer-card__heading">{{ col.title | safe }}</h3>
        <ul class="checks-list">
          {%- for it in col.items %}<li>{{ it | safe }}</li>{%- endfor %}
        </ul>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── ADVISORY · standing brand line carried as section prose. (H2: Automation handles the data entry. We handle the judgment.) ── #}
<section class="section section--alt" id="ny-svc-smallbiz-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Beyond the books</p>
      <h2 class="section__heading">Automation handles the data entry. We handle the judgment.</h2>
    </header>
    <div class="stack-8">
      {%- for p in advisoryBody %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="/contact/?intent=new-york&amp;state=new-york&amp;source_type=state-money&amp;funnel_stage=MOFU">Book the discovery call</a>
    </div>
  </div>
</section>

{# ── FAQ · 8 verbatim contract Q/A; visible faq__list = FAQPage schema (same array). (H2: New York small business accounting questions.) ── #}
<section class="section" id="ny-svc-smallbiz-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">New York small business accounting questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="ny-svc-smallbiz-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="ny-svc-smallbiz-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name (byline-block + meta-reviewed). (H2: Reviewed by the TechBrot Certified ProAdvisor team.) ── #}
<section class="section section--alt" id="ny-svc-smallbiz-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    </header>
    <div class="byline-block">
      <div class="byline-block__mark" aria-hidden="true"></div>
      <div>
        <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="byline-block__review">TechBrot Inc. &middot; Independent Certified QuickBooks ProAdvisor firm</p>
      </div>
    </div>
    <div class="prose">
      <p>This page reflects how TechBrot handles New York small-business engagements. It is maintained by the Certified QuickBooks ProAdvisor team at <strong>TechBrot Inc.</strong>, a Delaware-incorporated independent ProAdvisor firm, and reviewed for accuracy on the bookkeeping scope, entity-aware chart of accounts, and New York references (the <a href="https://www.nyc.gov/site/finance/business/business-unincorporated-business-tax-ubt.page" rel="noopener nofollow">NYC Unincorporated Business Tax</a> and NYC&rsquo;s combined 8.875% sales-tax rate). TechBrot keeps the books and coordinates with your CPA, who files; we do not file New York or federal returns and do not represent clients before the tax authorities.</p>
    </div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-07</span><span>Updated: 2026-06-07</span><span>Reviewed: 2026-06-07 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>
