{# ── CREDENTIALS · frozen H2 now a REAL heading (was sr-only in baseline — T3 no demotion). (H2: Certified QuickBooks ProAdvisor credentials) ── #}
<section class="section section--compact" id="ny-svc-qbcleanup-credentials">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Certified by Intuit</p>
      <h2 class="section__heading">Certified QuickBooks ProAdvisor credentials</h2>
    </header>
    <p class="prose">{{ credentials.statement | safe }}</p>
    <ul class="checks-list">
      {%- for c in credentials.badges %}<li>{{ c | safe }}</li>{%- endfor %}
    </ul>
  </div>
</section>

{# ── SUMMARY · real H2 carrying the cleanup summary prose. (H2: What New York QuickBooks cleanup actually is.) ── #}
<section class="section" id="ny-svc-qbcleanup-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In one paragraph</p>
      <h2 class="section__heading">What New York QuickBooks cleanup actually is.</h2>
    </header>
    <div class="stack-8">
      {%- for p in summary %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
