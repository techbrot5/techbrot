  </div>
</section>

{#- ENGAGEMENT SHAPES · three pricing models → r-3 dc-card. 3 frozen H3s verbatim. (H2 + 3 H3s) -#}
<section class="sec reveal" id="ny-svc-pricing-shapes">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Three engagement shapes</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Every New York engagement fits one of three shapes.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:68ch;">Pricing structure follows the shape of the work. All three run to the same standard: fixed fee, written scope, named ProAdvisor.</p>
    <div class="r-3">
      {%- for s in shapes %}
      <div class="dc-card"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ s.tag | safe }}</span><h3>{{ s.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ s.body | safe }}</p><p class="prose" style="font-size:14.5px;margin:8px 0 0;">{{ s.examples | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- FULL PRICING · every NY service + range → vs-table→.cmp. Canonical NY figures EXACT. (H2: Every New York service, every range.) -#}
<section class="sec reveal hub-rt--alt" id="ny-svc-pricing-ranges" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">All pricing</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Every New York service, every range.</h2>
    <p class="lede" style="margin:0 0 24px;max-width:70ch;">The complete pricing landscape for New York businesses. Every fee is fixed and scoped in writing before work begins.</p>
    <table class="cmp">
      <caption class="sr-only">TechBrot fixed-fee pricing across every New York service.</caption>
      <thead><tr><th scope="col">Service</th><th scope="col">Engagement type</th><th scope="col">Fee range</th><th scope="col">Cadence</th></tr></thead>
      <tbody>
        {%- for r in ranges %}
        <tr>
          <th scope="row" data-col="Service">{% if r.href %}<a href="{{ r.href }}">{{ r.service | safe }}</a>{% else %}{{ r.service | safe }}{% endif %}</th>
          <td data-col="Engagement type" style="color:var(--color-ink-mute);">{{ r.type | safe }}</td>
          <td class="num us" data-col="Fee range"><strong>{{ r.fee | safe }}</strong></td>
          <td data-col="Cadence" style="color:var(--color-ink-mute);">{{ r.cadence | safe }}</td>
        </tr>
        {%- endfor %}
      </tbody>
    </table>
    <p class="prose" style="font-size:13.5px;color:var(--color-ink-mute);margin-top:14px;">{{ rangesNote | safe }}</p>
  </div>
</section>

