{# ── TLDR · how NY pricing works (real H2 carrying the one-paragraph prose). (H2: How TechBrot New York pricing works.) ── #}
<section class="section section--compact" id="ny-svc-pricing-tldr">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In one paragraph</p>
      <h2 class="section__heading">How TechBrot New York pricing works.</h2>
    </header>
    <div class="stack-8">
      {%- for p in tldr %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. (H2: New York pricing, in five questions.) ── #}
<section class="section section--alt" id="ny-svc-pricing-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">New York pricing, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="ny-svc-pricing-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── ENGAGEMENT SHAPES · three pricing models (grid-3 buyer-cards). 3 frozen H3s verbatim. (H2 + 3 H3s) ── #}
<section class="section" id="ny-svc-pricing-shapes">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Three engagement shapes</p>
      <h2 class="section__heading">Every New York engagement fits one of three shapes.</h2>
      <p class="section__lede">Pricing structure follows the shape of the work. All three run to the same standard: fixed fee, written scope, named ProAdvisor.</p>
    </header>
    <div class="grid-3">
      {%- for s in shapes %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ s.tag | safe }}</p>
        <h3 class="buyer-card__heading">{{ s.title | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
        <p class="buyer-card__body">{{ s.examples | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── FULL PRICING · every NY service + range (grid-3 buyer-cards). Canonical figures only — range in buyer-card__body <strong>. (H2: Every New York service, every range.) ── #}
<section class="section section--alt" id="ny-svc-pricing-ranges">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">All pricing</p>
      <h2 class="section__heading">Every New York service, every range.</h2>
      <p class="section__lede">The complete pricing landscape for New York businesses. Every fee is fixed and scoped in writing before work begins.</p>
    </header>
    <div class="grid-3">
      {%- for r in ranges %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ r.type | safe }}</p>
        <h3 class="buyer-card__heading">{{ r.service | safe }}</h3>
        <p class="buyer-card__body"><strong>{{ r.fee | safe }}</strong></p>
        <p class="buyer-card__body">{{ r.cadence | safe }}</p>
        {%- if r.href %}<a class="buyer-card__cta" href="{{ r.href }}">{{ r.cta | safe }}</a>{%- endif %}
      </article>
      {%- endfor %}
    </div>
    <p class="prose">{{ rangesNote | safe }}</p>
  </div>
</section>

{# ── WHY FIXED-FEE · standing brand line as H2; body carried as prose. (H2: Why we don't bill by the hour.) ── #}
<section class="section" id="ny-svc-pricing-why">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Why fixed-fee</p>
      <h2 class="section__heading">Why we don&rsquo;t bill by the hour.</h2>
    </header>
    <div class="stack-8">
      {%- for p in whyBody %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── INCLUDES · six standards every fixed fee carries (grid-3 buyer-cards). 6 frozen H3s verbatim. (H2 + 6 H3s) ── #}
<section class="section section--alt" id="ny-svc-pricing-includes">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What&rsquo;s always included</p>
      <h2 class="section__heading">Every fixed fee includes these.</h2>
      <p class="section__lede">Regardless of service or price, every New York engagement includes the same six standards. They&rsquo;re not add-ons &mdash; they&rsquo;re the baseline.</p>
    </header>
    <div class="grid-3">
      {%- for inc in includes %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ inc.number | safe }}</p>
        <h3 class="buyer-card__heading">{{ inc.title | safe }}</h3>
        <p class="buyer-card__body">{{ inc.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── FAQ · 7 verbatim contract Q/A; visible faq__list = FAQPage schema (same array). (H2: Questions about cost.) ── #}
<section class="section" id="ny-svc-pricing-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Pricing FAQ</p>
      <h2 class="section__heading">Questions about cost.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="ny-svc-pricing-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="ny-svc-pricing-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name (byline-block + meta-reviewed). (H2: New York pricing maintained by the TechBrot ProAdvisor team.) ── #}
<section class="section section--alt" id="ny-svc-pricing-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Pricing standards</p>
      <h2 class="section__heading">New York pricing maintained by the TechBrot ProAdvisor team.</h2>
    </header>
    <div class="byline-block">
      <div class="byline-block__mark" aria-hidden="true"></div>
      <div>
        <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="byline-block__review">TechBrot Inc. &middot; Independent Certified QuickBooks ProAdvisor firm</p>
      </div>
    </div>
    <div class="prose">
      <p>Pricing on this page is maintained by the Certified QuickBooks ProAdvisor team at <strong>TechBrot Inc.</strong>, a Delaware-incorporated independent ProAdvisor firm serving New York businesses across all 62 counties. Ranges reflect current operational pricing for New York engagements and are reviewed periodically; specific fixed fees are quoted per engagement after a free discovery call. New York tax references &mdash; NYC&rsquo;s 8.875% combined sales-tax rate and the 4% NYC UBT &mdash; reflect <a href="https://www.tax.ny.gov/" rel="noopener nofollow">NYS Department of Taxation and Finance</a> and NYC Department of Finance rules current as of the date below. TechBrot performs bookkeeping and QuickBooks work and coordinates with your CPA, who files; it does not file New York tax returns.</p>
    </div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-07</span><span>Updated: 2026-06-07</span><span>Reviewed: 2026-06-07 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{# ── RELATED · where to go next (grid-2 buyer-cards). 4 frozen H3s verbatim. (H2: Where to go next. + 4 H3s) ── #}
<section class="section" id="ny-svc-pricing-related">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Related</p>
      <h2 class="section__heading">Where to go next.</h2>
    </header>
    <div class="grid-2">
      {%- for r in related %}
      <article class="buyer-card">
        <h3 class="buyer-card__heading">{{ r.title | safe }}</h3>
        <p class="buyer-card__body">{{ r.body | safe }}</p>
        <a class="buyer-card__cta" href="{{ r.href }}">{{ r.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>
