{# ── SUMMARY · real H2 carrying the training summary prose (right after the in-brief). (H2: What New York QuickBooks training actually is.) ── #}
<section class="section section--compact" id="ny-svc-qbtraining-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In one paragraph</p>
      <h2 class="section__heading">What New York QuickBooks training actually is.</h2>
    </header>
    <div class="stack-8">
      {%- for p in summary %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. (H2: New York QuickBooks training, in five questions.) ── #}
<section class="section" id="ny-svc-qbtraining-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">New York QuickBooks training, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="ny-svc-qbtraining-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── COVERS · the five training topics (grid-3 buyer-cards). (H2 + 5 H3s) ── #}
<section class="section section--alt" id="ny-svc-qbtraining-covers">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What we cover</p>
      <h2 class="section__heading">What New York QuickBooks training covers.</h2>
      <p class="section__lede">Every session is scoped to your role and your file, delivered live by a named Certified ProAdvisor and recorded for the team.</p>
    </header>
    <div class="grid-3">
      {%- for c in covers %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ c.num }}</p>
        <h3 class="buyer-card__heading">{{ c.title | safe }}</h3>
        <p class="buyer-card__body">{{ c.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── SCOPE · what training is and isn't (grid-2 + checks-list). (H2 + H3 Training covers / H3 Not training) ── #}
<section class="section" id="ny-svc-qbtraining-scope">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Honest scope</p>
      <h2 class="section__heading">What training gives you &mdash; and what it doesn&rsquo;t.</h2>
    </header>
    <div class="grid-2">
      <div>
        <h3>Training covers</h3>
        <ul class="checks-list">
          {%- for t in scopeDo %}<li>{{ t | safe }}</li>{%- endfor %}
        </ul>
      </div>
      <div>
        <h3>Not training</h3>
        <ul class="checks-list">
          {%- for t in scopeDont %}<li>{{ t | safe }}</li>{%- endfor %}
        </ul>
      </div>
    </div>
    <p class="prose">{{ scopeNote | safe }}</p>
  </div>
</section>

{# ── ADVISORY · standing brand line carried as section prose. (H2: Automation handles the data entry. We handle the judgment.) ── #}
<section class="section section--alt" id="ny-svc-qbtraining-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">The advisory line</p>
      <h2 class="section__heading">Automation handles the data entry. We handle the judgment.</h2>
    </header>
    <div class="stack-8">
      {%- for p in advisoryBody %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="/contact/?intent=new-york&amp;state=new-york&amp;source_type=state-spoke&amp;funnel_stage=BOFU">Book the discovery call</a>
    </div>
  </div>
</section>

{# ── FAQ · 7 verbatim contract Q/A; visible faq__list = FAQPage schema (same array). (H2: What people ask before booking QuickBooks training.) ── #}
<section class="section" id="ny-svc-qbtraining-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">What people ask before booking QuickBooks training.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="ny-svc-qbtraining-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="ny-svc-qbtraining-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name (byline-block + meta-reviewed). (H2: Reviewed by the TechBrot Certified ProAdvisor team.) ── #}
<section class="section section--alt" id="ny-svc-qbtraining-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    </header>
    <div class="byline-block">
      <div class="byline-block__mark" aria-hidden="true"></div>
      <div>
        <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="byline-block__review">TechBrot Inc. &middot; Independent Certified QuickBooks ProAdvisor firm</p>
      </div>
    </div>
    <div class="prose">
      <p>This page reflects how TechBrot delivers New York QuickBooks training. It is maintained by the Certified QuickBooks ProAdvisor team at <strong>TechBrot Inc.</strong>, a Delaware-incorporated independent ProAdvisor firm, and reviewed for technical accuracy on QuickBooks Online and Desktop instruction and on the New York sales-tax handling taught in sessions &mdash; destination-based sourcing, the NYC 8.875% combined rate, and the quarterly <a href="https://www.tax.ny.gov/" rel="noopener nofollow">New York State return</a>. Pricing reflects TechBrot&rsquo;s New York training rates. TechBrot teaches the software and coordinates with your CPA, who files.</p>
    </div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-07</span><span>Updated: 2026-06-07</span><span>Reviewed: 2026-06-07 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>
