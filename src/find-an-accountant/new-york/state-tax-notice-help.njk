  </div>
</section>

{# ── AI SUMMARY · five-question block. (H2: New York tax notices, in five questions.) ── #}
<section class="section" id="ny-svc-notice-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">New York tax notices, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="ny-svc-notice-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── NOTICE TYPES · the real NY notices (grid-3 buyer-cards). (H2: Common New York State business tax notices.) ── #}
<section class="section section--alt" id="ny-svc-notice-types">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Know what you&rsquo;re holding</p>
      <h2 class="section__heading">Common New York State business tax notices.</h2>
      <p class="section__lede">The form number is usually printed at the top. Match it here before you do anything else &mdash; the right response depends entirely on which notice this is. Identifying the type and deadline is where we start; your CPA, EA, or tax attorney responds.</p>
    </header>
    <div class="grid-3">
      {%- for n in noticeTypes %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ n.form | safe }}</p>
        <h3 class="buyer-card__heading">{{ n.title | safe }}</h3>
        <p class="buyer-card__body">{{ n.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ noticeTypesNote | safe }}</small></p>
  </div>
</section>

{# ── BOOKS PROBLEMS · why so many notices are reconciliation issues. (H2: Why so many New York notices are really books problems) ── #}
<section class="section" id="ny-svc-notice-books">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">The most common root cause</p>
      <h2 class="section__heading">Why so many New York notices are really books problems</h2>
    </header>
    <div class="stack-8">
      {%- for p in booksBody %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
    <ul class="checks-list" id="ny-svc-notice-trustfund">
      <li><strong>Trust-fund tax.</strong> {{ trustFund | safe }}</li>
    </ul>
  </div>
</section>

{# ── SCOPE SPLIT · honest who-does-what (grid-2 buyer-cards). (H2: Who does what when a notice arrives. + 2 H3s) ── #}
