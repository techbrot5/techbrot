          {%- for li in scopeDo %}<li>{{ li | safe }}</li>{%- endfor %}
        </ul>
      </article>
      <article class="buyer-card">
        <h3 class="buyer-card__heading">Your CPA or tax attorney handles</h3>
        <ul class="checks-list">
          {%- for li in scopeDont %}<li>{{ li | safe }}</li>{%- endfor %}
        </ul>
      </article>
    </div>
  </div>
</section>

{# ── FAQ · 8 verbatim contract Q/A; visible faq__list = FAQPage schema (same array). (H2: New York tax notice questions.) ── #}
<section class="section" id="ny-svc-notice-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Common questions</p>
      <h2 class="section__heading">New York tax notice questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="ny-svc-notice-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="ny-svc-notice-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

