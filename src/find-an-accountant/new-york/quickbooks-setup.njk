{# ── SHORT VERSION · real H2 carrying the setup summary prose (right after the in-brief). (H2: The short version.) ── #}
<section class="section section--compact" id="ny-svc-qbsetup-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In one paragraph</p>
      <h2 class="section__heading">The short version.</h2>
    </header>
    <div class="stack-8">
      {%- for p in summary %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── FIVE QUESTIONS · AI-summary block. (H2: QuickBooks Setup in New York, in five questions.) ── #}
<section class="section" id="ny-svc-qbsetup-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">QuickBooks Setup in New York, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="ny-svc-qbsetup-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── HOW WE HANDLE · the five setup steps (grid-3 buyer-cards). (H2: How we handle quickbooks setup for New York businesses. + 5 H3s) ── #}
<section class="section section--alt" id="ny-svc-qbsetup-handle">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What&rsquo;s involved</p>
      <h2 class="section__heading">How we handle quickbooks setup for New York businesses.</h2>
      <p class="section__lede">Every setup is scoped to your business and delivered in your own QuickBooks file by a named Certified ProAdvisor.</p>
    </header>
    <div class="grid-3">
      {%- for s in handle %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ s.num }}</p>
        <h3 class="buyer-card__heading">{{ s.title | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── SCOPE SPLIT · honest books/CPA boundary (grid-2 buyer-cards). (H2: What we do — and what your CPA does. + H3 TechBrot + H3 Your CPA) ── #}
<section class="section" id="ny-svc-qbsetup-scope">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Honest scope</p>
      <h2 class="section__heading">What we do &mdash; and what your CPA does.</h2>
    </header>
    <div class="grid-2">
      {%- for col in scope %}
      <article class="buyer-card">
        <h3 class="buyer-card__heading">{{ col.title | safe }}</h3>
        <ul class="checks-list">
          {%- for i in col.items %}<li>{{ i | safe }}</li>{%- endfor %}
        </ul>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── ADVISORY · standing brand line carried as section prose. (H2: Automation handles the data entry. We handle the judgment.) ── #}
<section class="section section--alt" id="ny-svc-qbsetup-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">The advisory line</p>
      <h2 class="section__heading">Automation handles the data entry. We handle the judgment.</h2>
    </header>
    <div class="stack-8">
      {%- for p in advisoryBody %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="/contact/?intent=new-york">Book the discovery call</a>
    </div>
  </div>
</section>

{# ── FAQ · 8 verbatim contract Q/A; visible faq__list = FAQPage schema (same array). (H2: QuickBooks Setup questions.) ── #}
<section class="section" id="ny-svc-qbsetup-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Common questions</p>
      <h2 class="section__heading">QuickBooks Setup questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="ny-svc-qbsetup-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="ny-svc-qbsetup-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name (byline-block + meta-reviewed). (H2: Reviewed by the TechBrot Certified ProAdvisor team.) ── #}
