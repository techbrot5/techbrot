{# ── SUMMARY · real H2 carrying the real-estate summary prose (right after the in-brief). (H2: The short version.) ── #}
<section class="section section--compact" id="ny-ind-realestate-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In one paragraph</p>
      <h2 class="section__heading">The short version.</h2>
    </header>
    <div class="stack-8">
      {%- for p in summary %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. (H2: New York real estate accounting, in five questions.) ── #}
<section class="section" id="ny-ind-realestate-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">New York real estate accounting, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="ny-ind-realestate-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── CHALLENGES · three places investors lose the real numbers (grid-3 buyer-cards). (H2 + 3 H3s) ── #}
<section class="section section--alt" id="ny-ind-realestate-challenges">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why NY real-estate books mislead</p>
      <h2 class="section__heading">Three places New York investors lose the real numbers.</h2>
      <p class="section__lede">A growing portfolio can look healthy in aggregate while one property bleeds and a tax position quietly erodes. Knowing which of these you&rsquo;re in tells us where to start.</p>
    </header>
    <div class="grid-3">
      {%- for c in challenges %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ c.signal | safe }}</p>
        <h3 class="buyer-card__heading">{{ c.title | safe }}</h3>
        <p class="buyer-card__body">{{ c.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── WHAT WE HANDLE · the six services (grid-3 buyer-cards). (H2 + 6 H3s) ── #}
<section class="section" id="ny-ind-realestate-handle">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What TechBrot handles</p>
      <h2 class="section__heading">New York real estate accounting, done by an expert.</h2>
      <p class="section__lede">Every engagement is scoped to your properties and entities, delivered in your own QuickBooks file by a named Certified ProAdvisor &mdash; coordinating with your CPA and Qualified Intermediary.</p>
    </header>
    <div class="grid-3">
      {%- for s in handle %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ s.num }}</p>
        <h3 class="buyer-card__heading">{{ s.title | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
        <a class="buyer-card__cta" href="{{ s.href }}">{{ s.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── INTEGRATIONS · tools reconciled with QuickBooks (checks-list). (H2: Connected to how you manage property.) ── #}
<section class="section section--alt" id="ny-ind-realestate-integrations">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Tools we work alongside</p>
      <h2 class="section__heading">Connected to how you manage property.</h2>
    </header>
    <ul class="checks-list">
      {%- for t in integrations %}<li>{{ t | safe }}</li>{%- endfor %}
    </ul>
    <p class="prose">{{ integrationsNote | safe }}</p>
  </div>
</section>

{# ── PROCESS · four-phase engagement rhythm (grid-2 buyer-cards). (H2 + 4 H3s) ── #}
<section class="section" id="ny-ind-realestate-process">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">How engagements work</p>
      <h2 class="section__heading">From portfolio guesswork to per-property clarity.</h2>
      <p class="section__lede">Every New York real-estate engagement follows the same four-phase rhythm &mdash; books accurate first, per-property visibility second, advisory third.</p>
    </header>
    <div class="grid-2">
      {%- for p in process %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ p.phase }}</p>
        <h3 class="buyer-card__heading">{{ p.title | safe }}</h3>
        <p class="buyer-card__body">{{ p.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── ADVISORY · standing brand line carried as section prose. (H2: Per-property clarity is the start. Building the portfolio is the point.) ── #}
<section class="section section--alt" id="ny-ind-realestate-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Beyond the books</p>
      <h2 class="section__heading">Per-property clarity is the start. Building the portfolio is the point.</h2>
    </header>
    <div class="stack-8">
      {%- for p in advisoryBody %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="/contact/?intent=new-york&amp;state=new-york&amp;source_type=industry&amp;funnel_stage=BOFU">Book the discovery call</a>
    </div>
  </div>
</section>

{# ── FAQ · 8 verbatim contract Q/A; visible faq__list = FAQPage schema (same array). (H2: New York real estate accounting questions.) ── #}
<section class="section" id="ny-ind-realestate-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">New York real estate accounting questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="ny-ind-realestate-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="ny-ind-realestate-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name (byline-block + meta-reviewed). (H2: Reviewed by the TechBrot Certified ProAdvisor team.) ── #}
<section class="section section--alt" id="ny-ind-realestate-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    </header>
    <div class="byline-block">
      <div class="byline-block__mark" aria-hidden="true"></div>
      <div>
        <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="byline-block__review">TechBrot Inc. &middot; Independent Certified QuickBooks ProAdvisor firm</p>
      </div>
    </div>
    <div class="prose">
      <p>This page reflects how TechBrot handles New York real-estate engagements. It is maintained by the Certified QuickBooks ProAdvisor team at <strong>TechBrot Inc.</strong>, a Delaware-incorporated independent ProAdvisor firm, and reviewed for technical accuracy on per-property and per-entity reporting, depreciation and adjusted basis, 1031-exchange recordkeeping (<a href="https://www.tax.ny.gov/" rel="noopener nofollow">federal Section 1031 followed by New York</a>), nonresident Form IT-2663 withholding, and the NYC <a href="https://www.nyc.gov/site/finance/property/property-rpie.page" rel="noopener nofollow">RPIE</a> and Commercial Rent Tax data the books must produce. TechBrot keeps the books; your CPA files and your Qualified Intermediary runs any exchange.</p>
    </div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-07</span><span>Updated: 2026-06-07</span><span>Reviewed: 2026-06-07 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{# ── RELATED · NY services & industries (grid-2 buyer-cards). (H2 + 4 H3s) ── #}
<section class="section" id="ny-ind-realestate-related">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Related</p>
      <h2 class="section__heading">Related New York services &amp; industries.</h2>
