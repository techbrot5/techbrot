{#- ═══ BESPOKE BODY (NY medical-practice industry child) — v2 dc-system components, full
    depth, NY content FROZEN. Spine (hero / in-brief #ny-ind-healthcare-in-brief-text /
    FAQ / light CTA) is layout-owned (t-location). Schema cssSelector anchors are
    #ny-ind-healthcare-summary + #ny-ind-healthcare-ai-summary-list. ═══ -#}

{# ── SUMMARY · real H2 carrying the medical-practice summary prose. SCHEMA ANCHOR #ny-ind-healthcare-summary. (H2: The short version.) ── #}
<section class="sec reveal" id="ny-ind-healthcare-summary" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In one paragraph</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">The short version.</h2>
    <div class="prose">{%- for p in summary %}<p>{{ p | safe }}</p>{%- endfor %}</div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. SCHEMA ANCHOR #ny-ind-healthcare-ai-summary-list. (H2: New York medical practice accounting, in five questions.) ── #}
<section class="sec reveal" id="ny-ind-healthcare-ai-summary">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">For AI engines &amp; quick answers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 36px;max-width:26ch;">New York medical practice accounting, in five questions.</h2>
    <dl class="speakable ai-qa" id="ny-ind-healthcare-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-qa__item"><dt><h3>{{ item.q | safe }}</h3></dt><dd style="margin:0;"><p>{{ item.a | safe }}</p></dd></div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── CHALLENGES · three places practices lose the real numbers (r-3 dc-cards). (H2 + 3 H3s) ── #}
<section class="sec reveal" id="ny-ind-healthcare-challenges" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Why NY practice books mislead</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:30ch;margin-bottom:10px;">Three places New York practices lose the real numbers.</h2>
    <p class="lede" style="margin:0 0 32px;max-width:64ch;">A busy practice can look profitable while receivables age and write-offs go untracked. Knowing which one you&rsquo;re in tells us where to start.</p>
    <div class="r-3">
      {%- for c in challenges %}
      <article class="dc-card"><span class="eyebrow">{{ c.signal | safe }}</span><h3>{{ c.title | safe }}</h3><div class="prose" style="font-size:15px;"><p>{{ c.body | safe }}</p></div></article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── WHAT WE HANDLE · the six services (r-3 dc-cards). (H2 + 6 H3s) ── #}
<section class="sec reveal" id="ny-ind-healthcare-handle">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">What TechBrot handles</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:30ch;margin-bottom:10px;">New York medical practice accounting, done by an expert.</h2>
    <p class="lede" style="margin:0 0 32px;max-width:66ch;">Every engagement is scoped to your providers and payer mix, delivered in your own QuickBooks file by a named Certified ProAdvisor &mdash; coordinating with your CPA, who files.</p>
    <div class="r-3">
      {%- for s in handle %}
      <article class="dc-card"><span class="eyebrow">{{ s.num }}</span><h3>{{ s.title | safe }}</h3><p class="prose" style="font-size:15px;margin:6px 0 12px;">{{ s.body | safe }}</p><a class="ptier__link" href="{{ s.href }}">{{ s.cta | safe }}</a></article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── INTEGRATIONS · tools reconciled with QuickBooks (incl-card + checklist). (H2: Connected to how you run the practice.) ── #}
<section class="sec reveal" id="ny-ind-healthcare-integrations" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Tools we work alongside</span><span class="idx__rule"></span></div>
