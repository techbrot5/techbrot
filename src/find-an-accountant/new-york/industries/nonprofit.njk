{# ── SUMMARY · real H2 carrying the nonprofit summary prose. SCHEMA ANCHOR #ny-ind-nonprofit-summary. (H2: The short version.) ── #}
<section class="sec reveal" id="ny-ind-nonprofit-summary" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In one paragraph</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">The short version.</h2>
    <div class="prose">{%- for p in summary %}<p>{{ p | safe }}</p>{%- endfor %}</div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. SCHEMA ANCHOR #ny-ind-nonprofit-ai-summary-list. (H2: New York nonprofit accounting, in five questions.) ── #}
<section class="sec reveal" id="ny-ind-nonprofit-ai-summary">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">For AI engines &amp; quick answers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 36px;max-width:26ch;">New York nonprofit accounting, in five questions.</h2>
    <dl class="speakable ai-qa" id="ny-ind-nonprofit-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-qa__item"><dt><h3>{{ item.q | safe }}</h3></dt><dd style="margin:0;"><p>{{ item.a | safe }}</p></dd></div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── CHALLENGES · three places NY nonprofits lose compliance and funder trust (r-3 dc-cards). (H2 + 3 H3s) ── #}
<section class="sec reveal" id="ny-ind-nonprofit-challenges" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Why NY nonprofit books slip</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:30ch;margin-bottom:10px;">Three places New York nonprofits lose compliance and funder trust.</h2>
    <p class="lede" style="margin:0 0 32px;max-width:64ch;">A mission-focused organization can fall behind on the books that keep its status and its grants. Knowing which of these you&rsquo;re in tells us where to start.</p>
    <div class="r-3">
      {%- for c in challenges %}
      <article class="dc-card"><span class="eyebrow">{{ c.signal | safe }}</span><h3>{{ c.title | safe }}</h3><div class="prose" style="font-size:15px;"><p>{{ c.body | safe }}</p></div></article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── WHAT WE HANDLE · the six services (r-3 dc-cards). (H2 + 6 H3s) ── #}
<section class="sec reveal" id="ny-ind-nonprofit-handle">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">What TechBrot handles</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:30ch;margin-bottom:10px;">New York nonprofit accounting, done by an expert.</h2>
