---json
{
  "layout": "layouts/t-location.njk",
  "permalink": "/find-an-accountant/new-york/industries/ecommerce/",
  "slug": "ny-ind-ecommerce",
  "tierClass": "section--tier-hub",
  "bodyClass": "page--location page--industry",
  "callBar": true,
  "title": "New York E-commerce Accounting · TechBrot",
  "description": "E-commerce accounting for New York Shopify, Amazon & multi-channel sellers — multi-state sales-tax nexus, inventory & COGS, marketplace reconciliation. From $400/mo. Call (877) 751-5575.",
  "breadcrumb": [
