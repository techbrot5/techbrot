      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="ny-svc-qbmigration-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="ny-svc-qbmigration-faq-a{{ loop.index }}" data-open="false">
