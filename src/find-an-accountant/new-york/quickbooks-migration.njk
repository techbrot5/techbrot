{# ── URGENCY · the Intuit Desktop sunset timeline (grid-3 buyer-cards). (H2 + 4 H3s) ── #}
<section class="section section--alt" id="ny-svc-qbmigration-urgency">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">The Intuit Desktop sunset</p>
      <h2 class="section__heading">What&rsquo;s actually happening &mdash; and why timing matters.</h2>
      <p class="section__lede">{{ sunsetLede | safe }}</p>
    </header>
    <div class="grid-3">
      {%- for s in sunset %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ s.date | safe }}</p>
        <h3 class="buyer-card__heading">{{ s.title | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
    <p class="prose">{{ sunsetNote | safe }}</p>
  </div>
</section>

{# ── SUMMARY · real H2 carrying the migration summary prose. (H2: What New York QuickBooks migration actually is.) ── #}
<section class="section" id="ny-svc-qbmigration-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In one paragraph</p>
      <h2 class="section__heading">What New York QuickBooks migration actually is.</h2>
    </header>
    <div class="stack-8">
      {%- for p in summary %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. (H2: New York QuickBooks migration, in five questions.) ── #}
<section class="section section--alt" id="ny-svc-qbmigration-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">New York QuickBooks migration, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="ny-svc-qbmigration-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── SIGNALS · when migration is the right call (grid-3 buyer-cards). (H2 + 6 H3s) ── #}
<section class="section" id="ny-svc-qbmigration-signals">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">When migration is the right call</p>
      <h2 class="section__heading">If any of these apply, the answer is yes.</h2>
      <p class="section__lede">{{ signalsLede | safe }}</p>
    </header>
    <div class="grid-3">
      {%- for s in signals %}
      <article class="buyer-card">
        <h3 class="buyer-card__heading">{{ s.title | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── PHASES · four-phase migration methodology (grid-2 buyer-cards). (H2 + 4 H3s) ── #}
<section class="section section--alt" id="ny-svc-qbmigration-phases">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">The migration methodology</p>
      <h2 class="section__heading">Every migration runs four phases.</h2>
      <p class="section__lede">{{ phasesLede | safe }}</p>
