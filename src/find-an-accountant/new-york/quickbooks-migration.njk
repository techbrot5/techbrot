        <p class="buyer-card__opener">{{ p.phase }}</p>
        <h3 class="buyer-card__heading">{{ p.title | safe }}</h3>
        <p class="buyer-card__body">{{ p.body | safe }}</p>
        {%- if p.meta %}<p class="buyer-card__opener">{{ p.meta | safe }}</p>{%- endif %}
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── DELIVERABLES · what a migration delivers (two checks-lists, each under a real H3 — T3 no demotion). (H2 + 2 H3s) ── #}
<section class="section" id="ny-svc-qbmigration-deliverables">
  <div class="container">
    <header class="section__header">
