{#- ═══ BESPOKE BODY (Staten Island city child) — v2 dc-system components, full depth, NY
    content FROZEN. Spine (hero / in-brief #ny-statenisland-in-brief-text / FAQ / light CTA)
    is layout-owned (t-location). Section ids preserved on their pageGraph anchors; the
    schema speakable cssSelector anchors are #ny-statenisland-summary (below) +
    #ny-statenisland-ai-summary-list (below). ═══ -#}

{# ── SHORT VERSION · real H2 carrying the Staten Island summary prose. frozen speakable anchor #ny-statenisland-summary ── #}
<section class="sec reveal" id="ny-statenisland-summary" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In full</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">The short version.</h2>
    <div class="prose"><p>{{ summarized | safe }}</p></div>
  </div>
</section>

{# ── AI SUMMARY (H2: Staten Island bookkeeping, in five questions.) — frozen anchor #ny-statenisland-ai-summary-list ── #}
<section class="sec reveal" id="ny-statenisland-ai-summary">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">For AI engines &amp; quick answers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 36px;max-width:26ch;">Staten Island bookkeeping, in five questions.</h2>
    <dl class="speakable ai-qa" id="ny-statenisland-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-qa__item"><dt><h3>{{ item.q | safe }}</h3></dt><dd style="margin:0;"><p>{{ item.a | safe }}</p></dd></div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── WHY LOCAL · the un-clonable band (H2: Why Staten Island books have their own character.) ── #}
<section class="sec reveal" id="ny-statenisland-local" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Bookkeeping built for how Staten Island actually operates</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Why Staten Island books have their own character.</h2>
    <div class="prose">
      {%- for p in localContext %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AREAS WE SERVE · neighborhood chips (name + note preserved). (H2: Staten Island areas we serve.) ── #}
<section class="sec reveal" id="ny-statenisland-areas">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Across the borough</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:20px;">Staten Island areas we serve.</h2>
    <div class="chips">
      {%- for a in areas %}
      <span class="chip"><strong>{{ a.name | safe }}</strong>&nbsp;<span class="chip__note">&middot; {{ a.note | safe }}</span></span>
      {%- endfor %}
      <a class="chip chip--more" href="/find-an-accountant/new-york/cities/">All New York cities &rarr;</a>
    </div>
  </div>
</section>

{# ── LOCAL TAX STACK · RATE-FREE v2 figure built from the REAL `taxStack` data (figure + desc).
     No invented rates; every figure/desc verbatim from the data. (H2: Staten Island's tax stack, at a glance.) ── #}
<section class="sec reveal" id="ny-statenisland-tax" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">The Staten Island tax picture we build into your books</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 30px;max-width:24ch;">Staten Island&rsquo;s tax stack, at a glance.</h2>
    <figure style="margin:0;" aria-label="Staten Island local tax facts">
      <div class="r-3">
        {%- for t in taxStack %}
        <div class="dc-card"><div class="trust-row__value" style="font-size:30px;margin-bottom:8px;">{{ t.figure | safe }}</div><p class="prose" style="font-size:15px;">{{ t.desc | safe }}</p></div>
        {%- endfor %}
      </div>
    </figure>
    <p class="prose" style="font-size:13px;color:var(--color-ink-faint);margin-top:18px;">{{ taxNote | safe }}</p>
  </div>
</section>

{# ── INDUSTRIES · chips, each links to the NY industry page (label + note). (H2: Industry-specific bookkeeping for Staten Island businesses.) ── #}
