---

{#- ═══ BESPOKE BODY (Buffalo city child) — v2 dc-system components, full depth, NY content
    FROZEN. Spine (hero / in-brief #ny-buffalo-in-brief-text / FAQ / light CTA) is layout-owned.
    Schema cssSelector anchors preserved: #ny-buffalo-in-brief-text (LAYOUT) +
    #ny-buffalo-ai-summary-list (AI-summary dl). Section ids = this page's own pageGraph
    anchors (ny-buffalo-*). ═══ -#}

{# ── SHORT VERSION · real H2 carrying the summary prose (right after the in-brief) ── #}
<section class="sec reveal" id="ny-buffalo-summarized" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In full</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">The short version.</h2>
    <div class="prose"><p>{{ summarized | safe }}</p></div>
  </div>
</section>

{# ── AI SUMMARY (H2: Buffalo bookkeeping, in five questions.) — frozen anchor #ny-buffalo-ai-summary-list ── #}
<section class="sec reveal" id="ny-buffalo-ai-summary">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">For AI engines &amp; quick answers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 36px;max-width:26ch;">Buffalo bookkeeping, in five questions.</h2>
    <dl class="speakable ai-qa" id="ny-buffalo-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-qa__item"><dt><h3>{{ item.q | safe }}</h3></dt><dd style="margin:0;"><p>{{ item.a | safe }}</p></dd></div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── WHY LOCAL · the un-clonable band (H2: Why Buffalo books have their own rhythm.) ── #}
<section class="sec reveal" id="ny-buffalo-context" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Bookkeeping built for how Buffalo actually operates</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Why Buffalo books have their own rhythm.</h2>
    <div class="prose">
      <p><strong>{{ localLead | safe }}</strong></p>
      {%- for p in localBody %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AREAS WE SERVE · neighborhood chips (name + note preserved). (H2: Buffalo areas we serve.) ── #}
<section class="sec reveal" id="ny-buffalo-areas">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Across Erie County &amp; Western New York</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:20px;">Buffalo areas we serve.</h2>
    <div class="chips">
      {%- for a in areas %}
      <span class="chip"><strong>{{ a.name | safe }}</strong>&nbsp;<span class="chip__note">&middot; {{ a.note | safe }}</span></span>
      {%- endfor %}
      <a class="chip chip--more" href="/find-an-accountant/new-york/cities/">All New York cities &rarr;</a>
    </div>
  </div>
</section>

{# ── LOCAL TAX STACK · RATE-FREE v2 figure built from the REAL `taxFacts` data (fig + desc).
     No invented rates; every figure/desc verbatim. (H2: Buffalo sales tax, at a glance.) ── #}
<section class="sec reveal" id="ny-buffalo-tax" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">{{ taxEyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 30px;max-width:24ch;">Buffalo sales tax, at a glance.</h2>
    <figure style="margin:0;" aria-label="Buffalo local tax facts">
      <div class="r-3">
        {%- for t in taxFacts %}
        <div class="dc-card"><div class="trust-row__value" style="font-size:30px;margin-bottom:8px;">{{ t.fig | safe }}</div><p class="prose" style="font-size:15px;">{{ t.desc | safe }}</p></div>
        {%- endfor %}
      </div>
    </figure>
  </div>
</section>

{# ── INDUSTRIES · chips, each links to the NY industry page. (H2: Industry-specific bookkeeping for Buffalo businesses.) ── #}
<section class="sec reveal" id="ny-buffalo-industries">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Buffalo verticals we know</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Industry-specific bookkeeping for Buffalo businesses.</h2>
    <p class="lede" style="margin:0 0 24px;max-width:62ch;">Each links to our dedicated New York industry page, with the local wrinkles built in.</p>
    <div class="chips">
      {%- for i in industries %}
      <a class="chip" href="{{ i.href }}">{{ i.name | safe }} &rarr;</a>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── VALUE STACK · 4 services, real H3s. (H2: Complete bookkeeping, locally aware. + 4 H3s) ── #}
<section class="sec reveal" id="ny-buffalo-value" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">What we do for Buffalo businesses</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:30px;">Complete bookkeeping, locally aware.</h2>
    <div class="r-2">
      {%- for v in valueStack %}
      <div class="dc-card"><span class="eyebrow">{{ v.num }}</span><h3>{{ v.title | safe }}</h3><div class="prose" style="font-size:15.5px;">{{ v.body | safe }}</div></div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── ADVISORY · standing brand line (pull-quote .statement). (H2: Automation handles the data entry. We handle the judgment.) ── #}
<section class="sec reveal" id="ny-buffalo-advisory">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">The advisory line</span><span class="idx__rule"></span></div>
    <h2 class="statement" style="margin-bottom:18px;">Automation handles the data entry. We handle the judgment.</h2>
    <div class="prose"><p>{{ advisoryBody | safe }}</p></div>
    <div style="margin-top:22px;display:flex;flex-wrap:wrap;gap:14px;align-items:center;">
      <a class="btn btn-cta" href="/contact/?intent=new-york&amp;state=new-york&amp;city=buffalo&amp;source_type=location&amp;funnel_stage=BOFU" style="display:inline-flex;align-items:center;height:48px;padding:0 22px;border-radius:11px;font-size:15px;font-weight:600;">Book the discovery call</a>
      <a class="ptier__link" href="/accounting/advisory/fractional-cfo/">Fractional CFO (New York) &rarr;</a>
    </div>
  </div>
</section>

{# ── TWO WAYS TO START · dual-path call + shared intake-form partial. (H2: Two ways to start a Buffalo engagement.) ── #}
<section class="sec reveal" id="ny-buffalo-intake" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Talk to a Certified ProAdvisor</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Two ways to start a Buffalo engagement.</h2>
    <p class="lede" style="margin:0 0 32px;max-width:60ch;">Both paths go to the same Certified ProAdvisor. Pick the one that fits how you work.</p>
    <div class="r-2">
      <article class="incl-card">
        <span class="eyebrow" style="display:block;margin-bottom:10px;">Option 01</span>
        <h3>Call directly.</h3>
        <p class="prose" style="font-size:15px;margin:8px 0 8px;">A Certified ProAdvisor answers &mdash; not a call center. Best for same-day diagnostics, behind-on-the-books situations, or a quick read on your Buffalo file.</p>
        <p class="prose" style="font-size:14.5px;margin:0 0 16px;color:var(--color-ink-mute);">{{ teamProAdvisor.line | safe }}</p>
        <a class="btn btn-cta" href="tel:{{ site.phone.e164 }}" data-ga="phone_click" data-tb-event="phone_click" style="display:inline-flex;align-items:center;gap:9px;height:48px;padding:0 22px;border-radius:11px;font-size:15px;font-weight:600;">Speak to a ProAdvisor</a>
        <ul class="checklist" style="margin-top:16px;">{%- for a in callAssurance %}<li>{{ a | safe }}</li>{%- endfor %}</ul>
      </article>
      {#- footprint reduction 2026-06-25: city pages are CALL-FIRST. Online option routes to the central full form with NY context (no per-city form). -#}
      <article class="incl-card">
        <span class="eyebrow" style="display:block;margin-bottom:10px;">Option 02</span>
        <h3>Prefer to send details online?</h3>
        <p class="prose" style="font-size:15px;margin:8px 0 16px;">Write out a short discovery brief and a Certified ProAdvisor responds by the next business day &mdash; a scoping call or, if not a fit, a referral. Includes a free QuickBooks file review of the top 3 issues before any engagement.</p>
        <a class="btn btn--ghost" href="/contact/?intent=new-york&amp;state=new-york&amp;city=buffalo" data-cta="city-online-intake" style="display:inline-flex;align-items:center;gap:9px;height:48px;padding:0 22px;border-radius:11px;font-size:15px;font-weight:600;">Send the Discovery Brief</a>
      </article>
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name. (H2: Reviewed by the TechBrot Certified ProAdvisor team.) ── #}
<section class="sec reveal" id="ny-buffalo-review">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Page review &amp; standards</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    <div class="prose"><p>{{ reviewBody | safe }}</p></div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value" style="font-size:15px;">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-07</span><span>Updated: 2026-06-07</span><span>Reviewed: 2026-06-07 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>
