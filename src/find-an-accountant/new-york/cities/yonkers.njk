{#- ═══ BESPOKE BODY (Yonkers city child) — v2 dc-system components, full depth, NY
    content FROZEN. Spine (hero / in-brief #ny-yonkers-in-brief-text / FAQ / light CTA)
    is layout-owned (t-location). Section ids preserved on their pageGraph anchors; the
    schema speakable cssSelector anchors are #ny-yonkers-summary (below) +
    #ny-yonkers-ai-summary-list (below). ═══ -#}

{# ── SHORT VERSION · real H2 carrying the Yonkers summary prose. frozen speakable anchor #ny-yonkers-summary ── #}
<section class="sec reveal" id="ny-yonkers-summary" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In full</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">The short version.</h2>
    <div class="prose"><p>{{ summarized | safe }}</p></div>
  </div>
</section>

{# ── AI SUMMARY (H2: Yonkers bookkeeping, in five questions.) — frozen anchor #ny-yonkers-ai-summary-list ── #}
<section class="sec reveal" id="ny-yonkers-ai-summary">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">For AI engines &amp; quick answers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 36px;max-width:26ch;">Yonkers bookkeeping, in five questions.</h2>
    <dl class="speakable ai-qa" id="ny-yonkers-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-qa__item"><dt><h3>{{ item.q | safe }}</h3></dt><dd style="margin:0;"><p>{{ item.a | safe }}</p></dd></div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── WHY LOCAL · the un-clonable band (H2: Why Yonkers books have their own character.) ── #}
<section class="sec reveal" id="ny-yonkers-local" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Bookkeeping built for how Yonkers actually operates</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Why Yonkers books have their own character.</h2>
    <div class="prose">
      {%- for p in localContext %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AREAS WE SERVE · neighborhood chips (name + note preserved). (H2: Yonkers areas we serve.) ── #}
<section class="sec reveal" id="ny-yonkers-areas">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Across Yonkers &amp; lower Westchester</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:20px;">Yonkers areas we serve.</h2>
    <div class="chips">
      {%- for a in areas %}
      <span class="chip"><strong>{{ a.name | safe }}</strong>&nbsp;<span class="chip__note">&middot; {{ a.note | safe }}</span></span>
      {%- endfor %}
      <a class="chip chip--more" href="/find-an-accountant/new-york/cities/">All New York cities &rarr;</a>
    </div>
  </div>
</section>

{# ── LOCAL TAX STACK · RATE-FREE v2 figure built from the REAL `taxStack` data (figure + desc).
     No invented rates; every figure/desc verbatim from the data. (H2: Yonkers sales tax, at a glance.) ── #}
<section class="sec reveal" id="ny-yonkers-tax" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">The Yonkers tax fact we build into your books</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 30px;max-width:24ch;">Yonkers sales tax, at a glance.</h2>
    <figure style="margin:0;" aria-label="Yonkers local tax facts">
      <div class="r-3">
        {%- for t in taxStack %}
        <div class="dc-card"><div class="trust-row__value" style="font-size:30px;margin-bottom:8px;">{{ t.figure | safe }}</div><p class="prose" style="font-size:15px;">{{ t.desc | safe }}</p></div>
        {%- endfor %}
      </div>
    </figure>
    <p class="prose" style="font-size:13px;color:var(--color-ink-faint);margin-top:18px;">{{ taxNote | safe }}</p>
  </div>
</section>

{# ── INDUSTRIES · chips, each links to the NY industry page (label + note). (H2: Industry-specific bookkeeping for Yonkers businesses.) ── #}
<section class="sec reveal" id="ny-yonkers-industries">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Yonkers verticals we know</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Industry-specific bookkeeping for Yonkers businesses.</h2>
    <p class="lede" style="margin:0 0 24px;max-width:62ch;">Each links to our dedicated New York industry page, with the local wrinkles built in.</p>
    <div class="r-2">
      {%- for i in industries %}
      <div class="dc-card"><h3 style="margin:0 0 6px;"><a class="prose" href="{{ i.href }}" style="color:var(--color-accent);">{{ i.label | safe }} &rarr;</a></h3><p class="prose" style="font-size:15px;">{{ i.note | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── VALUE STACK · 4 services, real H3s (dc-card grid). (H2: Complete bookkeeping, locally aware. + 4 H3s) ── #}
<section class="sec reveal" id="ny-yonkers-services" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">What we do for Yonkers businesses</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:30px;">Complete bookkeeping, locally aware.</h2>
    <div class="r-2">
      {%- for s in services %}
      <div class="dc-card"><span class="eyebrow">{{ s.num }}</span><h3>{{ s.title | safe }}</h3><div class="prose" style="font-size:15.5px;"><p>{{ s.body | safe }}</p></div><a class="ptier__link" href="{{ s.href }}" style="margin-top:12px;">{{ s.cta | safe }}</a></div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── ADVISORY · standing brand line (pull-quote .statement). (H2: Automation handles the data entry. We handle the judgment.) ── #}
<section class="sec reveal" id="ny-yonkers-advisory">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">The advisory line</span><span class="idx__rule"></span></div>
    <h2 class="statement" style="margin-bottom:18px;">Automation handles the data entry. We handle the judgment.</h2>
    <div class="prose"><p>{{ advisoryBody | safe }}</p></div>
    <div style="margin-top:22px;display:flex;flex-wrap:wrap;gap:14px;align-items:center;">
      <a class="btn btn-cta" href="/contact/?intent=new-york&amp;state=new-york&amp;city=yonkers&amp;source_type=city-page&amp;funnel_stage=BOFU" style="display:inline-flex;align-items:center;height:48px;padding:0 22px;border-radius:11px;font-size:15px;font-weight:600;">Book the discovery call</a>
      <a class="ptier__link" href="/accounting/advisory/fractional-cfo/">Fractional CFO (New York) &rarr;</a>
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name. trust-row credential cells.
     (H2: Reviewed by the TechBrot Certified ProAdvisor team.) ── #}
<section class="sec reveal" id="ny-yonkers-review">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Page review &amp; standards</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    <div class="prose">
      <p>Reviewed and maintained by the accounting team at <strong>TechBrot Inc.</strong>, an independent Certified QuickBooks ProAdvisor firm serving Yonkers and Westchester County businesses. The Yonkers combined sales-tax rate &mdash; 8.875% (4% New York State + 4% Westchester County + 0.375% MCTD + 0.5% Yonkers city tax) &mdash; reflects <a href="https://www.tax.ny.gov/" rel="noopener nofollow">NY State Department of Taxation and Finance</a> rates current as of the date below and is reviewed periodically. TechBrot provides bookkeeping and coordinates with your CPA, who files.</p>
    </div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value" style="font-size:15px;">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-07</span><span>Updated: 2026-06-07</span><span>Reviewed: 2026-06-07 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>
