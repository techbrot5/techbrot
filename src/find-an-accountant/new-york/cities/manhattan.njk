<section class="sec reveal" id="ny-manhattan-tax" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">The Manhattan tax picture we build into your books</span><span class="idx__rule"></span></div>
