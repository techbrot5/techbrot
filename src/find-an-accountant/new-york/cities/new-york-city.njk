{#- ═══ BESPOKE BODY (New York City five-borough page) — v2 dc-system components, full depth,
    NY content FROZEN. Spine (hero / in-brief #ny-nyc-in-brief-text / FAQ / light CTA) is
    layout-owned. Schema cssSelector anchors preserved: #ny-nyc-summary (short-version section) +
    #ny-nyc-ai-summary-list (AI-summary dl). Section ids = this page's own pageGraph anchors
    (ny-nyc-*). ═══ -#}

{# ── SHORT VERSION · real H2 carrying the summary prose (right after the in-brief) ── #}
<section class="sec reveal" id="ny-nyc-summary" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In full</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">The short version.</h2>
    <div class="prose"><p>{{ summarized | safe }}</p></div>
  </div>
</section>

{# ── AI SUMMARY (H2: New York City bookkeeping, in five questions.) — frozen anchor #ny-nyc-ai-summary-list ── #}
<section class="sec reveal" id="ny-nyc-ai-summary">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">For AI engines &amp; quick answers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 36px;max-width:26ch;">New York City bookkeeping, in five questions.</h2>
    <dl class="speakable ai-qa" id="ny-nyc-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-qa__item"><dt><h3>{{ item.q | safe }}</h3></dt><dd style="margin:0;"><p>{{ item.a | safe }}</p></dd></div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── WHY LOCAL · the un-clonable band (H2: Why New York City books are different.) ── #}
<section class="sec reveal" id="ny-nyc-local" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Bookkeeping built for how NYC actually operates</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Why New York City books are different.</h2>
    <div class="prose">
      {%- for p in localContext %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AREAS WE SERVE · five-borough chips (name + note preserved). (H2: New York City areas we serve.) ── #}
<section class="sec reveal" id="ny-nyc-areas">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Across the five boroughs</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:20px;">New York City areas we serve.</h2>
    <div class="chips">
      {%- for a in areas %}
      <span class="chip"><strong>{{ a.name | safe }}</strong>&nbsp;<span class="chip__note">&middot; {{ a.note | safe }}</span></span>
      {%- endfor %}
      <a class="chip chip--more" href="/find-an-accountant/new-york/cities/">All New York cities &rarr;</a>
    </div>
  </div>
</section>

{# ── LOCAL TAX STACK · RATE-FREE v2 figure built from the REAL `taxStack` data (figure + desc).
     No invented rates; every figure/desc verbatim. (H2: New York City's tax stack, at a glance.) ── #}
<section class="sec reveal" id="ny-nyc-tax" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">The three NYC taxes we build into your books</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 30px;max-width:24ch;">New York City&rsquo;s tax stack, at a glance.</h2>
    <figure style="margin:0;" aria-label="New York City local tax facts">
      <div class="r-3">
        {%- for t in taxStack %}
        <div class="dc-card"><div class="trust-row__value" style="font-size:30px;margin-bottom:8px;">{{ t.figure | safe }}</div><p class="prose" style="font-size:15px;">{{ t.desc | safe }}</p></div>
        {%- endfor %}
      </div>
      <figcaption class="prose" style="font-size:13px;color:var(--color-ink-mute);margin-top:18px;">{{ taxNote | safe }}</figcaption>
    </figure>
  </div>
</section>

{# ── INDUSTRIES · chips, each links to the NY industry page. (H2: Industry-specific bookkeeping for NYC businesses.) ── #}
<section class="sec reveal" id="ny-nyc-industries">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">NYC verticals we know</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Industry-specific bookkeeping for NYC businesses.</h2>
    <p class="lede" style="margin:0 0 24px;max-width:62ch;">Each links to our dedicated New York industry page, with the city-specific wrinkles built in.</p>
    <ul class="checklist" style="max-width:none;">
      {%- for i in industries %}
      <li><a href="{{ i.href }}">{{ i.label | safe }}</a> &mdash; {{ i.note | safe }}</li>
      {%- endfor %}
    </ul>
  </div>
</section>

{# ── VALUE STACK · 4 services, real H3s. (H2: Complete bookkeeping, NYC-aware. + 4 H3s) ── #}
<section class="sec reveal" id="ny-nyc-services" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">What we do for NYC businesses</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:30px;">Complete bookkeeping, NYC-aware.</h2>
    <div class="r-2">
      {%- for s in services %}
      <div class="dc-card"><span class="eyebrow">{{ s.num }}</span><h3>{{ s.title | safe }}</h3><div class="prose" style="font-size:15.5px;">{{ s.body | safe }}</div><p style="margin:14px 0 0;"><a class="ptier__link" href="{{ s.href }}">{{ s.cta | safe }}</a></p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── ADVISORY · standing brand line (pull-quote .statement). (H2: Automation handles the data entry. We handle the judgment.) ── #}
<section class="sec reveal" id="ny-nyc-advisory">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">The advisory line</span><span class="idx__rule"></span></div>
    <h2 class="statement" style="margin-bottom:18px;">Automation handles the data entry. We handle the judgment.</h2>
    <div class="prose"><p>{{ advisoryBody | safe }}</p></div>
    <div style="margin-top:22px;display:flex;flex-wrap:wrap;gap:14px;align-items:center;">
      <a class="btn btn-cta" href="/contact/?intent=new-york&amp;state=new-york&amp;city=new-york-city&amp;source_type=city-page&amp;funnel_stage=BOFU" style="display:inline-flex;align-items:center;height:48px;padding:0 22px;border-radius:11px;font-size:15px;font-weight:600;">Book the discovery call</a>
      <a class="ptier__link" href="/accounting/advisory/fractional-cfo/">Fractional CFO (New York) &rarr;</a>
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name. (H2: Reviewed by the TechBrot Certified ProAdvisor team.) ── #}
<section class="sec reveal" id="ny-nyc-review">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Page review &amp; standards</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    <div class="prose">
      <p>Reviewed and maintained by the accounting team at <strong>TechBrot Inc.</strong>, an independent Certified QuickBooks ProAdvisor firm serving New York City across all five boroughs. NYC tax figures &mdash; the 8.875% combined sales tax (4% state + 4.5% city + 0.375% MTA/MCTD); the 4% UBT after the $95,000 gross-income threshold, with a credit fully offsetting UBT of $3,400 or less; and the Commercial Rent Tax, which applies only to Manhattan tenants south of 96th Street paying $250,000+ in annual rent &mdash; reflect <a href="https://www.nyc.gov/site/finance/index.page" rel="noopener nofollow">NYC Department of Finance</a> and <a href="https://www.tax.ny.gov/" rel="noopener nofollow">NY DTF</a> rules current as of the date below and are reviewed periodically. TechBrot provides bookkeeping and coordinates with your CPA, who files.</p>
    </div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value" style="font-size:15px;">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-07</span><span>Updated: 2026-06-07</span><span>Reviewed: 2026-06-07 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>
