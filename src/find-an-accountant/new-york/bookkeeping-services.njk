{#- §04 INCLUDED (5 monthly-bookkeeping workstreams → lift cards, num+title+body+cta) — white -#}
<section class="sec reveal" id="ny-svc-bookkeeping-included">
  <div class="ct">
    <div class="idx"><span class="idx__n">§04</span><span class="idx__t">What&rsquo;s included every month</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:26ch;margin-bottom:12px;">Complete monthly bookkeeping, not a partial service.</h2>
    <p class="lede" style="margin:0 0 36px;max-width:62ch;">Every engagement is scoped to your business and delivered in your own QuickBooks file by a named Certified ProAdvisor.</p>
    <div class="r-2">
      {%- for s in included %}
      <div class="lift">
        <span class="lift__n">{{ s.num }}</span>
        <div>
          <h3>{{ s.title | safe }}</h3>
          <p>{{ s.body | safe }}</p>
          {%- if s.href %}<p style="margin-top:10px;"><a class="ptier__link" style="margin-top:0;" href="{{ s.href }}">{{ s.cta | safe }}</a></p>{%- endif %}
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

