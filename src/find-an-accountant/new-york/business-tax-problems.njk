{# ── BOUNDARIES · Sheet-7 disclosure reinforced as a prominent checks-list of explicit
   boundaries, directly under the above-the-fold in-brief disclosure. Chosen treatment:
   in-brief leads with the plain disclosure (above the fold), and this checks-list spells out
   the boundaries (no invented banner/callout class). ── #}
<section class="section section--compact" id="ny-svc-biztax-boundaries">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Before we start &mdash; what we are and aren&rsquo;t</p>
      <h2 class="section__heading">The short version.</h2>
    </header>
    <ul class="checks-list">
      {%- for b in boundaries %}<li>{{ b | safe }}</li>{%- endfor %}
    </ul>
    <div class="stack-8">
      <p class="prose">{{ shortVersion | safe }}</p>
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. (H2: New York business tax problems, in five questions.) ── #}
<section class="section" id="ny-svc-biztax-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">New York business tax problems, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="ny-svc-biztax-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
    {# Resolution paths — baseline reference table as grid-3 buyer-cards. No new H2 (supporting block). #}
    <div class="grid-3">
      {%- for p in paths %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ p.signal | safe }}</p>
        <h3 class="buyer-card__heading">{{ p.title | safe }}</h3>
        <p class="buyer-card__body">{{ p.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── LEVERAGE · why fix the books first (section prose + a definition stack). (H2: Why "fix the books first" isn't a delay — it's the leverage) ── #}
<section class="section section--alt" id="ny-svc-biztax-leverage">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">The order that works</p>
      <h2 class="section__heading">Why "fix the books first" isn&rsquo;t a delay &mdash; it&rsquo;s the leverage</h2>
    </header>
    <div class="stack-8">
      <p class="prose">{{ leverageBody[0] | safe }}</p>
      <div class="stack-8">
        <p class="section__eyebrow">{{ leverageTerm | safe }}</p>
        <p class="prose">{{ leverageDef | safe }}</p>
      </div>
      <p class="prose">{{ leverageBody[1] | safe }}</p>
    </div>
  </div>
</section>

{# ── ENGAGEMENT SPLIT · the honesty core (grid-2 buyer-cards, 2 frozen H3s). (H2: How a New York tax-problem engagement splits. + H3: TechBrot handles / H3: Your CPA or tax attorney handles) ── #}
<section class="section" id="ny-svc-biztax-split">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Honest scope</p>
      <h2 class="section__heading">How a New York tax-problem engagement splits.</h2>
    </header>
    <div class="grid-2">
      <article class="buyer-card">
        <h3 class="buyer-card__heading">TechBrot handles</h3>
        <ul class="checks-list">
          {%- for li in splitDo %}<li>{{ li | safe }}</li>{%- endfor %}
        </ul>
      </article>
      <article class="buyer-card">
        <h3 class="buyer-card__heading">Your CPA or tax attorney handles</h3>
        <ul class="checks-list">
          {%- for li in splitDont %}<li>{{ li | safe }}</li>{%- endfor %}
        </ul>
      </article>
    </div>
  </div>
</section>

{# ── FAQ · 8 verbatim contract Q/A; visible faq__list = FAQPage schema (same array). (H2: New York business tax problem questions.) ── #}
<section class="section section--alt" id="ny-svc-biztax-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">New York business tax problem questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="ny-svc-biztax-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="ny-svc-biztax-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

