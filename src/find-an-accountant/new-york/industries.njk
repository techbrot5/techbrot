    <div class="prose">
      {%- for p in why %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── MORE INDUSTRIES · additional dedicated pages routing (additive — NOT a frozen heading section) ── #}
<section class="sec reveal" id="ny-ind-hub-more" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">More New York industries</span><span class="idx__rule"></span></div>
