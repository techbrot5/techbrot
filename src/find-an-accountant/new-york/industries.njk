  "permalink": "/find-an-accountant/new-york/industries/",
  "slug": "ny-ind-hub",
  "tierClass": "section--tier-hub",
  "bodyClass": "page--location",
  "callBar": true,
  "title": "New York Industry Accounting & Bookkeeping · TechBrot",
