{# ── INDUSTRY ACCOUNTING, PLAINLY · real H2 carrying the one-paragraph summary (right after the in-brief) ── #}
<section class="sec reveal" id="ny-ind-hub-coverage" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In one paragraph</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">New York industry accounting, plainly.</h2>
    <div class="prose"><p>{{ coverage | safe }}</p></div>
  </div>
</section>

{# ── AI SUMMARY · 5 entity-dense Q&As — frozen anchor #ny-ind-hub-ai-summary-list (H2: New York industry accounting, in five questions.) ── #}
<section class="sec reveal" id="ny-ind-hub-ai-summary">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">For AI engines &amp; quick answers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 36px;max-width:28ch;">New York industry accounting, in five questions.</h2>
    <dl class="speakable ai-qa" id="ny-ind-hub-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-qa__item"><dt><h3>{{ item.q | safe }}</h3></dt><dd style="margin:0;"><p>{{ item.a | safe }}</p></dd></div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── FEATURED INDUSTRIES · industry routing rel-cards; each H3 verbatim, each links to its industry page ──
   (H2: Where we go deep in New York. + 6 H3s) #}
<section class="sec reveal" id="ny-ind-hub-featured" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">New York industry expertise</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Where we go deep in New York.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:64ch;">Six industries with dedicated New York pages &mdash; each built around the number that runs that business, with the state&rsquo;s rules included.</p>
    <div class="r-3">
      {%- for c in featured %}
      <a class="rel-card" href="{{ c.href }}">
        <span class="eyebrow" style="display:block;margin-bottom:8px;">{{ c.num }} &middot; {{ c.eyebrow | safe }}</span>
        <h3 class="rel-card__t">{{ c.heading | safe }}</h3>
        <p class="rel-card__d">{{ c.body | safe }}</p>
        <p class="rel-card__d" style="margin-top:8px;"><strong>Focus</strong> &middot; {{ c.focus | safe }}</p>
        <span class="ptier__link" style="margin-top:12px;">{{ c.cta | safe }}</span>
      </a>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── WHY INDUSTRY · context prose (H2: Generic bookkeeping misses the number that runs your business — twice over in New York.) ── #}
<section class="sec reveal" id="ny-ind-hub-why">
