{# ── SUMMARY · real H2 carrying the sales-tax summary prose (right after the in-brief). (H2: The short version.) ── #}
<section class="section section--compact" id="ny-svc-salestax-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <h2 class="section__heading">The short version.</h2>
    </header>
    <p class="prose">{{ summary | safe }}</p>
  </div>
</section>

{# ── AI SUMMARY · five-question block. (H2: New York sales tax, in five questions.) ── #}
<section class="section" id="ny-svc-salestax-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">New York sales tax, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="ny-svc-salestax-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── WHY IT TRIPS BUSINESSES UP · body prose + the three reasons (grid-3 buyer-cards). (H2: Why New York sales tax trips up so many businesses) ── #}
<section class="section section--alt" id="ny-svc-salestax-why">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Why New York is hard</p>
      <h2 class="section__heading">Why New York sales tax trips up so many businesses</h2>
    </header>
    <div class="stack-8">
      {%- for p in whyBody %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="grid-3">
      {%- for c in whyCards %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ c.signal | safe }}</p>
        <h3 class="buyer-card__heading">{{ c.title | safe }}</h3>
        <p class="buyer-card__body">{{ c.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── SCOPE · honest do/don't split (grid-2; checks-list inside each col). 2 frozen H3s verbatim. (H2: How we help with New York sales tax. + h3 TechBrot handles / h3 You or your CPA handle) ── #}
<section class="section" id="ny-svc-salestax-scope">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Honest scope</p>
      <h2 class="section__heading">How we help with New York sales tax.</h2>
    </header>
    <div class="grid-2">
      <div class="stack-8">
        <h3>TechBrot handles</h3>
        <ul class="checks-list">
          {%- for d in scopeDo %}<li>{{ d | safe }}</li>{%- endfor %}
        </ul>
      </div>
      <div class="stack-8">
        <h3>You or your CPA handle</h3>
        <ul class="checks-list">
          {%- for d in scopeDont %}<li>{{ d | safe }}</li>{%- endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

{# ── ADVISORY · standing brand line lives inside the body. (H2: Automation handles the data entry. We handle the judgment.) ── #}
<section class="section section--alt" id="ny-svc-salestax-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">The advisory line</p>
      <h2 class="section__heading">Automation handles the data entry. We handle the judgment.</h2>
    </header>
    <div class="stack-8">
      {%- for p in advisoryBody %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── FAQ · 8 verbatim contract Q/A; visible faq__list = FAQPage schema (same array). (H2: New York sales tax questions.) ── #}
<section class="section" id="ny-svc-salestax-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Common questions</p>
      <h2 class="section__heading">New York sales tax questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="ny-svc-salestax-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="ny-svc-salestax-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no personal name (byline-block + trust-row + meta-reviewed). (H2: Reviewed by the TechBrot Certified ProAdvisor team.) ── #}
<section class="section section--alt" id="ny-svc-salestax-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    </header>
    <div class="byline-block">
      <div class="byline-block__mark" aria-hidden="true"></div>
      <div>
        <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="byline-block__review">TechBrot Inc. &middot; Independent Certified QuickBooks ProAdvisor firm</p>
      </div>
    </div>
    <div class="prose">
      <p>Reviewed and maintained by the accounting team at <strong>TechBrot Inc.</strong>, an independent Certified QuickBooks ProAdvisor and bookkeeping firm serving New York businesses remotely across all 62 counties. New York sales-tax figures &mdash; the 8.875% NYC combined rate, the $500K / 100-transaction economic-nexus threshold, Form DTF-17, the quarterly due dates, and SaaS taxability &mdash; reflect rules current as of the date below and are reviewed periodically against the <a href="https://www.tax.ny.gov/" rel="noopener nofollow">NY Department of Taxation &amp; Finance</a>. This page is educational and operational; it is not tax advice or a substitute for filing. TechBrot provides bookkeeping and sales-tax tracking and coordinates with your CPA, who files; we do not file New York sales-tax or income-tax returns and do not represent clients before the Tax Department.</p>
    </div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-15</span><span>Updated: 2026-06-15</span><span>Reviewed: 2026-06-15 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>
