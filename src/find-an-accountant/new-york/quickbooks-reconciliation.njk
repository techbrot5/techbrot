{# ── SUMMARY · real H2 carrying the short-version prose (right after the in-brief). (H2: The short version.) ── #}
<section class="section section--compact" id="ny-svc-qbrecon-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In short</p>
      <h2 class="section__heading">The short version.</h2>
    </header>
    <div class="stack-8">
      {%- for p in summary %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AI SUMMARY · five-question block. (H2: QuickBooks Reconciliation in New York, in five questions.) ── #}
<section class="section section--alt" id="ny-svc-qbrecon-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">QuickBooks Reconciliation in New York, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="ny-svc-qbrecon-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── WHAT'S INVOLVED · the five reconciliation workstreams (grid-3 buyer-cards). (H2 + 5 H3s) ── #}
<section class="section" id="ny-svc-qbrecon-handle">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What&rsquo;s involved</p>
      <h2 class="section__heading">How we handle quickbooks reconciliation for New York businesses.</h2>
      <p class="section__lede">Every reconciliation engagement is scoped to your accounts and delivered in your own QuickBooks file by a named Certified ProAdvisor.</p>
    </header>
    <div class="grid-3">
      {%- for s in handle %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ s.num }}</p>
        <h3 class="buyer-card__heading">{{ s.title | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── SCOPE SPLIT · what we do and what your CPA does (grid-2 buyer-cards w/ checks-list). (H2 + 2 H3s: TechBrot / Your CPA) ── #}
<section class="section section--alt" id="ny-svc-qbrecon-scope">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Honest scope</p>
      <h2 class="section__heading">What we do &mdash; and what your CPA does.</h2>
      <p class="section__lede">We reconcile the books and coordinate the handoff. Your CPA files the returns from the reconciled numbers.</p>
    </header>
    <div class="grid-2">
      {%- for col in scope %}
      <article class="buyer-card">
        <h3 class="buyer-card__heading">{{ col.title | safe }}</h3>
        <ul class="checks-list">
          {%- for item in col.items %}<li>{{ item | safe }}</li>{%- endfor %}
        </ul>
      </article>
      {%- endfor %}
    </div>
    <p class="prose">{{ scopeNote | safe }}</p>
  </div>
</section>

{# ── ADVISORY · standing brand line carried as section prose. (H2: Automation handles the data entry. We handle the judgment.) ── #}
<section class="section" id="ny-svc-qbrecon-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">The advisory line</p>
      <h2 class="section__heading">Automation handles the data entry. We handle the judgment.</h2>
    </header>
    <div class="stack-8">
      {%- for p in advisoryBody %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── FAQ · 8 verbatim contract Q/A; visible faq__list = FAQPage schema (same array). (H2: QuickBooks Reconciliation questions.) ── #}
<section class="section section--alt" id="ny-svc-qbrecon-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">QuickBooks Reconciliation questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="ny-svc-qbrecon-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="ny-svc-qbrecon-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name (byline-block + meta-reviewed). (H2: Reviewed by the TechBrot Certified ProAdvisor team.) ── #}
<section class="section" id="ny-svc-qbrecon-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    </header>
    <div class="byline-block">
      <div class="byline-block__mark" aria-hidden="true"></div>
      <div>
        <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="byline-block__review">TechBrot Inc. &middot; Independent Certified QuickBooks ProAdvisor firm</p>
      </div>
    </div>
    <div class="prose">
      <p>This page reflects how TechBrot handles New York QuickBooks reconciliation engagements. It is maintained by the Certified QuickBooks ProAdvisor team at <strong>TechBrot Inc.</strong>, a Delaware-incorporated independent ProAdvisor firm. Reconciliation is delivered as part of bookkeeping engagements; New York tax references reflect <a href="https://www.tax.ny.gov/" rel="noopener nofollow">NYS Department of Taxation and Finance</a> rules current as of the date below and are reviewed periodically. TechBrot performs bookkeeping and QuickBooks work and coordinates with your CPA, who files; it does not file New York tax returns or represent clients before tax authorities.</p>
    </div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-07</span><span>Updated: 2026-06-07</span><span>Reviewed: 2026-06-07 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>
