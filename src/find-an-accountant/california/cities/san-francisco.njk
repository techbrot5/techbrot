---json
{
  "layout": "layouts/t-location.njk",
  "permalink": "/find-an-accountant/california/cities/san-francisco/",
  "slug": "sf",
  "tierClass": "section--tier-hub",
  "bodyClass": "page--location",
  "callBar": true,
  "heroLight": true,
  "title": "San Francisco Bookkeeper & QuickBooks Accountant · TechBrot",
  "description": "Certified QuickBooks ProAdvisor bookkeeping for San Francisco businesses — fluent in the SF Gross Receipts Tax, California's $800 franchise tax, CDTFA sales tax & AB5. Fixed-fee. Call (877) 751-5575.",
  "breadcrumb": [
    { "name": "Home", "href": "/" },
    { "name": "Find an Accountant", "href": "/find-an-accountant/" },
    { "name": "California", "href": "/find-an-accountant/california/" },
    { "name": "San Francisco" }
  ],
  "hero": {
    "eyebrow": "San Francisco &middot; Bay Area &middot; California",
    "heading": "San Francisco bookkeeper &amp; QuickBooks accountant.",
    "subheading": "Certified QuickBooks ProAdvisor bookkeeping for San Francisco businesses &mdash; built around the city&rsquo;s Gross Receipts Tax (levied on gross receipts, not profit), California&rsquo;s $800 minimum franchise tax and FTB filing, and CDTFA sales tax. A named bookkeeper on the same file every month, kept CPA-ready for your CPA to file.",
    "actions": [
      { "label": "Get the free file review", "href": "/quickbooks/file-review/?intent=file-review", "class": "btn--primary" },
      { "label": "Speak to a ProAdvisor", "tel": true, "class": "btn--ghost" }
    ],
    "trust": [
      "Certified QuickBooks ProAdvisor team",
      "San Francisco &amp; the Bay Area",
      "Fixed-fee &middot; written scope in 3 days"
    ]
  },
  "inBrief": {
    "text": "<strong>TechBrot</strong> delivers <strong>Certified QuickBooks ProAdvisor bookkeeping for San Francisco businesses</strong> &mdash; monthly bookkeeping, <a href=\"/accounting/bookkeeping/cleanup-bookkeeping/\">cleanup</a>, and QuickBooks management by a named bookkeeper on the same file every month, fluent in the San Francisco Gross Receipts Tax and California&rsquo;s FTB and CDTFA structure. The full San Francisco summary is below.",
    "source": "Reviewed by the Certified QuickBooks ProAdvisor team at TechBrot Inc., an independent firm &mdash; not affiliated with Intuit Inc. San Francisco &amp; California tax figures verified against the CA FTB, the CDTFA, and the SF Office of the Treasurer &amp; Tax Collector."
  },
  "ctaBand": {
    "eyebrow": "San Francisco businesses start here",
    "heading": "Book a San Francisco discovery call.",
    "lede": "30 minutes. We review where your books stand and your San Francisco context &mdash; gross-receipts classification, the $800 franchise tax, CDTFA sales tax, AB5 contractor mix &mdash; and recommend the right engagement. <strong>Written fixed-fee scope within 3 business days.</strong> No pitch. Independent firm &mdash; does not file CA/SF taxes; coordinates with your CPA.",
    "actions": [
      { "label": "Book the discovery call", "href": "/contact/?intent=california&state=california&city=san-francisco&source_type=city-page&funnel_stage=BOFU", "class": "btn--primary" },
      { "label": "Speak to a ProAdvisor", "tel": true, "class": "btn--ghost" }
    ]
  }
}
---

{# ── SUMMARY · real H2 right after the in-brief. (H2: The short version.) ── #}
<section class="section section--compact" id="sf-summary-sec">
  <div class="container container--narrow">
    <header class="section__header">
      <h2 class="section__heading">The short version.</h2>
    </header>
    <p class="prose" id="sf-summary">{{ summarized | safe }}</p>
  </div>
</section>

{# ── AI SUMMARY · five-question block. (H2: San Francisco bookkeeping, in five questions.) ── #}
<section class="section" id="sf-ai-summary-sec">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">San Francisco bookkeeping, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="sf-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── LOCAL CONTEXT · the un-clonable band. (H2: Why San Francisco books are different.) ── #}
<section class="section section--alt" id="sf-local">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Bookkeeping built for how San Francisco actually taxes</p>
      <h2 class="section__heading">Why San Francisco books are different.</h2>
    </header>
    <div class="stack-8">
      {%- for p in localContext %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AREAS. (H2: San Francisco areas we serve.) ── #}
<section class="section" id="sf-areas">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Across the city &amp; the Bay</p>
      <h2 class="section__heading">San Francisco areas we serve.</h2>
    </header>
    <div class="grid-3">
      {%- for a in areas %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ a.name | safe }}</p>
        <p class="prose">{{ a.note | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── TAX STACK · grid-3. (H2: San Francisco's tax stack, at a glance.) ── #}
<section class="section section--alt" id="sf-tax">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">The taxes we build into your books</p>
      <h2 class="section__heading">San Francisco&rsquo;s tax stack, at a glance.</h2>
    </header>
    <div class="grid-3">
      {%- for t in taxStack %}
      <div class="stack-8">
        <p class="proof-strip__rating">{{ t.figure | safe }}</p>
        <p class="prose">{{ t.desc | safe }}</p>
      </div>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ taxNote | safe }}</small></p>
  </div>
</section>

{# ── INDUSTRIES · checks-list into national industry pages, with SF wrinkles. (H2: Industry-specific bookkeeping for San Francisco businesses.) ── #}
<section class="section" id="sf-industries">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">San Francisco verticals we know</p>
      <h2 class="section__heading">Industry-specific bookkeeping for San Francisco businesses.</h2>
      <p class="section__lede">Each links to our dedicated industry page, with the San Francisco wrinkles built in.</p>
    </header>
    <ul class="checks-list">
      {%- for i in industries %}
      <li><a href="{{ i.href }}">{{ i.label | safe }}</a> &mdash; {{ i.note | safe }}</li>
      {%- endfor %}
    </ul>
  </div>
</section>

{# ── SERVICES · grid-2 buyer-cards. (H2: Complete bookkeeping, San Francisco-aware. + 4 H3s) ── #}
<section class="section section--alt" id="sf-services">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What we do for San Francisco businesses</p>
      <h2 class="section__heading">Complete bookkeeping, San Francisco-aware.</h2>
    </header>
    <div class="grid-2">
      {%- for s in services %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ s.num }}</p>
        <h3 class="buyer-card__heading">{{ s.title | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
        <a class="buyer-card__cta" href="{{ s.href }}">{{ s.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── ADVISORY · standing brand line. (H2: Automation handles the data entry. We handle the judgment.) ── #}
<section class="section" id="sf-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Beyond bookkeeping</p>
      <h2 class="section__heading">Automation handles the data entry. We handle the judgment.</h2>
    </header>
    <p class="prose">{{ advisoryBody | safe }}</p>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="/contact/?intent=california-advisory&amp;state=california&amp;city=san-francisco&amp;source_type=city-page&amp;funnel_stage=BOFU">Book the discovery call</a>
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name. (H2: Reviewed by the TechBrot Certified ProAdvisor team.) ── #}
<section class="section section--alt" id="sf-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    </header>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-17</span><span>Updated: 2026-06-17</span><span>Reviewed: 2026-06-17 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{# ── FAQ · 8 Q/A; visible faq__list = FAQPage schema. (H2: San Francisco bookkeeping questions.) ── #}
<section class="section" id="sf-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">San Francisco FAQ</p>
      <h2 class="section__heading">San Francisco bookkeeping questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="sf-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="sf-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
