{#- ═══ BESPOKE MIDDLE (IN industry child, t-money) — industry-specific sections in shared
    dc-system v2 components. Spine (hero / proof / §01 in-brief #in-ind-real-estate-in-brief-text /
    §03 aiSummary / related / call / faq / cta) is layout-owned (t-money). Schema cssSelector
    anchors are #{{slug}}-summary + #{{slug}}-ai-summary-list. Section bg alternates white/sand. ═══ -#}

<section class="sec reveal" id="{{ slug }}-summary" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In one paragraph</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">{{ secSummaryH | safe }}</h2>
    <div class="prose">{%- for p in summary %}<p>{{ p | safe }}</p>{%- endfor %}</div>
  </div>
</section>

<section class="sec reveal" id="{{ slug }}-challenges">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Where the books break</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:32ch;margin-bottom:10px;">{{ secChallengesH | safe }}</h2>
    <p class="lede" style="margin:0 0 32px;max-width:64ch;">{{ secChallengesLede | safe }}</p>
    <div class="r-3">
      {%- for c in challenges %}
      <article class="dc-card"><span class="eyebrow">{{ c.signal | safe }}</span><h3>{{ c.title | safe }}</h3><div class="prose" style="font-size:15px;"><p>{{ c.body | safe }}</p></div></article>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="sec reveal" id="{{ slug }}-handle" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">What TechBrot handles</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:32ch;margin-bottom:10px;">{{ secHandleH | safe }}</h2>
    <p class="lede" style="margin:0 0 32px;max-width:66ch;">{{ secHandleLede | safe }}</p>
    <div class="r-3">
      {%- for s in handle %}
      <article class="dc-card"><span class="eyebrow">{{ s.num | safe }}</span><h3>{{ s.title | safe }}</h3><p class="prose" style="font-size:15px;margin:6px 0 12px;">{{ s.body | safe }}</p><a class="ptier__link" href="{{ s.href }}">{{ s.cta | safe }}</a></article>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="sec reveal" id="{{ slug }}-integrations">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ secIntegrationsTag | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">{{ secIntegrationsH | safe }}</h2>
    <div class="incl-card">
      <ul class="checklist">
        {%- for t in integrations %}<li>{{ t | safe }}</li>{%- endfor %}
      </ul>
    </div>
    <div class="prose" style="margin-top:18px;"><p>{{ integrationsNote | safe }}</p></div>
  </div>
</section>

<section class="sec reveal" id="{{ slug }}-process" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">How engagements work</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:30ch;margin-bottom:10px;">{{ secProcessH | safe }}</h2>
    <p class="lede" style="margin:0 0 32px;max-width:66ch;">{{ secProcessLede | safe }}</p>
    <div class="r-2">
      {%- for p in process %}
      <article class="dc-card"><span class="eyebrow">{{ p.phase }}</span><h3>{{ p.title | safe }}</h3><div class="prose" style="font-size:15px;"><p>{{ p.body | safe }}</p></div></article>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="sec reveal" id="{{ slug }}-advisory">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Beyond the books</span><span class="idx__rule"></span></div>
    <h2 class="statement" style="margin-bottom:18px;">{{ secAdvisoryH | safe }}</h2>
    <div class="prose">{%- for p in advisoryBody %}<p>{{ p | safe }}</p>{%- endfor %}</div>
    <div style="margin-top:22px;"><a class="btn btn-cta" href="/contact/?intent=indiana&amp;state=indiana&amp;source_type=industry&amp;funnel_stage=BOFU" style="display:inline-flex;align-items:center;height:48px;padding:0 22px;border-radius:11px;font-size:15px;font-weight:600;">Book the discovery call</a></div>
  </div>
</section>

<section class="sec reveal" id="{{ slug }}-review" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Page review &amp; standards</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    <div class="byline" style="display:flex;align-items:center;gap:14px;margin-bottom:18px;">
      <div class="byline__mark" aria-hidden="true" style="width:38px;height:38px;border-radius:9px;background:var(--color-accent);flex:none;"></div>
      <div><p class="byline__name" style="margin:0;font-weight:600;color:var(--color-ink);">By the Certified QuickBooks ProAdvisor team</p><p class="byline__review" style="margin:2px 0 0;">TechBrot Inc. &middot; Independent Certified QuickBooks ProAdvisor firm</p></div>
    </div>
    <div class="prose"><p>{{ reviewProse | safe }}</p></div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value" style="font-size:15px;">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-26</span><span>Updated: 2026-06-26</span><span>Reviewed: 2026-06-26 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>
