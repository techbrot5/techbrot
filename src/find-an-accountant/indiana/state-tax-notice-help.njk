{# ── SHORT VERSION · TL;DR prose. Speakable anchor #in-svc-notice-tldr-body preserved. (H2: The short version.) ── #}
<section class="sec reveal" id="in-svc-notice-tldr" style="padding-top:8px;">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">&sect;01</span><span class="idx__t">In short</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">The short version.</h2>
    <div class="prose">
      <p id="in-svc-notice-tldr-body">{{ tldr | safe }}</p>
    </div>
  </div>
</section>

{# ── NOTICE TYPES · the real IN notices (.dc-card grid, issuer/type as eyebrow). (H2: Common Indiana business tax notices.) ── #}
<section class="sec reveal" id="in-svc-notice-types" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">&sect;02</span><span class="idx__t">Know what you&rsquo;re holding</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:14px;">Common Indiana business tax notices.</h2>
    <p class="lede" style="margin:0 0 32px;max-width:62ch;">The issuing agency and the type are usually printed at the top. Match it here before you do anything else &mdash; the right response depends entirely on which notice this is. Identifying the type and deadline is where we start; your CPA, EA, or tax attorney responds.</p>
    <div class="r-3">
      {%- for n in noticeTypes %}
      <div class="dc-card">
        <p class="eyebrow" style="margin-bottom:10px;">{{ n.form | safe }}</p>
        <h3>{{ n.title | safe }}</h3>
        <p class="prose">{{ n.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
    <p class="prose" style="margin-top:24px;"><small>{{ noticeTypesNote | safe }}</small></p>
  </div>
</section>

{# ── BOOKS PROBLEMS · why so many notices are reconciliation issues + trust-fund callout (.disclose). (H2: Why so many Indiana notices are really books problems) ── #}
<section class="sec reveal" id="in-svc-notice-books">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">&sect;03</span><span class="idx__t">The most common root cause</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Why so many Indiana notices are really books problems</h2>
    <div class="prose">
      {%- for p in booksBody %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="disclose" id="in-svc-notice-trustfund" style="margin-top:26px;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true"><path d="M12 3l9 16H3z" stroke-linejoin="round"/><path d="M12 10v4M12 17.5v.3" stroke-linecap="round"/></svg>
      <div class="disclose__body"><strong>Trust-fund tax.</strong> {{ trustFund | safe }}</div>
    </div>
  </div>
</section>

{# ── SCOPE SPLIT · honest who-does-what (.incl-card + .checklist ×2). 2 frozen H3s. (H2: Who does what when a notice arrives. + 2 H3s) ── #}
<section class="sec reveal" id="in-svc-notice-scope" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">&sect;04</span><span class="idx__t">Honest scope</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:14px;">Who does what when a notice arrives.</h2>
    <p class="lede" style="margin:0 0 36px;max-width:62ch;">A clean line between the books work we do and the response and representation only a licensed professional can do.</p>
    <div class="r-2">
      <div class="incl-card">
        <h3>TechBrot handles</h3>
        <ul class="checklist">{%- for li in scopeDo %}<li>{{ li | safe }}</li>{%- endfor %}</ul>
      </div>
      <div class="incl-card">
        <h3>Your CPA or tax attorney handles</h3>
        <ul class="checklist">{%- for li in scopeDont %}<li>{{ li | safe }}</li>{%- endfor %}</ul>
      </div>
    </div>
  </div>
</section>

