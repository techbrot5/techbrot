{#- ═══ IL F2 STATE PRICING (money cluster, canonical figures). t-bofu→t-prose. Every
    heading verbatim at its level; canonical IL ranges EXACT (tldr text + `ranges` data,
    untouched). Speakable preserved: #il-svc-pricing-summary (tldr first p) +
    #il-svc-pricing-ai-summary-list (city-child cssSelector) carried onto the tldr block.
    ai-summary + faq rendered by t-prose (sec.aiH/faqH). ═══ -#}

{#- TL;DR (body) — canonical figures verbatim. #il-svc-pricing-summary = speakable;
    #il-svc-pricing-ai-summary-list (2nd speakable selector) carried here too. -#}
<section class="sec reveal" id="il-svc-pricing-tldr" style="padding-top:8px;">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In one paragraph</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:16px;">How TechBrot Illinois pricing works.</h2>
    <div class="tldr-prose" id="il-svc-pricing-ai-summary-list">
      {%- for p in tldr %}<p class="prose"{% if loop.first %} id="il-svc-pricing-summary"{% endif %} style="margin:0 0 14px;">{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{#- SHAPES — 3 engagement shapes (h3s). -#}
<section class="sec reveal hub-rt--alt" id="il-svc-pricing-shapes" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Three engagement shapes</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Every Illinois engagement fits one of three shapes.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">Pricing structure follows the shape of the work. All three run to the same standard: fixed fee, written scope, named ProAdvisor.</p>
    <div class="r-3">
      {%- for s in shapes %}
      <div class="dc-card"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ s.tag | safe }}</span><h3>{{ s.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ s.body | safe }}</p><p class="prose" style="font-size:14.5px;margin:8px 0 0;">{{ s.examples | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- THE FULL TABLE — canonical IL ranges from `ranges` data (untouched). vs-table→.cmp. -#}
<section class="sec reveal" id="il-svc-pricing-ranges">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">All pricing</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Every Illinois service, every range.</h2>
    <p class="lede" style="margin:0 0 24px;max-width:70ch;">The complete pricing landscape for Illinois businesses. Every fee is fixed and scoped in writing before work begins.</p>
    <table class="cmp">
      <caption class="sr-only">TechBrot fixed-fee Illinois pricing across all engagement types.</caption>
      <thead><tr><th scope="col">Service</th><th scope="col">Engagement type</th><th scope="col">Fee range</th><th scope="col">Cadence</th></tr></thead>
      <tbody>
        {%- for r in ranges %}
        <tr>
          <th scope="row" data-col="Service">{% if r.href %}<a href="{{ r.href }}">{{ r.service | safe }}</a>{% else %}{{ r.service | safe }}{% endif %}</th>
          <td data-col="Engagement type" style="color:var(--color-ink-mute);">{{ r.type | safe }}</td>
          <td class="num us" data-col="Fee range"><strong>{{ r.fee | safe }}</strong></td>
          <td data-col="Cadence" style="color:var(--color-ink-mute);">{{ r.cadence | safe }}</td>
        </tr>
        {%- endfor %}
      </tbody>
    </table>
    <p class="prose" style="font-size:13.5px;color:var(--color-ink-mute);margin-top:14px;">{{ rangesNote | safe }}</p>
  </div>
</section>

{#- WHY FIXED-FEE — prose. -#}
<section class="sec reveal hub-rt--alt" id="il-svc-pricing-why" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Why fixed-fee</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:14px;">Why we don&rsquo;t bill by the hour.</h2>
    <div class="prose">
      {%- for p in whyBody %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{#- INCLUDES — 6 (h3s). -#}
<section class="sec reveal" id="il-svc-pricing-includes">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">What&rsquo;s always included</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Every fixed fee includes these.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:70ch;">Regardless of service or price, every Illinois engagement includes the same six standards. They&rsquo;re not add-ons &mdash; they&rsquo;re the baseline.</p>
    <div class="r-3">
      {%- for inc in includes %}
      <div class="dc-card"><span class="eyebrow" style="display:block;margin-bottom:8px;">{{ inc.number | safe }}</span><h3>{{ inc.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;">{{ inc.body | safe }}</p></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- PRICING STANDARDS — byline + prose + trust-row. Founder-name-zero. -#}
<section class="sec reveal hub-rt--alt" id="il-svc-pricing-review" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read read--doc">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Pricing standards</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:14px;">Illinois pricing maintained by the TechBrot ProAdvisor team.</h2>
    <div class="byline">
      <svg class="byline__mark" viewBox="0 0 64 64" role="img" aria-label="TechBrot"><rect width="64" height="64" rx="14" fill="#0E4A50"></rect><g transform="translate(12.16 12.16) scale(0.62)" fill="#FCFBF8"><path d="M8 10 H38 V54 H26 V22 H8 Z"></path><rect x="42" y="10" width="14" height="12"></rect></g></svg>
      <div><p class="byline__name">By the Certified QuickBooks ProAdvisor team</p><p class="byline__review">TechBrot Inc. &middot; Independent Certified QuickBooks ProAdvisor firm</p></div>
    </div>
    <div class="prose"><p>{{ reviewProse | safe }}</p></div>
    <div class="trust-row" style="margin-top:22px;">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-18</span><span>Updated: 2026-06-18</span><span>Reviewed: 2026-06-18 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{#- RELATED — route cards (h3s). -#}
<section class="sec reveal" id="il-svc-pricing-related">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Related</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">Where to go next.</h2>
    <div class="r-2">
      {%- for r in related %}
      <a class="dc-card hub-card" href="{{ r.href }}"><h3>{{ r.title | safe }}</h3><p class="prose" style="font-size:14.5px;margin:6px 0 0;color:var(--color-ink-mute);">{{ r.body | safe }}</p><span class="hub-card__go">{{ r.cta | safe }} <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 12h15M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg></span></a>
      {%- endfor %}
    </div>
  </div>
</section>
