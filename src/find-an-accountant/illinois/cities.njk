{#- ═══ BESPOKE BODY (IL cities sub-hub) — v2 dc-system, full depth, FROZEN content.
    Section ids == this page's own pageGraph anchors (#il-cities-summary speakable +
    #il-cities-grid + #il-cities-faq handled by layout). ═══ -#}

{# ── SUMMARY · real H2 carrying the TL;DR (.idx + .prose) — sand ── #}
<section class="sec reveal" id="il-cities-summary-sec" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In short</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Illinois bookkeeping, city by city.</h2>
    <div class="prose"><p id="il-cities-summary">{{ summary | safe }}</p></div>
  </div>
</section>

{# ── CITY ROUTING · dedicated metro pages → .rel-card grid (r-3), each links its child ── #}
<section class="sec reveal" id="il-cities-grid">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Dedicated city pages</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Illinois metros we serve.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:62ch;">Each city page is built around that city&rsquo;s real economy &mdash; not a name swap.</p>
    <div class="r-3">
      {%- for c in cities %}
      <a class="rel-card" href="{{ c.href }}"><h3 class="rel-card__t">{{ c.name | safe }}</h3><p class="rel-card__d">{{ c.note | safe }}</p><span class="ptier__link" style="margin-top:10px;">{{ c.name | safe }} bookkeeper &rarr;</span></a>
      {%- endfor %}
    </div>
    <div class="prose" style="margin-top:26px;"><p>{{ citiesNote | safe }}</p></div>
  </div>
</section>
