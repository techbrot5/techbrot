---

{# ── SUMMARY ── #}
<section class="section section--compact" id="il-cities-summary-sec">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In short</p>
      <h2 class="section__heading">Illinois bookkeeping, city by city.</h2>
    </header>
    <p class="prose" id="il-cities-summary">{{ summary | safe }}</p>
  </div>
</section>

{# ── CITIES GRID · the dedicated metro pages (buyer-cards) ── #}
<section class="section" id="il-cities-grid">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Dedicated city pages</p>
      <h2 class="section__heading">Illinois metros we serve.</h2>
      <p class="section__lede">Each city page is built around that city&rsquo;s real economy &mdash; not a name swap.</p>
    </header>
    <div class="grid-3">
      {%- for c in cities %}
      <article class="buyer-card">
        <h3 class="buyer-card__heading">{{ c.name | safe }}</h3>
        <p class="buyer-card__body">{{ c.note | safe }}</p>
        <a class="buyer-card__cta" href="{{ c.href }}">{{ c.name | safe }} bookkeeper &rarr;</a>
      </article>
      {%- endfor %}
    </div>
    <p class="prose">{{ citiesNote | safe }}</p>
  </div>
</section>

{# ── FAQ ── #}
<section class="section section--alt" id="il-cities-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">FAQ</p>
      <h2 class="section__heading">Illinois cities &amp; coverage questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="il-cities-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="il-cities-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
