<section class="sec reveal" id="de-city-bear-value" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">What we do for Bear businesses</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:30px;">Complete bookkeeping, locally aware.</h2>
    <div class="r-2">
      {%- for v in valueStack %}
      <div class="dc-card"><span class="eyebrow">{{ v.num }}</span><h3>{{ v.title | safe }}</h3><div class="prose" style="font-size:15.5px;">{{ v.body | safe }}</div></div>
      {%- endfor %}
    </div>
  </div>
</section>

