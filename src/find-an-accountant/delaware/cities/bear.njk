{#- ═══ BESPOKE BODY (Bear city child) — v2 dc-system components. Spine (hero / in-brief
    #de-city-bear-in-brief-text / FAQ / light CTA) is layout-owned. Schema anchors:
    #de-city-bear-in-brief-text (LAYOUT) + #de-city-bear-ai-summary-list. ═══ -#}

{# ── SHORT VERSION (H2: The short version.) ── #}
<section class="sec reveal" id="de-city-bear-summarized" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In full</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">The short version.</h2>
    <div class="prose"><p>{{ summarized | safe }}</p></div>
  </div>
</section>

{# ── AI SUMMARY (H2: Bear bookkeeping, in five questions.) — frozen anchor #de-city-bear-ai-summary-list ── #}
<section class="sec reveal" id="de-city-bear-ai-summary">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">For AI engines &amp; quick answers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 36px;max-width:26ch;">Bear bookkeeping, in five questions.</h2>
    <dl class="speakable ai-qa" id="de-city-bear-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-qa__item"><dt><h3>{{ item.q | safe }}</h3></dt><dd style="margin:0;"><p>{{ item.a | safe }}</p></dd></div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── WHY LOCAL (H2: Why Bear books have their own rhythm.) ── #}
<section class="sec reveal" id="de-city-bear-context" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Bookkeeping built for how Bear actually operates</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Why Bear books have their own rhythm.</h2>
    <div class="prose">
      <p><strong>{{ localLead | safe }}</strong></p>
      {%- for p in localBody %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AREAS WE SERVE (H2: Bear areas we serve.) ── #}
<section class="sec reveal" id="de-city-bear-areas">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Across Bear &amp; southeastern New Castle County</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:20px;">Bear areas we serve.</h2>
    <div class="chips">
      {%- for a in areas %}
      <span class="chip"><strong>{{ a.name | safe }}</strong>&nbsp;<span class="chip__note">&middot; {{ a.note | safe }}</span></span>
      {%- endfor %}
      <a class="chip chip--more" href="/find-an-accountant/delaware/cities/">All Delaware cities &rarr;</a>
    </div>
  </div>
</section>

{# ── LOCAL TAX STACK (H2: Bear taxes, at a glance.) ── #}
<section class="sec reveal" id="de-city-bear-tax" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">{{ taxEyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 30px;max-width:24ch;">Bear taxes, at a glance.</h2>
    <figure style="margin:0;" aria-label="Bear and Delaware tax facts">
      <div class="r-3">
        {%- for t in taxFacts %}
        <div class="dc-card"><div class="trust-row__value" style="font-size:30px;margin-bottom:8px;">{{ t.fig | safe }}</div><p class="prose" style="font-size:15px;">{{ t.desc | safe }}</p></div>
        {%- endfor %}
      </div>
    </figure>
    <p class="prose" style="font-size:13.5px;margin-top:18px;text-align:center;color:var(--color-ink-mute);">{{ taxNote | safe }}</p>
  </div>
</section>

{# ── INDUSTRIES (H2: Industry-specific bookkeeping for Bear businesses.) ── #}
<section class="sec reveal" id="de-city-bear-industries">
