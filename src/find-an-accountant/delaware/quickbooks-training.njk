{#- WHAT TRAINING IS — speakable summary (#de-svc-training-summary) — white -#}
<section class="sec reveal" id="de-svc-training-summary">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In one paragraph</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">What Delaware QuickBooks training actually is.</h2>
    <div class="prose speakable">
      {%- for p in summary %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{#- WHAT WE COVER — the five training topics (numbered lift cards) — sand -#}
<section class="sec reveal" id="de-svc-training-covers" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__t">What we cover</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:24ch;margin-bottom:12px;">What Delaware QuickBooks training covers.</h2>
    <p class="lede" style="margin:0 0 36px;max-width:62ch;">Every session is scoped to your role and your file, delivered live by a named Certified ProAdvisor and recorded for the team.</p>
    <div class="r-2">
      {%- for c in covers %}
      <div class="lift"><span class="lift__n">{{ c.num | safe }}</span><div><h3>{{ c.title | safe }}</h3><p>{{ c.body | safe }}</p></div></div>
      {%- endfor %}
    </div>
  </div>
</section>

{#- HONEST SCOPE — what training gives you / what it doesn't (two checklist cards) + note — white -#}
<section class="sec reveal" id="de-svc-training-scope">
  <div class="ct">
    <div class="idx"><span class="idx__t">Honest scope</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:24ch;margin-bottom:36px;">What training gives you &mdash; and what it doesn&rsquo;t.</h2>
    <div class="r-2">
      <div class="incl-card">
        <h3>Training covers</h3>
        <ul class="checklist">{%- for t in scopeDo %}<li>{{ t | safe }}</li>{%- endfor %}</ul>
      </div>
      <div class="incl-card">
        <h3>Not training</h3>
        <ul class="checklist">{%- for t in scopeDont %}<li>{{ t | safe }}</li>{%- endfor %}</ul>
      </div>
    </div>
    <p class="prose" style="margin-top:28px;max-width:72ch;">{{ scopeNote | safe }}</p>
  </div>
</section>

{#- THE ADVISORY LINE — statement + body prose — sand -#}
<section class="sec reveal" id="de-svc-training-advisory" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
