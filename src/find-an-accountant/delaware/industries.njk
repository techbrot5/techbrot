{#- ═══ BESPOKE BODY (DE industries sub-hub) — mirrors the proven NY industries hub
    (find-an-accountant/new-york/industries.njk). Spine (hero / in-brief
    #de-industries-in-brief-text / FAQ [sec.faqH] / light CTA) is layout-owned
    (t-location). Every section id == this page's own pageGraph schema anchor; the
    AI-summary list keeps #de-industries-ai-summary-list intact. ═══ -#}

{# ── INDUSTRY ACCOUNTING, PLAINLY · real H2 carrying the one-paragraph summary (right after the in-brief) ── #}
<section class="sec reveal" id="de-industries-coverage" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In one paragraph</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Delaware industry accounting, plainly.</h2>
    <div class="prose"><p>{{ coverage | safe }}</p></div>
  </div>
</section>

{# ── AI SUMMARY · 5 entity-dense Q&As — frozen anchor #de-industries-ai-summary-list ── #}
<section class="sec reveal" id="de-industries-ai-summary">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">For AI engines &amp; quick answers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 36px;max-width:28ch;">Delaware industry accounting, in five questions.</h2>
    <dl class="speakable ai-qa" id="de-industries-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-qa__item"><dt><h3>{{ item.q | safe }}</h3></dt><dd style="margin:0;"><p>{{ item.a | safe }}</p></dd></div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── FEATURED INDUSTRIES · 6 dedicated DE industry pages (rel-card grid) ── #}
<section class="sec reveal" id="de-industries-featured" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Delaware industry expertise</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Where we go deep in Delaware.</h2>
    <p class="lede" style="margin:0 0 28px;max-width:64ch;">Six industries with dedicated Delaware pages &mdash; each built around the number that runs that business, with the state&rsquo;s rules included.</p>
    <div class="r-3">
      {%- for c in featured %}
      <a class="rel-card" href="{{ c.href }}">
        <span class="eyebrow" style="display:block;margin-bottom:8px;">{{ c.num }} &middot; {{ c.eyebrow | safe }}</span>
        <h3 class="rel-card__t">{{ c.heading | safe }}</h3>
        <p class="rel-card__d">{{ c.body | safe }}</p>
        <p class="rel-card__d" style="margin-top:8px;"><strong>Focus</strong> &middot; {{ c.focus | safe }}</p>
        <span class="ptier__link" style="margin-top:12px;">{{ c.cta | safe }}</span>
      </a>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── WHY INDUSTRY · context prose ── #}
<section class="sec reveal" id="de-industries-why">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Why it matters</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Generic bookkeeping misses the number that runs your business &mdash; twice over in Delaware.</h2>
    <div class="prose">
      {%- for p in why %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── MORE INDUSTRIES · additional sectors routed to the global industry pages (additive routing) ── #}
<section class="sec reveal" id="de-industries-more" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">More Delaware industries</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">We build for these Delaware industries too.</h2>
    <p class="lede" style="margin:0 0 24px;max-width:64ch;">The same operating standard and Certified ProAdvisor delivery, with each industry&rsquo;s real Delaware angle.</p>
    <div class="r-2">
      {%- for c in moreIndustries %}
      <a class="rel-card" href="{{ c.href }}"><h3 class="rel-card__t">{{ c.name | safe }}</h3><p class="rel-card__d">{{ c.angle | safe }}</p><span class="ptier__link" style="margin-top:10px;">Explore &rarr;</span></a>
      {%- endfor %}
    </div>
    <div class="prose" style="margin-top:22px;"><p><small>{{ moreNote | safe }}</small></p></div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name ── #}
<section class="sec reveal" id="de-industries-review">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Page review &amp; standards</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    <div class="byline" style="display:flex;align-items:center;gap:14px;margin-bottom:18px;">
      <div class="byline__mark" aria-hidden="true" style="width:38px;height:38px;border-radius:9px;background:var(--color-accent);flex:none;"></div>
      <div>
        <p class="byline__name" style="margin:0;font-weight:600;color:var(--color-ink);">By the Certified QuickBooks ProAdvisor team</p>
        <p class="byline__review" style="margin:2px 0 0;">TechBrot Inc. &middot; Independent Certified ProAdvisor firm</p>
      </div>
    </div>
    <div class="prose">
      <p>Maintained by the accounting team at <strong>TechBrot Inc.</strong>, a Delaware-incorporated independent Certified QuickBooks ProAdvisor firm with its office in Middletown, serving New Castle, Kent, and Sussex counties, and reviewed for technical accuracy across the industries represented here &mdash; including Delaware-specific rules (the gross receipts tax by business activity, the annual franchise-tax reserve, and Wilmington&rsquo;s wage and net-profits tax per the <a href="https://revenue.delaware.gov/" rel="noopener nofollow">Delaware Division of Revenue</a> and <a href="https://corp.delaware.gov/" rel="noopener nofollow">Division of Corporations</a>). TechBrot keeps the books and coordinates with your CPA and registered agent, who file.</p>
    </div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value" style="font-size:15px;">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-25</span><span>Updated: 2026-06-25</span><span>Reviewed: 2026-06-25 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{# ── RELATED · next-step rel-cards ── #}
<section class="sec reveal" id="de-industries-related" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Related</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:28px;">Related Delaware services.</h2>
    <div class="r-2">
      {%- for r in related %}
      <a class="rel-card" href="{{ r.href }}"><h3 class="rel-card__t">{{ r.name | safe }}</h3><p class="rel-card__d">{{ r.body | safe }}</p><span class="ptier__link" style="margin-top:10px;">{{ r.cta | safe }}</span></a>
      {%- endfor %}
    </div>
  </div>
</section>
