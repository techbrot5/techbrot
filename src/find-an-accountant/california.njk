{# ── COMPARISON (H2: TechBrot vs. the alternatives for California businesses.) ── #}
<section class="section section--alt" id="ca-pillar-comparison">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">How we compare</p>
      <h2 class="section__heading">TechBrot vs. the alternatives for California businesses.</h2>
      <p class="section__lede">An honest read on where TechBrot fits and where it doesn&rsquo;t. Most California businesses end up using TechBrot <em>and</em> a local CA CPA together &mdash; TechBrot handles the QuickBooks operations; the CPA handles FTB filings and tax strategy.</p>
    </header>
    <div class="vs-scroll">
      <table class="vs-table">
        <caption class="sr-only">TechBrot vs. local California CPA vs. national remote bookkeeping for California businesses.</caption>
        <thead><tr><th scope="col">Dimension</th><th scope="col" class="vs-table__us">TechBrot</th><th scope="col">Local CA CPA</th><th scope="col">National remote bookkeeping</th></tr></thead>
        <tbody>
          {%- for r in comparison %}
          <tr><th scope="row">{{ r.dim | safe }}</th>
            <td class="vs-table__us"{% if r.winner == 'us' %} data-winner="us"{% endif %}>{{ r.us | safe }}</td>
            <td{% if r.winner == 'them' %} data-winner="them"{% endif %}>{{ r.cpa | safe }}</td>
            <td>{{ r.remote | safe }}</td>
          </tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
    <p class="prose">{{ comparisonVerdict | safe }}</p>
    <p class="prose"><small>{{ comparisonRelated | safe }}</small></p>
  </div>
</section>

