---json
{
  "layout": "layouts/t-state-pillar.njk",
  "permalink": "/find-an-accountant/california/",
  "slug": "ca-pillar",
  "heroMotif": "partials/motif-align-full.svg",
  "tierClass": "section--tier-hub",
  "bodyClass": "page--location",
  "callBar": true,
  "title": "California QuickBooks ProAdvisors & Bookkeeping · TechBrot",
  "description": "Certified QuickBooks ProAdvisors & bookkeeping for California businesses, all 58 counties. AB5, district sales tax, ASC 606 for SaaS. Call (877) 751-5575.",
  "breadcrumb": [
    { "name": "Home", "href": "/" },
    { "name": "Find an Accountant", "href": "/find-an-accountant/" },
    { "name": "California" }
  ],
  "heroFigure": "taccount",
  "hero": {
    "trust": [
      "Certified QuickBooks ProAdvisor team",
      "California businesses &middot; all 58 counties",
      "Fixed-fee &middot; written scope in 3 days"
    ],
    "eyebrow": "California &middot; LA to the Bay Area &middot; All 58 Counties",
    "heading": "QuickBooks ProAdvisors &amp; Bookkeeping for California Businesses.",
    "subheading": "Professional bookkeeping, QuickBooks setup and cleanup, payroll, and sales tax compliance &mdash; delivered directly by TechBrot, with trusted partner practices in California where in-region presence adds value. Built around California&rsquo;s AB5 worker-classification rules, district sales tax (the most complex in the U.S.), the $800 FTB franchise tax, and the highest personal income tax in the country &mdash; and the operational realities of running a SaaS company, agency, ecommerce brand, or production business from Los Angeles to Silicon Valley.",
    "actions": [
      { "label": "Book the discovery call", "href": "/contact/?intent=california&state=california&source_type=location&funnel_stage=MOFU", "class": "btn--primary" },
      { "label": "Send the Discovery Brief", "href": "#ca-pillar-intake", "class": "btn--ghost" },
      { "label": "Speak to a ProAdvisor", "tel": true, "class": "btn--ghost" }
    ]
  },
  "inBrief": {
    "text": "<strong>TechBrot</strong> delivers <strong>Certified QuickBooks ProAdvisor services</strong>, California bookkeeping, QuickBooks setup, cleanup, migration, California sales tax compliance, and fractional CFO engagements to California businesses across <strong>all 58 counties</strong> &mdash; from Los Angeles and San Diego to San Francisco, San Jose, and Sacramento. The full California summary is below.",
    "source": "Reviewed by the Certified QuickBooks ProAdvisor team at TechBrot Inc., an independent firm &mdash; not affiliated with Intuit Inc. CA rates verified against the FTB, CDTFA, and EDD."
  },
  "ctaBand": {
    "eyebrow": "California businesses start here",
    "heading": "Book a California discovery call.",
    "lede": "30 minutes. We review where your books are, your California operational context &mdash; AB5 contractor exposure, district sales-tax footprint, ASC 606 for SaaS, multi-state activity &mdash; and recommend the right engagement. <strong>Written fixed-fee scope within 3 business days.</strong> No pitch. Independent firm &mdash; does not file CA/federal taxes; coordinates with your CPA.",
    "actions": [
      { "label": "Book the discovery call", "href": "/contact/?intent=california&state=california&source_type=location&funnel_stage=BOFU", "class": "btn--primary" },
      { "label": "Speak to a ProAdvisor", "tel": true, "class": "btn--ghost" }
    ]
  }
}
---

{# ── SUMMARY · real H2 carrying the California summary prose (right after the in-brief) ── #}
<section class="section section--compact" id="ca-pillar-summarized">
  <div class="container container--narrow">
    <header class="section__header">
      <h2 class="section__heading">TechBrot in California, summarized.</h2>
    </header>
    <p class="prose">{{ summarized | safe }}</p>
  </div>
</section>

{# ── CREDENTIALS · proof-strip + cert line (H2: Certified QuickBooks ProAdvisor credentials) ── #}
<section class="section section--compact section--tier-hub" id="ca-pillar-credentials">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Certified by Intuit</p>
      <h2 class="section__heading">Certified QuickBooks ProAdvisor credentials</h2>
    </header>
    <p class="prose">{{ credLede | safe }}</p>
    <ul class="proof-strip" role="list">
      {%- for b in credBadges %}
      <li class="proof-strip__item"><b>{{ b.label }}</b> <span class="sr-only">{{ b.name }}</span></li>
      {%- endfor %}
    </ul>
    <div class="trust-row">
      {%- for r in trustRow %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.value | safe }}</p><p class="trust-row__label">{{ r.label | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
  </div>
</section>

{# ── STATE BY THE NUMBERS · proof-strip stat row (H2: The state by the numbers.) ── #}
<section class="section section--alt" id="ca-pillar-stats">
  <div class="container">
    <header class="section__header section__header--centered">
      <p class="section__eyebrow">California at a glance</p>
      <h2 class="section__heading">The state by the numbers.</h2>
      <p class="section__lede">A short read on the operational profile that shapes how accounting is done in California &mdash; from the Bay Area tech corridor to LA&rsquo;s production economy and the Central Valley.</p>
    </header>
    <div class="grid-3">
      {%- for s in stats %}
      <div><div class="stat__value">{{ s.figure | safe }}</div><div class="stat__label">{{ s.label | safe }}</div></div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── AI SUMMARY (H2: TechBrot in California, in five questions.) ── #}
<section class="section" id="ca-pillar-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">TechBrot in California, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="ca-pillar-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── GLOSSARY (H2: The California terms that matter for QuickBooks & bookkeeping.) ── #}
<section class="section section--alt" id="ca-pillar-glossary">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">California accounting glossary</p>
      <h2 class="section__heading">The California terms that matter for QuickBooks &amp; bookkeeping.</h2>
      <p class="section__lede">Short, specific, definitional. These are the terms that come up in nearly every California engagement &mdash; and the ones AI engines and search engines reach for when answering California accounting questions.</p>
    </header>
    <div class="grid-2">
      {%- for g in stateTerms %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ g.term | safe }}</p>
        <p class="prose">{{ g.def | safe }}</p>
      </div>
      {%- endfor %}
    </div>
    <p class="prose"><small>Always confirm current rates and thresholds against the <a href="https://www.ftb.ca.gov/" rel="noopener nofollow">Franchise Tax Board</a>, the <a href="https://www.cdtfa.ca.gov/" rel="noopener nofollow">CDTFA</a>, and the <a href="https://edd.ca.gov/" rel="noopener nofollow">EDD</a>.</small></p>
  </div>
</section>

{# ── DELIVERY · direct vs partners (H2: What we deliver in California. + 2 H3s) ── #}
<section class="section" id="ca-pillar-delivery">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Service coverage</p>
      <h2 class="section__heading">What we deliver in California.</h2>
      <p class="section__lede">Two delivery modes, one operating standard. Engagements route to direct or network based on the work required, your location in the state, and industry specialization.</p>
    </header>
    <div class="grid-2">
      {%- for d in delivery %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ d.eyebrow | safe }}</p>
        <h3 class="buyer-card__heading">{{ d.heading | safe }}</h3>
        <p class="buyer-card__body">{{ d.lede | safe }}</p>
        <ul class="checks-list">{%- for li in d.list %}<li>{{ li | safe }}</li>{%- endfor %}</ul>
        <a class="buyer-card__cta" href="{{ d.href }}">{{ d.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ deliveryNote | safe }}</small></p>
  </div>
</section>

{# ── CONTEXT (H2: What makes California accounting different. + 4 H3s) ── #}
<section class="section section--alt" id="ca-pillar-context">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why California is different</p>
      <h2 class="section__heading">What makes California accounting different.</h2>
      <p class="section__lede">California&rsquo;s tax structure, worker-classification regime, and industry concentration create accounting requirements that don&rsquo;t look like any other state. Generic out-of-state bookkeeping &mdash; or bookkeepers unfamiliar with AB5 and district sales tax &mdash; misses what matters most.</p>
    </header>
    <div class="grid-2">
      {%- for c in context %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ c.category | safe }}</p>
        <h3>{{ c.heading | safe }}</h3>
        {%- for p in c.body %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
      </div>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ contextNote | safe }}</small></p>
  </div>
</section>

{# ── SCENARIOS · honestly-labeled composites (H2: What a California engagement actually looks like. + 3 H3s) ── #}
<section class="section" id="ca-pillar-scenarios">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">California scenarios</p>
      <h2 class="section__heading">What a California engagement actually looks like.</h2>
      <p class="section__lede">{{ scenariosNote | safe }}</p>
    </header>
    <div class="grid-3">
      {%- for s in scenarios %}
      <article class="stack-8">
        <p class="section__eyebrow">{{ s.tag | safe }}</p>
        <h3>{{ s.heading | safe }}</h3>
        {%- for p in s.body %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
        <a class="buyer-card__cta" href="{{ s.href }}">{{ s.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── REPRESENTATIVE OUTCOMES · REFRAMED per R5 (H2: Recent California results.) ── #}
<section class="section section--alt" id="ca-pillar-outcomes">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Representative outcomes</p>
      <h2 class="section__heading">Recent California results.</h2>
    </header>
    <div class="grid-3">
      {%- for o in outcomes %}
      <div><div class="stat__value">{{ o.figure | safe }}</div><div class="stat__label">{{ o.detail | safe }}<br><small>{{ o.meta | safe }}</small></div></div>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ outcomesNote | safe }}</small></p>
  </div>
</section>

{# ── ADVISORY · standing brand line (H2: Automation handles the data entry. We handle the judgment.) ── #}
<section class="section" id="ca-pillar-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Beyond bookkeeping</p>
      <h2 class="section__heading">Automation handles the data entry. We handle the judgment.</h2>
    </header>
    <p class="prose">{{ advisoryBody | safe }}</p>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="/contact/?intent=california-advisory&amp;state=california&amp;source_type=location&amp;funnel_stage=BOFU">Book the discovery call</a>
    </div>
    <p class="prose"><a href="/accounting/advisory/fractional-cfo/">Fractional CFO (California)</a></p>
  </div>
</section>

{# ── INDUSTRIES (H2: Industry-specific accounting for California's economy. + 6 H3s) ── #}
<section class="section" id="ca-pillar-industries">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">California industries we serve</p>
      <h2 class="section__heading">Industry-specific accounting for California&rsquo;s economy.</h2>
      <p class="section__lede">California&rsquo;s industry mix is unlike any other state. Our engagements concentrate in the sectors that drive California&rsquo;s economy &mdash; each with its own QuickBooks configuration, revenue recognition, and compliance requirements.</p>
    </header>
    <div class="grid-3">
      {%- for i in industries %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ i.num }}</p>
        <h3>{{ i.name | safe }}</h3>
        <p class="prose">{{ i.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ industriesNote | safe }}</small></p>
  </div>
</section>

{# ── SERVICES · buyer-card content (H2: Find the right service for your California business. + 6 H3s) ── #}
<section class="section section--alt" id="ca-pillar-services">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Services for California businesses</p>
      <h2 class="section__heading">Find the right service for your California business.</h2>
      <p class="section__lede">The engagements below describe what we deliver for California businesses, with fixed-fee starting ranges and cadence. Book the discovery call and we&rsquo;ll scope the right one for you.</p>
    </header>
    <div class="grid-3">
      {%- for s in services %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ s.eyebrow }}</p>
        <h3 class="buyer-card__heading">{{ s.name | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
        <div class="proof-strip">
          <span class="proof-strip__item"><b>Starting</b> {{ s.starting | safe }}</span>
          <span class="proof-strip__item"><b>Cadence</b> {{ s.cadence | safe }}</span>
        </div>
        <a class="buyer-card__cta" href="{{ s.href }}">{{ s.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ servicesNote | safe }}</small></p>
  </div>
</section>

{# ── ECOSYSTEM (H2: Every California page in one place. + 6 cluster H3s) — NO child links; content describes coverage ── #}
<section class="section" id="ca-pillar-ecosystem">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">The full California coverage map</p>
      <h2 class="section__heading">Every California page in one place.</h2>
      <p class="section__lede">California is a complete authority hub covering every service, industry, city, and tax topic California business owners search for. The clusters below map the full coverage &mdash; dedicated California pages publish on a rolling cadence.</p>
    </header>
    <div class="grid-3">
      {%- for cl in ecosystem %}
      <article class="stack-8">
        <p class="section__eyebrow">{{ cl.eyebrow }}</p>
        <h3>{{ cl.heading | safe }}</h3>
        <p class="prose">{{ cl.lede | safe }}</p>
        <ul class="checks-list">
          {%- for l in cl.links %}<li>{% if l.href %}<a href="{{ l.href }}">{{ l.label | safe }}</a>{% else %}{{ l.label | safe }}{% endif %}{% if l.tag %} <span class="proof-strip__rating">{{ l.tag | safe }}</span>{% endif %}</li>{%- endfor %}
        </ul>
      </article>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ ecosystemNote | safe }}</small></p>
  </div>
</section>

{# ── PRICING (H2: Fixed-fee starting ranges for California engagements.) ── #}
<section class="section section--alt" id="ca-pillar-pricing">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">California pricing</p>
      <h2 class="section__heading">Fixed-fee starting ranges for California engagements.</h2>
      <p class="section__lede">Every California engagement is quoted as a fixed fee against a written scope before any work begins &mdash; no hourly billing. Final scope and fee are delivered in writing within 3 business days of the discovery call.</p>
    </header>
    <div class="vs-scroll">
      <table class="vs-table" aria-describedby="ca-pillar-pricing-note">
        <caption class="sr-only">Indicative fixed-fee starting ranges for California QuickBooks and bookkeeping engagements.</caption>
        <thead><tr><th scope="col">Engagement</th><th scope="col">Starting range</th><th scope="col">Cadence</th><th scope="col">California notes</th></tr></thead>
        <tbody>
          {%- for r in pricing %}
          <tr><th scope="row">{% if r.href %}<a href="{{ r.href }}">{{ r.svc | safe }}</a>{% else %}{{ r.svc | safe }}{% endif %}</th><td><strong>{{ r.range | safe }}</strong></td><td>{{ r.cadence | safe }}</td><td>{{ r.notes | safe }}</td></tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
    <p class="prose" id="ca-pillar-pricing-note"><small>{{ pricingNote | safe }}</small></p>
  </div>
</section>

{# ── CITIES + COUNTIES (H2: Serving California businesses statewide. + 2 H3s) — NO child links ── #}
<section class="section" id="ca-pillar-cities">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Cities &amp; metros</p>
      <h2 class="section__heading">Serving California businesses statewide.</h2>
      <p class="section__lede">TechBrot serves California businesses across <strong>all 58 counties</strong>. Below are the major metros where demand concentrates, plus a representative sample of the counties served &mdash; all delivered remotely today.</p>
    </header>
    <h3>Top California metros &mdash; each has a dedicated city page</h3>
    <ul class="checks-list">
      {%- for c in cities %}
      <li>{{ c.name | safe }} &mdash; {{ c.county | safe }}</li>
      {%- endfor %}
    </ul>
    <h3>California counties served &mdash; representative sample</h3>
    <p class="prose">{{ countyProse | safe }}</p>
    <p class="prose"><small>{{ citiesNote | safe }}</small></p>
  </div>
</section>

{# ── INTAKE · dual-path call + shared intake-form partial (H2: Two ways to start... + 2 H3s) ── #}
<section class="section section--alt" id="ca-pillar-intake">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Talk to a Certified ProAdvisor</p>
      <h2 class="section__heading">Two ways to start a California engagement.</h2>
      <p class="section__lede">Both paths go to the same Certified ProAdvisor. Pick the one that fits how you work.</p>
    </header>

    <div class="grid-2">
      <div class="stack-8">
        <div class="byline-block">
          <div class="byline-block__mark" aria-hidden="true"></div>
          <div>
            <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
            <p class="byline-block__review">{{ teamDavid.name }} &middot; {{ teamDavid.role }}</p>
          </div>
        </div>
        <p class="section__eyebrow">{{ teamDavid.creds | safe }}</p>
        <p class="prose">{{ teamDavid.line | safe }}</p>
        <a class="buyer-card__cta" href="https://proadvisor.intuit.com/" rel="noopener nofollow">Verify on Intuit&rsquo;s ProAdvisor directory <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a>
      </div>
      <div class="stack-8">
        <div class="byline-block">
          <div class="byline-block__mark" aria-hidden="true"></div>
          <div>
            <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
            <p class="byline-block__review">{{ teamIntake.name | safe }} &middot; {{ teamIntake.role }}</p>
          </div>
        </div>
        <p class="section__eyebrow">{{ teamIntake.creds | safe }}</p>
        <p class="prose">{{ teamIntake.line | safe }}</p>
      </div>
    </div>

    <div class="grid-2">
      <article class="buyer-card">
        <p class="buyer-card__opener">Option 01</p>
        <h3 class="buyer-card__heading">Call directly.</h3>
        <p class="buyer-card__body">A Certified ProAdvisor answers &mdash; not a call center. Best for same-day diagnostics, behind-on-the-books situations, or AB5 and CDTFA urgencies.</p>
        <a class="btn btn--primary btn--lg" href="tel:{{ site.phone.e164 }}" data-tb-event="phone_click">Speak to a ProAdvisor</a>
        <ul class="checks-list">{%- for a in callAssurance %}<li>{{ a | safe }}</li>{%- endfor %}</ul>
      </article>
      <div class="contact-form-wrap">
        <h3 class="buyer-card__heading" id="ca-pillar-intake-form-heading">Send a short discovery brief.</h3>
        <p class="prose">Six fields. We respond by the next business day with a path forward &mdash; a scoping call or, if not a fit, a referral. <strong>Includes a free QuickBooks file review &mdash; we&rsquo;ll identify the top 3 issues in your file before any engagement begins.</strong></p>
        {%- set intakePrefix = "ca-pillar" %}
        {%- set intakeFormId = "ca-pillar-intake-form" %}
        {%- set intakeIntent = "california" %}
        {%- set intakeSourceType = "location" %}
        {%- set intakeFunnelStage = "MOFU" %}
        {%- set intakeLegend = "What we should discuss for your California business" %}
        {%- set intakeSubmit = "Send the Discovery Brief" %}
        {%- set intakeReassurance = "Same-day diagnostic for emergencies, 1 business day for scoping, written fixed-fee scope within 3 business days of the first call." %}
        {% include "partials/intake-form.njk" %}
      </div>
    </div>
  </div>
</section>

{# ── OPERATORS · partner placeholder + vetting standards (H2: Trusted California partner practices. + 2 H3s) ── #}
<section class="section" id="ca-pillar-operators">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">California partner practices</p>
      <h2 class="section__heading">Trusted California partner practices.</h2>
      <p class="section__lede">When in-region presence, deep SaaS or entertainment specialization, or local CDTFA and EDD coordination matters, engagements route to a vetted California operator.</p>
    </header>
    <div class="grid-2">
      <article class="buyer-card">
        <p class="buyer-card__opener">Partner practice &middot; Onboarding 2026</p>
        <h3 class="buyer-card__heading">California partner practice slot open</h3>
        <p class="buyer-card__body">We&rsquo;re onboarding vetted California accounting practices as partner practices for the state. Until they go live, <strong>TechBrot delivers all California engagements directly</strong> &mdash; same standards, same fixed-fee scoping, same Certified ProAdvisor credentials. If you&rsquo;re a California accounting practice interested in joining the TechBrot partner practices: <a href="/partners/">apply here</a>.</p>
        <a class="buyer-card__cta" href="/partners/">Apply to partner practices <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a>
      </article>
      <div class="stack-8">
        <p class="section__eyebrow">The vetting standard</p>
        <h3>What a California partner practice must meet.</h3>
        <p class="prose">Every operator runs under the same standard TechBrot delivers directly. The bar to carry the brand in California:</p>
        <ul class="checks-list">
          {%- for o in operatorStandards %}
          <li><strong>{{ o.term | safe }}.</strong> {{ o.detail | safe }}</li>
          {%- endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

{# ── WHY TECHBROT (H2: What separates us from generic remote bookkeeping. + 4 H3s) ── #}
<section class="section section--alt" id="ca-pillar-why">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why California businesses choose TechBrot</p>
      <h2 class="section__heading">What separates us from generic remote bookkeeping.</h2>
      <p class="section__lede">California has no shortage of bookkeeping options. What TechBrot brings: actual California operational depth &mdash; AB5, district sales tax, ASC 606, the $800 franchise tax &mdash; real Certified ProAdvisor credentials, and a structurally accountable engagement model.</p>
    </header>
    <div class="grid-2">
      {%- for w in why %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ w.num }}</p>
        <h3>{{ w.name | safe }}</h3>
        <p class="prose">{{ w.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── REVIEWS · ONLY the 2 real Clutch reviews (H2: Verified client reviews.) ── #}
