  </div>
</section>

{#- THE FINANCIAL BACKBONE — the five services (numbered lift cards, each with its cross-link) — sand -#}
<section class="sec reveal" id="wa-svc-smb-handle" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__t">What we handle for Washington small businesses</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:24ch;margin-bottom:12px;">The financial backbone, built and maintained.</h2>
    <p class="lede" style="margin:0 0 36px;max-width:62ch;">Every engagement is scoped to your business and entity, delivered in your own QuickBooks file by a named Certified ProAdvisor.</p>
    <div class="r-2">
      {%- for s in handle %}
      <div class="lift"><span class="lift__n">{{ s.num | safe }}</span><div><h3>{{ s.title | safe }}</h3><p>{{ s.body | safe }}</p><p style="margin-top:10px;"><a href="{{ s.href }}" style="color:var(--color-accent);font-size:14px;font-weight:600;">{{ s.cta | safe }}</a></p></div></div>
      {%- endfor %}
    </div>
  </div>
</section>

