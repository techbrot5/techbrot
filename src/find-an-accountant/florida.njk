        <p class="prose">{{ r.body | safe }}</p>
        <a class="buyer-card__cta" href="{{ r.href }}">{{ r.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ relatedNote | safe }}</small></p>
  </div>
</section>
