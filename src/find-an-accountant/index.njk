---

{# ── STATE ROUTING SYSTEM · selector (pick-your-state, routes built-out → state page,
     else → contact) + premium routing-card grid. Data-driven (allStates/states), scales
     to 50 states. (H2: Find an accountant by state.) ── #}
<section class="section" id="faa-states">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Routing by state</p>
      <h2 class="section__heading">Find an accountant by state.</h2>
      <p class="section__lede">Pick your state to route straight to the right page &mdash; or browse the built-out states below. Each state page is built around what&rsquo;s actually different there: the local taxes, the filing realities, the industries.</p>
    </header>
    <div class="state-router">
      <div class="intake-field state-router__field">
        <label class="intake-field__label" for="faa-state-select">Pick your state</label>
        <select id="faa-state-select" aria-label="Choose your state to find an accountant">
          <option value="" selected>Choose your state&hellip;</option>
          {%- for s in allStates %}
          <option value="{{ s.href }}">{{ s.name }}{% if s.built %} &mdash; dedicated page{% endif %}</option>
          {%- endfor %}
        </select>
      </div>
      <button type="button" class="btn btn--primary btn--lg" id="faa-state-go" data-tb-state-go>Find my accountant</button>
    </div>
    <p class="section__eyebrow" style="margin-bottom:var(--space-4)">Built-out states</p>
    <div class="grid-3">
      {%- for s in states %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ s.tag }}</p>
        <h3 class="buyer-card__heading"><a href="{{ s.href }}">{{ s.name | safe }}</a></h3>
        <p class="buyer-card__body">{{ s.note | safe }}</p>
        <a class="buyer-card__cta" href="{{ s.href }}">{{ s.name | safe }} accountants &rarr;</a>
      </article>
      {%- endfor %}
      <article class="buyer-card">
        <p class="buyer-card__opener">Every other state</p>
        <h3 class="buyer-card__heading"><a href="/contact/?intent=find-an-accountant">Served remotely &mdash; tell us where you are</a></h3>
        <p class="buyer-card__body">We serve businesses in every state remotely on QuickBooks. Tell us your state and what you need, and a Certified ProAdvisor will route you.</p>
        <a class="buyer-card__cta" href="/contact/?intent=find-an-accountant">Tell us where you are &rarr;</a>
      </article>
    </div>
  </div>
</section>

{# ── WHAT YOU GET · premium numbered process (the ONE numbered system, variety #12a). (H2: What you get, in any state.) ── #}
<section class="section section--alt" id="faa-value">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What you get</p>
      <h2 class="section__heading">What you get, in any state.</h2>
    </header>
    <ol class="process-diagram">
      {%- for v in valueProps %}
      <li class="process-step">
        <p class="process-step__number">0{{ loop.index }}</p>
        <h3 class="process-step__heading">{{ v.name | safe }}</h3>
        <p class="process-step__body">{{ v.body | safe }}</p>
      </li>
      {%- endfor %}
    </ol>
  </div>
</section>

{# ── ROUTE BY NEED · silo routing (QuickBooks → /quickbooks/, accounting → /accounting/,
     start → file-review). The hub routes to the RIGHT silo. (H2: Or start with what you need.) ── #}
<section class="section" id="faa-needs">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Routing by need</p>
      <h2 class="section__heading">Or start with what you need.</h2>
      <p class="section__lede">Know the work already? Go straight to the right silo.</p>
    </header>
    <div class="grid-2">
      {%- for n in needs %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ n.opener | safe }}</p>
        <h3 class="buyer-card__heading"><a href="{{ n.href }}">{{ n.name | safe }}</a></h3>
        <p class="buyer-card__body">{{ n.body | safe }}</p>
        <a class="buyer-card__cta" href="{{ n.href }}">{{ n.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── NETWORK · deliver-card feature cards (the honest model, not a wall of text). (H2: How the network works.) ── #}
<section class="section section--alt" id="faa-network">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Direct delivery + vetted partners</p>
      <h2 class="section__heading">How the network works.</h2>
    </header>
    <div class="grid-3">
      {%- for n in network %}
      <div class="deliver-card">
        <span class="deliver-card__tick" aria-hidden="true"></span>
        <div><h3>{{ n.title | safe }}</h3><p class="prose">{{ n.body | safe }}</p></div>
      </div>
      {%- endfor %}
    </div>
    <p class="prose"><small>TechBrot is an independent Certified QuickBooks ProAdvisor firm &mdash; not affiliated with Intuit Inc. It provides bookkeeping and operational accounting and coordinates with your CPA or EA, who files tax returns and represents you before tax authorities.</small></p>
  </div>
</section>

{# ── CALL conversion. ── #}
<section class="section section--compact" id="faa-call">
  <div class="container container--narrow">
    <div class="call-breakout">
      <div>
        <p class="call-breakout__title">Not sure which page fits your business?</p>
        <p class="call-breakout__sub">A Certified ProAdvisor reviews your QuickBooks file and your state&rsquo;s situation, then scopes the work in writing &mdash; fixed-fee. Independent firm; not Intuit.</p>
      </div>
      <a class="btn btn--primary" href="tel:{{ site.phone.e164 }}" data-tb-event="phone_click">Speak to a ProAdvisor</a>
    </div>
  </div>
</section>

{# ── FAQ · 6 Q/A; visible faq__list = FAQPage schema. (H2: Find-an-accountant questions.) ── #}
<section class="section section--alt" id="faa-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Common questions</p>
      <h2 class="section__heading">Find-an-accountant questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="faa-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="faa-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# State router: route to the selected state's destination. Progressive enhancement —
   the built-out grid above covers no-JS users. #}
<script>
(function(){
  var s=document.getElementById("faa-state-select"),b=document.getElementById("faa-state-go");
  if(!s||!b)return;
  function go(){ if(s.value){ window.location.href=s.value; } }
  b.addEventListener("click",go);
  s.addEventListener("keydown",function(e){ if(e.key==="Enter"){ go(); } });
})();
</script>
