---json
{
  "layout": "layouts/t-state-pillar.njk",
  "permalink": "/find-an-accountant/texas/",
  "slug": "tx-pillar",
  "tierClass": "section--tier-hub",
  "bodyClass": "page--location",
  "callBar": true,
  "heroMotif": "partials/motif-align-full.svg",
  "title": "Texas QuickBooks ProAdvisors & Bookkeeping · TechBrot",
  "description": "Certified QuickBooks ProAdvisors & bookkeeping for Texas businesses, all 254 counties. Franchise tax, SaaS 80% taxable, sales tax. Call (877) 751-5575.",
  "breadcrumb": [
    { "name": "Home", "href": "/" },
    { "name": "Find an Accountant", "href": "/find-an-accountant/" },
    { "name": "Texas" }
  ],
  "heroFigure": "taccount",
  "hero": {
    "trust": [
      "Certified QuickBooks ProAdvisor team",
      "Texas businesses &middot; all 254 counties",
      "Fixed-fee &middot; written scope in 3 days"
    ],
    "eyebrow": "Texas &middot; Houston to El Paso &middot; All 254 Counties",
    "heading": "QuickBooks ProAdvisors &amp; Bookkeeping for Texas Businesses.",
    "subheading": "Professional bookkeeping, QuickBooks setup and cleanup, payroll, and sales tax compliance &mdash; delivered directly by TechBrot, with trusted partner practices in Texas where in-state presence adds value. Built around Texas&rsquo;s franchise (margin) tax, the $2.65M no-tax-due threshold, no state personal income tax, and SaaS taxed at 80% of sales price &mdash; and the operational realities of running a business in Houston, Dallas&ndash;Fort Worth, Austin, San Antonio, and across all 254 Texas counties.",
    "actions": [
      { "label": "Book the discovery call", "href": "/contact/?intent=texas&state=texas&source_type=location&funnel_stage=MOFU", "class": "btn--primary" },
      { "label": "Send the Discovery Brief", "href": "#tx-intake", "class": "btn--ghost" },
      { "label": "Speak to a ProAdvisor", "tel": true, "class": "btn--ghost" }
    ]
  },
  "inBrief": {
    "text": "<strong>TechBrot</strong> delivers <strong>Certified QuickBooks ProAdvisor services</strong>, Texas bookkeeping, QuickBooks setup, cleanup, migration, Texas sales tax compliance, and fractional CFO engagements to Texas businesses across <strong>all 254 counties</strong> &mdash; from Houston, Dallas&ndash;Fort Worth, and Austin to San Antonio, El Paso, and the Permian Basin. The full Texas summary is below.",
    "source": "Reviewed by the Certified QuickBooks ProAdvisor team at TechBrot Inc., an independent firm &mdash; not affiliated with Intuit Inc. TX rates verified against the Texas Comptroller of Public Accounts."
  },
  "ctaBand": {
    "eyebrow": "Texas businesses start here",
    "heading": "Book a Texas discovery call.",
    "lede": "30 minutes. We review where your books are, your Texas operational context &mdash; metro vs. rural, franchise-tax position, SaaS 80% taxability, origin-based sales tax, oil-and-gas cost tracking &mdash; and recommend the right engagement. <strong>Written fixed-fee scope within 3 business days.</strong> No pitch. Independent firm &mdash; does not file the Texas franchise tax report; coordinates with your CPA.",
    "actions": [
      { "label": "Book the discovery call", "href": "/contact/?intent=texas&state=texas&source_type=location&funnel_stage=BOFU", "class": "btn--primary" },
      { "label": "Speak to a ProAdvisor", "tel": true, "class": "btn--ghost" }
    ]
  }
}
---

{# ── SUMMARY · real H2 carrying the Texas summary prose (right after the in-brief) ── #}
<section class="section section--compact" id="tx-summarized">
  <div class="container container--narrow">
    <header class="section__header">
      <h2 class="section__heading">TechBrot in Texas, summarized.</h2>
    </header>
    <p class="prose">{{ summarized | safe }}</p>
  </div>
</section>

{# ── CREDENTIALS · proof-strip + cert line (H2: Certified QuickBooks ProAdvisor credentials) ── #}
<section class="section section--compact section--tier-hub" id="tx-credentials">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Certified by Intuit</p>
      <h2 class="section__heading">Certified QuickBooks ProAdvisor credentials</h2>
    </header>
    <p class="prose">{{ credLede | safe }}</p>
    <ul class="proof-strip" role="list">
      {%- for b in credBadges %}
      <li class="proof-strip__item"><b>{{ b.label }}</b> <span class="sr-only">{{ b.name }}</span></li>
      {%- endfor %}
    </ul>
    <div class="trust-row">
      {%- for r in trustRow %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.value | safe }}</p><p class="trust-row__label">{{ r.label | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
  </div>
</section>

{# ── STATE BY THE NUMBERS · proof-strip stat row (H2: The state by the numbers.) ── #}
<section class="section section--alt" id="tx-stats">
  <div class="container">
    <header class="section__header section__header--centered">
      <p class="section__eyebrow">Texas at a glance</p>
      <h2 class="section__heading">The state by the numbers.</h2>
      <p class="section__lede">A short read on the operational profile that shapes how accounting is done in Texas &mdash; from the Houston and DFW metros to West Texas and everywhere in between.</p>
    </header>
    <div class="grid-3">
      {%- for s in stats %}
      <div><div class="stat__value">{{ s.figure | safe }}</div><div class="stat__label">{{ s.label | safe }}</div></div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── TL;DR is in the layout in-brief. AI SUMMARY (H2: TechBrot in Texas, in five questions.) ── #}
<section class="section" id="tx-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">TechBrot in Texas, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="tx-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── GLOSSARY (H2: The Texas terms that matter for QuickBooks & bookkeeping.) ── #}
<section class="section section--alt" id="tx-glossary">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Texas accounting glossary</p>
      <h2 class="section__heading">The Texas terms that matter for QuickBooks &amp; bookkeeping.</h2>
      <p class="section__lede">Short, specific, definitional. These are the terms that come up in nearly every Texas engagement &mdash; and the ones AI engines and search engines reach for when answering Texas accounting questions.</p>
    </header>
    <div class="grid-2">
      {%- for g in stateTerms %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ g.term | safe }}</p>
        <p class="prose">{{ g.def | safe }}</p>
      </div>
      {%- endfor %}
    </div>
    <p class="prose"><small>Always confirm current rates and thresholds against the <a href="https://comptroller.texas.gov/taxes/franchise/" rel="noopener nofollow">Texas Comptroller of Public Accounts</a>.</small></p>
  </div>
</section>

{# ── DELIVERY · direct vs partners (H2: What we deliver in Texas. + 2 H3s) ── #}
<section class="section" id="tx-delivery">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Service coverage</p>
      <h2 class="section__heading">What we deliver in Texas.</h2>
      <p class="section__lede">Two delivery modes, one operating standard. Engagements route to direct or network based on the work required, your location in the state, and industry specialization.</p>
    </header>
    <div class="grid-2">
      {%- for d in delivery %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ d.eyebrow | safe }}</p>
        <h3 class="buyer-card__heading">{{ d.heading | safe }}</h3>
        <p class="buyer-card__body">{{ d.lede | safe }}</p>
        <ul class="checks-list">{%- for li in d.list %}<li>{{ li | safe }}</li>{%- endfor %}</ul>
        <a class="buyer-card__cta" href="{{ d.href }}">{{ d.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ deliveryNote | safe }}</small></p>
  </div>
</section>

{# ── CONTEXT (H2: What makes Texas accounting different. + 4 H3s) ── #}
<section class="section section--alt" id="tx-context">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why Texas is different</p>
      <h2 class="section__heading">What makes Texas accounting different.</h2>
      <p class="section__lede">Texas&rsquo;s tax structure, industry concentration, and operational profile create accounting requirements that don&rsquo;t look like any other state. Generic out-of-state bookkeeping &mdash; or bookkeepers unfamiliar with the franchise tax and SaaS rules &mdash; misses what matters most.</p>
    </header>
    <div class="grid-2">
      {%- for c in context %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ c.category | safe }}</p>
        <h3>{{ c.heading | safe }}</h3>
        {%- for p in c.body %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
      </div>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ contextNote | safe }}</small></p>
  </div>
</section>

{# ── SCENARIOS · honestly-labeled composites (H2: What a Texas engagement actually looks like. + 3 H3s) ── #}
<section class="section" id="tx-scenarios">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Texas scenarios</p>
      <h2 class="section__heading">What a Texas engagement actually looks like.</h2>
      <p class="section__lede">{{ scenariosNote | safe }}</p>
    </header>
    <div class="grid-3">
      {%- for s in scenarios %}
      <article class="stack-8">
        <p class="section__eyebrow">{{ s.tag | safe }}</p>
        <h3>{{ s.heading | safe }}</h3>
        {%- for p in s.body %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
        <a class="buyer-card__cta" href="{{ s.href }}">{{ s.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── RECENT RESULTS · REFRAMED metas (H2: Recent Texas results.) ── #}
<section class="section section--alt" id="tx-outcomes">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Outcomes</p>
      <h2 class="section__heading">Recent Texas results.</h2>
    </header>
    <div class="grid-3">
      {%- for o in outcomes %}
      <div><div class="stat__value">{{ o.figure | safe }}</div><div class="stat__label">{{ o.detail | safe }}<br><small>{{ o.meta | safe }}</small></div></div>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ outcomesNote | safe }}</small></p>
  </div>
</section>

{# ── ADVISORY · standing brand line (H2: Automation handles the data entry. We handle the judgment.) ── #}
<section class="section" id="tx-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Beyond bookkeeping</p>
      <h2 class="section__heading">Automation handles the data entry. We handle the judgment.</h2>
    </header>
    <p class="prose">{{ advisoryBody | safe }}</p>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="/contact/?intent=texas-advisory&amp;state=texas&amp;source_type=location&amp;funnel_stage=BOFU">Book the discovery call</a>
    </div>
    <p class="prose"><a href="/accounting/advisory/fractional-cfo/">Fractional CFO (Texas)</a></p>
  </div>
</section>

{# ── INDUSTRIES (H2: Industry-specific accounting for Texas's economy. + 6 H3s) · NO child links ── #}
<section class="section" id="tx-industries">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Texas industries we serve</p>
      <h2 class="section__heading">Industry-specific accounting for Texas&rsquo;s economy.</h2>
      <p class="section__lede">Texas&rsquo;s industry mix is unlike any other state. Our engagements concentrate in the sectors that drive Texas&rsquo;s economy &mdash; each with its own QuickBooks configuration, tax treatment, and compliance requirements.</p>
    </header>
    <div class="grid-3">
      {%- for i in industries %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ i.num }}</p>
        <h3>{{ i.name | safe }}</h3>
        <p class="prose">{{ i.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ industriesNote | safe }}</small></p>
  </div>
</section>

{# ── SERVICES · buyer-card routing (H2: Find the right service for your Texas business. + 6 H3s) · headings PLAIN, CTA → /contact/ ── #}
<section class="section section--alt" id="tx-services">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Services for Texas businesses</p>
      <h2 class="section__heading">Find the right service for your Texas business.</h2>
      <p class="section__lede">Each Texas service is delivered directly by TechBrot&rsquo;s lead practice today, with fixed-fee scopes, delivery cadence, and engagement details set in writing before any work begins.</p>
    </header>
    <div class="grid-3">
      {%- for s in services %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ s.eyebrow }}</p>
        <h3 class="buyer-card__heading">{{ s.name | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
        <div class="proof-strip">
          <span class="proof-strip__item"><b>Starting</b> {{ s.starting | safe }}</span>
          <span class="proof-strip__item"><b>Cadence</b> {{ s.cadence | safe }}</span>
        </div>
        <a class="buyer-card__cta" href="{{ s.href }}">{{ s.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ servicesNote | safe }}</small></p>
  </div>
</section>

{# ── ECOSYSTEM (H2: Every Texas page in one place. + 6 cluster H3s) · NO-CHILDREN: label-only, no links ── #}
<section class="section" id="tx-ecosystem">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">The full Texas ecosystem</p>
      <h2 class="section__heading">Every Texas page in one place.</h2>
      <p class="section__lede">Texas is more than one page &mdash; it&rsquo;s a complete authority hub covering every service, industry, city, and tax topic Texas business owners search for. Every item below is delivered today within the direct Texas engagement; dedicated pages publish on a rolling cadence.</p>
    </header>
    <div class="grid-3">
      {%- for cl in ecosystem %}
      <article class="stack-8">
        <p class="section__eyebrow">{{ cl.eyebrow }}</p>
        <h3>{{ cl.heading | safe }}</h3>
        <p class="prose">{{ cl.lede | safe }}</p>
        <ul class="checks-list">
          {%- for l in cl.links %}<li>{% if l.href %}<a href="{{ l.href }}">{{ l.label | safe }}</a>{% else %}{{ l.label | safe }}{% endif %}{% if l.tag %} <span class="proof-strip__rating">{{ l.tag | safe }}</span>{% endif %}</li>{%- endfor %}
        </ul>
      </article>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ ecosystemNote | safe }}</small></p>
  </div>
</section>

{# ── PRICING (H2: Fixed-fee starting ranges for Texas engagements.) · service cells PLAIN ── #}
<section class="section section--alt" id="tx-pricing">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Texas pricing</p>
      <h2 class="section__heading">Fixed-fee starting ranges for Texas engagements.</h2>
      <p class="section__lede">Every Texas engagement is quoted as a fixed fee against a written scope before any work begins &mdash; no hourly billing. Final scope and fee are delivered in writing within 3 business days of the discovery call.</p>
    </header>
    <div class="vs-scroll">
      <table class="vs-table" aria-describedby="tx-pricing-note">
        <caption class="sr-only">Indicative fixed-fee starting ranges for Texas QuickBooks and bookkeeping engagements.</caption>
        <thead><tr><th scope="col">Engagement</th><th scope="col">Starting range</th><th scope="col">Cadence</th><th scope="col">Texas notes</th></tr></thead>
        <tbody>
          {%- for r in pricing %}
          <tr><th scope="row">{% if r.href %}<a href="{{ r.href }}">{{ r.svc | safe }}</a>{% else %}{{ r.svc | safe }}{% endif %}</th><td><strong>{{ r.range | safe }}</strong></td><td>{{ r.cadence | safe }}</td><td>{{ r.notes | safe }}</td></tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
    <p class="prose" id="tx-pricing-note"><small>{{ pricingNote | safe }}</small></p>
  </div>
</section>

{# ── CITIES + COUNTIES (H2: Serving Texas businesses statewide. + 2 H3s) · city names PLAIN ── #}
<section class="section" id="tx-cities">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Cities &amp; metros</p>
      <h2 class="section__heading">Serving Texas businesses statewide.</h2>
      <p class="section__lede">TechBrot serves Texas businesses across <strong>all 254 counties</strong>. Below are the 8 primary metros, plus a representative sample of the counties served. Dedicated city pages publish on a rolling cadence.</p>
    </header>
    <h3>Top Texas cities &mdash; each has a dedicated city page</h3>
    <ul class="checks-list">
      {%- for c in cities %}
      <li>{{ c.name | safe }} &mdash; {{ c.county | safe }}</li>
      {%- endfor %}
    </ul>
    <h3>Texas counties served &mdash; representative sample</h3>
    <p class="prose">{{ countyProse | safe }}</p>
    <p class="prose"><small>{{ citiesNote | safe }}</small></p>
  </div>
</section>

{# ── INTAKE · dual-path call + shared intake-form partial (H2: Two ways to start... + 2 H3s) ── #}
<section class="section section--alt" id="tx-intake">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Talk to a Certified ProAdvisor</p>
      <h2 class="section__heading">Two ways to start a Texas engagement.</h2>
      <p class="section__lede">Both paths go to the same Certified ProAdvisor. Pick the one that fits how you work.</p>
    </header>

    <div class="grid-2">
      <div class="stack-8">
        <div class="byline-block">
          <div class="byline-block__mark" aria-hidden="true"></div>
          <div>
            <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
            <p class="byline-block__review">{{ teamDavid.name }} &middot; {{ teamDavid.role }}</p>
          </div>
        </div>
        <p class="section__eyebrow">{{ teamDavid.creds | safe }}</p>
        <p class="prose">{{ teamDavid.line | safe }}</p>
        <a class="buyer-card__cta" href="https://proadvisor.intuit.com/" rel="noopener nofollow">Verify on Intuit&rsquo;s ProAdvisor directory <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a>
      </div>
      <div class="stack-8">
        <div class="byline-block">
          <div class="byline-block__mark" aria-hidden="true"></div>
          <div>
            <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
            <p class="byline-block__review">{{ teamIntake.name | safe }} &middot; {{ teamIntake.role }}</p>
          </div>
        </div>
        <p class="section__eyebrow">{{ teamIntake.creds | safe }}</p>
        <p class="prose">{{ teamIntake.line | safe }}</p>
      </div>
    </div>

    <div class="grid-2">
      <article class="buyer-card">
        <p class="buyer-card__opener">Option 01</p>
        <h3 class="buyer-card__heading">Call directly.</h3>
        <p class="buyer-card__body">A Certified ProAdvisor answers &mdash; not a call center. Best for same-day diagnostics, behind-on-the-books situations, or Texas franchise-tax and sales-tax compliance urgencies.</p>
        <a class="btn btn--primary btn--lg" href="tel:{{ site.phone.e164 }}" data-tb-event="phone_click">Speak to a ProAdvisor</a>
        <ul class="checks-list">{%- for a in callAssurance %}<li>{{ a | safe }}</li>{%- endfor %}</ul>
      </article>
      <div class="contact-form-wrap">
        <h3 class="buyer-card__heading" id="tx-intake-form-heading">Send a short discovery brief.</h3>
        <p class="prose">Six fields. We respond by the next business day with a path forward &mdash; a scoping call or, if not a fit, a referral. <strong>Includes a free QuickBooks file review &mdash; we&rsquo;ll identify the top 3 issues in your file before any engagement begins.</strong></p>
        {%- set intakePrefix = "tx" %}
        {%- set intakeFormId = "tx-intake-form" %}
        {%- set intakeIntent = "texas" %}
        {%- set intakeSourceType = "location" %}
        {%- set intakeFunnelStage = "MOFU" %}
        {%- set intakeLegend = "What we should discuss for your Texas business" %}
        {%- set intakeSubmit = "Send the Discovery Brief" %}
        {%- set intakeReassurance = "Same-day diagnostic for emergencies, 1 business day for scoping, written fixed-fee scope within 3 business days of the first call." %}
        {% include "partials/intake-form.njk" %}
      </div>
    </div>
  </div>
</section>

{# ── OPERATORS · partner placeholder + vetting standards (H2: Trusted Texas partner practices. + 2 H3s) ── #}
<section class="section" id="tx-operators">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Texas partner practices</p>
      <h2 class="section__heading">Trusted Texas partner practices.</h2>
      <p class="section__lede">When metro presence, oil-and-gas / energy-services depth, franchise-tax optimization, or large-contractor job costing matters, engagements route to a vetted Texas operator.</p>
    </header>
    <div class="grid-2">
      <article class="buyer-card">
        <p class="buyer-card__opener">Partner practice &middot; Onboarding 2026</p>
        <h3 class="buyer-card__heading">Texas partner practice slot open</h3>
        <p class="buyer-card__body">We&rsquo;re onboarding a vetted Texas accounting practice as the lead partner practice for the state. Until that operator goes live, <strong>TechBrot delivers all Texas engagements directly</strong> &mdash; same standards, same fixed-fee scoping, same Certified ProAdvisor credentials. If you&rsquo;re a Texas accounting practice interested in joining the TechBrot partner practices: <a href="/partners/">apply here</a>.</p>
        <a class="buyer-card__cta" href="/partners/">Apply to partner practices <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a>
      </article>
      <div class="stack-8">
        <p class="section__eyebrow">The vetting standard</p>
        <h3>What a Texas partner practice must meet.</h3>
        <p class="prose">Every operator runs under the same standard TechBrot delivers directly. The bar to carry the brand in Texas:</p>
        <ul class="checks-list">
          {%- for o in operatorStandards %}
          <li><strong>{{ o.term | safe }}.</strong> {{ o.detail | safe }}</li>
          {%- endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

{# ── WHY TECHBROT (H2: What separates us from generic remote bookkeeping. + 4 H3s) ── #}
<section class="section section--alt" id="tx-why">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Why Texas businesses choose TechBrot</p>
      <h2 class="section__heading">What separates us from generic remote bookkeeping.</h2>
      <p class="section__lede">Texas has no shortage of bookkeeping options. What TechBrot brings: actual Texas operational depth &mdash; franchise/margin tax, origin-based sales tax, 80% SaaS taxability, oil-and-gas cost accounting &mdash; real Certified ProAdvisor credentials, and a structurally accountable engagement model.</p>
    </header>
    <div class="grid-2">
      {%- for w in why %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ w.num }}</p>
        <h3>{{ w.name | safe }}</h3>
        <p class="prose">{{ w.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── REVIEWS · ONLY the 2 real Clutch reviews (H2: Verified client reviews.) ── #}
<section class="section" id="tx-reviews">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What clients say</p>
      <h2 class="section__heading">Verified client reviews.</h2>
      <p class="section__lede">Independently collected and verified on Clutch &mdash; real engagements, real names, unedited. 5.0 overall from 2 verified reviews. <a href="{{ site.clutchProfile }}#reviews" rel="noopener nofollow">See all reviews on Clutch <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a></p>
    </header>
    <div class="grid-2">
      {%- for r in reviews %}
      <article class="review-card">
        <blockquote class="review-card__quote">&ldquo;{{ r.quote | safe }}&rdquo;</blockquote>
        <p class="review-card__fact">{{ r.context | safe }}</p>
        <p class="review-card__role">{{ r.author }} &mdash; {{ r.role | safe }} &middot; {{ r.meta | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── COMPARISON (H2: TechBrot vs. the alternatives for Texas businesses.) ── #}
<section class="section section--alt" id="tx-comparison">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">How we compare</p>
      <h2 class="section__heading">TechBrot vs. the alternatives for Texas businesses.</h2>
      <p class="section__lede">An honest read on where TechBrot fits and where it doesn&rsquo;t. Most Texas businesses end up using TechBrot <em>and</em> a local Texas CPA together &mdash; TechBrot handles the QuickBooks operations; the CPA handles the franchise tax filing and tax strategy.</p>
    </header>
    <div class="vs-scroll">
      <table class="vs-table">
        <caption class="sr-only">TechBrot vs. local Texas CPA vs. national remote bookkeeping for Texas businesses.</caption>
        <thead><tr><th scope="col">Dimension</th><th scope="col" class="vs-table__us">TechBrot</th><th scope="col">Local Texas CPA</th><th scope="col">National remote bookkeeping</th></tr></thead>
        <tbody>
          {%- for r in comparison %}
          <tr><th scope="row">{{ r.dim | safe }}</th>
            <td class="vs-table__us"{% if r.winner == 'us' %} data-winner="us"{% endif %}>{{ r.us | safe }}</td>
            <td{% if r.winner == 'them' %} data-winner="them"{% endif %}>{{ r.cpa | safe }}</td>
            <td>{{ r.remote | safe }}</td>
          </tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
    <p class="prose">{{ comparisonVerdict | safe }}</p>
    <p class="prose"><small>{{ comparisonRelated | safe }}</small></p>
  </div>
</section>

{# ── AUTHORITY (H2: Verify everything on this page.) ── #}
<section class="section" id="tx-authority">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Authority sources &amp; verification</p>
      <h2 class="section__heading">Verify everything on this page.</h2>
      <p class="section__lede">Texas tax rates, thresholds, and program details change. The sources below are authoritative; confirm any specific figure or rule before relying on it.</p>
    </header>
    {%- for a in authority %}
    <div class="stack-8">
      <h3><a href="{{ a.href }}" rel="noopener nofollow">{{ a.name | safe }}</a></h3>
      <p class="prose">{{ a.detail | safe }}</p>
    </div>
    {%- endfor %}
  </div>
</section>

{# ── FAQ · 17 verbatim Q/A; visible = FAQPage schema (H2: Texas QuickBooks & accounting questions.) ── #}
<section class="section section--alt" id="tx-faq">
