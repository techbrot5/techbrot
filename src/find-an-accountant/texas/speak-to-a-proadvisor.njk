---

{# ── DISCLOSURE · honest-triage amber ATF banner (not-Intuit boundary). ── #}
<section class="section section--compact" id="tx-svc-speak-disclosure">
  <div class="container container--narrow">
    <div class="disclosure disclosure--warn">
      <svg class="disclosure__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#A4660A" stroke-width="1.75" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 7.5v.3" stroke-linecap="round"/></svg>
      <div class="disclosure__body"><strong>TechBrot is an independent Certified QuickBooks ProAdvisor firm &mdash; not Intuit, and not a call center.</strong> A Certified ProAdvisor reviews your own QuickBooks file. For an Intuit account, billing, or login issue, contact Intuit directly; for filing Texas tax returns or representation, your CPA or EA handles that. What this team does is the accounting work inside your books.</div>
    </div>
  </div>
</section>

{# ── CALL · honest-triage converts by CALL. ── #}
<section class="section section--compact" id="tx-svc-speak-call">
  <div class="container container--narrow">
    <div class="call-breakout">
      <div>
        <p class="call-breakout__title">Speak to a Certified ProAdvisor.</p>
        <p class="call-breakout__sub">A real ProAdvisor reviews your own QuickBooks file and tells you honestly what you need &mdash; setup, cleanup, monthly management, or advisory. No call center, no obligation.</p>
      </div>
      <a class="btn btn--primary" href="tel:{{ site.phone.e164 }}" data-tb-event="phone_click">Speak to a ProAdvisor</a>
    </div>
  </div>
</section>

{# ── SUMMARY ── #}
<section class="section section--compact" id="tx-svc-speak-tldr">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In short</p>
      <h2 class="section__heading">The short version.</h2>
    </header>
    <div class="stack-8">
      {%- for p in summary %}<p class="prose"{% if loop.first %} id="tx-svc-speak-summary"{% endif %}>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── WHO + SPLIT · who should talk to a ProAdvisor vs. who Intuit should handle (grid-2). ── #}
<section class="section section--alt" id="tx-svc-speak-split">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Who should call &mdash; and who Intuit should handle</p>
      <h2 class="section__heading">Is a ProAdvisor call the right call?</h2>
      <p class="section__lede">A discovery call with this team is about <strong>your own books</strong> &mdash; how your QuickBooks file is set up and run. It is not Intuit support. The split below tells you where to go.</p>
    </header>
    <div class="grid-2">
      {%- for s in split %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ s.tag | safe }}</p>
        <h3 class="buyer-card__heading">{{ s.title | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
        <ul class="checks-list">{%- for li in s.list %}<li>{{ li | safe }}</li>{%- endfor %}</ul>
        {%- if s.cta %}<a class="buyer-card__cta" href="{{ s.href }}"{% if s.rel %} rel="{{ s.rel }}"{% endif %}>{{ s.cta | safe }}</a>{%- endif %}
      </article>
      {%- endfor %}
    </div>
    <p class="prose">{{ splitNote | safe }}</p>
  </div>
</section>

{# ── AI SUMMARY ── #}
<section class="section" id="tx-svc-speak-ai-summary-sec">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">Talking to a Texas ProAdvisor, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="tx-svc-speak-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── CONVERSATION · how the call runs (grid-3). ── #}
<section class="section section--alt" id="tx-svc-speak-conversation">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">What to expect on the call</p>
      <h2 class="section__heading">A real conversation, not a sales funnel.</h2>
      <p class="section__lede">You speak with a Certified ProAdvisor &mdash; the kind of person who would do or oversee the work &mdash; not a salesperson and not a product-support queue. Here is how it goes.</p>
    </header>
    <div class="grid-3">
      {%- for c in conversation %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ c.num | safe }}</p>
        <h3 class="buyer-card__heading">{{ c.title | safe }}</h3>
        <p class="buyer-card__body">{{ c.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── FAQ ── #}
<section class="section" id="tx-svc-speak-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Common questions</p>
      <h2 class="section__heading">Questions about speaking with a ProAdvisor.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="tx-svc-speak-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="tx-svc-speak-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW ── #}
<section class="section section--alt" id="tx-svc-speak-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    </header>
    <div class="byline-block">
      <div class="byline-block__mark" aria-hidden="true"></div>
      <div>
        <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="byline-block__review">TechBrot Inc. &middot; Independent Certified QuickBooks ProAdvisor firm</p>
      </div>
    </div>
    <div class="prose"><p>{{ reviewProse | safe }}</p></div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-18</span><span>Updated: 2026-06-18</span><span>Reviewed: 2026-06-18 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>
