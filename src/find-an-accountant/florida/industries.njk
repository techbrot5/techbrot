      <a class="rel-card" href="{{ i.href }}"><h3 class="rel-card__t">{{ i.title | safe }}</h3><p class="rel-card__d">{{ i.body | safe }}</p><span class="ptier__link" style="margin-top:10px;">{{ i.cta | safe }}</span></a>
      {%- endfor %}
    </div>
    <div class="prose" style="margin-top:26px;"><p>{{ industriesNote | safe }}</p></div>
  </div>
</section>
