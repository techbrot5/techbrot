      <div class="flow__step flow__step--accent"><span class="flow__label">Free file review</span><span class="flow__sub">the diagnostic</span></div>
      <span class="flow__arrow" aria-hidden="true"><svg width="22" height="10" viewBox="0 0 22 10"><line x1="0" y1="5" x2="16" y2="5" stroke="currentColor" stroke-width="1.5"></line><path d="M14 1 L20 5 L14 9" fill="none" stroke="currentColor" stroke-width="1.5"></path></svg></span>
      <div class="flow__step"><span class="flow__label">Written scope</span><span class="flow__sub">within 3 business days</span></div>
      <span class="flow__arrow" aria-hidden="true"><svg width="22" height="10" viewBox="0 0 22 10"><line x1="0" y1="5" x2="16" y2="5" stroke="currentColor" stroke-width="1.5"></line><path d="M14 1 L20 5 L14 9" fill="none" stroke="currentColor" stroke-width="1.5"></path></svg></span>
      <div class="flow__step"><span class="flow__label">Fixed fee, in writing</span><span class="flow__sub">no hourly billing</span></div>
      <span class="flow__arrow" aria-hidden="true"><svg width="22" height="10" viewBox="0 0 22 10"><line x1="0" y1="5" x2="16" y2="5" stroke="currentColor" stroke-width="1.5"></line><path d="M14 1 L20 5 L14 9" fill="none" stroke="currentColor" stroke-width="1.5"></path></svg></span>
      <div class="flow__step"><span class="flow__label">Work begins</span><span class="flow__sub">named operator</span></div>
    </div>
  </div>
</section>

<section class="section" id="pcl-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Before you call</p>
      <h2 class="section__heading">Questions about cleanup &amp; catch-up cost.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="pcl-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="pcl-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section section--alt" id="pcl-next">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Next steps</p>
      <h2 class="section__heading">Where to go next.</h2>
    </header>
    <div class="grid-2">
      {%- for card in nextCards %}
      <article class="review-card">
        <h3>{{ card.name }}</h3>
        <p class="review-card__fact">{{ card.body | safe }}</p>
        <a class="review-card__link" href="{{ card.href }}">{{ card.cta }} <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>
