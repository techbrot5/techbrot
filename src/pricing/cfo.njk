          <td class="num us" data-col="Where it tends to land"><strong>{{ row.range | safe }}</strong><span style="color:var(--color-ink-faint);font-weight:400;">/mo</span></td>
        </tr>
        {%- endfor %}
      </tbody>
    </table>
    <p class="prose" style="font-size:13.5px;color:var(--color-ink-mute);margin-top:14px;">Ranges are representative and never a quote. Every retainer is fixed, scoped per engagement after a free discovery call, and confirmed in writing &mdash; engagements are accepted by application, with limited capacity per quarter.</p>
  </div>
