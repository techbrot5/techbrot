{#- Shared body for definitional /vs/ comparisons (round 88, vs Wave B).
    The page sets: slug, vsLeft, vsRight, optional usSide ("left"|"right").
    Data (from the page's .11tydata.js): bylineName, bylineReview, summary[],
    aiSummary[], sides[], vsTable[{cap,left,right}], decision[], fit[],
    fitSpec[], faq[], related[]. vs-table is the design-fidelity component;
    byline-block is the second. Honesty/founder-name-zero handled in the data. -#}

<section class="section section--compact" id="{{ slug }}-byline">
  <div class="container container--narrow">
    <div class="byline-block">
      <svg class="byline-block__mark" viewBox="0 0 64 64" role="img" aria-label="TechBrot"><rect width="64" height="64" rx="14" fill="#1A1915"></rect><g transform="translate(12.16 12.16) scale(0.62)" fill="#F5F3EC"><path d="M8 10 H38 V54 H26 V22 H8 Z"></path><rect x="42" y="10" width="14" height="12"></rect></g></svg>
      <div>
        <p class="byline-block__name">{{ bylineName | safe }}</p>
        <p class="byline-block__review">{{ bylineReview | safe }}</p>
      </div>
    </div>
  </div>
</section>

<section class="section section--alt" id="{{ slug }}-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">In one paragraph</p>
      <h2 class="section__heading">The honest summary.</h2>
    </header>
    <div class="prose">
      {%- for p in summary %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

<section class="section" id="{{ slug }}-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">{{ vsLeft | safe }} vs {{ vsRight | safe }}, in five questions.</h2>
    </header>
    <div class="ai-summary ai-summary--ruled">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <h3 class="ai-summary__question">{{ item.q | safe }}</h3>
        <div class="ai-summary__answer"><p>{{ item.a | safe }}</p></div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section section--alt" id="{{ slug }}-sides">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">The two, defined</p>
      <h2 class="section__heading">What each one actually is.</h2>
      <p class="section__lede">Most confusion comes from using the terms loosely. Here&rsquo;s what each means in U.S. small business practice.</p>
    </header>
    <div class="grid-2">
      {%- for r in sides %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ r.eyebrow | safe }}</p>
        <h3>{{ r.name | safe }}</h3>
        <p class="prose">{{ r.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section" id="{{ slug }}-dimensions">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Side by side</p>
      <h2 class="section__heading">Across the dimensions that matter.</h2>
      <p class="section__lede">The practical differences that decide which one you need &mdash; or whether you need both.</p>
    </header>
    <div class="vs-scroll">
      <table class="vs-table">
        <caption class="sr-only">{{ vsLeft | safe }} versus {{ vsRight | safe }} comparison across the dimensions that determine fit, from an independent Certified QuickBooks ProAdvisor firm.</caption>
        <thead><tr><th scope="col">Dimension</th><th scope="col"{% if usSide == "left" %} class="vs-table__us"{% endif %}>{{ vsLeft | safe }}</th><th scope="col"{% if usSide == "right" %} class="vs-table__us"{% endif %}>{{ vsRight | safe }}</th></tr></thead>
        <tbody>
          {%- for r in vsTable %}
          <tr><th scope="row">{{ r.cap | safe }}</th>
            <td{% if usSide == "left" %} class="vs-table__us"{% endif %}><span class="vs-table__concede">{{ r.left | safe }}</span></td>
            <td{% if usSide == "right" %} class="vs-table__us"{% endif %}><span class="vs-table__concede">{{ r.right | safe }}</span></td>
          </tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="section section--alt" id="{{ slug }}-decision">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">A practical decision guide</p>
      <h2 class="section__heading">Which one fits your situation.</h2>
      <p class="section__lede">Three patterns cover most U.S. small businesses. Find the one that matches where you are.</p>
    </header>
    <div class="grid-3">
      {%- for d in decision %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ d.eyebrow | safe }}</p>
        <h3>{{ d.name | safe }}</h3>
        <p class="prose">{{ d.body | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section" id="{{ slug }}-fit">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Where TechBrot fits</p>
      <h2 class="section__heading">{{ fitHeading | safe }}</h2>
    </header>
    <div class="prose">
      {%- for p in fit %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
    <div class="trust-row">
      {%- for r in fitSpec %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.value | safe }}</p><p class="trust-row__label">{{ r.label | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section section--alt" id="{{ slug }}-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Common questions</p>
      <h2 class="section__heading">What people ask before choosing.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="{{ slug }}-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="{{ slug }}-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-19</span><span>Updated: 2026-06-19</span><span>Reviewed: 2026-06-19 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

<section class="section" id="{{ slug }}-related">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Other comparisons</p>
      <h2 class="section__heading">More honest comparisons in the same series.</h2>
    </header>
    {%- for n in related %}
    <div class="stack-8">
      <h3><a href="{{ n.href }}">{{ n.title | safe }}</a></h3>
      <p class="prose">{{ n.body | safe }}</p>
    </div>
    {%- endfor %}
  </div>
</section>
