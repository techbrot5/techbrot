{#- SHARED STATE-INDUSTRY-CHILD BODY (find-an-accountant state cluster, growth phase) — v2 dc-system.
    ONE source for per-state industry children under /find-an-accountant/<state>/industries/<industry>/.
    t-location + heroLight. v2 components, DOM modelled on the founder-approved NY industry children
    (new-york/industries/nonprofit.njk): summary · ai-5Q · challenges · what-we-handle · integrations ·
    process · advisory · expert-review · related · FAQ. NO tax-stack. Spine (hero / in-brief
    #{{ slug }}-in-brief-text / light CTA) is layout-owned (t-location); this partial renders the
    bespoke body AND its own FAQ (the layout FAQ is gated on sec.faqH, which partial pages do NOT set).
    Everything state+industry-specific comes from the page's .11tydata.js: summary, aiSummary,
    challenges, handle, integrations, integrationsNote, process, advisoryBody, faq, reviewProse,
    reviewCreds, related, copy.*, bookHref.
    Frozen schema cssSelectors (city graph): #{{ slug }}-summary (first summary para) + #{{ slug }}-ai-summary-list.
    HARD BAR: genuine state×industry substance; the mad-libs test must FAIL. HONESTY: real facts,
    tax specifics deferred to the authority + CPA/EA; founder-name-zero; not Intuit. -#}

{# ── SUMMARY · frozen anchor #{{ slug }}-summary on the first paragraph. ── #}
<section class="sec reveal" id="{{ slug }}-summary-sec" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In one paragraph</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">{{ copy.summaryHeading | safe }}</h2>
    <div class="prose">{%- for p in summary %}<p{% if loop.first %} id="{{ slug }}-summary"{% endif %}>{{ p | safe }}</p>{%- endfor %}</div>
  </div>
</section>

{# ── AI SUMMARY · five-question block; frozen anchor #{{ slug }}-ai-summary-list. ── #}
<section class="sec reveal" id="{{ slug }}-ai-summary-sec">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">For AI engines &amp; quick answers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 36px;max-width:26ch;">{{ copy.aiHeading | safe }}</h2>
    <dl class="speakable ai-qa" id="{{ slug }}-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-qa__item"><dt><h3>{{ item.q | safe }}</h3></dt><dd style="margin:0;"><p>{{ item.a | safe }}</p></dd></div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── CHALLENGES · the un-clonable band (r-3 dc-cards). ── #}
<section class="sec reveal" id="{{ slug }}-challenges" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ copy.challengesEyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:30ch;margin-bottom:10px;">{{ copy.challengesHeading | safe }}</h2>
    {%- if copy.challengesLede %}<p class="lede" style="margin:0 0 32px;max-width:64ch;">{{ copy.challengesLede | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for c in challenges %}
      <article class="dc-card"><span class="eyebrow">{{ c.signal | safe }}</span><h3>{{ c.title | safe }}</h3><div class="prose" style="font-size:15px;"><p>{{ c.body | safe }}</p></div></article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── WHAT WE HANDLE · the services (r-3 dc-cards). ── #}
<section class="sec reveal" id="{{ slug }}-handle">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">What TechBrot handles</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:30ch;margin-bottom:10px;">{{ copy.handleHeading | safe }}</h2>
    {%- if copy.handleLede %}<p class="lede" style="margin:0 0 32px;max-width:66ch;">{{ copy.handleLede | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for s in handle %}
      <article class="dc-card"><span class="eyebrow">{{ s.num }}</span><h3>{{ s.title | safe }}</h3><p class="prose" style="font-size:15px;margin:6px 0 12px;">{{ s.body | safe }}</p>{%- if s.href %}<a class="ptier__link" href="{{ s.href }}">{{ s.cta | safe }}</a>{%- endif %}</article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── INTEGRATIONS · tools reconciled with QuickBooks (incl-card + checklist). ── #}
<section class="sec reveal" id="{{ slug }}-integrations" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Tools we work alongside</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">{{ copy.integrationsHeading | safe }}</h2>
    <div class="incl-card">
      <ul class="checklist">
        {%- for t in integrations %}<li>{{ t | safe }}</li>{%- endfor %}
      </ul>
    </div>
    {%- if integrationsNote %}<div class="prose" style="margin-top:18px;"><p>{{ integrationsNote | safe }}</p></div>{%- endif %}
  </div>
</section>

{# ── PROCESS · four-phase engagement rhythm (r-2 dc-cards). ── #}
<section class="sec reveal" id="{{ slug }}-process">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">How engagements work</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:28ch;margin-bottom:10px;">{{ copy.processHeading | safe }}</h2>
    {%- if copy.processLede %}<p class="lede" style="margin:0 0 32px;max-width:66ch;">{{ copy.processLede | safe }}</p>{%- endif %}
    <div class="r-2">
      {%- for p in process %}
      <article class="dc-card"><span class="eyebrow">{{ p.phase }}</span><h3>{{ p.title | safe }}</h3><div class="prose" style="font-size:15px;"><p>{{ p.body | safe }}</p></div></article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── ADVISORY · standing brand line (pull-quote .statement). ── #}
<section class="sec reveal" id="{{ slug }}-advisory" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Beyond the books</span><span class="idx__rule"></span></div>
    <h2 class="statement" style="margin-bottom:18px;">{{ copy.advisoryHeading | safe }}</h2>
    <div class="prose">{%- for p in advisoryBody %}<p>{{ p | safe }}</p>{%- endfor %}</div>
    <div style="margin-top:22px;"><a class="btn btn-cta" href="{{ bookHref }}" style="display:inline-flex;align-items:center;height:48px;padding:0 22px;border-radius:11px;font-size:15px;font-weight:600;">Book the discovery call</a></div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name (byline + trust-row). ── #}
<section class="sec reveal" id="{{ slug }}-review">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Page review &amp; standards</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    <div class="byline" style="margin-bottom:18px;">
      <svg class="byline__mark" viewBox="0 0 64 64" role="img" aria-label="TechBrot"><rect width="64" height="64" rx="14" fill="#0E4A50"></rect><g transform="translate(12.16 12.16) scale(0.62)" fill="#FCFBF8"><path d="M8 10 H38 V54 H26 V22 H8 Z"></path><rect x="42" y="10" width="14" height="12"></rect></g></svg>
      <div><p class="byline__name">By the Certified QuickBooks ProAdvisor team</p><p class="byline__review">TechBrot Inc. &middot; Independent Certified QuickBooks ProAdvisor firm</p></div>
    </div>
    <div class="prose"><p>{{ reviewProse | safe }}</p></div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value" style="font-size:15px;">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-17</span><span>Updated: 2026-06-17</span><span>Reviewed: 2026-06-17 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{# ── RELATED · state services & industries (r-2 rel-cards). ── #}
{%- if related %}
<section class="sec reveal" id="{{ slug }}-related" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Related</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">{{ copy.relatedHeading | safe }}</h2>
    <div class="r-2">
      {%- for r in related %}
      <a class="rel-card" href="{{ r.href }}"><h3 class="rel-card__t">{{ r.title | safe }}</h3><p class="rel-card__d">{{ r.body | safe }}</p><span class="ptier__link" style="margin-top:10px;">{{ r.cta | safe }}</span></a>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

{# ── FAQ · v2 details/summary; visible = FAQPage schema. id #{{ slug }}-faq. ── #}
<section class="sec reveal" id="{{ slug }}-faq" style="padding-top:72px;">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">FAQ</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">{{ copy.faqHeading | safe }}</h2>
    <div class="faq">
      {%- for item in faq %}
      <details name="{{ slug }}-faq"{% if loop.first %} open{% endif %}><summary>{{ item.q | safe }}<span class="pl"></span></summary><div>{{ item.a | safe }}</div></details>
      {%- endfor %}
    </div>
  </div>
</section>
