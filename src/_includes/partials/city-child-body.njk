{#- SHARED CITY-CHILD BODY (growth phase, find-an-accountant state cluster) — v2 dc-system.
    ONE source for every city child under /find-an-accountant/<state>/cities/<city>/.
    DOM is proven-equivalent to the founder-approved San Francisco proof (san-francisco.njk):
    v2 components, section order + ids + schema selectors identical. Spine (hero / in-brief
    #{{ slug }}-in-brief-text / light CTA) is layout-owned (t-location); this partial renders the
    bespoke body AND its own FAQ (the layout FAQ is gated on sec.faqH, which partial pages do NOT set).
    Everything locale-specific comes from the page's .11tydata.js:
      cityName  — full city name for headings (e.g. "Los Angeles")
      slug      — section-ID prefix + speakable selector key (e.g. "la")
      copy.*    — per-section eyebrows (locale-flavoured, NOT mad-libs)
      summarized · aiSummary · localContext · areas · taxStack · taxNote ·
      industries · services · advisoryBody · advisoryCtaHref · reviewCreds · faq
    Frozen schema cssSelectors (city graph): #{{ slug }}-summary (TL;DR para) + #{{ slug }}-ai-summary-list.
    TAX STACK is RATE-FREE — every figure/desc verbatim from the page's real taxStack data; no
    invented rates. HONESTY: real facts only; nexus/filing deferred to CPA/EA. Founder-name-zero. -#}

{# ── SHORT VERSION · real H2 carrying the TL;DR prose; frozen anchor #{{ slug }}-summary on the para. ── #}
<section class="sec reveal" id="{{ slug }}-summary-sec" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">In full</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">The short version.</h2>
    <div class="prose"><p id="{{ slug }}-summary">{{ summarized | safe }}</p></div>
  </div>
</section>

{# ── AI SUMMARY · five-question block; frozen anchor #{{ slug }}-ai-summary-list. ── #}
<section class="sec reveal" id="{{ slug }}-ai-summary-sec">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">For AI engines &amp; quick answers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 36px;max-width:26ch;">{{ cityName | safe }} bookkeeping, in five questions.</h2>
    <dl class="speakable ai-qa" id="{{ slug }}-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-qa__item"><dt><h3>{{ item.q | safe }}</h3></dt><dd style="margin:0;"><p>{{ item.a | safe }}</p></dd></div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── LOCAL CONTEXT · the un-clonable band. ── #}
<section class="sec reveal" id="{{ slug }}-local" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ copy.localEyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">Why {{ cityName | safe }} books are different.</h2>
    <div class="prose">
      {%- for p in localContext %}<p>{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AREAS · neighborhood chips (name + note preserved). ── #}
<section class="sec reveal" id="{{ slug }}-areas">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ copy.areasEyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:20px;">{{ cityName | safe }} areas we serve.</h2>
    <div class="chips">
      {%- for a in areas %}
      <span class="chip"><strong>{{ a.name | safe }}</strong>&nbsp;<span class="chip__note">&middot; {{ a.note | safe }}</span></span>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── LOCAL TAX STACK · RATE-FREE v2 figure built from the REAL `taxStack` data (figure + desc).
     No invented rates; every figure/desc verbatim from the data. taxNote preserved below. ── #}
<section class="sec reveal" id="{{ slug }}-tax" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">{{ copy.taxEyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 30px;max-width:24ch;">{{ cityName | safe }}&rsquo;s tax stack, at a glance.</h2>
    <figure style="margin:0;" aria-label="{{ cityName }} local tax facts">
      <div class="r-3">
        {%- for t in taxStack %}
        <div class="dc-card"><div class="trust-row__value" style="font-size:30px;margin-bottom:8px;">{{ t.figure | safe }}</div><p class="prose" style="font-size:15px;">{{ t.desc | safe }}</p></div>
        {%- endfor %}
      </div>
      {%- if taxNote %}<figcaption class="prose" style="margin-top:18px;font-size:13px;color:var(--color-ink-faint);">{{ taxNote | safe }}</figcaption>{%- endif %}
    </figure>
  </div>
</section>

{# ── INDUSTRIES · chips, each links to the dedicated industry page with the local wrinkle. ── #}
<section class="sec reveal" id="{{ slug }}-industries">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ copy.industriesEyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:10px;">Industry-specific bookkeeping for {{ cityName | safe }} businesses.</h2>
    <p class="lede" style="margin:0 0 24px;max-width:62ch;">Each links to our dedicated industry page, with the {{ cityName | safe }} wrinkles built in.</p>
    <div class="chips">
      {%- for i in industries %}
      <a class="chip" href="{{ i.href }}"><strong>{{ i.label | safe }}</strong>&nbsp;<span class="chip__note">&middot; {{ i.note | safe }}</span>&nbsp;&rarr;</a>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── VALUE STACK · services, real H3s (dc-card + eyebrow num + cta). ── #}
<section class="sec reveal" id="{{ slug }}-services" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ copy.servicesEyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:30px;">Complete bookkeeping, {{ cityName | safe }}-aware.</h2>
    <div class="r-2">
      {%- for s in services %}
      <div class="dc-card"><span class="eyebrow">{{ s.num }}</span><h3>{{ s.title | safe }}</h3><div class="prose" style="font-size:15.5px;"><p>{{ s.body | safe }}</p></div><a class="ptier__link" href="{{ s.href }}">{{ s.cta | safe }}</a></div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── ADVISORY · standing brand line (pull-quote .statement). ── #}
<section class="sec reveal" id="{{ slug }}-advisory">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Beyond bookkeeping</span><span class="idx__rule"></span></div>
    <h2 class="statement" style="margin-bottom:18px;">Automation handles the data entry. We handle the judgment.</h2>
    <div class="prose"><p>{{ advisoryBody | safe }}</p></div>
    <div style="margin-top:22px;"><a class="btn btn-cta" href="{{ advisoryCtaHref }}" style="display:inline-flex;align-items:center;height:48px;padding:0 22px;border-radius:11px;font-size:15px;font-weight:600;">Book the discovery call</a></div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name (trust-row from reviewCreds). ── #}
<section class="sec reveal" id="{{ slug }}-review" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">Page review &amp; standards</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value" style="font-size:15px;">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-17</span><span>Updated: 2026-06-17</span><span>Reviewed: 2026-06-17 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{# ── FAQ · v2 details/summary; visible = FAQPage schema. id #{{ slug }}-faq. ── #}
<section class="sec reveal" id="{{ slug }}-faq" style="padding-top:72px;">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ copy.faqEyebrow | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">{{ cityName | safe }} bookkeeping questions.</h2>
    <div class="faq">
      {%- for item in faq %}
      <details name="{{ slug }}-faq"{% if loop.first %} open{% endif %}><summary>{{ item.q | safe }}<span class="pl"></span></summary><div>{{ item.a | safe }}</div></details>
      {%- endfor %}
    </div>
  </div>
</section>
