{#- SHARED CITY-CHILD BODY (growth phase, find-an-accountant state cluster).
    ONE source for every city child under /find-an-accountant/<state>/cities/<city>/.
    DOM is proven-equivalent to the founder-approved San Francisco proof
    (san-francisco.njk) — section order, classes, schema selectors identical.
    Everything locale-specific comes from the page's .11tydata.js:
      cityName  — full city name for headings (e.g. "Los Angeles")
      slug      — section-ID prefix + speakable selector key (e.g. "la")
      copy.*    — per-section eyebrows (locale-flavoured, NOT mad-libs)
      summarized · aiSummary · localContext · areas · taxStack · taxNote ·
      industries · services · advisoryBody · advisoryCtaHref · reviewCreds · faq
    The un-clonable LOCAL CONTEXT + TAX STACK bands carry the real local-tax
    substance; the mad-libs test must FAIL on every page (swap the place name →
    it reads false). HONESTY: real facts only; nexus/filing deferred to CPA/EA. -#}

{# ── SUMMARY · real H2 right after the in-brief. ── #}
<section class="section section--compact" id="{{ slug }}-summary-sec">
  <div class="container container--narrow">
    <header class="section__header">
      <h2 class="section__heading">The short version.</h2>
    </header>
    <p class="prose" id="{{ slug }}-summary">{{ summarized | safe }}</p>
  </div>
</section>

{# ── AI SUMMARY · five-question block. ── #}
<section class="section" id="{{ slug }}-ai-summary-sec">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">{{ cityName | safe }} bookkeeping, in five questions.</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="{{ slug }}-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── LOCAL CONTEXT · the un-clonable band. ── #}
<section class="section section--alt" id="{{ slug }}-local">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{{ copy.localEyebrow | safe }}</p>
      <h2 class="section__heading">Why {{ cityName | safe }} books are different.</h2>
    </header>
    <div class="stack-8">
      {%- for p in localContext %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
  </div>
</section>

{# ── AREAS. ── #}
<section class="section" id="{{ slug }}-areas">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">{{ copy.areasEyebrow | safe }}</p>
      <h2 class="section__heading">{{ cityName | safe }} areas we serve.</h2>
    </header>
    <div class="grid-3">
      {%- for a in areas %}
      <div class="stack-8">
        <p class="section__eyebrow">{{ a.name | safe }}</p>
        <p class="prose">{{ a.note | safe }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── TAX STACK · grid-3. ── #}
<section class="section section--alt" id="{{ slug }}-tax">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">{{ copy.taxEyebrow | safe }}</p>
      <h2 class="section__heading">{{ cityName | safe }}&rsquo;s tax stack, at a glance.</h2>
    </header>
    <div class="grid-3">
      {%- for t in taxStack %}
      <div class="stack-8">
        <p class="proof-strip__rating">{{ t.figure | safe }}</p>
        <p class="prose">{{ t.desc | safe }}</p>
      </div>
      {%- endfor %}
    </div>
    <p class="prose"><small>{{ taxNote | safe }}</small></p>
  </div>
</section>

{# ── INDUSTRIES · checks-list into national industry pages, with local wrinkles. ── #}
<section class="section" id="{{ slug }}-industries">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{{ copy.industriesEyebrow | safe }}</p>
      <h2 class="section__heading">Industry-specific bookkeeping for {{ cityName | safe }} businesses.</h2>
      <p class="section__lede">Each links to our dedicated industry page, with the {{ cityName | safe }} wrinkles built in.</p>
    </header>
    <ul class="checks-list">
      {%- for i in industries %}
      <li><a href="{{ i.href }}">{{ i.label | safe }}</a> &mdash; {{ i.note | safe }}</li>
      {%- endfor %}
    </ul>
  </div>
</section>

{# ── SERVICES · grid-2 buyer-cards. ── #}
<section class="section section--alt" id="{{ slug }}-services">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">{{ copy.servicesEyebrow | safe }}</p>
      <h2 class="section__heading">Complete bookkeeping, {{ cityName | safe }}-aware.</h2>
    </header>
    <div class="grid-2">
      {%- for s in services %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ s.num }}</p>
        <h3 class="buyer-card__heading">{{ s.title | safe }}</h3>
        <p class="buyer-card__body">{{ s.body | safe }}</p>
        <a class="buyer-card__cta" href="{{ s.href }}">{{ s.cta | safe }}</a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── ADVISORY · standing brand line. ── #}
<section class="section" id="{{ slug }}-advisory">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Beyond bookkeeping</p>
      <h2 class="section__heading">Automation handles the data entry. We handle the judgment.</h2>
    </header>
    <p class="prose">{{ advisoryBody | safe }}</p>
    <div class="hero__actions">
      <a class="btn btn--primary btn--lg" href="{{ advisoryCtaHref }}">Book the discovery call</a>
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no founder name. ── #}
<section class="section section--alt" id="{{ slug }}-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    </header>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-17</span><span>Updated: 2026-06-17</span><span>Reviewed: 2026-06-17 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>

{# ── FAQ · visible faq__list = FAQPage schema. ── #}
<section class="section" id="{{ slug }}-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{{ copy.faqEyebrow | safe }}</p>
      <h2 class="section__heading">{{ cityName | safe }} bookkeeping questions.</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="{{ slug }}-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="{{ slug }}-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
