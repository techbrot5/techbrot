{#- SHARED STATE-TRIAGE-CHILD BODY (find-an-accountant honest-triage, growth phase).
    ONE source for per-state honest-triage pages (state-tax-notice-help, business-tax-problems).
    t-bofu tier. DOM modelled on the founder-approved NY honest-triage pages
    (new-york/state-tax-notice-help.njk) — Sheet-7 honest-triage discipline (§8):
      • amber .disclosure--warn banner ABOVE THE FOLD + explicit do/don't boundaries
      • not a tax authority, not a CPA/EA/attorney; contacting us reaches no agency
      • we deliver the BOOKS work; the licensed professional responds + represents
      • converts by CALL; never "official"; never implies Intuit/agency affiliation
    All state+page-specific content comes from the page's .11tydata.js (disclosure,
    boundariesDo/Dont, callBreakout, tldr, aiSummary, problemTypes, booksBody, scopeDo/Dont,
    faq, reviewProse, reviewCreds, copy.*). HONESTY is the #1 gate on these pages. -#}

{# ── DISCLOSURE BANNER · ABOVE THE FOLD (Sheet-7) ── #}
<section class="section section--compact" id="{{ slug }}-disclosure">
  <div class="container container--narrow">
    <div class="disclosure disclosure--warn">
      <svg class="disclosure__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#A4660A" stroke-width="1.75" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 7.5v.3" stroke-linecap="round"/></svg>
      <div class="disclosure__body">{{ disclosure | safe }}</div>
    </div>
    <ul class="checks-list" id="{{ slug }}-boundaries">
      <li><strong>What we do:</strong> {{ boundariesDo | safe }}</li>
      <li><strong>What we do not do:</strong> {{ boundariesDont | safe }}</li>
    </ul>
  </div>
</section>

{# ── CALL · honest-triage converts by CALL ── #}
<section class="section section--compact" id="{{ slug }}-call">
  <div class="container container--narrow">
    <div class="call-breakout">
      <div>
        <p class="call-breakout__title">{{ callBreakout.title | safe }}</p>
        <p class="call-breakout__sub">{{ callBreakout.sub | safe }}</p>
      </div>
      <a class="btn btn--primary" href="tel:{{ site.phone.e164 }}" data-tb-event="phone_click">Speak to a ProAdvisor</a>
    </div>
  </div>
</section>

{# ── SHORT VERSION · TL;DR ── #}
<section class="section section--compact" id="{{ slug }}-tldr">
  <div class="container container--narrow">
    <header class="section__header">
      <h2 class="section__heading">The short version.</h2>
    </header>
    <p class="prose" id="{{ slug }}-summary">{{ tldr | safe }}</p>
  </div>
</section>

{# ── AI SUMMARY · five-question block ── #}
<section class="section" id="{{ slug }}-ai-summary-sec">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">{{ copy.aiHeading | safe }}</h2>
    </header>
    <dl class="ai-summary ai-summary--ruled" id="{{ slug }}-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <dt class="ai-summary__question">{{ item.q | safe }}</dt>
        <dd class="ai-summary__answer"><p>{{ item.a | safe }}</p></dd>
      </div>
      {%- endfor %}
    </dl>
  </div>
</section>

{# ── PROBLEM / NOTICE TYPES · grid-3 buyer-cards ── #}
<section class="section section--alt" id="{{ slug }}-types">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">{{ copy.typesEyebrow | safe }}</p>
      <h2 class="section__heading">{{ copy.typesHeading | safe }}</h2>
      {%- if copy.typesLede %}<p class="section__lede">{{ copy.typesLede | safe }}</p>{%- endif %}
    </header>
    <div class="grid-3">
      {%- for n in problemTypes %}
      <article class="buyer-card">
        <p class="buyer-card__opener">{{ n.form | safe }}</p>
        <h3 class="buyer-card__heading">{{ n.title | safe }}</h3>
        <p class="buyer-card__body">{{ n.body | safe }}</p>
      </article>
      {%- endfor %}
    </div>
    {%- if problemTypesNote %}<p class="prose"><small>{{ problemTypesNote | safe }}</small></p>{%- endif %}
  </div>
</section>

{# ── BOOKS-PROBLEM root-cause band ── #}
<section class="section" id="{{ slug }}-books">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">{{ copy.booksEyebrow | safe }}</p>
      <h2 class="section__heading">{{ copy.booksHeading | safe }}</h2>
    </header>
    <div class="stack-8">
      {%- for p in booksBody %}<p class="prose">{{ p | safe }}</p>{%- endfor %}
    </div>
    {%- if booksNote %}<ul class="checks-list" id="{{ slug }}-booksnote"><li>{{ booksNote | safe }}</li></ul>{%- endif %}
  </div>
</section>

{# ── SCOPE SPLIT · honest who-does-what (grid-2 buyer-cards) ── #}
<section class="section section--alt" id="{{ slug }}-scope">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Honest scope</p>
      <h2 class="section__heading">{{ copy.scopeHeading | safe }}</h2>
      {%- if copy.scopeLede %}<p class="section__lede">{{ copy.scopeLede | safe }}</p>{%- endif %}
    </header>
    <div class="grid-2">
      <article class="buyer-card">
        <h3 class="buyer-card__heading">{{ copy.scopeDoTitle | safe }}</h3>
        <ul class="checks-list">
          {%- for li in scopeDo %}<li>{{ li | safe }}</li>{%- endfor %}
        </ul>
      </article>
      <article class="buyer-card">
        <h3 class="buyer-card__heading">{{ copy.scopeDontTitle | safe }}</h3>
        <ul class="checks-list">
          {%- for li in scopeDont %}<li>{{ li | safe }}</li>{%- endfor %}
        </ul>
      </article>
    </div>
  </div>
</section>

{# ── FAQ · visible faq__list = FAQPage schema ── #}
<section class="section" id="{{ slug }}-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Common questions</p>
      <h2 class="section__heading">{{ copy.faqHeading | safe }}</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="{{ slug }}-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="{{ slug }}-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

{# ── EXPERT REVIEW · firm-level, no personal name ── #}
<section class="section section--alt" id="{{ slug }}-review">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Page review &amp; standards</p>
      <h2 class="section__heading">Reviewed by the TechBrot Certified ProAdvisor team.</h2>
    </header>
    <div class="byline-block">
      <div class="byline-block__mark" aria-hidden="true"></div>
      <div>
        <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="byline-block__review">TechBrot Inc. &middot; Independent Certified QuickBooks ProAdvisor firm</p>
      </div>
    </div>
    <div class="prose"><p>{{ reviewProse | safe }}</p></div>
    <div class="trust-row">
      {%- for c in reviewCreds %}
      <div class="trust-row__item"><p class="trust-row__value">{{ c.label }}</p><p class="trust-row__label">{{ c.detail | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-17</span><span>Updated: 2026-06-17</span><span>Reviewed: 2026-06-17 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>
