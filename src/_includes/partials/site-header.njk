{#- Site header chrome — ELEVATED SKIN (Gallery 04 mid-mega capture, 2026-06-16).
    chrome: "full" (default) | "minimal" (BOFU endpoints — logo + phone only).
    Contained mid-mega panels (~50%, anchored under trigger, descriptive 2-col +
    mega-call), find-an-accountant = DIRECT link, real crawlable hrefs (no #).
    JS hooks unchanged (tb-nav.js): .nav__trigger / .nav__dropdown[data-open] /
    .nav__hamburger / .drawer / .drawer__trigger / .drawer__panel. Link set carried
    from the prior chrome (content equity); markup recomposed to the mid-mega. -#}
{%- if chrome != "minimal" %}
<div class="util-bar" role="region" aria-label="Secondary">
  <div class="container">
    <span class="util-bar__left">Independent Certified QuickBooks ProAdvisor firm &middot; U.S.-based</span>
    <span class="util-bar__links">
      <a href="/find-an-accountant/">Find an Accountant</a>
      <a class="util-bar__foracct" href="/partners/">For Accountants &rarr;</a>
    </span>
  </div>
</div>
{%- endif %}

<header class="site-header{% if chrome == "minimal" %} site-header--minimal{% endif %}" role="banner" id="site-header">
  <div class="container">
    <a class="site-header__logo" href="/" aria-label="TechBrot home">
      <img src="/assets/img/brand/logo-horizontal.svg" alt="TechBrot" width="116" height="30">
    </a>

    {%- if chrome != "minimal" %}
    <ul class="site-nav" aria-label="Primary navigation" id="primary-nav">
      <li class="nav__item"><a class="nav__link" href="/find-an-accountant/">Find an accountant</a></li>
      <li class="nav__item">
        <button class="nav__trigger" type="button" aria-expanded="false" aria-controls="nav-menu-accounting" aria-haspopup="true">Accounting</button>
        <div class="nav__dropdown nav__dropdown--mega" id="nav-menu-accounting" role="region" aria-label="Accounting" data-open="false">
          <div class="nav__mega">
            <div class="nav__mega-col">
              <p class="nav__mega-head">Core services</p>
              <a href="/accounting/bookkeeping/monthly-bookkeeping/">Monthly bookkeeping<span>Reconciled monthly, fixed fee</span></a>
              <a href="/accounting/advisory/">Fractional CFO &amp; advisory<span>Judgment, not just data entry</span></a>
              <a href="/accounting/sales-tax-compliance/">Sales tax &amp; payroll<span>Filed and reconciled monthly</span></a>
            </div>
            <div class="nav__mega-col">
              <p class="nav__mega-head">Start here</p>
              <a href="/accounting/bookkeeping/cleanup-bookkeeping/">Cleanup &amp; catch-up<span>Bring a behind file current</span></a>
              <a href="/quickbooks/file-review/">Free file review<span>We look before we scope</span></a>
              <a href="/pricing/">Pricing<span>Fixed fee, in writing first</span></a>
            </div>
          </div>
          <div class="nav__mega-call">
            <span>Accounting, cleanup, advisory &mdash; we match the right expert to your books.</span>
            <a href="/accounting/">All accounting services <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a>
          </div>
        </div>
      </li>
      <li class="nav__item">
        <button class="nav__trigger" type="button" aria-expanded="false" aria-controls="nav-menu-quickbooks" aria-haspopup="true">QuickBooks</button>
        <div class="nav__dropdown nav__dropdown--mega" id="nav-menu-quickbooks" role="region" aria-label="QuickBooks" data-open="false">
          <div class="nav__mega">
            <div class="nav__mega-col">
              <p class="nav__mega-head">Fix &amp; set up</p>
              <a href="/quickbooks/cleanup/">Cleanup &amp; catch-up<span>Behind, broken, or messy books</span></a>
              <a href="/quickbooks/setup/">Setup &amp; migration<span>Set up right; Desktop &rarr; Online</span></a>
              <a href="/quickbooks/speak-to-a-quickbooks-expert/">Speak to an expert<span>Independent &middot; not Intuit</span></a>
            </div>
            <div class="nav__mega-col">
              <p class="nav__mega-head">Keep it clean</p>
              <a href="/accounting/bookkeeping/">Ongoing bookkeeping<span>Monthly, reconciled to the bank</span></a>
              <a href="/quickbooks/payroll/">QuickBooks Payroll<span>Filed and tied out</span></a>
              <a href="/quickbooks/help/">Help &amp; error codes<span>How the work actually goes</span></a>
            </div>
          </div>
          <div class="nav__mega-call">
            <span>Free file review &mdash; written scope in 3 business days.</span>
            <a href="/quickbooks/">Explore QuickBooks help <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a>
          </div>
        </div>
      </li>
      <li class="nav__item"><a class="nav__link" href="/vs/">Compare</a></li>
      <li class="nav__item"><a class="nav__link" href="/resources/research/">Resources</a></li>
    </ul>
    {%- endif %}

    <div class="site-header__actions">
      <a class="site-header__phone" href="tel:{{ site.phone.e164 }}" data-tb-event="phone_click" aria-label="Call TechBrot at {{ site.phone.display }}">
        {% include "icons/phone.svg" %}
        <span>{{ site.phone.display }}</span>
      </a>
      {%- if chrome != "minimal" %}
      <a class="btn btn--dark site-header__cta" href="/contact/?intent=home">Book the discovery call</a>
      <button class="nav__hamburger" type="button" aria-expanded="false" aria-controls="site-drawer" aria-label="Open navigation menu">
        {% include "icons/menu.svg" %}
      </button>
      {%- endif %}
    </div>
  </div>
</header>

{%- if chrome != "minimal" %}
<div class="drawer" id="site-drawer" role="dialog" aria-modal="true" aria-label="Navigation" data-open="false">
  <div class="drawer__head">
    <a class="site-header__logo" href="/" aria-label="TechBrot home">
      <img src="/assets/img/brand/logo-horizontal.svg" alt="TechBrot" width="116" height="30">
    </a>
    <button class="drawer__close" type="button" aria-label="Close navigation menu" data-action="close-drawer">
      {% include "icons/x.svg" %}
    </button>
  </div>
  <nav aria-label="Mobile primary navigation">
    <div class="drawer__group"><a class="drawer__link" href="/find-an-accountant/">Find an accountant</a></div>
    <div class="drawer__group">
      <button class="drawer__trigger" type="button" aria-expanded="false" aria-controls="drawer-accounting">Accounting</button>
      <div class="drawer__panel" id="drawer-accounting" data-open="false">
        <ul>
          <li><a href="/accounting/bookkeeping/monthly-bookkeeping/">Monthly bookkeeping</a></li>
          <li><a href="/accounting/bookkeeping/cleanup-bookkeeping/">Cleanup &amp; catch-up</a></li>
          <li><a href="/accounting/advisory/">Fractional CFO &amp; advisory</a></li>
          <li><a href="/accounting/sales-tax-compliance/">Sales tax &amp; payroll</a></li>
          <li><a href="/pricing/">Pricing</a></li>
          <li><a href="/accounting/">Accounting overview <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a></li>
        </ul>
      </div>
    </div>
    <div class="drawer__group">
      <button class="drawer__trigger" type="button" aria-expanded="false" aria-controls="drawer-quickbooks">QuickBooks</button>
      <div class="drawer__panel" id="drawer-quickbooks" data-open="false">
        <ul>
          <li><a href="/quickbooks/cleanup/">Cleanup &amp; catch-up</a></li>
          <li><a href="/quickbooks/setup/">Setup &amp; migration</a></li>
          <li><a href="/quickbooks/speak-to-a-quickbooks-expert/">Speak to an expert</a></li>
          <li><a href="/quickbooks/payroll/">QuickBooks Payroll</a></li>
          <li><a href="/quickbooks/help/">Help &amp; error codes</a></li>
          <li><a href="/quickbooks/">QuickBooks overview <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a></li>
        </ul>
      </div>
    </div>
    <div class="drawer__group"><a class="drawer__link" href="/vs/">Compare</a></div>
    <div class="drawer__group"><a class="drawer__link" href="/resources/research/">Resources</a></div>
  </nav>
  <div class="drawer__foot">
    <a class="btn btn--primary btn--lg" href="tel:{{ site.phone.e164 }}" data-tb-event="phone_click">{% include "icons/phone.svg" %} Speak to a ProAdvisor</a>
    <a class="btn btn--ghost" href="/contact/?intent=home">Book the discovery call</a>
  </div>
</div>
{%- endif %}
