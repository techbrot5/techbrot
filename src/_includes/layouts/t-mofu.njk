---
layout: layouts/base.njk
tierClass: section--tier-guide
callBar: true
---
{#- T-MOFU tier skeleton — NEW SKIN (tiers/t-mofu.html + PLACEMENT-MAP).
    Paper compact hero (hero--rule opt-in via `heroRule: true` ONLY when
    the page has no motif row) · breadcrumb · sticky call-bar (mobile,
    by rule on MOFU) · guide tint. chrome: full (base default).
    Pages disable the bar with callBar: false. Content machinery FENCED. -#}

{%- if breadcrumb %}
<nav class="breadcrumb" aria-label="Breadcrumb" id="{{ slug }}-breadcrumb">
  <div class="container">
    <ol>
      {%- for item in breadcrumb %}
      {%- if item.href %}
      <li><a href="{{ item.href }}">{{ item.name }}</a></li>
      <li class="sep" aria-hidden="true">/</li>
      {%- else %}
      <li aria-current="page">{{ item.name }}</li>
      {%- endif %}
      {%- endfor %}
    </ol>
  </div>
</nav>
{%- endif %}

{%- if hero %}
<section class="section hero-tier hero--compact{% if heroRule %} hero--rule{% endif %}" id="{{ slug }}-hero">
  <div class="container">
    <div class="hero">
      <p class="hero__eyebrow">{{ hero.eyebrow | safe }}</p>
      <h1 class="hero__heading">{{ hero.heading | safe }}</h1>
      <p class="hero__subheading">{{ hero.subheading | safe }}</p>
      {%- if hero.actions %}
      <div class="hero__actions">
        {%- for action in hero.actions %}
        <a class="btn {{ action.class }} btn--lg" href="{% if action.tel %}tel:{{ site.phone.e164 }}{% else %}{{ action.href }}{% endif %}"
          {%- if action.tel or (action.href and action.href.startsWith("tel:")) %} data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
        {%- endfor %}
      </div>
      {%- endif %}
    </div>
  </div>
</section>
{%- endif %}

{%- if inBrief %}
<section class="section section--compact" id="{{ slug }}-in-brief">
  <div class="container">
    <div class="in-brief">
      <p class="in-brief__text" id="{{ slug }}-in-brief-text">{{ inBrief.text | safe }}</p>
      {%- if inBrief.source %}<p class="in-brief__source">{{ inBrief.source | safe }}</p>{%- endif %}
    </div>
  </div>
</section>
{%- endif %}

{{ content | safe }}

{%- if ctaBand %}
<section class="section section--cta-band section--cta-band--light {{ tierClass }}" id="{{ slug }}-cta">
  <div class="cta-band__motif" aria-hidden="true">{% include "partials/motif-align-single.svg" %}</div>
  <div class="container">
    <div class="final-cta">
      <p class="section__eyebrow">{{ ctaBand.eyebrow | safe }}</p>
      <h2 class="final-cta__heading">{{ ctaBand.heading | safe }}</h2>
      <p class="final-cta__lede">{{ ctaBand.lede | safe }}</p>
      <div class="final-cta__actions">
        {%- for action in ctaBand.actions %}
        <a class="btn {{ action.class }}" href="{% if action.tel %}tel:{{ site.phone.e164 }}{% else %}{{ action.href }}{% endif %}"
          {%- if action.tel or (action.href and action.href.startsWith("tel:")) %} data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
        {%- endfor %}
      </div>
      <p class="final-cta__disclaimer">TechBrot is an independent accounting firm and Certified QuickBooks ProAdvisor. We are not Intuit. QuickBooks and Intuit are registered trademarks of Intuit Inc.</p>
    </div>
  </div>
</section>
{%- endif %}
