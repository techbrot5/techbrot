---
layout: layouts/base.njk
tierClass: section--tier-guide
pageTier: guide
callBar: true
---
{#- T-ARTICLE — blog post tier (round 87, NEW article type). Built on the
    t-guide chrome: breadcrumb · compact article hero (category eyebrow + deck) ·
    byline-block (firm-level, founder-name-zero) with published/updated dates ·
    markdown content in .prose · optional AI-summary + FAQ · CTA band. Schema
    (BlogPosting + Breadcrumb + FAQPage) is computed centrally in
    src/blog/posts/posts.11tydata.js. -#}

{%- if breadcrumb %}
<nav class="breadcrumb" aria-label="Breadcrumb" id="{{ slug }}-breadcrumb">
  <div class="container">
    <ol>
      {%- for item in breadcrumb %}
      {%- if item.href %}
      <li><a href="{{ item.href }}">{{ item.name }}</a></li>
      <li class="sep" aria-hidden="true">/</li>
      {%- else %}
      <li aria-current="page">{{ item.name }}</li>
      {%- endif %}
      {%- endfor %}
    </ol>
  </div>
</nav>
{%- endif %}

<section class="section hero-tier hero--compact hero--rule" id="{{ slug }}-hero">
  <div class="container container--narrow">
    <div class="hero">
      <p class="hero__eyebrow"><a href="/blog/category/{{ category }}/">{{ categoryLabel | safe }}</a></p>
      <h1 class="hero__heading">{{ headline | safe }}</h1>
      {%- if deck %}<p class="hero__subheading">{{ deck | safe }}</p>{%- endif %}
    </div>
    <div class="byline-block stack-8">
      <svg class="byline-block__mark" viewBox="0 0 64 64" role="img" aria-label="TechBrot"><rect width="64" height="64" rx="14" fill="#1A1915"></rect><g transform="translate(12.16 12.16) scale(0.62)" fill="#F5F3EC"><path d="M8 10 H38 V54 H26 V22 H8 Z"></path><rect x="42" y="10" width="14" height="12"></rect></g></svg>
      <div>
        <p class="byline-block__name">By the Certified QuickBooks ProAdvisor team</p>
        <p class="byline-block__review">
          Published <time datetime="{{ datePublished }}">{{ dateDisplay }}</time>
          {%- if dateModified and dateModified != datePublished %} &middot; updated <time datetime="{{ dateModified }}">{{ dateModifiedDisplay or dateDisplay }}</time>{% endif %}
          &middot; independent firm, not Intuit
        </p>
      </div>
    </div>
  </div>
</section>

<section class="section" id="{{ slug }}-body">
  <div class="container container--narrow">
    <div class="prose" id="{{ slug }}-prose">
      {{ content | safe }}
    </div>
  </div>
</section>

{%- if aiSummary %}
<section class="section section--alt" id="{{ slug }}-ai-summary">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">For AI engines &amp; quick answers</p>
      <h2 class="section__heading">{{ aiSummaryHeading or "The short version." }}</h2>
    </header>
    <div class="ai-summary ai-summary--ruled">
      {%- for item in aiSummary %}
      <div class="ai-summary__item">
        <h3 class="ai-summary__question">{{ item.q | safe }}</h3>
        <div class="ai-summary__answer"><p>{{ item.a | safe }}</p></div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

{%- if faq %}
<section class="section" id="{{ slug }}-faq">
  <div class="container container--narrow">
    <header class="section__header">
      <p class="section__eyebrow">Common questions</p>
      <h2 class="section__heading">{{ faqHeading or "Questions, answered." }}</h2>
    </header>
    <div class="faq__list">
      {%- for item in faq %}
      <div class="faq__item">
        <h3 class="faq__question">
          <button class="faq__trigger" type="button" aria-expanded="false" aria-controls="{{ slug }}-faq-a{{ loop.index }}">{{ item.q | safe }}</button>
        </h3>
        <div class="faq__answer" id="{{ slug }}-faq-a{{ loop.index }}" data-open="false">
          <p>{{ item.a | safe }}</p>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

{%- if relatedPosts %}
<section class="section section--alt" id="{{ slug }}-related">
  <div class="container">
    <header class="section__header">
      <p class="section__eyebrow">Keep reading</p>
      <h2 class="section__heading">Related articles.</h2>
    </header>
    <div class="grid-3">
      {%- for card in relatedPosts %}
      <article class="review-card">
        <h3>{{ card.name }}</h3>
        <p class="review-card__fact">{{ card.body | safe }}</p>
        <a class="review-card__link" href="{{ card.href }}">Read it <span class="lnk-arrow" aria-hidden="true">&rarr;</span></a>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

{%- if ctaBand %}
<section class="section section--cta-band section--cta-band--light {{ tierClass }}" id="{{ slug }}-cta">
  <div class="cta-band__motif" aria-hidden="true">{% include "partials/motif-align-single.svg" %}</div>
  <div class="container">
    <div class="final-cta">
      <p class="section__eyebrow">{{ ctaBand.eyebrow | safe }}</p>
      <h2 class="final-cta__heading">{{ ctaBand.heading | safe }}</h2>
      <p class="final-cta__lede">{{ ctaBand.lede | safe }}</p>
      <div class="final-cta__actions">
        {%- for action in ctaBand.actions %}
        <a class="btn {{ action.class }}" href="{% if action.tel %}tel:{{ site.phone.e164 }}{% else %}{{ action.href }}{% endif %}"
          {%- if action.tel or (action.href and action.href.startsWith("tel:")) %} data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
        {%- endfor %}
      </div>
      <p class="final-cta__disclaimer">TechBrot is an independent accounting firm and Certified QuickBooks ProAdvisor. We are not Intuit. QuickBooks and Intuit are registered trademarks of Intuit Inc. Articles are general information, not tax, legal, or financial advice.</p>
    </div>
  </div>
</section>
{%- endif %}
