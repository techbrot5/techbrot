---
layout: layouts/dc-base.njk
footerNav:
  label: Find an accountant
  links:
    - { href: "/find-an-accountant/new-york/", text: "New York" }
    - { href: "/find-an-accountant/california/", text: "California" }
    - { href: "/find-an-accountant/", text: "All states" }
---
{#- ===========================================================================
    t-state-pillar — D3 state-pillar family (NEW handoff "State Pillar.dc.html").
    New handoff CHROME via dc-base; the pillar body (already on the elevated
    sense-of-place vocabulary: trust strip · stat band · in-brief · LIGHT ruled
    multi-Q&A AI · deliver · process · industries · directory · vs-table · form ·
    review · faq) renders via the elevated component layer. Hero = light split
    article-hero + signature figure (heroFigure). Final CTA = LIGHT (pillar
    convention). Frozen speakable #<slug>-in-brief-text preserved.
    ⚠ state-servicemap viz: handoff ships NY's map only; CA/TX/FL/IL maps are NOT
    in the handoff → keep the real heroFigure (taccount) until founder rules on
    per-state map assets (FLAGGED — never fabricate geography).
    =========================================================================== -#}
{%- set heroFigure = heroFigure if heroFigure is defined else false -%}
{%- if heroFigure %}
<section class="section hero-tier hero--compact hero--rule hero--split" id="{{ slug }}-hero">
  <div class="container">
    <div class="hero-split">
      <div class="hero">
        <p class="hero__eyebrow"><span class="hero__eyebrow-mark" aria-hidden="true"><span></span><span></span></span>{{ hero.eyebrow | safe }}</p>
        <h1 class="hero__heading speakable">{{ hero.heading | safe }}</h1>
        <p class="hero__subheading speakable">{{ hero.subheading | safe }}</p>
        <div class="hero__actions">
          {%- for action in hero.actions.slice(0, 2) %}
          <a class="btn {{ action.class }} btn--lg" href="{% if action.tel %}tel:{{ site.phone.e164 }}{% else %}{{ action.href }}{% endif %}"
            {%- if action.tel or (action.href and action.href.startsWith("tel:")) %} data-ga="phone_click" data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
          {%- endfor %}
        </div>
        {%- if hero.trust %}
        <ul class="hero__trust">
          {%- for t in hero.trust %}<li class="hero__trust-item">{{ t | safe }}</li>{%- endfor %}
        </ul>
        {%- endif %}
      </div>
      <div class="hero__figure">{% include "partials/figure-" + heroFigure + ".svg" %}</div>
    </div>
  </div>
</section>
{%- else %}
<section class="section hero-tier hero--compact hero--rule" id="{{ slug }}-hero">
  <div class="container">
    <div class="hero">
      <p class="hero__eyebrow"><span class="hero__eyebrow-mark" aria-hidden="true"><span></span><span></span></span>{{ hero.eyebrow | safe }}</p>
      <h1 class="hero__heading speakable">{{ hero.heading | safe }}</h1>
      <p class="hero__subheading speakable">{{ hero.subheading | safe }}</p>
      <div class="hero__actions">
        {%- for action in hero.actions.slice(0, 2) %}
        <a class="btn {{ action.class }} btn--lg" href="{% if action.tel %}tel:{{ site.phone.e164 }}{% else %}{{ action.href }}{% endif %}"
          {%- if action.tel or (action.href and action.href.startsWith("tel:")) %} data-ga="phone_click" data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
        {%- endfor %}
      </div>
      {%- if hero.trust %}
      <ul class="hero__trust">
        {%- for t in hero.trust %}<li class="hero__trust-item">{{ t | safe }}</li>{%- endfor %}
      </ul>
      {%- endif %}
    </div>
  </div>
</section>
{%- endif %}

{%- if inBrief %}
<section class="section section--compact" id="{{ slug }}-in-brief">
  <div class="container">
    <div class="in-brief">
      <p class="in-brief__text" id="{{ slug }}-in-brief-text">{{ inBrief.text | safe }}</p>
      {%- if inBrief.source %}<p class="in-brief__source">{{ inBrief.source | safe }}</p>{%- endif %}
    </div>
  </div>
</section>
{%- endif %}

{{ content | safe }}

{%- if ctaBand %}
<section class="section section--cta-band section--cta-band--light section--tier-hub" id="{{ slug }}-cta">
  <div class="cta-band__motif" aria-hidden="true">{% include "partials/motif-align-single.svg" %}</div>
  <div class="container">
    <div class="final-cta">
      <p class="section__eyebrow">{{ ctaBand.eyebrow | safe }}</p>
      <h2 class="final-cta__heading">{{ ctaBand.heading | safe }}</h2>
      <p class="final-cta__lede">{{ ctaBand.lede | safe }}</p>
      <div class="final-cta__actions">
        {%- for action in ctaBand.actions %}
        <a class="btn {{ action.class }}" href="{% if action.tel %}tel:{{ site.phone.e164 }}{% else %}{{ action.href }}{% endif %}"
          {%- if action.tel or (action.href and action.href.startsWith("tel:")) %} data-ga="phone_click" data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
        {%- endfor %}
      </div>
      <p class="final-cta__disclaimer">TechBrot is an independent accounting firm and Certified QuickBooks ProAdvisor. We are not Intuit. QuickBooks and Intuit are registered trademarks of Intuit Inc.</p>
    </div>
  </div>
</section>
{%- endif %}
