---
layout: layouts/dc-base.njk
footerNav:
  label: Find an accountant
  links:
    - { href: "/find-an-accountant/new-york/", text: "New York" }
    - { href: "/find-an-accountant/california/", text: "California" }
    - { href: "/find-an-accountant/", text: "All states" }
---
{#- ===========================================================================
    t-state-pillar — D3 state-pillar family (handoff "State Pillar - Template.dc.html").
    DATA-DRIVEN SPINE: all 5 pillars (NY/CA/TX/FL/IL) share the same ~40 data
    fields, so this one layout renders the full handoff composition from each
    page's frontmatter (`sec` per-state heading/eyebrow/lede strings) + the
    .11tydata.js content arrays — the page bodies are now frontmatter only.

    Section order = handoff: HERO (taccount figure — founder ruling: NO fabricated
    state maps; all 5 use the T-account ledger SVG) · TRUST STRIP (shared partial,
    sand) · STAT BAND (r-4 by-the-numbers) · IN-BRIEF (shared partial, sand —
    leads, 2026-06-26 founder reorder) · §credentials · §summary (dense block,
    now below) · AI SUMMARY (light ruled, place-framed) · glossary ·
    DELIVER (r-2 buyer cards) · context · scenarios · outcomes · PULL QUOTE
    (statement) · INDUSTRIES (r-3) · services · ecosystem · PRICING (cmp) · CITY
    DIRECTORY (r-4 citylinks) · INTAKE+CALL (dual path + shared intake-form) ·
    operators · why · REVIEW (2 real Clutch) · COMPARISON (cmp vs-table) ·
    authority · FAQ · expert review · related · FINAL CTA (LIGHT — pillar
    convention). Backgrounds alternate sand/white so no two tinted sections
    collide (in-brief partial is sand).

    FROZEN speakable ids preserved: #{{ slug }}-in-brief-text (in-brief partial)
    and #{{ slug }}-ai-summary-list (AI summary) — both referenced by each page's
    pageGraph cssSelector. Section ids kept on the same anchors the intra-page
    links + schema use.
    =========================================================================== -#}
{%- set sec = sec or {} %}

{#- HERO — light split, taccount figure, rule-mark eyebrow (handoff sense-of-place) -#}
<section class="sec" id="{{ slug }}-hero" style="padding-top:64px;padding-bottom:56px;border-bottom:1px solid var(--border-subtle);">
  <div class="ct dc-rhero">
    <div>
      <p class="eyebrow" style="display:inline-flex;align-items:center;gap:12px;margin-bottom:22px;"><span class="rule-mark" aria-hidden="true"><span></span><span></span></span>{{ hero.eyebrow | safe }}</p>
      <h1 class="dsp speakable" style="font-weight:500;font-variation-settings:'opsz' 96;font-size:clamp(36px,1.8rem + 3.4vw,60px);margin:0 0 22px;">{{ hero.heading | safe }}</h1>
      {#- ABOVE-FOLD intro: short + conversion-first (what we do · for whom · the hook). The dense
          per-state tax detail is NOT led with here — it lives lower in the `summarized` block + the
          stats strip + the glossary/context sections (kept, not duplicated). State name derived from
          the breadcrumb tail so all 20 pillars inherit this from the layout. (Founder 2026-06-26.) -#}
      {%- set _pillarState = (breadcrumb | last).name -%}
      <p class="lede speakable" style="margin:0 0 30px;max-width:46ch;">Professional bookkeeping, QuickBooks setup and cleanup, payroll, and tax compliance &mdash; delivered directly by TechBrot, serving {{ _pillarState | safe }} businesses remotely. Real local tax fluency, a named Certified ProAdvisor on your file, and a fixed-fee written scope before any work begins.</p>
      {%- if hero.actions %}
      <div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:22px;">
        {%- for a in hero.actions.slice(0, 2) %}
        <a class="btn {% if loop.first %}btn-cta{% else %}btn-ghost{% endif %}" href="{% if a.tel %}tel:{{ site.phone.e164 }}{% else %}{{ a.href }}{% endif %}"{% if a.tel %} data-ga="phone_click" data-tb-event="phone_click"{% endif %} style="display:inline-flex;align-items:center;gap:9px;height:52px;padding:0 24px;border-radius:12px;font-size:16px;font-weight:{% if loop.first %}600{% else %}500{% endif %};">{{ a.label }}</a>
        {%- endfor %}
      </div>
      {%- endif %}
      {%- if hero.trust %}
      <p style="font-size:14px;color:var(--color-ink-mute);margin:0;max-width:46ch;">{% for t in hero.trust %}{{ t | safe }}{% if not loop.last %} &middot; {% endif %}{% endfor %}</p>
      {%- endif %}
    </div>
    <figure class="figcard"><div class="figcard__grid" aria-hidden="true"></div><figcaption><span class="figcard__t">{{ sec.heroFigCaption | default("How the books tie out", true) | safe }}</span><span class="figcard__tag mono">ledger view</span></figcaption>{% include "partials/figure-taccount.svg" %}</figure>
  </div>
</section>

{#- TRUST STRIP — shared partial (Intuit credentials band, sand) -#}
{%- if showBadges %}{% include "partials/trust-strip.njk" %}{% endif %}

{#- STAT BAND — "by the numbers" r-4 (white) -#}
{%- if stats %}
<section class="sec reveal" id="{{ slug }}-stats" style="padding-top:44px;padding-bottom:44px;border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.statsTag | default("By the numbers", true) | safe }}</span><span class="idx__rule"></span></div>
    {%- if sec.statsH %}<h2 class="h2" style="max-width:22ch;margin-bottom:8px;">{{ sec.statsH | safe }}</h2>{%- endif %}
    {%- if sec.statsLede %}<p class="lede" style="margin:0 0 30px;max-width:60ch;">{{ sec.statsLede | safe }}</p>{%- endif %}
    <div class="r-4">
      {%- for s in stats %}
      <div><div class="mono" style="font-size:30px;font-weight:500;color:var(--color-accent);">{{ s.figure | safe }}</div><div style="font-size:13px;line-height:1.5;color:var(--color-ink-mute);margin-top:8px;">{{ s.label | safe }}</div></div>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

{#- §01 IN BRIEF — shared partial (sand). Frozen speakable id #{{ slug }}-in-brief-text.
   REORDERED 2026-06-26 (founder, all pillars): lead with the short scannable in-brief;
   credentials sit next; the dense AI-extraction "summarized" block drops BELOW (was: summary
   first → credentials → in-brief lower). Position swap only — no content change. Background
   alternation preserved: STAT (white) → in-brief (sand) → credentials (white) → summarized (sand). -#}
{% include "partials/in-brief.njk" %}

{#- §CREDENTIALS — cert line + proof-strip pills + trust-row (white) -#}
{%- if credLede %}
<section class="sec reveal" id="{{ slug }}-credentials">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.credTag | default("Certified by Intuit", true) | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">{{ sec.credH | safe }}</h2>
    <div class="prose" style="margin-bottom:18px;">{{ credLede | safe }}</div>
    {%- if credBadges %}
    <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:6px;">
      {%- for b in credBadges %}<span class="figcard__tag mono" style="font-size:12px;">{{ b.label }} <span class="sr-only">{{ b.name }}</span></span>{%- endfor %}
    </div>
    {%- endif %}
    {%- if trustRow %}
    <div class="trust-row">
      {%- for r in trustRow %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.value | safe }}</p><p class="trust-row__label">{{ r.label | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    {%- endif %}
  </div>
</section>
{%- endif %}

{#- §SUMMARY — real H2 carrying the full state summary prose (sand). Sits BELOW the in-brief +
   credentials per the 2026-06-26 founder reorder (dense block under the scannable lead). -#}
{%- if summarized %}
<section class="sec reveal" id="{{ slug }}-summarized" style="background:var(--color-paper-warm);border-bottom:1px solid var(--border-subtle);">
  <div class="ct read">
    <h2 class="h2" style="margin-bottom:18px;">{{ sec.summarizedH | safe }}</h2>
    <div class="prose">{{ summarized | safe }}</div>
  </div>
</section>
{%- endif %}

{#- AI SUMMARY — place-framed light ruled multi-Q&A. Frozen id #{{ slug }}-ai-summary-list -#}
{%- if aiSummary %}
<section class="sec reveal" id="{{ slug }}-ai-summary">
  <div class="ct read">
    <div class="idx idx--center"><span class="idx__n">§</span><span class="idx__t">For AI engines &amp; quick answers</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="text-align:center;margin:0 auto 36px;max-width:24ch;">{{ sec.aiH | safe }}</h2>
    <dl class="speakable ai-qa" id="{{ slug }}-ai-summary-list">
      {%- for item in aiSummary %}
      <div class="ai-qa__item"><dt><h3>{{ item.q | safe }}</h3></dt><dd style="margin:0;"><p>{{ item.a | safe }}</p></dd></div>
      {%- endfor %}
    </dl>
  </div>
</section>
{%- endif %}

{#- §GLOSSARY — state terms grid-2 (sand) -#}
{%- if stateTerms %}
<section class="sec reveal" id="{{ slug }}-glossary" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.glossaryTag | default("Accounting glossary", true) | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:26ch;margin-bottom:10px;">{{ sec.glossaryH | safe }}</h2>
    {%- if sec.glossaryLede %}<p class="lede" style="margin:0 0 32px;max-width:62ch;">{{ sec.glossaryLede | safe }}</p>{%- endif %}
    <div class="r-2">
      {%- for g in stateTerms %}
      <div class="dc-card"><span class="eyebrow">{{ g.term | safe }}</span><div class="prose">{{ g.def | safe }}</div></div>
      {%- endfor %}
    </div>
    {%- if sec.glossaryNote %}<p class="prose" style="margin-top:24px;font-size:14px;color:var(--color-ink-mute);">{{ sec.glossaryNote | safe }}</p>{%- endif %}
  </div>
</section>
{%- endif %}

{#- §DELIVER — direct vs partners, buyer-card r-2 (white) -#}
{%- if delivery %}
<section class="sec reveal" id="{{ slug }}-delivery">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.deliveryTag | default("Service coverage", true) | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:22ch;margin-bottom:10px;">{{ sec.deliveryH | safe }}</h2>
    {%- if sec.deliveryLede %}<p class="lede" style="margin:0 0 32px;max-width:62ch;">{{ sec.deliveryLede | safe }}</p>{%- endif %}
    <div class="r-2">
      {%- for d in delivery %}
      <article class="incl-card"><span class="eyebrow" style="display:block;margin-bottom:10px;">{{ d.eyebrow | safe }}</span><h3>{{ d.heading | safe }}</h3><p class="prose" style="font-size:15px;margin:8px 0 0;">{{ d.lede | safe }}</p><ul class="checklist">{%- for li in d.list %}<li>{{ li | safe }}</li>{%- endfor %}</ul><a class="ptier__link" href="{{ d.href }}">{{ d.cta | safe }}</a></article>
      {%- endfor %}
    </div>
    {%- if deliveryNote %}<p class="prose" style="margin-top:24px;font-size:14px;color:var(--color-ink-mute);">{{ deliveryNote | safe }}</p>{%- endif %}
  </div>
</section>
{%- endif %}

{#- §CONTEXT — what makes this state different, grid-2 (sand) -#}
{%- if context %}
<section class="sec reveal" id="{{ slug }}-context" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.contextTag | default("Why this state is different", true) | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:24ch;margin-bottom:10px;">{{ sec.contextH | safe }}</h2>
    {%- if sec.contextLede %}<p class="lede" style="margin:0 0 32px;max-width:64ch;">{{ sec.contextLede | safe }}</p>{%- endif %}
    <div class="r-2">
      {%- for c in context %}
      <div class="dc-card"><span class="eyebrow">{{ c.category | safe }}</span><h3>{{ c.heading | safe }}</h3><div class="prose">{%- for p in c.body %}<p>{{ p | safe }}</p>{%- endfor %}</div></div>
      {%- endfor %}
    </div>
    {%- if contextNote %}<p class="prose" style="margin-top:24px;font-size:14px;color:var(--color-ink-mute);">{{ contextNote | safe }}</p>{%- endif %}
  </div>
</section>
{%- endif %}

{#- §SCENARIOS — honestly-labeled composites, grid-3 (white) -#}
{%- if scenarios %}
<section class="sec reveal" id="{{ slug }}-scenarios">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.scenariosTag | default("Engagement scenarios", true) | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:26ch;margin-bottom:10px;">{{ sec.scenariosH | safe }}</h2>
    {%- if scenariosNote %}<p class="lede" style="margin:0 0 32px;max-width:64ch;">{{ scenariosNote | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for s in scenarios %}
      <article class="dc-card"><span class="eyebrow">{{ s.tag | safe }}</span><h3>{{ s.heading | safe }}</h3><div class="prose">{%- for p in s.body %}<p>{{ p | safe }}</p>{%- endfor %}</div><a class="ptier__link" href="{{ s.href }}">{{ s.cta | safe }}</a></article>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

{#- §OUTCOMES — representative figures, grid-3 (sand) -#}
{%- if outcomes %}
<section class="sec reveal" id="{{ slug }}-outcomes" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.outcomesTag | default("Representative outcomes", true) | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:30px;">{{ sec.outcomesH | safe }}</h2>
    <div class="r-3">
      {%- for o in outcomes %}
      <div class="dc-card"><div class="trust-row__value" style="font-size:30px;">{{ o.figure | safe }}</div><p class="prose" style="font-size:15px;margin:6px 0 0;">{{ o.detail | safe }}<br><small style="color:var(--color-ink-faint);">{{ o.meta | safe }}</small></p></div>
      {%- endfor %}
    </div>
    {%- if outcomesNote %}<p class="prose" style="margin-top:24px;font-size:14px;color:var(--color-ink-mute);">{{ outcomesNote | safe }}</p>{%- endif %}
  </div>
</section>
{%- endif %}

{#- §ADVISORY — standing brand line + body (white, read) -#}
{%- if advisoryBody %}
<section class="sec reveal" id="{{ slug }}-advisory">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.advisoryTag | default("Beyond bookkeeping", true) | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">{{ sec.advisoryH | safe }}</h2>
    <div class="prose">{{ advisoryBody | safe }}</div>
    {%- if sec.advisoryHref %}
    <div style="margin-top:22px;"><a class="btn btn-cta" href="{{ sec.advisoryHref | safe }}" style="display:inline-flex;align-items:center;height:48px;padding:0 22px;border-radius:11px;font-size:15px;font-weight:600;">Book the discovery call</a></div>
    {%- endif %}
    {%- if sec.advisoryLink %}<p class="prose" style="margin-top:16px;">{{ sec.advisoryLink | safe }}</p>{%- endif %}
  </div>
</section>
{%- endif %}

{#- §INDUSTRIES — r-3 (sand) -#}
{%- if industries %}
<section class="sec reveal" id="{{ slug }}-industries" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.industriesTag | default("Industries we serve", true) | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:26ch;margin-bottom:10px;">{{ sec.industriesH | safe }}</h2>
    {%- if sec.industriesLede %}<p class="lede" style="margin:0 0 32px;max-width:64ch;">{{ sec.industriesLede | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for i in industries %}
      <div class="dc-card"><span class="eyebrow">{{ i.num }}</span><h3>{% if i.href %}<a href="{{ i.href }}">{{ i.name | safe }}</a>{% else %}{{ i.name | safe }}{% endif %}</h3><p class="prose" style="font-size:15px;margin:6px 0 0;">{{ i.body | safe }}</p></div>
      {%- endfor %}
    </div>
    {%- if industriesNote %}<p class="prose" style="margin-top:24px;font-size:14px;color:var(--color-ink-mute);">{{ industriesNote | safe }}</p>{%- endif %}
  </div>
</section>
{%- endif %}

{#- §SERVICES — buyer-card routing r-3 (white) -#}
{%- if services %}
<section class="sec reveal" id="{{ slug }}-services">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.servicesTag | default("Services", true) | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:26ch;margin-bottom:10px;">{{ sec.servicesH | safe }}</h2>
    {%- if sec.servicesLede %}<p class="lede" style="margin:0 0 32px;max-width:64ch;">{{ sec.servicesLede | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for s in services %}
      <article class="dc-card"><span class="eyebrow">{{ s.eyebrow }}</span><h3>{% if sec.servicesLinkNames and s.href %}<a href="{{ s.href }}">{{ s.name | safe }}</a>{% else %}{{ s.name | safe }}{% endif %}</h3><p class="prose" style="font-size:15px;margin:6px 0 12px;">{{ s.body | safe }}</p><p class="mono" style="font-size:12px;color:var(--color-ink-mute);margin:0 0 10px;">Starting {{ s.starting | safe }} &middot; {{ s.cadence | safe }}</p><a class="ptier__link" href="{% if sec.servicesCtaContact %}/contact/?intent={{ intent | default(slug, true) }}{% else %}{{ s.href }}{% endif %}">{{ s.cta | safe }}</a></article>
      {%- endfor %}
    </div>
    {%- if servicesNote %}<p class="prose" style="margin-top:24px;font-size:14px;color:var(--color-ink-mute);">{{ servicesNote | safe }}</p>{%- endif %}
  </div>
</section>
{%- endif %}

{#- §ECOSYSTEM — cluster directory r-3 (sand). links (NY/CA/TX) or items (FL/IL) -#}
{%- if ecosystem %}
<section class="sec reveal" id="{{ pillarAnchor | default(slug, true) }}-ecosystem" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.ecosystemTag | default("The full ecosystem", true) | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:24ch;margin-bottom:10px;">{{ sec.ecosystemH | safe }}</h2>
    {%- if sec.ecosystemLede %}<p class="lede" style="margin:0 0 32px;max-width:64ch;">{{ sec.ecosystemLede | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for cl in ecosystem %}
      <article class="dc-card"><span class="eyebrow">{{ cl.eyebrow }}</span><h3>{{ cl.heading | safe }}</h3><p class="prose" style="font-size:15px;margin:6px 0 12px;">{{ cl.lede | safe }}</p><ul class="checklist">
        {%- for l in (cl.links or cl.items) %}<li>{% if l.href %}<a href="{{ l.href }}">{{ l.label | safe }}</a>{% elif l.label %}{{ l.label | safe }}{% else %}{{ l | safe }}{% endif %}{% if l.tag %} <span class="figcard__tag mono" style="font-size:10px;">{{ l.tag | safe }}</span>{% endif %}</li>{%- endfor %}
      </ul></article>
      {%- endfor %}
    </div>
    {%- if ecosystemNote %}<p class="prose" style="margin-top:24px;font-size:14px;color:var(--color-ink-mute);">{{ ecosystemNote | safe }}</p>{%- endif %}
  </div>
</section>
{%- endif %}

{#- §PRICING — fixed-fee ranges, cmp table (white) -#}
{%- if pricing %}
<section class="sec reveal" id="{{ slug }}-pricing">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.pricingTag | default("Pricing", true) | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:28ch;margin-bottom:10px;">{{ sec.pricingH | safe }}</h2>
    {%- if sec.pricingLede %}<p class="lede" style="margin:0 0 30px;max-width:64ch;">{{ sec.pricingLede | safe }}</p>{%- endif %}
    <table class="cmp" aria-describedby="{{ slug }}-pricing-note">
      <caption>{{ sec.pricingCaption | default("Indicative fixed-fee starting ranges", true) | safe }}</caption>
      <thead><tr><th scope="col">Engagement</th><th scope="col">Starting range</th><th scope="col">Cadence</th><th scope="col">{{ sec.pricingNotesCol | default("Notes", true) | safe }}</th></tr></thead>
      <tbody>
        {%- for r in pricing %}
        <tr><th scope="row">{% if r.href %}<a href="{{ r.href }}">{{ r.svc | safe }}</a>{% else %}{{ r.svc | safe }}{% endif %}</th><td data-col="Starting range"><strong>{{ r.range | safe }}</strong></td><td data-col="Cadence">{{ r.cadence | safe }}</td><td data-col="Notes">{{ r.notes | safe }}</td></tr>
        {%- endfor %}
      </tbody>
    </table>
    {%- if pricingNote %}<p class="prose" id="{{ slug }}-pricing-note" style="margin-top:18px;font-size:14px;color:var(--color-ink-mute);">{{ pricingNote | safe }}</p>{%- endif %}
  </div>
</section>
{%- endif %}

{#- §CITY DIRECTORY — statewide r-4 citylinks (sand). cities linked (NY) or plain -#}
{%- if cities %}
<section class="sec reveal" id="{{ slug }}-cities" style="background:var(--color-paper-warm);border-top:1px solid var(--border-subtle);border-bottom:1px solid var(--border-subtle);">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.citiesTag | default("Statewide", true) | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:22ch;margin-bottom:10px;">{{ sec.citiesH | safe }}</h2>
    {%- if sec.citiesLede %}<p class="lede" style="margin:0 0 30px;max-width:62ch;">{{ sec.citiesLede | safe }}</p>{%- endif %}
    {%- if sec.citiesSubH %}<h3 class="prose" style="font-family:'Fraunces',serif;font-weight:600;font-size:19px;margin:0 0 16px;">{{ sec.citiesSubH | safe }}</h3>{%- endif %}
    <div class="r-3">
      {%- for c in cities %}
      <div class="dc-card" style="padding:16px 18px;">{% if c.href %}<a href="{{ c.href }}"><strong>{{ c.name | safe }}</strong></a>{% else %}<strong>{{ c.name | safe }}</strong>{% endif %} <span class="mono" style="font-size:12px;color:var(--color-ink-faint);">&mdash; {{ c.county | safe }}</span></div>
      {%- endfor %}
    </div>
    {%- if countyProse %}
