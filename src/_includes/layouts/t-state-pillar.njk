{#- §INTAKE — dual path (call + shared intake-form partial), byline credits (white) -#}
{%- if teamDavid %}
<section class="sec reveal" id="{{ slug }}-intake">
  <div class="ct">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.intakeTag | default("Talk to a Certified ProAdvisor", true) | safe }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="max-width:28ch;margin-bottom:10px;">{{ sec.intakeH | safe }}</h2>
    {%- if sec.intakeLede %}<p class="lede" style="margin:0 0 32px;max-width:60ch;">{{ sec.intakeLede | safe }}</p>{%- endif %}

    <div class="r-2" style="margin-bottom:18px;">
      <div class="dc-card">
        <div class="byline" style="margin-bottom:14px;"><svg class="byline__mark" viewBox="0 0 64 64" role="img" aria-label="TechBrot"><rect width="64" height="64" rx="14" fill="#0E4A50"></rect><g transform="translate(12.16 12.16) scale(0.62)" fill="#FCFBF8"><path d="M8 10 H38 V54 H26 V22 H8 Z"></path><rect x="42" y="10" width="14" height="12"></rect></g></svg><div><p class="byline__name">By the Certified QuickBooks ProAdvisor team</p><p class="byline__review">{{ teamDavid.name }} &middot; {{ teamDavid.role }}</p></div></div>
        <p class="eyebrow" style="margin-bottom:8px;">{{ teamDavid.creds | safe }}</p>
        <p class="prose" style="font-size:15px;">{{ teamDavid.line | safe }}</p>
      </div>
      {%- if teamIntake %}
      <div class="dc-card">
        <div class="byline" style="margin-bottom:14px;"><svg class="byline__mark" viewBox="0 0 64 64" role="img" aria-label="TechBrot"><rect width="64" height="64" rx="14" fill="#0E4A50"></rect><g transform="translate(12.16 12.16) scale(0.62)" fill="#FCFBF8"><path d="M8 10 H38 V54 H26 V22 H8 Z"></path><rect x="42" y="10" width="14" height="12"></rect></g></svg><div><p class="byline__name">By the Certified QuickBooks ProAdvisor team</p><p class="byline__review">{{ teamIntake.name | safe }} &middot; {{ teamIntake.role }}</p></div></div>
        <p class="eyebrow" style="margin-bottom:8px;">{{ teamIntake.creds | safe }}</p>
        <p class="prose" style="font-size:15px;">{{ teamIntake.line | safe }}</p>
      </div>
      {%- endif %}
    </div>

    <div class="r-2">
      <article class="incl-card">
        <span class="eyebrow" style="display:block;margin-bottom:10px;">Option 01</span>
        <h3>{{ sec.callH | default("Call directly.", true) | safe }}</h3>
        <p class="prose" style="font-size:15px;margin:8px 0 16px;">{{ sec.callBody | default("A Certified ProAdvisor answers &mdash; not a call center. Best for same-day diagnostics, behind-on-the-books situations, or compliance urgencies.", true) | safe }}</p>
        <a class="btn btn-cta" href="tel:{{ site.phone.e164 }}" data-ga="phone_click" data-tb-event="phone_click" style="display:inline-flex;align-items:center;gap:9px;height:48px;padding:0 22px;border-radius:11px;font-size:15px;font-weight:600;">{% include "icons/phone.svg" %} Speak to a ProAdvisor</a>
        {%- if callAssurance %}<ul class="checklist" style="margin-top:16px;">{%- for a in callAssurance %}<li>{{ a | safe }}</li>{%- endfor %}</ul>{%- endif %}
      </article>
      <div class="incl-card">
        <h3 id="{{ slug }}-intake-form-heading">{{ sec.formH | default("Send a short discovery brief.", true) | safe }}</h3>
        <p class="prose" style="font-size:15px;margin:8px 0 16px;">Six fields. We respond by the next business day with a path forward &mdash; a scoping call or, if not a fit, a referral. <strong>Includes a free QuickBooks file review &mdash; we&rsquo;ll identify the top 3 issues in your file before any engagement begins.</strong></p>
        {%- set intakePrefix = slug %}
        {%- set intakeFormId = slug + "-intake-form" %}
        {%- set intakeIntent = intent | default(slug, true) %}
        {%- set intakeSourceType = "location" %}
        {%- set intakeFunnelStage = "MOFU" %}
        {%- set intakeLegend = sec.intakeLegend | default("What we should discuss for your business", true) %}
        {%- set intakeSubmit = "Send the Discovery Brief" %}
        {%- set intakeReassurance = "Same-day diagnostic for emergencies, 1 business day for scoping, written fixed-fee scope within 3 business days of the first call." %}
        {# footprint reduction 2026-06-25: pillars on the MINIMAL form (call-first) #}
        {% include "partials/intake-minimal.njk" %}
      </div>
    </div>
  </div>
</section>
{%- endif %}

