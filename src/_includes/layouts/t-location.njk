---
layout: layouts/base.njk
tierClass: section--tier-hub
pageTier: location
callBar: true
---
{#- T-LOCATION tier skeleton — NEW SKIN (tiers/t-location.html +
    PLACEMENT-MAP). Dark hero + STATE CONTOUR LEDGER motif (NY grade
    shipped; per-state generation rule in the SVG header: 16 rows · h24 ·
    pitch 40 · one anchor channel · echo layer +12/+14 at 12%) ·
    breadcrumb · sticky call-bar (mobile) · hub tint (ruling: location =
    hub surface). Pages override `motif` to a per-state partial when
    generated. -#}

{%- if breadcrumb %}
<nav class="breadcrumb" aria-label="Breadcrumb" id="{{ slug }}-breadcrumb">
  <div class="container">
    <ol>
      {%- for item in breadcrumb %}
      {%- if item.href %}
      <li><a href="{{ item.href }}">{{ item.name }}</a></li>
      <li class="sep" aria-hidden="true">/</li>
      {%- else %}
      <li aria-current="page">{{ item.name }}</li>
      {%- endif %}
      {%- endfor %}
    </ol>
  </div>
</nav>
{%- endif %}

{#- State pillar hero (founder 2026-06-17, locked State Pillar template): the
    elevated treatment is the LIGHT split article-hero + signature ledger figure
    (heroFigure), NOT the legacy dark state-contour hero. heroFigure is OPT-IN —
    the NY pillar leads on it; the legacy dark-contour hero stays the fallback for
    state landings until each is fanned out. -#}
{%- set heroFigure = heroFigure if heroFigure is defined else false -%}
{%- if heroFigure %}
<section class="section hero-tier hero--compact hero--rule hero--split" id="{{ slug }}-hero">
  <div class="container">
    <div class="hero-split">
      <div class="hero">
        <p class="hero__eyebrow">{{ hero.eyebrow | safe }}</p>
        <h1 class="hero__heading">{{ hero.heading | safe }}</h1>
        <p class="hero__subheading">{{ hero.subheading | safe }}</p>
        <div class="hero__actions">
          {%- for action in hero.actions.slice(0, 2) %}
          <a class="btn {{ action.class }} btn--lg" href="{% if action.tel %}tel:{{ site.phone.e164 }}{% else %}{{ action.href }}{% endif %}"
            {%- if action.tel or (action.href and action.href.startsWith("tel:")) %} data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
          {%- endfor %}
        </div>
        {%- if hero.trust %}
        <ul class="hero__trust">
          {%- for t in hero.trust %}<li class="hero__trust-item">{{ t | safe }}</li>{%- endfor %}
        </ul>
        {%- endif %}
      </div>
      <div class="hero__figure">{% include "partials/figure-" + heroFigure + ".svg" %}</div>
    </div>
  </div>
</section>
{%- elif heroLight %}
{#- LOCATION CHILD (founder ruling 2026-06-17, Gallery 06 A4 fix): cities &
    industries get a LIGHTER, conversion-focused compact hero — clearly
    subordinate to the pillar, NEVER the pillar's heavy figure-split hero. No
    figure, no dark contour, no motif. -#}
<section class="section hero-tier hero--compact hero--rule" id="{{ slug }}-hero">
  <div class="container">
    <div class="hero">
      <p class="hero__eyebrow">{{ hero.eyebrow | safe }}</p>
      <h1 class="hero__heading">{{ hero.heading | safe }}</h1>
      <p class="hero__subheading">{{ hero.subheading | safe }}</p>
      <div class="hero__actions">
        {%- for action in hero.actions.slice(0, 2) %}
        <a class="btn {{ action.class }} btn--lg" href="{% if action.tel %}tel:{{ site.phone.e164 }}{% else %}{{ action.href }}{% endif %}"
          {%- if action.tel or (action.href and action.href.startsWith("tel:")) %} data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
        {%- endfor %}
      </div>
      {%- if hero.trust %}
      <ul class="hero__trust">
        {%- for t in hero.trust %}<li class="hero__trust-item">{{ t | safe }}</li>{%- endfor %}
      </ul>
      {%- endif %}
    </div>
  </div>
</section>
{%- else %}
<section class="section hero-tier hero--location" id="{{ slug }}-hero">
  <div class="hero__motif" aria-hidden="true">{% include heroMotif or "partials/motif-align-ny.svg" %}</div>
  <div class="container">
    <div class="hero">
      <p class="hero__eyebrow">{{ hero.eyebrow | safe }}</p>
      <h1 class="hero__heading">{{ hero.heading | safe }}</h1>
      <p class="hero__subheading">{{ hero.subheading | safe }}</p>
      <div class="hero__actions">
        {%- for action in hero.actions.slice(0, 2) %}
        <a class="btn {{ action.class }} btn--inverted btn--lg" href="{% if action.tel %}tel:{{ site.phone.e164 }}{% else %}{{ action.href }}{% endif %}"
          {%- if action.tel or (action.href and action.href.startsWith("tel:")) %} data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
        {%- endfor %}
      </div>
    </div>
  </div>
</section>
{%- endif %}

{%- if inBrief %}
<section class="section section--compact" id="{{ slug }}-in-brief">
  <div class="container">
    <div class="in-brief">
      <p class="in-brief__text" id="{{ slug }}-in-brief-text">{{ inBrief.text | safe }}</p>
      {%- if inBrief.source %}<p class="in-brief__source">{{ inBrief.source | safe }}</p>{%- endif %}
    </div>
  </div>
</section>
{%- endif %}

{{ content | safe }}

{%- if ctaBand %}
<section class="section section--cta-band section--cta-band--light {{ tierClass }}" id="{{ slug }}-cta">
  <div class="cta-band__motif" aria-hidden="true">{% include "partials/motif-align-single.svg" %}</div>
  <div class="container">
    <div class="final-cta">
      <p class="section__eyebrow">{{ ctaBand.eyebrow | safe }}</p>
      <h2 class="final-cta__heading">{{ ctaBand.heading | safe }}</h2>
      <p class="final-cta__lede">{{ ctaBand.lede | safe }}</p>
      <div class="final-cta__actions">
        {%- for action in ctaBand.actions %}
        <a class="btn {{ action.class }}" href="{% if action.tel %}tel:{{ site.phone.e164 }}{% else %}{{ action.href }}{% endif %}"
          {%- if action.tel or (action.href and action.href.startsWith("tel:")) %} data-tb-event="phone_click"{% endif %}>{{ action.label }}</a>
        {%- endfor %}
      </div>
      <p class="final-cta__disclaimer">TechBrot is an independent accounting firm and Certified QuickBooks ProAdvisor. We are not Intuit. QuickBooks and Intuit are registered trademarks of Intuit Inc.</p>
    </div>
  </div>
</section>
{%- endif %}
