---
layout: layouts/dc-base.njk
footerNav:
  label: Find an accountant
  links:
    - { href: "/find-an-accountant/new-york/", text: "New York" }
    - { href: "/find-an-accountant/california/", text: "California" }
    - { href: "/find-an-accountant/", text: "All states" }
---
{#- ===========================================================================
    t-location — D4/D5/D6 location-child family (handoff "Location Child -
    Template.dc.html"). v2 dc-system spine. layout: dc-base.njk owns the chrome
    (topbar / mega-nav / breadcrumb / footer / drawer); this layout renders the
    COMMON location-child frame in v2 components and hands the BESPOKE body to
    {{ content }}.

    Section order (handoff Location Child): compact LIGHT hero (rule-mark eyebrow
    + place H1 + lede + 2 actions + trust line) · IN BRIEF (sand TL;DR card,
    frozen speakable id #{{ slug }}-in-brief-text) · {{ content }} (the page's
    bespoke body: AI-summary / why-local / local-tax-stack / areas / deliver /
    advisory / pull-quote / reviews / two-ways-to-start — all in v2 components,
    each section id == that page's own pageGraph schema anchor) · FAQ (visible =
    FAQPage schema) · FINAL CTA (LIGHT — location-child convention).

    The AI-summary block stays BODY-rendered so each page keeps its own schema
    cssSelector anchor (#<slug>-ai-summary-list) intact. The in-brief card is
    layout-rendered so the frozen #<slug>-in-brief-text resolves once.
    =========================================================================== -#}
{%- set sec = sec or {} %}

{#- HERO — compact, LIGHT (location child is subordinate to the pillar): rule-mark
    eyebrow + place H1 + lede + 2 actions + trust line. No figure, no dark contour. -#}
<section class="sec" id="{{ slug }}-hero" style="padding-top:52px;padding-bottom:44px;border-bottom:1px solid var(--border-faint);">
  <div class="ct read">
    <p class="eyebrow" style="display:inline-flex;align-items:center;gap:12px;margin-bottom:20px;"><span class="rule-mark" aria-hidden="true"><span></span><span></span></span>{{ hero.eyebrow | safe }}</p>
    <h1 class="dsp speakable" style="font-weight:500;font-variation-settings:'opsz' 80;font-size:clamp(33px,1.7rem + 2.4vw,50px);margin:0 0 18px;">{{ hero.heading | safe }}</h1>
    <p class="lede speakable" style="margin:0 0 26px;max-width:48ch;">{{ hero.subheading | safe }}</p>
    {%- if hero.actions %}
    <div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:22px;">
      {%- for a in hero.actions.slice(0, 2) %}
      <a class="btn {% if loop.first %}btn-cta{% else %}btn-ghost{% endif %}" href="{% if a.tel %}tel:{{ site.phone.e164 }}{% else %}{{ a.href }}{% endif %}"{% if a.tel or (a.href and a.href.startsWith('tel:')) %} data-ga="phone_click" data-tb-event="phone_click"{% endif %} style="display:inline-flex;align-items:center;gap:9px;height:50px;padding:0 22px;border-radius:12px;font-size:16px;font-weight:{% if loop.first %}600{% else %}500{% endif %};">{{ a.label }}</a>
      {%- endfor %}
    </div>
    {%- endif %}
    {%- if hero.trust %}
    <p style="font-size:14px;color:var(--color-ink-mute);margin:0;max-width:52ch;">{% for t in hero.trust %}{{ t | safe }}{% if not loop.last %} &middot; {% endif %}{% endfor %}</p>
    {%- endif %}
  </div>
</section>

{#- IN BRIEF — sand TL;DR card (handoff "The short version"). Frozen speakable id
    #{{ slug }}-in-brief-text on the answer paragraph. -#}
{%- if inBrief %}
<section class="sec reveal" id="{{ slug }}-in-brief" style="padding-top:44px;padding-bottom:28px;">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.inBriefTag | default("The short version", true) }}</span><span class="idx__rule"></span></div>
    <div class="tldr speakable">
      <p id="{{ slug }}-in-brief-text">{{ inBrief.text | safe }}</p>
      {%- if inBrief.source %}<p class="tldr__src">{{ inBrief.source | safe }}</p>{%- endif %}
    </div>
  </div>
</section>
{%- endif %}

{#- ═══ BESPOKE BODY — the page's unique location-child sections in v2 dc-system
    components; each section id == the page's own pageGraph schema anchor ═══ -#}
{{ content | safe }}

{#- FAQ — visible = FAQPage schema (white). id #{{ slug }}-faq.
    Gated on sec.faqH: the LAYOUT renders FAQ only for pages that set sec.faqH (the NY/SF
    bespoke pages). The partial-driven CA/TX/FL/IL pages render FAQ from their shared partial
    instead, so they DON'T set sec.faqH — avoiding a double FAQ. -#}
{%- if faq and sec.faqH %}
<section class="sec reveal" id="{{ slug }}-faq" style="padding-top:72px;">
  <div class="ct read">
    <div class="idx"><span class="idx__n">§</span><span class="idx__t">{{ sec.faqTag | default("Questions", true) }}</span><span class="idx__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">{{ sec.faqH | default("Questions.", true) | safe }}</h2>
    <div class="faq">
      {%- for item in faq %}
      <details name="{{ slug }}-faq"{% if loop.first %} open{% endif %}><summary>{{ item.q | safe }}<span class="pl"></span></summary><div>{{ item.a | safe }}</div></details>
      {%- endfor %}
    </div>
    {%- if metaReviewed %}<p class="meta-reviewed"><span>Reviewed by the TechBrot Certified ProAdvisor team &middot; Updated {{ metaReviewed }}</span></p>{%- endif %}
  </div>
</section>
{%- endif %}

{#- FINAL CTA — LIGHT (location-child convention) -#}
{%- if ctaBand %}
<section class="sec reveal section--cta-band--light" id="{{ slug }}-cta" style="padding:80px 0;">
  <div class="ct read">
    <div class="final-cta">
      {%- if ctaBand.eyebrow %}<p class="eyebrow" style="margin-bottom:16px;">{{ ctaBand.eyebrow | safe }}</p>{%- endif %}
      <h2 class="final-cta__h">{{ ctaBand.heading | safe }}</h2>
      <p class="final-cta__lede">{{ ctaBand.lede | safe }}</p>
      <div class="final-cta__actions">
        {%- for a in ctaBand.actions %}
        <a class="btn {% if loop.first %}btn-cta{% else %}btn-ghost{% endif %}" href="{% if a.tel %}tel:{{ site.phone.e164 }}{% else %}{{ a.href }}{% endif %}"{% if a.tel or (a.href and a.href.startsWith('tel:')) %} data-ga="phone_click" data-tb-event="phone_click"{% endif %} style="display:inline-flex;align-items:center;gap:10px;height:54px;padding:0 24px;border-radius:13px;font-size:15.5px;font-weight:{% if loop.first %}600{% else %}500{% endif %};">{{ a.label }}</a>
        {%- endfor %}
      </div>
      {#- disclaimer rationalized (2026-06-25): canonical disclaimer lives in the dc-base footer; duplicate removed. -#}
    </div>
  </div>
</section>
{%- endif %}
