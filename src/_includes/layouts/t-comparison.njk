---
layout: layouts/dc-base.njk
navActive: compare
footerNav:
  label: Compare
  links:
    - { href: "/vs/", text: "All comparisons" }
    - { href: "/quickbooks/compare/", text: "QuickBooks editions" }
    - { href: "/accounting/bookkeeping/", text: "Bookkeeping" }
---
{#- ===========================================================================
    t-comparison — C2 family layout (NEW handoff "Comparison - Template.dc.html").
    Renders the page's frozen content into the handoff components, in template
    rhythm. comparisonIntent flag (role|product|competitor) changes ONLY: hero
    weight (all calm here — MOFU), verdict-block presence/tone, final-CTA intensity.
    Frozen speakable IDs preserved: #{{ slug }}-in-brief-text · #{{ slug }}-ai-summary.
    Every section guarded — reused by both concept-vs and techbrot-vs pages.
    =========================================================================== -#}
{%- set intent = comparisonIntent or "role" %}
{%- set sec = sec or {} %}
{%- set cmpCols = cmpCols or {} %}

{#- HERO — editorial-calm: eyebrow + H1 + lede, ~820px, no buttons (MOFU) -#}
<section style="padding:56px 0 12px;">
  <div class="ct read">
    {%- if hero.eyebrow %}<div class="eyebrow" style="margin-bottom:18px;">{{ hero.eyebrow | safe }}</div>{%- endif %}
    <h1 class="dsp speakable" style="font-weight:500;font-variation-settings:'opsz' 80;font-size:clamp(32px,1.7rem + 2.4vw,50px);margin:0 0 18px;">{{ hero.heading | safe }}</h1>
    <p class="lede speakable" style="margin:0;">{{ hero.subheading | safe }}</p>
  </div>
</section>

{#- BYLINE -#}
{%- if bylineName %}
<section class="sec" style="padding-top:28px;padding-bottom:8px;">
  <div class="ct read">
    <div class="byline">
      <svg class="byline__mark" viewBox="0 0 64 64" role="img" aria-label="TechBrot"><rect width="64" height="64" rx="14" fill="#0E4A50"></rect><g transform="translate(12.16 12.16) scale(0.62)" fill="#FCFBF8"><path d="M8 10 H38 V54 H26 V22 H8 Z"></path><rect x="42" y="10" width="14" height="12"></rect></g></svg>
      <div>
        <p class="byline__name">{{ bylineName | safe }}</p>
        <p class="byline__review">{{ bylineReview | safe }}</p>
      </div>
    </div>
  </div>
</section>
{%- endif %}

{#- TL;DR card (frozen speakable id on body) -#}
{%- if inBrief %}
<section class="sec reveal" style="padding-top:28px;padding-bottom:28px;">
  <div class="ct read">
    <div class="tldr speakable">
      <div class="eyebrow">TL;DR</div>
      <p id="{{ slug }}-in-brief-text">{{ inBrief.text | safe }}</p>
      {%- if inBrief.source %}<p class="tldr__src">{{ inBrief.source | safe }}</p>{%- endif %}
    </div>
  </div>
</section>
{%- endif %}

{#- DISCLOSURE — competitor/product caveat (guarded; trademark + publicly-available info) -#}
{%- if disclosure %}
<section class="sec reveal" style="padding-top:20px;padding-bottom:8px;">
  <div class="ct read">
    <div class="ph"><span class="ph__t">{{ sec.disclosureTag | default("Disclosure", true) | safe }}</span><span class="ph__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">{{ sec.disclosureH | default("About this comparison.", true) | safe }}</h2>
    <div class="prose">{%- for p in disclosure %}<p>{{ p | safe }}</p>{%- endfor %}</div>
  </div>
</section>
{%- endif %}

{#- SUMMARY prose -#}
{%- if summary %}
<section class="sec reveal" style="padding-top:20px;padding-bottom:24px;">
  <div class="ct read">
    <div class="ph"><span class="ph__t">{{ sec.summaryTag | default("In one paragraph", true) | safe }}</span><span class="ph__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">{{ sec.summaryH | default("The honest summary.", true) | safe }}</h2>
    <div class="prose">{%- for p in summary %}<p>{{ p | safe }}</p>{%- endfor %}</div>
  </div>
</section>
{%- endif %}

{#- AI-SUMMARY — variant by CONTENT SHAPE (founder rule): a single-paragraph
    verdict (aiVerdict) → petrol left-rule; a multi-Q&A list (aiSummary array)
    → ruled rows (State Pillar/Money treatment). Frozen speakable id on section. -#}
{%- if aiVerdict or aiSummary %}
<section class="sec reveal" id="{{ slug }}-ai-summary" style="padding-top:20px;padding-bottom:24px;">
  <div class="ct read">
    <div class="eyebrow" style="margin-bottom:12px;">For AI engines &amp; quick answers</div>
    {%- if aiSummaryHeading %}<h2 class="h2" style="margin-bottom:18px;">{{ aiSummaryHeading | safe }}</h2>{%- endif %}
    {%- if aiVerdict %}
    <div class="speakable ai-verdict"><p class="ai-verdict__lead">{{ aiVerdict | safe }}</p></div>
    {%- else %}
    <div class="speakable ai-qa">
      {%- for item in aiSummary %}
      <div class="ai-qa__item"><h3>{{ item.q | safe }}</h3><p>{{ item.a | safe }}</p></div>
      {%- endfor %}
    </div>
    {%- endif %}
  </div>
</section>
{%- endif %}

{#- ROLES / SIDES — definitional grid-2 (concept pages pass `sides`, same shape) -#}
{%- set roleItems = roles or sides %}
{%- if roleItems %}
<section class="sec reveal">
  <div class="ct">
    <div class="ph"><span class="ph__t">{{ sec.rolesTag | default("The two roles, defined", true) | safe }}</span><span class="ph__rule"></span></div>
    <h2 class="h2">{{ sec.rolesH | default("What each role does &mdash; in plain language.", true) | safe }}</h2>
    {%- if sec.rolesLede != false %}<p class="lede" style="margin:10px 0 28px;max-width:60ch;">{{ sec.rolesLede | default("Most confusion between the two roles comes from people using the terms interchangeably. They&rsquo;re not interchangeable. Here&rsquo;s what each actually means in U.S. small business practice.", true) | safe }}</p>{%- endif %}
    <div class="r-2">
      {%- for r in roleItems %}
      <div class="dc-card"><span class="eyebrow">{{ r.eyebrow | safe }}</span><h3>{{ r.name | safe }}</h3><div class="prose">{{ r.body | safe }}</div></div>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

{#- COMPARISON TABLE — the C2 signature viz -#}
{%- if vsTable %}
{%- set dk = cmpCols.dimKey | default("cap", true) %}
{%- set akey = cmpCols.aKey | default("bk", true) %}
{%- set bkey = cmpCols.bKey | default("acct", true) %}
{%- set usCol = cmpCols.usCol | default("a", true) %}
{%- set aLabel = cmpCols.aLabel | default("Bookkeeper", true) %}
{%- set bLabel = cmpCols.bLabel | default("Accountant / CPA", true) %}
<section class="sec reveal">
  <div class="ct read">
    <div class="ph"><span class="ph__t">{{ sec.cmpTag | default("Side by side", true) | safe }}</span><span class="ph__rule"></span></div>
    <h2 class="h2" style="margin-bottom:8px;">{{ sec.cmpH | default("Across the dimensions that actually matter.", true) | safe }}</h2>
    <p class="lede" style="margin:0 0 24px;">{{ sec.cmpLede | default("Twelve dimensions where the two roles differ in practice. Neither role &ldquo;wins&rdquo; &mdash; they do different things. This table makes the boundaries clear.", true) | safe }}</p>
    <table class="cmp" data-viz="comparison-table" data-viz-state="FINAL">
      <caption>{{ cmpCols.caption | default("Bookkeeper vs accountant &middot; what each role actually does across twelve dimensions", true) | safe }}</caption>
      <thead><tr><th scope="col">{{ cmpCols.c1 | default("Dimension", true) | safe }}</th><th scope="col"{% if usCol == "a" %} class="us"{% endif %}>{{ aLabel | safe }}{% if cmpCols.aSub %}<span class="sub">{{ cmpCols.aSub | safe }}</span>{% elif not cmpCols.aKey %}<span class="sub">day-to-day records</span>{% endif %}</th><th scope="col"{% if usCol == "b" %} class="us"{% endif %}>{{ bLabel | safe }}{% if cmpCols.bSub %}<span class="sub">{{ cmpCols.bSub | safe }}</span>{% elif not cmpCols.bKey %}<span class="sub">analysis &amp; planning</span>{% endif %}</th></tr></thead>
      <tbody>
        {%- for r in vsTable %}
        <tr>
          <th scope="row">{{ r[dk] | safe }}</th>
          <td{% if usCol == "a" %} class="us"{% endif %} data-col="{{ aLabel | safe }}">{{ r[akey] | safe }}</td>
          <td{% if usCol == "b" %} class="us"{% endif %} data-col="{{ bLabel | safe }}">{{ r[bkey] | safe }}</td>
        </tr>
        {%- endfor %}
      </tbody>
    </table>
  </div>
</section>
{%- endif %}

{#- TOGETHER prose -#}
{%- if together %}
<section class="sec reveal">
  <div class="ct read">
    <div class="ph"><span class="ph__t">{{ sec.togetherTag | default("How they work together", true) | safe }}</span><span class="ph__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">{{ sec.togetherH | default("The bookkeeper produces. The accountant interprets.", true) | safe }}</h2>
    <div class="prose">{%- for p in together %}<p>{{ p | safe }}</p>{%- endfor %}</div>
  </div>
</section>
{%- endif %}

{#- DECISION — practical guide grid-3 -#}
{%- if decision %}
<section class="sec reveal">
  <div class="ct">
    <div class="ph"><span class="ph__t">{{ sec.decisionTag | default("When you need each", true) | safe }}</span><span class="ph__rule"></span></div>
    <h2 class="h2">{{ sec.decisionH | default("A practical decision guide.", true) | safe }}</h2>
    {%- if sec.decisionLede != false %}<p class="lede" style="margin:10px 0 28px;max-width:60ch;">{{ sec.decisionLede | default("Three patterns cover most U.S. small businesses. Find the one that fits your situation.", true) | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for d in decision %}
      <div class="dc-card"><span class="eyebrow">{{ d.eyebrow | safe }}</span><h3>{{ d.name | safe }}</h3><div class="prose">{{ d.body | safe }}</div></div>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

{#- CREDENTIALS — demystified grid-3 -#}
{%- if credentials %}
<section class="sec reveal">
  <div class="ct">
    <div class="ph"><span class="ph__t">{{ sec.credentialsTag | default("Credentials, demystified", true) | safe }}</span><span class="ph__rule"></span></div>
    <h2 class="h2">{{ sec.credentialsH | default("What each credential actually means.", true) | safe }}</h2>
    {%- if sec.credentialsLede != false %}<p class="lede" style="margin:10px 0 28px;max-width:60ch;">{{ sec.credentialsLede | default("U.S. accounting credentials confuse a lot of buyers. Here&rsquo;s what each one means and what it actually authorizes.", true) | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for c in credentials %}
      <div class="dc-card"><span class="eyebrow">{{ c.tag | safe }}</span><h3>{{ c.name | safe }}</h3><div class="prose">{{ c.body | safe }}</div></div>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

{#- FIT — where TechBrot fits + trust-row -#}
{%- if fit %}
<section class="sec reveal">
  <div class="ct read">
    <div class="ph"><span class="ph__t">{{ sec.fitTag | default("Where TechBrot fits", true) | safe }}</span><span class="ph__rule"></span></div>
    <h2 class="h2" style="margin-bottom:18px;">{{ sec.fitH | default("We&rsquo;re the bookkeeping side. Done well.", true) | safe }}</h2>
    <div class="prose">{%- for p in fit %}<p>{{ p | safe }}</p>{%- endfor %}</div>
    {%- if fitSpec %}
    <div class="trust-row">
      {%- for r in fitSpec %}
      <div class="trust-row__item"><p class="trust-row__value">{{ r.value | safe }}</p><p class="trust-row__label">{{ r.label | safe }}</p></div>
      {%- if not loop.last %}<div class="trust-row__divider"></div>{%- endif %}
      {%- endfor %}
    </div>
    {%- endif %}
  </div>
</section>
{%- endif %}

{#- VERDICT — competitor/product intents only (role omits per template) -#}
{%- if verdict and intent != "role" %}
<section class="sec reveal" style="padding-top:8px;">
  <div class="ct read">
    <div class="verdict">
      <div class="eyebrow">The honest verdict</div>
      <p class="verdict__lead">{{ verdict.lead | safe }}</p>
      {%- if verdict.sub %}<p class="verdict__sub">{{ verdict.sub | safe }}</p>{%- endif %}
    </div>
  </div>
</section>
{%- endif %}

{#- VERDICT CARDS — competitor/product "when each fits" grid-3 (guarded) -#}
{%- if verdictCards %}
<section class="sec reveal">
  <div class="ct">
    <div class="ph"><span class="ph__t">{{ sec.verdictTag | default("The verdict", true) | safe }}</span><span class="ph__rule"></span></div>
    <h2 class="h2">{{ sec.verdictH | default("When each option actually fits.", true) | safe }}</h2>
    {%- if sec.verdictLede %}<p class="lede" style="margin:10px 0 28px;max-width:62ch;">{{ sec.verdictLede | safe }}</p>{%- endif %}
    <div class="r-3">
      {%- for v in verdictCards %}
      <div class="dc-card">{% if v.eyebrow %}<span class="eyebrow">{{ v.eyebrow | safe }}</span>{% endif %}<h3>{{ v.name | safe }}</h3>{% if v.bullets %}<ul class="checklist">{% for b in v.bullets %}<li>{{ b | safe }}</li>{% endfor %}</ul>{% endif %}{% if v.note %}<p class="prose" style="font-size:14px;margin:12px 0 0;color:var(--color-ink-mute);">{{ v.note | safe }}</p>{% endif %}</div>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

{#- RELATED — sibling comparisons (sand band) -#}
{%- if related %}
<section class="sec reveal" style="background:#F7F2E9;border-top:1px solid #ECE5D8;border-bottom:1px solid #ECE5D8;">
  <div class="ct">
    <div class="ph"><span class="ph__t">{{ sec.relatedTag | default("Other comparisons", true) | safe }}</span><span class="ph__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">{{ sec.relatedH | default("More honest comparisons in the same series.", true) | safe }}</h2>
    <div class="r-3">
      {%- for n in related %}
      <a class="rel-card" href="{{ n.href }}"><h3 class="rel-card__t">{{ n.title | safe }}</h3><p class="rel-card__d">{{ n.body | safe }}</p></a>
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

{#- FAQ -#}
{%- if faq %}
<section class="sec reveal">
  <div class="ct read">
    <div class="ph"><span class="ph__t">{{ sec.faqTag | default("Common questions", true) | safe }}</span><span class="ph__rule"></span></div>
    <h2 class="h2" style="margin-bottom:24px;">{{ sec.faqH | default("What people ask before choosing.", true) | safe }}</h2>
    <div class="faq">
      {%- for item in faq %}
      <details name="cmp-faq"{% if loop.first %} open{% endif %}><summary>{{ item.q | safe }}<span class="pl"></span></summary><div>{{ item.a | safe }}</div></details>
      {%- endfor %}
    </div>
    <p class="meta-reviewed"><span>Published: 2026-06-15</span><span>Updated: 2026-06-15</span><span>Reviewed: 2026-06-15 &middot; Certified QuickBooks ProAdvisor</span></p>
  </div>
</section>
{%- endif %}

{#- FINAL CTA — role intent = calm, light, centered -#}
{%- if ctaBand %}
<section class="sec reveal{% if intent == 'competitor' %} final-cta--dark{% endif %}" style="padding:72px 0;">
  <div class="ct read">
    <div class="final-cta">
      <h2 class="final-cta__h">{{ ctaBand.heading | safe }}</h2>
      <p class="final-cta__lede">{{ ctaBand.lede | safe }}</p>
      <div class="final-cta__actions">
        {%- for a in ctaBand.actions %}
        <a href="{% if a.tel %}tel:{{ site.phone.e164 }}{% else %}{{ a.href }}{% endif %}"{% if a.tel %} data-ga="phone_click" data-tb-event="phone_click"{% endif %} class="btn {% if loop.first %}btn-cta{% else %}btn-ghost{% if a.tel %} mono{% endif %}{% endif %}" style="display:inline-flex;align-items:center;gap:10px;height:54px;padding:0 24px;border-radius:13px;font-size:15.5px;font-weight:{% if loop.first %}600{% else %}500{% endif %};">{{ a.label }}</a>
        {%- endfor %}
      </div>
    </div>
  </div>
</section>
{%- endif %}
