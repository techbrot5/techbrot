<script>
(function () {
  if (window.__tbDcNav) return; window.__tbDcNav = true;
  function closeMenus(x){document.querySelectorAll('[data-menu-panel]').forEach(function(p){if(p.getAttribute('data-menu-panel')!==x)p.removeAttribute('data-open');});document.querySelectorAll('[data-menu]').forEach(function(b){if(b.getAttribute('data-menu')!==x)b.setAttribute('aria-expanded','false');});}
  function drawer(o){var d=document.querySelector('[data-drawer]');if(d){if(o){d.setAttribute('data-open','');document.body.style.overflow='hidden';}else{d.removeAttribute('data-open');document.body.style.overflow='';}}}
  document.addEventListener('click',function(e){
    var t=e.target.closest('[data-menu]');
    if(t){e.preventDefault();var n=t.getAttribute('data-menu');var p=document.querySelector('[data-menu-panel="'+n+'"]');var open=t.getAttribute('aria-expanded')==='true';closeMenus(open?null:n);if(p){if(open){p.removeAttribute('data-open');}else{p.setAttribute('data-open','');}t.setAttribute('aria-expanded',open?'false':'true');}return;}
    if(e.target.closest('[data-menu-panel]'))return;
    closeMenus(null);
    if(e.target.closest('[data-drawer-open]'))drawer(true);
    if(e.target.closest('[data-drawer-close]'))drawer(false);
  });
  document.addEventListener('keydown',function(e){if(e.key==='Escape'){closeMenus(null);drawer(false);}});
})();
</script>
