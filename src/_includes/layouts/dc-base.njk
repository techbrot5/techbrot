<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
{%- if robotsOverride %}
<meta name="robots" content="{{ robotsOverride }}">
{%- elif env.production %}
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
{%- else %}
<meta name="robots" content="noindex, nofollow">
{%- endif %}
{%- set canon = canonicalUrl or page.url %}
<link rel="canonical" href="{{ site.url }}{{ canon }}">
<link rel="alternate" hreflang="en-US" href="{{ site.url }}{{ canon }}">
<link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ canon }}">
<meta name="format-detection" content="telephone=yes">
<meta name="theme-color" content="#FCFBF8">
<meta name="trademark" content="QuickBooks is a registered trademark of Intuit Inc. TechBrot Inc. is an independent Certified QuickBooks ProAdvisor firm and is not affiliated with, endorsed by, or sponsored by Intuit Inc.">
<link rel="icon" href="/assets/img/brand/icon.svg" type="image/svg+xml">
<link rel="icon" type="image/png" sizes="32x32" href="/assets/img/brand/favicon-32.png">
<link rel="apple-touch-icon" href="/assets/img/brand/apple-touch-icon.png">
<link rel="manifest" href="/site.webmanifest">
{#- NEW design system fonts. PROOF: Google Fonts CDN for exact template fidelity
    (preview is noindex). PRE-FLIP TODO: self-host Spline Sans Mono woff2 (400/500/600)
    + Fraunces/Geist already self-hosted; drop the CDN per the manifest no-CDN rule. -#}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Geist:wght@300..700&family=Spline+Sans+Mono:wght@400;500;600&display=swap" rel="stylesheet">
{#- Body component layer (the already-elevated petrol/warm design: all tokens +
    section/idx/buyer-card/feature/stat-tier/call-block/etc.). dc-system.css loads
    AFTER it so the NEW chrome + the new C2 .cmp win on the (one) collision. The old
    chrome CSS in here is unused — dc-base renders the new chrome markup. -#}
<link rel="stylesheet" href="/assets/css/site.min.css">
<link rel="stylesheet" href="/assets/css/dc-system.css">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:title" content="{{ ogTitle or title }}">
<meta property="og:description" content="{{ ogDescription or description }}">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:image" content="{{ site.url }}{{ ogImage or '/assets/og/default.png' }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="{{ ogTitle or title }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ ogTitle or title }}">
<meta name="twitter:description" content="{{ ogDescription or description }}">
<meta name="twitter:image" content="{{ site.url }}{{ ogImage or '/assets/og/default.png' }}">
<meta name="twitter:site" content="{{ site.twitterHandle }}">
<script type="application/ld+json">{{ schemaGlobal | dump | safe }}</script>
{%- if pageGraph %}
<script type="application/ld+json">{{ pageGraph | dump | safe }}</script>
{%- endif %}
<script>window.TB_ENV={{ env.name | dump | safe }};window.TB_FORM_ENDPOINT={{ site.formEndpoint | dump | safe }};</script>
{%- if env.production %}
<script async src="https://www.googletagmanager.com/gtag/js?id={{ site.ga4Id }}"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','{{ site.ga4Id }}');</script>
{%- endif %}
</head>
<body class="{{ bodyClass }}">
<a href="#main" style="position:absolute;left:-9999px;">Skip to content</a>

